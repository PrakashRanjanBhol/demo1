import { createAsyncThunk, createSlice, PayloadAction } from '@reduxjs/toolkit';
import {
  AdminSettings,
  fetchAdminSettingsApi,
  fetchModelsApi,
  saveAdminSettingsApi,
} from '../../api/generalSettingsApi';

interface GeneralSettingsState {
  settings: AdminSettings | null;
  models: string[];
  modelsLoading: boolean;
  loading: boolean;
  saving: boolean;
  error: string | null;
  saveError: string | null;
  saveSuccess: boolean;
}

const initialState: GeneralSettingsState = {
  settings: null,
  models: [],
  modelsLoading: false,
  loading: false,
  saving: false,
  error: null,
  saveError: null,
  saveSuccess: false,
};

export const fetchAdminSettings = createAsyncThunk(
  'generalSettings/fetch',
  async (_, { rejectWithValue }) => {
    try {
      return await fetchAdminSettingsApi();
    } catch (err: unknown) {
      const message = err instanceof Error ? err.message : 'Failed to fetch settings';
      return rejectWithValue(message);
    }
  }
);

export const fetchModels = createAsyncThunk(
  'generalSettings/fetchModels',
  async (_, { rejectWithValue }) => {
    try {
      return await fetchModelsApi();
    } catch (err: unknown) {
      const message = err instanceof Error ? err.message : 'Failed to fetch models';
      return rejectWithValue(message);
    }
  }
);

export const saveAdminSettings = createAsyncThunk(
  'generalSettings/save',
  async (payload: AdminSettings, { rejectWithValue }) => {
    try {
      await saveAdminSettingsApi(payload);
      return payload;
    } catch (err: unknown) {
      const message = err instanceof Error ? err.message : 'Failed to save settings';
      return rejectWithValue(message);
    }
  }
);

const generalSettingsSlice = createSlice({
  name: 'generalSettings',
  initialState,
  reducers: {
    clearSaveStatus(state) {
      state.saveSuccess = false;
      state.saveError = null;
    },
  },
  extraReducers: (builder) => {
    builder
      // fetch settings
      .addCase(fetchAdminSettings.pending, (state) => {
        state.loading = true;
        state.error = null;
      })
      .addCase(fetchAdminSettings.fulfilled, (state, action: PayloadAction<AdminSettings>) => {
        state.loading = false;
        state.settings = action.payload;
      })
      .addCase(fetchAdminSettings.rejected, (state, action) => {
        state.loading = false;
        state.error = action.payload as string;
      })
      // fetch models
      .addCase(fetchModels.pending, (state) => {
        state.modelsLoading = true;
      })
      .addCase(fetchModels.fulfilled, (state, action: PayloadAction<string[]>) => {
        state.modelsLoading = false;
        state.models = action.payload;
      })
      .addCase(fetchModels.rejected, (state) => {
        state.modelsLoading = false;
      })
      // save settings
      .addCase(saveAdminSettings.pending, (state) => {
        state.saving = true;
        state.saveError = null;
        state.saveSuccess = false;
      })
      .addCase(saveAdminSettings.fulfilled, (state, action: PayloadAction<AdminSettings>) => {
        state.saving = false;
        state.saveSuccess = true;
        state.settings = action.payload;
      })
      .addCase(saveAdminSettings.rejected, (state, action) => {
        state.saving = false;
        state.saveError = action.payload as string;
      });
  },
});

export const { clearSaveStatus } = generalSettingsSlice.actions;
export default generalSettingsSlice.reducer;











