    </div>

    <div class="sldc-divider"></div>

    <div class="sldc-error" *ngIf="isError(qa.loadState)">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
        <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.2"/>
        <path d="M8 5v4M8 11v.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
      Failed to load questions data. Please try again.
    </div>

    <div class="sldc-metrics-grid sldc-metrics-grid--2">
      <div class="sldc-metric">
        <p class="sldc-metric__label">Total questions on Jira</p>
        <p class="sldc-metric__value">{{ qa.data?.jira_count ?? '—' }}</p>
