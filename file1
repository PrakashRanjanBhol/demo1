        </svg>
        <span class="date-text">{{ startDate }}</span>
        <svg class="arrow-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
        <span class="date-text">{{ endDate }}</span>
      </div>
    </div>

    <div class="header-actions">
      <!-- Filter toggle -->
      <button class="icon-btn" [class.active]="isFilterVisible" (click)="toggleFilter()" title="Filter">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z" />
        </svg>
      </button>

      <!-- Delete mode toggle -->
      <button class="icon-btn icon-btn--danger"
              *ngIf="hasAnyFiles"
              [class.active]="isDeleteMode"
              [disabled]="isProcessingDelete"
              (click)="toggleDeleteMode()"
              title="Delete files">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
        </svg>
      </button>

      <!-- Inference mode toggle — only shown when no running/queued files -->
      <button class="icon-btn icon-btn--inference"
              *ngIf="canUseInferenceMode"
              [class.active]="isInferenceMode"
              (click)="toggleInferenceMode()"
              title="Run batch inference">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z" />
        </svg>
      </button>
    </div>
  </div>

  <!-- ── Filter Section ── -->
  <div class="filter-section" *ngIf="isFilterVisible">
    <div class="filter-group">
      <label class="filter-label">Date Range</label>
      <div class="date-filter">
        <div class="date-input-wrapper">
          <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
          </svg>
          <input type="date" class="date-input" [(ngModel)]="filterFromDate">
        </div>
        <span class="date-separator">to</span>
        <div class="date-input-wrapper">
          <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
          </svg>
          <input type="date" class="date-input" [(ngModel)]="filterToDate">
        </div>
        <button class="refresh-btn" (click)="applyDateFilter()" [disabled]="isRefreshing">
          <svg [class.spinning]="isRefreshing" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
          </svg>
        </button>
      </div>
    </div>

    <div class="filter-group">
      <label class="filter-label">Search</label>
      <div class="search-input-wrapper">
        <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
        </svg>
        <input type="text" class="search-input" [(ngModel)]="searchText" (ngModelChange)="onSearchChange()" placeholder="Search by file name or ID...">
        <button class="clear-search-btn" *ngIf="searchText" (click)="clearSearch()">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- ── Live Poll Bar ── -->
  <div class="poll-bar" *ngIf="isLivePolling">
    <span class="pulse-dot"></span>
    <span class="poll-text">
      Live — refreshing in <strong>{{ pollCountdown }}s</strong>
      <span class="poll-detail" *ngIf="liveFileCount">&nbsp;·&nbsp;{{ liveFileCount }}</span>
    </span>
  </div>

  <!-- ── Delete Action Bar ── -->
  <div class="delete-action-bar" *ngIf="isDeleteMode">
    <span class="delete-action-info">{{ selectedDeleteItems.size }} file(s) selected</span>
    <div class="delete-action-buttons">
      <button class="cancel-btn" (click)="cancelMultipleDelete()">Cancel</button>
      <button class="confirm-delete-btn" [disabled]="selectedDeleteItems.size === 0" (click)="showDeleteConfirmation()">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
        </svg>
        Delete ({{ selectedDeleteItems.size }})
      </button>
    </div>
  </div>

  <!-- ── Inference Action Bar ── -->
  <div class="inference-action-bar" *ngIf="isInferenceMode">
    <div class="inference-action-info">
      <svg class="inference-info-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
      </svg>
      <span>{{ inferenceSelectionCount }} file(s) selected for inference</span>
    </div>
    <div class="inference-action-buttons">
      <button class="cancel-btn" (click)="cancelInference()">Cancel</button>
      <button class="start-inference-btn"
              [disabled]="inferenceSelectionCount === 0 || isSubmittingBatch"
              (click)="startBatchInference()">
        <svg *ngIf="isSubmittingBatch" class="spinning" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
        <svg *ngIf="!isSubmittingBatch" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.348a1.125 1.125 0 010 1.971l-11.54 6.347a1.125 1.125 0 01-1.667-.985V5.653z" />
        </svg>
        {{ isSubmittingBatch ? 'Starting...' : 'Run Inference (' + inferenceSelectionCount + ')' }}
      </button>
    </div>
  </div>

  <!-- ── Panel Content ── -->
  <div class="panel-content">

    <!-- Loading skeletons -->
    <ng-container *ngIf="isLoading">
      <div class="section-block">
        <div class="skeleton-header"></div>
        <div class="skeleton-row" *ngFor="let i of [1,2,3]">
          <div class="skeleton-icon"></div>
          <div class="skeleton-details">
            <div class="skeleton-name"></div>
            <div class="skeleton-date"></div>
          </div>
          <div class="skeleton-badge"></div>
        </div>
      </div>
    </ng-container>

    <!-- Empty state -->
    <div class="empty-state" *ngIf="!isLoading && !hasAnyFiles">
      <div class="empty-icon">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z" />
        </svg>
      </div>
      <h3 class="empty-title">No History Available</h3>
      <p class="empty-desc">Upload your first file to get started</p>

      <div class="guide-steps">
        <div class="guide-step" *ngFor="let step of (showAllSteps ? allSteps : allSteps.slice(0,4))">
          <div class="step-num">{{ step.num }}</div>
          <div>
            <p class="step-title">{{ step.title }}</p>
            <p class="step-desc" [innerHTML]="step.desc"></p>
          </div>
        </div>
        <button class="view-more-btn" (click)="toggleShowAllSteps()">
          {{ showAllSteps ? 'Show less' : 'View +2 more steps' }}
        </button>
      </div>
    </div>

    <!-- ── File Sections ── -->
    <ng-container *ngIf="!isLoading && hasAnyFiles">

      <!-- RUNNING -->
      <div class="section-block section-block--running" *ngIf="runningFiles.length > 0 || isRefreshing">
        <div class="section-header" (click)="toggleSection('running')">
          <span class="status-dot status-dot--running"></span>
          <span class="section-label">Running</span>
          <span class="section-count">{{ isRefreshing ? '…' : runningFiles.length }} files</span>
          <div class="select-all-wrap" *ngIf="isDeleteMode" (click)="$event.stopPropagation(); toggleSelectAll('running')">
            <div class="checkbox" [class.checked]="areAllSelected('running')">
              <svg *ngIf="areAllSelected('running')" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            </div>
          </div>
          <button class="chevron-btn" [class.collapsed]="!sectionExpanded['running']">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
          </button>
        </div>

        <div class="section-body" *ngIf="sectionExpanded['running']">
          <div class="file-row"
               *ngFor="let item of runningFiles"
               [attr.data-item-id]="item.id"
               [class.selected]="selectedHistoryItem?.id === item.id"
               [class.delete-selected]="isDeleteMode && isSelectedForDelete(item.id)"
               (click)="onHistoryItemClick(item.id)">

            <div class="delete-checkbox" *ngIf="isDeleteMode" (click)="$event.stopPropagation(); toggleDeleteSelection(item.id)">
              <div class="checkbox" [class.checked]="isSelectedForDelete(item.id)">
                <svg *ngIf="isSelectedForDelete(item.id)" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              </div>
            </div>

            <div class="file-icon file-icon--running">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" />
              </svg>
            </div>

            <div class="file-info">
              <p class="file-name">
                <span class="file-id">#{{ item.id }}</span>
                <span class="file-name-text">{{ item.name }}</span>
              </p>
              <p class="file-date">{{ item.displayDate }}</p>
              <div class="progress-wrap">
                <div class="progress-track">
                  <div class="progress-fill progress-fill--running" [style.width.%]="item.progress"></div>
                </div>
                <span class="progress-pct">{{ item.progress }}%</span>
              </div>
            </div>

            <div class="file-actions">
              <span class="badge badge--running">running</span>
            </div>
          </div>

          <div class="no-results" *ngIf="!isRefreshing && runningFiles.length === 0">
            <p>No running files</p>
          </div>
        </div>
      </div>

      <!-- QUEUED -->
      <div class="section-block section-block--queued" *ngIf="queuedFiles.length > 0">
        <div class="section-header" (click)="toggleSection('queued')">
          <span class="status-dot status-dot--queued"></span>
          <span class="section-label">Queued</span>
          <span class="section-count">{{ queuedFiles.length }} files</span>
          <div class="select-all-wrap" *ngIf="isDeleteMode" (click)="$event.stopPropagation(); toggleSelectAll('queued')">
            <div class="checkbox" [class.checked]="areAllSelected('queued')">
              <svg *ngIf="areAllSelected('queued')" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            </div>
          </div>
          <button class="chevron-btn" [class.collapsed]="!sectionExpanded['queued']">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
          </button>
        </div>

        <div class="section-body" *ngIf="sectionExpanded['queued']">
          <div class="file-row"
               *ngFor="let item of queuedFiles; let idx = index"
               [attr.data-item-id]="item.id"
               [class.selected]="selectedHistoryItem?.id === item.id"
               [class.delete-selected]="isDeleteMode && isSelectedForDelete(item.id)"
               (click)="onHistoryItemClick(item.id)">

            <div class="delete-checkbox" *ngIf="isDeleteMode" (click)="$event.stopPropagation(); toggleDeleteSelection(item.id)">
              <div class="checkbox" [class.checked]="isSelectedForDelete(item.id)">
                <svg *ngIf="isSelectedForDelete(item.id)" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              </div>
            </div>

            <div class="file-icon file-icon--queued">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" />
              </svg>
            </div>

            <div class="file-info">
              <p class="file-name">
                <span class="file-id">#{{ item.id }}</span>
                <span class="file-name-text">{{ item.name }}</span>
              </p>
              <p class="file-date">{{ item.displayDate }} &nbsp;·&nbsp; position {{ idx + 1 }}</p>
            </div>

            <div class="file-actions">
              <span class="badge badge--queued">queued</span>
              <button class="stop-btn" *ngIf="!isDeleteMode" (click)="stopQueuedFile(item.id, $event)" title="Stop this file">
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 10 10">
                  <rect x="1" y="1" width="8" height="8" rx="1"/>
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- PENDING -->
      <div class="section-block section-block--pending" *ngIf="pendingFiles.length > 0">
        <div class="section-header" (click)="toggleSection('pending')">
          <span class="status-dot status-dot--pending"></span>
          <span class="section-label">Pending</span>
          <span class="section-count">{{ pendingFiles.length }} files</span>
          <div class="select-all-wrap" *ngIf="isDeleteMode" (click)="$event.stopPropagation(); toggleSelectAll('pending')">
            <div class="checkbox" [class.checked]="areAllSelected('pending')">
              <svg *ngIf="areAllSelected('pending')" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            </div>
          </div>
          <div class="select-all-wrap" *ngIf="isInferenceMode" (click)="$event.stopPropagation(); toggleSelectAllInference('pending')">
            <div class="checkbox checkbox--inference" [class.checked]="areAllSelectedForInference('pending')">
              <svg *ngIf="areAllSelectedForInference('pending')" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            </div>
          </div>
          <button class="chevron-btn" [class.collapsed]="!sectionExpanded['pending']">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
          </button>
        </div>

        <div class="section-body" *ngIf="sectionExpanded['pending']">
          <div class="file-row"
               *ngFor="let item of pendingFiles"
               [attr.data-item-id]="item.id"
               [class.selected]="selectedHistoryItem?.id === item.id"
               [class.delete-selected]="isDeleteMode && isSelectedForDelete(item.id)"
               [class.inference-selected]="isInferenceMode && isSelectedForInference(item.id)"
               (click)="onHistoryItemClick(item.id)">

            <div class="delete-checkbox" *ngIf="isDeleteMode" (click)="$event.stopPropagation(); toggleDeleteSelection(item.id)">
              <div class="checkbox" [class.checked]="isSelectedForDelete(item.id)">
                <svg *ngIf="isSelectedForDelete(item.id)" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              </div>
            </div>

            <div class="delete-checkbox" *ngIf="isInferenceMode" (click)="$event.stopPropagation(); toggleInferenceSelection(item.id, $event)">
              <div class="checkbox checkbox--inference" [class.checked]="isSelectedForInference(item.id)">
                <svg *ngIf="isSelectedForInference(item.id)" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              </div>
            </div>

            <div class="file-icon file-icon--pending">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" />
              </svg>
            </div>

            <div class="file-info">
              <p class="file-name">
                <span class="file-id">#{{ item.id }}</span>
                <span class="file-name-text">{{ item.name }}</span>
              </p>
              <p class="file-date">{{ item.displayDate }}</p>
            </div>

            <div class="file-actions" *ngIf="!isDeleteMode && !isInferenceMode">
              <span class="badge badge--pending">pending</span>
              <button class="add-btn"
                      [class.added]="isAddedToGeneration(item.id)"
                      [disabled]="isFileUploading"
                      (click)="onAddToGeneration($event, item)"
                      [title]="isAddedToGeneration(item.id) ? 'Remove from generation' : 'Add to generation'">
                <svg *ngIf="!isAddedToGeneration(item.id)" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                <svg *ngIf="isAddedToGeneration(item.id)" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12h-15" />
                </svg>
              </button>
            </div>

            <div class="file-actions" *ngIf="isInferenceMode">
              <span class="badge badge--pending">pending</span>
            </div>
          </div>
        </div>
      </div>

      <!-- COMPLETED -->
      <div class="section-block section-block--completed" *ngIf="completedFiles.length > 0">
        <div class="section-header" (click)="toggleSection('completed')">
          <span class="status-dot status-dot--completed"></span>
          <span class="section-label">Completed</span>
          <span class="section-count">{{ completedFiles.length }} files</span>
          <div class="select-all-wrap" *ngIf="isDeleteMode" (click)="$event.stopPropagation(); toggleSelectAll('completed')">
            <div class="checkbox" [class.checked]="areAllSelected('completed')">
              <svg *ngIf="areAllSelected('completed')" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            </div>
          </div>
          <div class="select-all-wrap" *ngIf="isInferenceMode" (click)="$event.stopPropagation(); toggleSelectAllInference('completed')">
            <div class="checkbox checkbox--inference" [class.checked]="areAllSelectedForInference('completed')">
              <svg *ngIf="areAllSelectedForInference('completed')" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            </div>
          </div>
          <button class="chevron-btn" [class.collapsed]="!sectionExpanded['completed']">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
          </button>
        </div>

        <div class="section-body" *ngIf="sectionExpanded['completed']">
          <div class="file-row"
               *ngFor="let item of completedFiles"
               [attr.data-item-id]="item.id"
               [class.selected]="selectedHistoryItem?.id === item.id"
               [class.delete-selected]="isDeleteMode && isSelectedForDelete(item.id)"
               [class.inference-selected]="isInferenceMode && isSelectedForInference(item.id)"
               (click)="onHistoryItemClick(item.id)">

            <div class="delete-checkbox" *ngIf="isDeleteMode" (click)="$event.stopPropagation(); toggleDeleteSelection(item.id)">
              <div class="checkbox" [class.checked]="isSelectedForDelete(item.id)">
                <svg *ngIf="isSelectedForDelete(item.id)" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              </div>
            </div>

            <div class="delete-checkbox" *ngIf="isInferenceMode" (click)="$event.stopPropagation(); toggleInferenceSelection(item.id, $event)">
              <div class="checkbox checkbox--inference" [class.checked]="isSelectedForInference(item.id)">
                <svg *ngIf="isSelectedForInference(item.id)" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              </div>
            </div>

            <div class="file-icon file-icon--completed">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" />
              </svg>
            </div>

            <div class="file-info">
              <p class="file-name">
                <span class="file-id">#{{ item.id }}</span>
                <span class="file-name-text">{{ item.name }}</span>
              </p>
              <p class="file-date">{{ item.displayDate }}</p>
            </div>

            <div class="file-actions" *ngIf="!isDeleteMode && !isInferenceMode">
              <span class="badge badge--completed">completed</span>
              <button class="view-btn" (click)="onAddToGeneration($event, item)" title="View results">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </button>
            </div>

            <div class="file-actions" *ngIf="isInferenceMode">
              <span class="badge badge--completed">completed</span>
            </div>
          </div>
        </div>
      </div>

    </ng-container>
  </div>

  <!-- ── Delete Confirmation Modal ── -->
  <div class="modal-overlay" *ngIf="isDeleteConfirmationVisible">
    <div class="modal" (click)="$event.stopPropagation()">
      <div class="modal-header">
        <div class="modal-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
          </svg>
        </div>
        <h3 class="modal-title">Confirm Deletion</h3>
        <button class="modal-close" (click)="closeDeleteConfirmation()" [disabled]="isProcessingDelete">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div class="modal-body">
        <p class="modal-msg">Are you sure you want to delete <strong>{{ selectedDeleteItems.size }} file(s)</strong>?</p>
        <p class="modal-warning">This action cannot be undone. All associated data will be permanently removed.</p>
      </div>
      <div class="modal-footer">
        <button class="cancel-btn" (click)="closeDeleteConfirmation()" [disabled]="isProcessingDelete">Cancel</button>
        <button class="confirm-delete-btn" (click)="confirmMultipleDelete()" [disabled]="isProcessingDelete">
          <svg *ngIf="isProcessingDelete" class="spinning" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          <span>{{ isProcessingDelete ? 'Deleting...' : 'Delete Files' }}</span>
        </button>
      </div>
    </div>
  </div>

</div>



















/* ═══════════════════════════════════════
   Host & Panel
═══════════════════════════════════════ */
:host {
  display: flex;
  flex: 1;
  min-width: 0;
  min-height: 0;
}

.panel {
  flex: 1;
  background-color: var(--bg-color);
  border: 1px solid var(--border-color);
  display: flex;
  flex-direction: column;
  min-width: 0;
  min-height: 0;
  border-radius: 8px;
  overflow: hidden;
}

/* ═══════════════════════════════════════
   Header
═══════════════════════════════════════ */
.panel-header {
  position: sticky;
  top: 0;
  z-index: 10;
  padding: 14px 18px;
  border-bottom: 1px solid var(--border-color);
  flex-shrink: 0;
  background: linear-gradient(135deg, var(--primary-gradient-light-start), var(--primary-gradient-light-end));
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
  flex: 1;
}

.panel-title {
  font-size: 14px;
  font-weight: 700;
  color: var(--text-color);
  margin: 0;
  flex-shrink: 0;
  padding-left: 14px;
  position: relative;
}

.panel-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 3px;
  height: 16px;
  background: var(--primary-gradient);
  border-radius: 2px;
}

.date-range {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 4px 10px;
  background: linear-gradient(135deg, var(--primary-gradient-light-start), var(--primary-gradient-light-end));
  border: 1px solid var(--primary-border-color);
  border-radius: 20px;
  min-width: 0;
  overflow: hidden;
}

.date-icon, .arrow-icon {
  flex-shrink: 0;
}

.date-icon {
  width: 13px;
  height: 13px;
  stroke: var(--primary-color);
}

.arrow-icon {
  width: 11px;
  height: 11px;
  stroke: var(--primary-color);
  opacity: 0.5;
}

.date-text {
  font-size: 11px;
  font-weight: 600;
  color: var(--text-color);
  white-space: nowrap;
}

.header-actions {
  display: flex;
  gap: 6px;
  flex-shrink: 0;
}

.icon-btn {
  width: 30px;
  height: 30px;
  background: linear-gradient(135deg, var(--primary-gradient-light-start), var(--primary-gradient-light-end));
  border: 1.5px solid var(--primary-border-color);
  border-radius: 7px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s ease;
}

.icon-btn svg {
  width: 15px;
  height: 15px;
  stroke: var(--primary-color);
}

.icon-btn:hover {
  background: linear-gradient(135deg, var(--primary-gradient-medium-start), var(--primary-gradient-medium-end));
  border-color: var(--primary-color);
  box-shadow: 0 2px 6px var(--primary-shadow-light);
}

.icon-btn.active {
  background: var(--primary-gradient);
  border-color: var(--primary-color);
}

.icon-btn.active svg { stroke: white; }

.icon-btn--danger:hover { border-color: #ef4444; }
.icon-btn--danger.active { background: linear-gradient(135deg, #ef4444, #dc2626); border-color: #ef4444; }

.icon-btn--inference:hover { border-color: #EF9F27; }
.icon-btn--inference.active { background: linear-gradient(135deg, #f59e0b, #f97316); border-color: #f59e0b; }
.icon-btn--inference.active svg { stroke: white; }

.icon-btn:disabled { opacity: 0.4; cursor: not-allowed; }

/* ═══════════════════════════════════════
   Filter Section
═══════════════════════════════════════ */
.filter-section {
  background: linear-gradient(135deg, var(--primary-gradient-lighter-start), var(--primary-gradient-lighter-end));
  border-bottom: 1px solid var(--border-color);
  padding: 14px 18px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  animation: slideDown 0.25s ease;
}

.filter-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.filter-label {
  font-size: 11px;
  font-weight: 600;
  color: var(--text-color);
  opacity: 0.6;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.date-filter {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.date-input-wrapper {
  position: relative;
  flex: 1;
  min-width: 130px;
}

.date-input {
  width: 100%;
  padding: 8px 10px 8px 32px;
  background: var(--bg-color);
  border: 1.5px solid var(--border-color);
  border-radius: 7px;
  font-size: 12px;
  color: var(--text-color);
  transition: border-color 0.2s;
  box-sizing: border-box;
}

.date-input:focus {
  outline: none;
  border-color: var(--primary-color);
  box-shadow: 0 0 0 3px var(--primary-focus-shadow);
}

.date-separator {
  font-size: 12px;
  color: var(--text-color);
  opacity: 0.5;
}

.input-icon {
  position: absolute;
  left: 9px;
  top: 50%;
  transform: translateY(-50%);
  width: 14px;
  height: 14px;
  stroke: var(--primary-color);
  opacity: 0.5;
  pointer-events: none;
}

.refresh-btn {
  width: 36px;
  height: 36px;
  background: var(--primary-gradient);
  border: none;
  border-radius: 7px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.refresh-btn:hover:not(:disabled) {
  box-shadow: 0 3px 10px var(--primary-shadow);
  transform: translateY(-1px);
}

.refresh-btn:disabled { opacity: 0.5; cursor: not-allowed; }

.refresh-btn svg {
  width: 18px;
  height: 18px;
  stroke: white;
}

.search-input-wrapper {
  position: relative;
}

.search-input {
  width: 100%;
  padding: 8px 36px 8px 32px;
  background: var(--bg-color);
  border: 1.5px solid var(--border-color);
  border-radius: 7px;
  font-size: 12px;
  color: var(--text-color);
  transition: border-color 0.2s;
  box-sizing: border-box;
}

.search-input:focus {
  outline: none;
  border-color: var(--primary-color);
  box-shadow: 0 0 0 3px var(--primary-focus-shadow);
}

.search-input::placeholder { color: var(--text-color); opacity: 0.4; }

.clear-search-btn {
  position: absolute;
  right: 8px;
  top: 50%;
  transform: translateY(-50%);
  width: 22px;
  height: 22px;
  background: transparent;
  border: none;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.clear-search-btn svg {
  width: 13px;
  height: 13px;
  stroke: var(--text-color);
  opacity: 0.5;
}

/* ═══════════════════════════════════════
   Live Poll Bar
═══════════════════════════════════════ */
.poll-bar {
  padding: 7px 18px;
  background: rgba(55, 138, 221, 0.08);
  border-bottom: 1px solid rgba(55, 138, 221, 0.2);
  display: flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
}

.pulse-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: #185FA5;
  flex-shrink: 0;
  animation: pulse 1.4s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: 0.4; transform: scale(0.75); }
}

.poll-text {
  font-size: 11px;
  color: #0C447C;
}

.poll-text strong { font-weight: 700; }
.poll-detail { opacity: 0.8; }

/* ═══════════════════════════════════════
   Delete Action Bar
═══════════════════════════════════════ */
.delete-action-bar {
  padding: 10px 18px;
  background: linear-gradient(135deg, rgba(239, 68, 68, 0.08), rgba(220, 38, 38, 0.08));
  border-bottom: 1px solid rgba(239, 68, 68, 0.2);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  flex-shrink: 0;
  animation: slideDown 0.25s ease;
}

.delete-action-info {
  font-size: 12px;
  font-weight: 600;
  color: var(--text-color);
}

.delete-action-buttons {
  display: flex;
  gap: 8px;
}

/* ── Inference Action Bar ── */
.inference-action-bar {
  padding: 10px 18px;
  background: linear-gradient(135deg, rgba(245,158,11,0.08), rgba(249,115,22,0.08));
  border-bottom: 1px solid rgba(245,158,11,0.25);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  flex-shrink: 0;
  animation: slideDown 0.25s ease;
}

.inference-action-info {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  font-weight: 600;
  color: var(--text-color);
}

.inference-info-icon {
  width: 16px;
  height: 16px;
  stroke: #f59e0b;
  flex-shrink: 0;
}

.inference-action-buttons {
  display: flex;
  gap: 8px;
}

.start-inference-btn {
  padding: 6px 14px;
  font-size: 12px;
  font-weight: 600;
  background: linear-gradient(135deg, #f59e0b, #f97316);
  border: 1.5px solid #f59e0b;
  border-radius: 6px;
  color: white;
  cursor: pointer;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  gap: 6px;
}

.start-inference-btn:hover:not(:disabled) {
  box-shadow: 0 3px 10px rgba(245,158,11,0.35);
  transform: translateY(-1px);
}

.start-inference-btn:disabled { opacity: 0.5; cursor: not-allowed; }

.start-inference-btn svg {
  width: 14px;
  height: 14px;
}

.cancel-btn {
  padding: 6px 14px;
  font-size: 12px;
  font-weight: 600;
  background: transparent;
  border: 1.5px solid var(--border-color);
  border-radius: 6px;
  color: var(--text-color);
  cursor: pointer;
  transition: all 0.2s;
}

.cancel-btn:hover { background: rgba(107,114,128,0.08); border-color: #6b7280; }

.confirm-delete-btn {
  padding: 6px 14px;
  font-size: 12px;
  font-weight: 600;
  background: linear-gradient(135deg, #ef4444, #dc2626);
  border: 1.5px solid #ef4444;
  border-radius: 6px;
  color: white;
  cursor: pointer;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  gap: 6px;
}

.confirm-delete-btn:hover:not(:disabled) {
  box-shadow: 0 3px 10px rgba(239,68,68,0.35);
  transform: translateY(-1px);
}

.confirm-delete-btn:disabled { opacity: 0.5; cursor: not-allowed; }

.confirm-delete-btn svg {
  width: 14px;
  height: 14px;
}

/* ═══════════════════════════════════════
   Panel Content
═══════════════════════════════════════ */
.panel-content {
  flex: 1;
  padding: 14px 18px;
  overflow-y: auto;
  overflow-x: hidden;
  min-height: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.panel-content::-webkit-scrollbar { width: 5px; }
.panel-content::-webkit-scrollbar-track { background: var(--scrollbar-track-bg); border-radius: 3px; }
.panel-content::-webkit-scrollbar-thumb { background: var(--scrollbar-thumb-bg); border-radius: 3px; }
.panel-content::-webkit-scrollbar-thumb:hover { background: var(--primary-color); }

/* ═══════════════════════════════════════
   Section Blocks
═══════════════════════════════════════ */
.section-block {
  background: var(--bg-color);
  border: 1px solid var(--border-color);
  border-radius: 10px;
  overflow: hidden;
  transition: border-color 0.2s;
}

.section-block--running  { border-left: 3px solid #378ADD; }
.section-block--queued   { border-left: 3px solid #EF9F27; }
.section-block--pending  { border-left: 3px solid #888780; }
.section-block--completed{ border-left: 3px solid #639922; }

.section-header {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 14px;
  cursor: pointer;
  transition: background 0.15s;
  user-select: none;
}

.section-header:hover {
  background: linear-gradient(135deg, var(--primary-gradient-lighter-start), var(--primary-gradient-lighter-end));
}

.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

.status-dot--running   { background: #378ADD; animation: pulse 1.4s ease-in-out infinite; }
.status-dot--queued    { background: #EF9F27; }
.status-dot--pending   { background: #888780; }
.status-dot--completed { background: #639922; }

.section-label {
  font-size: 12px;
  font-weight: 700;
  color: var(--text-color);
  flex: 1;
}

.section-count {
  font-size: 11px;
  color: var(--text-color);
  opacity: 0.6;
  background: linear-gradient(135deg, var(--primary-gradient-lighter-start), var(--primary-gradient-lighter-end));
  border: 1px solid var(--border-color);
  border-radius: 10px;
  padding: 2px 8px;
}

.select-all-wrap {
  width: 22px;
  height: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.chevron-btn {
  width: 22px;
  height: 22px;
  background: transparent;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  flex-shrink: 0;
  transition: transform 0.2s;
}

.chevron-btn svg {
  width: 15px;
  height: 15px;
  stroke: var(--text-color);
  opacity: 0.5;
  transition: transform 0.25s ease;
}

.chevron-btn.collapsed svg { transform: rotate(-90deg); }

.section-body {
  padding: 0 10px 10px 10px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  animation: slideDown 0.2s ease;
}

/* ═══════════════════════════════════════
   Checkbox
═══════════════════════════════════════ */
.checkbox {
  width: 18px;
  height: 18px;
  border: 2px solid var(--border-color);
  border-radius: 4px;
  background: var(--bg-color);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  cursor: pointer;
}

.checkbox.checked {
  background: linear-gradient(135deg, #ef4444, #dc2626);
  border-color: #ef4444;
}

/* Amber variant for inference mode */
.checkbox--inference { border-color: var(--border-color); }
.checkbox--inference.checked {
  background: linear-gradient(135deg, #f59e0b, #f97316);
  border-color: #f59e0b;
}

.checkbox svg {
  width: 12px;
  height: 12px;
  stroke: white;
}

/* ═══════════════════════════════════════
   File Row
═══════════════════════════════════════ */
.file-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 12px;
  background: var(--bg-color);
  border: 1px solid var(--border-color);
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.18s ease;
  position: relative;
}

.file-row:hover {
  border-color: var(--primary-color);
  box-shadow: 0 2px 8px var(--primary-shadow-lighter);
}

.file-row.selected {
  background: linear-gradient(135deg, var(--primary-gradient-light-start), var(--primary-gradient-light-end));
  border-color: var(--primary-color);
  box-shadow: 0 2px 10px var(--primary-shadow-light);
}

.file-row.selected::before {
  content: '';
  position: absolute;
  left: -1px;
  top: 0;
  bottom: 0;
  width: 3px;
  background: var(--primary-gradient);
  border-radius: 8px 0 0 8px;
}

.file-row.delete-selected {
  background: linear-gradient(135deg, rgba(239,68,68,0.08), rgba(220,38,38,0.08));
  border-color: rgba(239,68,68,0.4);
}

.file-row.inference-selected {
  background: linear-gradient(135deg, rgba(245,158,11,0.08), rgba(249,115,22,0.08));
  border-color: rgba(245,158,11,0.4);
}

/* ═══════════════════════════════════════
   File Icon
═══════════════════════════════════════ */
.file-icon {
  width: 34px;
  height: 34px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}

.file-icon svg {
  width: 16px;
  height: 16px;
}

.file-icon--running   { background: rgba(55,138,221,0.12);  border: 1px solid rgba(55,138,221,0.25); }
.file-icon--running svg { stroke: #185FA5; }

.file-icon--queued    { background: rgba(239,159,39,0.12); border: 1px solid rgba(239,159,39,0.25); }
.file-icon--queued svg { stroke: #854F0B; }

.file-icon--pending   { background: rgba(136,135,128,0.1);  border: 1px solid rgba(136,135,128,0.2); }
.file-icon--pending svg { stroke: #5F5E5A; }

.file-icon--completed { background: rgba(99,153,34,0.1);   border: 1px solid rgba(99,153,34,0.2); }
.file-icon--completed svg { stroke: #3B6D11; }

.file-row.selected .file-icon {
  background: var(--primary-gradient);
  border-color: var(--primary-color);
}

.file-row.selected .file-icon svg { stroke: white; }

/* ═══════════════════════════════════════
   File Info
═══════════════════════════════════════ */
.file-info {
  flex: 1;
  min-width: 0;
}

.file-name {
  font-size: 12px;
  font-weight: 600;
  color: var(--text-color);
  margin: 0 0 3px 0;
  display: flex;
  align-items: center;
  gap: 6px;
  white-space: nowrap;
  overflow: hidden;
}

.file-id {
  font-size: 11px;
  font-weight: 700;
  color: var(--primary-color);
  background: linear-gradient(135deg, var(--primary-gradient-medium-start), var(--primary-gradient-medium-end));
  padding: 1px 6px;
  border-radius: 5px;
  border: 1px solid var(--primary-border-color);
  flex-shrink: 0;
}

.file-row.selected .file-id {
  background: var(--primary-gradient);
  color: white;
  border-color: var(--primary-color);
}

.file-name-text {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
  min-width: 0;
}

.file-date {
  font-size: 11px;
  color: var(--text-color);
  opacity: 0.55;
  margin: 0;
}

/* ═══════════════════════════════════════
   Progress Bar
═══════════════════════════════════════ */
.progress-wrap {
  display: flex;
  align-items: center;
  gap: 7px;
  margin-top: 5px;
}

.progress-track {
  flex: 1;
  height: 4px;
  background: rgba(55,138,221,0.15);
  border-radius: 2px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 2px;
  transition: width 0.4s ease;
}

.progress-fill--running { background: linear-gradient(90deg, #185FA5, #378ADD); }

.progress-pct {
  font-size: 10px;
  font-weight: 700;
  color: #185FA5;
  flex-shrink: 0;
  min-width: 26px;
  text-align: right;
}

/* ═══════════════════════════════════════
   File Actions
═══════════════════════════════════════ */
.file-actions {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-shrink: 0;
}

/* Badges */
.badge {
  font-size: 10px;
  font-weight: 600;
  padding: 2px 8px;
  border-radius: 10px;
  white-space: nowrap;
}

.badge--running   { background: rgba(55,138,221,0.12); color: #0C447C; border: 1px solid rgba(55,138,221,0.3); }
.badge--queued    { background: rgba(239,159,39,0.12); color: #633806; border: 1px solid rgba(239,159,39,0.3); }
.badge--pending   { background: rgba(136,135,128,0.1); color: #444441; border: 1px solid rgba(136,135,128,0.25); }
.badge--completed { background: rgba(99,153,34,0.1);  color: #27500A; border: 1px solid rgba(99,153,34,0.25); }

/* Stop button (queued) */
.stop-btn {
  width: 24px;
  height: 24px;
  border-radius: 5px;
  border: 1px solid rgba(239,159,39,0.4);
  background: rgba(239,159,39,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s;
}

.stop-btn:hover {
  background: rgba(239,159,39,0.2);
  border-color: #EF9F27;
  box-shadow: 0 2px 6px rgba(239,159,39,0.2);
}

.stop-btn svg {
  width: 10px;
  height: 10px;
  fill: #854F0B;
}

/* Add / View buttons */
.add-btn, .view-btn {
  width: 26px;
  height: 26px;
  border-radius: 6px;
  border: 1.5px solid var(--primary-border-color);
  background: linear-gradient(135deg, var(--primary-gradient-light-start), var(--primary-gradient-light-end));
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s;
}

.add-btn svg, .view-btn svg {
  width: 13px;
  height: 13px;
  stroke: var(--primary-color);
  transition: stroke 0.2s;
}

.add-btn:hover:not(:disabled), .view-btn:hover:not(:disabled) {
  background: var(--primary-gradient);
  border-color: var(--primary-color);
  box-shadow: 0 2px 8px var(--primary-shadow);
  transform: translateX(-1px);
}

.add-btn:hover:not(:disabled) svg, .view-btn:hover:not(:disabled) svg { stroke: white; }

.add-btn.added {
  background: linear-gradient(135deg, rgba(34,197,94,0.12), rgba(74,222,128,0.12));
  border-color: rgba(34,197,94,0.4);
}

.add-btn.added svg { stroke: #15803d; }

.add-btn.added:hover:not(:disabled) {
  background: linear-gradient(135deg, #22c55e, #4ade80);
  border-color: #22c55e;
}

.add-btn:disabled { opacity: 0.4; cursor: not-allowed; }

/* Delete checkbox in row */
.delete-checkbox {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* ═══════════════════════════════════════
   Skeleton Loader
═══════════════════════════════════════ */
.skeleton-header {
  height: 36px;
  background: linear-gradient(90deg, var(--primary-gradient-light-start) 0%, var(--primary-gradient-medium-start) 50%, var(--primary-gradient-light-start) 100%);
  background-size: 200% 100%;
  border-radius: 10px 10px 0 0;
  animation: shimmer 1.5s infinite;
  margin-bottom: 8px;
}

.skeleton-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 12px;
  border: 1px solid var(--border-color);
  border-radius: 8px;
  margin-bottom: 6px;
}

.skeleton-icon {
  width: 34px;
  height: 34px;
  border-radius: 8px;
  background: linear-gradient(90deg, var(--primary-gradient-light-start) 0%, var(--primary-gradient-medium-start) 50%, var(--primary-gradient-light-start) 100%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  flex-shrink: 0;
}

.skeleton-details { flex: 1; display: flex; flex-direction: column; gap: 6px; }

.skeleton-name {
  height: 13px;
  width: 65%;
  background: linear-gradient(90deg, var(--primary-gradient-light-start) 0%, var(--primary-gradient-medium-start) 50%, var(--primary-gradient-light-start) 100%);
  background-size: 200% 100%;
  border-radius: 4px;
  animation: shimmer 1.5s infinite;
}

.skeleton-date {
  height: 10px;
  width: 45%;
  background: linear-gradient(90deg, var(--primary-gradient-lighter-start) 0%, var(--primary-gradient-light-start) 50%, var(--primary-gradient-lighter-start) 100%);
  background-size: 200% 100%;
  border-radius: 4px;
  animation: shimmer 1.5s infinite 0.2s;
}

.skeleton-badge {
  width: 60px;
  height: 20px;
  border-radius: 10px;
  background: linear-gradient(90deg, var(--primary-gradient-light-start) 0%, var(--primary-gradient-medium-start) 50%, var(--primary-gradient-light-start) 100%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  flex-shrink: 0;
}

@keyframes shimmer {
  0%   { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

/* ═══════════════════════════════════════
   No Results
═══════════════════════════════════════ */
.no-results {
  padding: 18px;
  text-align: center;
}

.no-results p {
  font-size: 12px;
  color: var(--text-color);
  opacity: 0.5;
  margin: 0;
}

/* ═══════════════════════════════════════
   Empty State
═══════════════════════════════════════ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24px 0;
  animation: fadeIn 0.4s ease;
}

.empty-icon {
  width: 48px;
  height: 48px;
  background: linear-gradient(135deg, var(--primary-gradient-light-start), var(--primary-gradient-light-end));
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12px;
}

.empty-icon svg {
  width: 26px;
  height: 26px;
  stroke: var(--primary-color);
}

.empty-title {
  font-size: 16px;
  font-weight: 700;
  color: var(--text-color);
  margin: 0 0 4px 0;
}

.empty-desc {
  font-size: 13px;
  color: var(--text-color);
  opacity: 0.6;
  margin: 0 0 28px 0;
  text-align: center;
}

.guide-steps {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.guide-step {
  display: flex;
  gap: 10px;
  align-items: flex-start;
  padding: 10px 12px;
  background: var(--bg-color);
  border: 1px solid var(--border-color);
  border-radius: 8px;
  transition: all 0.2s;
  animation: slideDown 0.25s ease;
}

.guide-step:hover {
  border-color: var(--primary-color);
  transform: translateX(3px);
}

.step-num {
  width: 26px;
  height: 26px;
  background: var(--primary-gradient);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 700;
  flex-shrink: 0;
}

.step-title {
  font-size: 13px;
  font-weight: 700;
  color: var(--text-color);
  margin: 0 0 2px 0;
}

.step-desc {
  font-size: 12px;
  color: var(--text-color);
  opacity: 0.7;
  margin: 0;
  line-height: 1.5;
}

.step-desc strong { color: var(--primary-color); font-weight: 600; }

.view-more-btn {
  width: 100%;
  padding: 10px;
  background: linear-gradient(135deg, var(--primary-gradient-light-start), var(--primary-gradient-light-end));
  border: 1.5px solid var(--primary-border-color);
  border-radius: 8px;
  font-size: 12px;
  font-weight: 600;
  color: var(--text-color);
  cursor: pointer;
  transition: all 0.2s;
  margin-top: 4px;
}

.view-more-btn:hover {
  background: linear-gradient(135deg, var(--primary-gradient-medium-start), var(--primary-gradient-medium-end));
  border-color: var(--primary-color);
}

/* ═══════════════════════════════════════
   Delete Confirmation Modal
═══════════════════════════════════════ */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(3px);
  animation: fadeIn 0.2s ease;
}

.modal {
  background: var(--bg-color);
  border: 1px solid var(--border-color);
  border-radius: 12px;
  box-shadow: 0 16px 48px rgba(0,0,0,0.25);
  max-width: 440px;
  width: 90%;
  animation: modalIn 0.25s ease;
}

@keyframes modalIn {
  from { opacity: 0; transform: translateY(-16px) scale(0.97); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

.modal-header {
  padding: 20px 20px 14px 20px;
  border-bottom: 1px solid var(--border-color);
  display: flex;
  align-items: center;
  gap: 12px;
  position: relative;
}

.modal-icon {
  width: 42px;
  height: 42px;
  background: rgba(239,68,68,0.1);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.modal-icon svg {
  width: 24px;
  height: 24px;
  stroke: #ef4444;
}

.modal-title {
  font-size: 16px;
  font-weight: 700;
  color: var(--text-color);
  margin: 0;
  flex: 1;
}

.modal-close {
  position: absolute;
  top: 16px;
  right: 16px;
  width: 28px;
  height: 28px;
  background: transparent;
  border: none;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background 0.2s;
}

.modal-close:hover:not(:disabled) { background: rgba(239,68,68,0.1); }
.modal-close:disabled { opacity: 0.4; cursor: not-allowed; }
.modal-close svg { width: 16px; height: 16px; stroke: var(--text-color); opacity: 0.6; }

.modal-body { padding: 20px; }

.modal-msg {
  font-size: 13px;
  color: var(--text-color);
  margin: 0 0 10px 0;
  line-height: 1.6;
}

.modal-msg strong { color: #ef4444; }

.modal-warning {
  font-size: 12px;
  color: var(--text-color);
  opacity: 0.65;
  margin: 0;
  padding: 10px 12px;
  background: rgba(239,68,68,0.04);
  border-left: 3px solid #ef4444;
  border-radius: 4px;
  line-height: 1.5;
}

.modal-footer {
  padding: 14px 20px 20px 20px;
  display: flex;
  gap: 10px;
  justify-content: flex-end;
}

/* ═══════════════════════════════════════
   Row Animations
═══════════════════════════════════════ */
.file-row.adding-animation::after,
.file-row.removing-animation::after,
.file-row.success-animation::after,
.file-row.failure-animation::after,
.file-row.new-item-animation::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 8px;
  pointer-events: none;
  z-index: 1;
}

.file-row.adding-animation::after {
  background: linear-gradient(90deg, transparent 0%, var(--primary-glow-medium) 40%, var(--primary-glow-strong) 50%, var(--primary-glow-medium) 60%, transparent 100%);
  animation: sweepRight 0.7s ease-out;
}

.file-row.removing-animation::after {
  background: linear-gradient(90deg, transparent 0%, rgba(239,68,68,0.25) 40%, rgba(239,68,68,0.4) 50%, rgba(239,68,68,0.25) 60%, transparent 100%);
  animation: sweepLeft 0.7s ease-out;
}

.file-row.success-animation::after {
  background: linear-gradient(90deg, transparent 0%, rgba(34,197,94,0.25) 40%, rgba(74,222,128,0.4) 50%, rgba(34,197,94,0.25) 60%, transparent 100%);
  animation: sweepRight 0.8s ease-out;
}

.file-row.failure-animation::after {
  background: linear-gradient(90deg, transparent 0%, rgba(239,68,68,0.3) 40%, rgba(239,68,68,0.45) 50%, rgba(239,68,68,0.3) 60%, transparent 100%);
  animation: sweepLeft 0.8s ease-out;
}

.file-row > * { position: relative; z-index: 2; }

@keyframes sweepRight {
  from { transform: translateX(-100%); opacity: 0; }
  50%  { opacity: 1; }
  to   { transform: translateX(100%); opacity: 0; }
}

@keyframes sweepLeft {
  from { transform: translateX(100%); opacity: 0; }
  50%  { opacity: 1; }
  to   { transform: translateX(-100%); opacity: 0; }
}

.file-row.new-item-animation {
  animation: newItem 0.5s ease-out;
}

@keyframes newItem {
  from { transform: translateY(-10px); opacity: 0; }
  to   { transform: translateY(0); opacity: 1; }
}

/* ═══════════════════════════════════════
   Shared Animations
═══════════════════════════════════════ */
@keyframes slideDown {
  from { opacity: 0; transform: translateY(-8px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

.spinning {
  animation: spin 0.9s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

/* ═══════════════════════════════════════
   Responsive ≤ 1400px
═══════════════════════════════════════ */
@media screen and (max-width: 1400px) {
  .panel-header  { padding: 12px 14px; }
  .panel-content { padding: 12px 14px; gap: 8px; }
  .filter-section { padding: 12px 14px; }
  .poll-bar { padding: 6px 14px; }
  .delete-action-bar { padding: 8px 14px; }

  .panel-title { font-size: 13px; padding-left: 12px; }
  .panel-title::before { height: 14px; }

  .date-text { font-size: 10px; }
  .date-icon { width: 12px; height: 12px; }
  .arrow-icon { width: 10px; height: 10px; }

  .icon-btn { width: 27px; height: 27px; }
  .icon-btn svg { width: 13px; height: 13px; }

  .section-header { padding: 8px 12px; }
  .section-label  { font-size: 11px; }
  .section-count  { font-size: 10px; }

  .file-row   { padding: 8px 10px; gap: 8px; }
  .file-icon  { width: 30px; height: 30px; }
  .file-icon svg { width: 14px; height: 14px; }

  .file-name  { font-size: 11px; }
  .file-id    { font-size: 10px; }
  .file-date  { font-size: 10px; }

  .badge { font-size: 9px; padding: 2px 6px; }
  .stop-btn { width: 22px; height: 22px; }
  .add-btn, .view-btn { width: 24px; height: 24px; }
  .add-btn svg, .view-btn svg { width: 11px; height: 11px; }

  .progress-pct { font-size: 9px; }

  .modal { max-width: 90%; }
  .modal-footer { flex-direction: column; }
  .cancel-btn, .confirm-delete-btn { width: 100%; justify-content: center; }
}



















import { Injectable } from '@angular/core';
import { HttpClient, HttpHeaders } from '@angular/common/http';
import { Observable } from 'rxjs';

export interface FileItem {
  id: number;
  original_name: string;
  inserted_at: string;
  progress: string | null;
  summary_prompt: string | null;
  faq_prompt: string | null;
}

export interface FilesData {
  queued: FileItem[];
  completed: FileItem[];
  pending: FileItem[];
  running: FileItem[];
}

export interface ApiResponse {
  status: string;
  data: FilesData;
}

export interface DeleteResponse {
  status: string;
  message?: string;
  deleted_count?: number;
}

export interface ProgressResponse {
  status: string;
  result: { [fileId: string]: number };
}

export interface StopResponse {
  status: string;
  result: string;
}

export interface BatchProcessResponse {
  status: string;
  message?: string;
}

@Injectable({
  providedIn: 'root'
})
export class HistoryService {
  private baseUrl = 'http://localhost:3000/api';

  constructor(private http: HttpClient) {}

  private get jsonHeaders(): HttpHeaders {
    return new HttpHeaders({ 'Content-Type': 'application/json' });
  }

  /**
   * Get files grouped by status for a date range
   */
  getFilesByDateRange(startDate: string, endDate: string): Observable<ApiResponse> {
    const url = `${this.baseUrl}/content_analytics/files/by-date/`;
    return this.http.post<ApiResponse>(url, { start_date: startDate, end_date: endDate }, { headers: this.jsonHeaders });
  }

  /**
   * Get progress for multiple running files
   * POST /files/progress  { file_ids: [11, 12, ...] }
   * Response: { status: "Success", result: { "11": 64, "12": 31 } }
   */
  getFilesProgress(fileIds: number[]): Observable<ProgressResponse> {
    const url = `${this.baseUrl}/files/progress`;
    return this.http.post<ProgressResponse>(url, { file_ids: fileIds }, { headers: this.jsonHeaders });
  }

  /**
   * Stop queued files
   * PATCH /files/stop  { file_ids: [16] }
   * Response: { status: "success", result: "Stopped" }
   */
  stopFiles(fileIds: number[]): Observable<StopResponse> {
    const url = `${this.baseUrl}/files/stop`;
    return this.http.patch<StopResponse>(url, { file_ids: fileIds }, { headers: this.jsonHeaders });
  }

  /**
   * Batch process multiple files (only when queued + running are empty)
   * POST /batch_process  { file_ids: [1,2,3], model_name: "ABC" }
   * Response: 200 on success
   */
  batchProcess(fileIds: number[], modelName: string): Observable<BatchProcessResponse> {
    const url = `${this.baseUrl}/batch_process`;
    return this.http.post<BatchProcessResponse>(url, { file_ids: fileIds, model_name: modelName }, { headers: this.jsonHeaders });
  }

  /**
   * Delete multiple files by their IDs
   */
  deleteFiles(fileIds: number[]): Observable<DeleteResponse> {
    const url = `${this.baseUrl}/content_analytics/files/delete`;
    return this.http.post<DeleteResponse>(url, { file_ids: fileIds }, { headers: this.jsonHeaders });
  }

  /**
   * Get a single file by ID
   */
  getFileById(fileId: number): Observable<any> {
    const url = `${this.baseUrl}/content_analytics/files/${fileId}`;
    return this.http.get<any>(url);
  }
}
