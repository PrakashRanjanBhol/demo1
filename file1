// ── Gradient palette ──────────────────────────────────

const GRADIENTS: [string, string][] = [
  ["#6366f1", "#8b5cf6"],
  ["#0ea5e9", "#2684ff"],
  ["#10b981", "#06b6d4"],
  ["#f59e0b", "#ef4444"],
  ["#ec4899", "#8b5cf6"],
  ["#14b8a6", "#3b82f6"],
  ["#f97316", "#eab308"],
  ["#6366f1", "#ec4899"],
  ["#84cc16", "#10b981"],
  ["#8b5cf6", "#06b6d4"],
];

const getGradient = (key: string, id: string): [string, string] => {
  const combined = `${key}_${id}`;
  let hash = 0;
  for (let i = 0; i < combined.length; i++) {
    hash = combined.charCodeAt(i) + ((hash << 5) - hash);
  }
  return GRADIENTS[Math.abs(hash) % GRADIENTS.length];
};

// ── Project avatar ────────────────────────────────────

const ProjectAvatar: React.FC<{ projectKey: string; id: string; size?: "sm" | "md" }> = ({
  projectKey, id, size = "sm",
}) => {
  const [from, to] = getGradient(projectKey, id);
  return (
    <div
      className={`${styles.projectAvatar} ${size === "md" ? styles.projectAvatarMd : ""}`}
      style={{ background: `linear-gradient(135deg, ${from} 0%, ${to} 100%)` }}
    >
      {projectKey.charAt(0).toUpperCase()}
    </div>
  );
};

// ── Issue group card ──────────────────────────────────

interface IssueGroupCardProps {
  issueType: string;
  group: JiraIssueGroup;
  disabled: boolean;
  checkedTickets: Set<string>;
  atLimit: boolean;          // true when MAX_SELECTION already reached
  onTicketToggle: (key: string) => void;
}

const IssueGroupCard: React.FC<IssueGroupCardProps> = ({
  issueType, group, disabled, checkedTickets, atLimit, onTicketToggle,
}) => {
  const [expanded, setExpanded] = useState(false);

  return (
    <div className={`${styles.issueGroup} ${expanded ? styles.issueGroupExpanded : ""}`}>
      <button
        className={styles.issueGroupHeader}
        onClick={() => setExpanded((prev) => !prev)}
        disabled={disabled}
      >
        <div className={styles.issueGroupLeft}>
          {group.icon ? (
            <img
              src={group.icon}
              alt={issueType}
              className={styles.issueTypeIcon}
              width={16}
              height={16}
              onError={(e) => { (e.target as HTMLImageElement).style.display = "none"; }}
            />
          ) : (
            <span className={styles.issueTypeIconFallback}>
              {issueType.charAt(0).toUpperCase()}
            </span>
          )}
          <span className={styles.issueTypeName}>{issueType}</span>
          <span className={styles.issueTypeCount}>{group.tickets.length}</span>
        </div>
        <span className={`${styles.issueGroupChevron} ${expanded ? styles.chevronUp : ""}`}>
          <ChevronDownIcon />
        </span>
      </button>

      {expanded && (
        <ul className={styles.ticketList}>
          {group.tickets.map((ticket) => {
            const isChecked = checkedTickets.has(ticket.key);
            // Disable unchecked boxes once the limit is hit
            const isDisabled = disabled || (atLimit && !isChecked);
            return (
              <li key={ticket.key} className={styles.ticketItem}>
                <label className={`${styles.ticketLabel} ${isDisabled ? styles.ticketLabelDisabled : ""}`}>
                  <input
                    type="checkbox"
                    className={styles.ticketCheckbox}
                    checked={isChecked}
                    onChange={() => onTicketToggle(ticket.key)}
                    disabled={isDisabled}
                  />
                  <div className={styles.ticketInfo}>
                    <span className={styles.ticketKey}>{ticket.key}</span>
                    <span className={styles.ticketSummary}>{ticket.summary}</span>
                  </div>
                </label>
              </li>
            );
          })}
        </ul>
      )}
    </div>
  );
};

// ── Project detail panel ──────────────────────────────

interface ProjectDetailPanelProps {
  project: JiraProject;
  onBack: () => void;
}

const ProjectDetailPanel: React.FC<ProjectDetailPanelProps> = ({ project, onBack }) => {
  const dispatch = useDispatch<AppDispatch>();
  const { projectData, loadingProjectId, checkedTickets, error } = useSelector(
    (state: RootState) => state.jira
  );

  const data = projectData[project.id];
  const isLoading = loadingProjectId === project.id;
  const anyLoading = loadingProjectId !== null;
  const checkedSet = new Set(checkedTickets);
  const atLimit = checkedTickets.length >= MAX_SELECTION;

  useEffect(() => {
    if (!data) {
      dispatch(fetchProjectData(project));
    }
    return () => {
      dispatch(clearCheckedTickets());
    };
  }, [project.id]);

  const handleTicketToggle = (key: string) => {
    dispatch(toggleTicket(key));
  };

  const issueEntries = data ? Object.entries(data) : [];

  return (
    <div className={styles.projectDetailPanel}>
      {/* Panel header */}
      <div className={styles.projectDetailHeader}>
        <div className={styles.projectDetailTitle}>
          <ProjectAvatar projectKey={project.key} id={project.id} size="md" />
          <span className={styles.projectDetailName}>{project.key}</span>
        </div>
        <div className={styles.projectDetailActions}>
          {/* Selection counter badge */}
          <span
            className={`${styles.selectionBadge} ${atLimit ? styles.selectionBadgeAtLimit : ""}`}
            title={atLimit ? `Maximum ${MAX_SELECTION} tickets selected` : `${checkedTickets.length} of ${MAX_SELECTION} selected`}
          >
            {checkedTickets.length}/{MAX_SELECTION}
          </span>
          <button className={styles.projectDetailBack} onClick={onBack}>
            <BackIcon />
            <span>Projects</span>
          </button>
        </div>
      </div>

      {/* Loading */}
      {isLoading && (
        <div className={styles.loadingState}>
          <span className={styles.spinner} />
          <span>Loading issues…</span>
        </div>
      )}

      {/* Error */}
      {!isLoading && error && (
        <div className={styles.errorState}>{error}</div>
      )}

      {/* Issue groups */}
      {!isLoading && !error && data && (
        <div className={styles.issueGroupList}>
          {issueEntries.length === 0 ? (
            <div className={styles.emptyState}>
              <div className={styles.emptyIcon}><EmptyFolderIcon /></div>
              <p>No issues found</p>
              <span>This project has no issues yet.</span>
            </div>
          ) : (
            issueEntries.map(([issueType, group]) => (
              <IssueGroupCard
                key={issueType}
                issueType={issueType}
                group={group}
                disabled={anyLoading}
                checkedTickets={checkedSet}
                atLimit={atLimit}
                onTicketToggle={handleTicketToggle}
              />
            ))
          )}
        </div>
      )}
    </div>
  );
};

// ── Main component ────────────────────────────────────

export const JiraTool: React.FC<JiraToolProps> = ({ onBack }) => {
  const dispatch = useDispatch<AppDispatch>();

  const { isLoading: isDisconnecting } = useSelector(
    (state: RootState) => state.atlassian
  );
  const {
    allProjects,
    favoriteProjects,
    isLoadingProjects,
    isFavoriteUpdating,
    loadingProjectId,
    selectedProjectId,
    activeTab,
    searchQuery,
    error,
  } = useSelector((state: RootState) => state.jira);

  const selectedProject = selectedProjectId
    ? (allProjects[selectedProjectId] ?? favoriteProjects[selectedProjectId] ?? null)
    : null;

  useEffect(() => {
    dispatch(fetchJiraProjects());
  }, [dispatch]);

  const handleDisconnect = () => dispatch(disconnectAtlassian());
  const isFavorite = (id: string) => !!favoriteProjects[id];

  const handleToggleFavorite = (project: JiraProject) => {
    if (isFavoriteUpdating[project.id]) return;
    if (isFavorite(project.id)) {
      dispatch(removeFavoriteProject(project));
    } else {
      dispatch(addFavoriteProject(project));
    }
  };

  const handleTabChange = (tab: Tab) => dispatch(setJiraTab(tab));

  const handleProjectClick = (project: JiraProject) => {
    if (loadingProjectId !== null) return;
    dispatch(setSelectedProject(project.id));
    dispatch(fetchProjectData(project));
  };

  const allProjectsList = Object.values(allProjects);
  const favoriteProjectsList = Object.values(favoriteProjects);

  const query = searchQuery.toLowerCase().trim();
  const filteredAll = query
    ? allProjectsList.filter(
        (p) => p.key.toLowerCase().includes(query) || p.id.includes(query)
      )
    : allProjectsList;

  const filteredFavorites = query
    ? favoriteProjectsList.filter(
        (p) => p.key.toLowerCase().includes(query) || p.id.includes(query)
      )
    : favoriteProjectsList;

  // ── Shared tool header ────────────────────────────
  const ToolHeader = () => (
    <div className={styles.toolHeader}>
      <div className={styles.toolHeaderTop}>
        <div className={styles.breadcrumb}>
          <button className={styles.breadcrumbLink} onClick={onBack}>Tools</button>
          <span className={styles.breadcrumbSep}>›</span>
          <span className={styles.breadcrumbCurrent}>Jira</span>
        </div>
        <button
          className={styles.logoutBtn}
          onClick={handleDisconnect}
          disabled={isDisconnecting}
          title="Disconnect Jira"
        >
          <LogoutIcon />
        </button>
      </div>
      <div className={styles.toolHeaderBottom}>
        <div className={styles.toolIcon}>
          <img src={jiraIcon} alt="Jira" width={22} height={22} className={styles.img} />
        </div>
        <div className={styles.toolMeta}>
          <h2 className={styles.toolName}>Jira</h2>
        </div>
        <span className={styles.connectedBadge}>● Connected</span>
      </div>
    </div>
  );

  // ── Project detail view ───────────────────────────
  if (selectedProject) {
    return (
      <div className={styles.wrapper}>
        <ToolHeader />
        <ProjectDetailPanel
          project={selectedProject}
          onBack={() => dispatch(setSelectedProject(null))}
        />
      </div>
    );
  }

  // ── Project list view ─────────────────────────────
  return (
    <div className={styles.wrapper}>
      <ToolHeader />

      {/* Tabs */}
      <div className={styles.tabs}>
        <button
          className={`${styles.tab} ${activeTab === "favorites" ? styles.activeTab : ""}`}
          onClick={() => handleTabChange("favorites")}
        >
          Favorites
          {favoriteProjectsList.length > 0 && (
            <span className={styles.tabCount}>{favoriteProjectsList.length}</span>
          )}
        </button>
        <button
          className={`${styles.tab} ${activeTab === "all" ? styles.activeTab : ""}`}
          onClick={() => handleTabChange("all")}
        >
          All Projects
          {allProjectsList.length > 0 && (
            <span className={styles.tabCount}>{allProjectsList.length}</span>
          )}
        </button>
      </div>

      {/* Search */}
      {!isLoadingProjects && !error && (
        <div className={styles.searchBar}>
          <span className={styles.searchIcon}><SearchIcon /></span>
          <input
            type="text"
            className={styles.searchInput}
            placeholder="Search projects…"
            value={searchQuery}
            onChange={(e) => dispatch(setJiraSearch(e.target.value))}
          />
          {searchQuery && (
            <button className={styles.clearBtn} onClick={() => dispatch(setJiraSearch(""))} title="Clear">
              <ClearIcon />
            </button>
          )}
        </div>
      )}

      {/* Content */}
      <div className={styles.content}>

        {isLoadingProjects && (
          <div className={styles.loadingState}>
            <span className={styles.spinner} />
            <span>Loading projects…</span>
          </div>
        )}

        {!isLoadingProjects && error && (
          <div className={styles.errorState}>{error}</div>
        )}

        {/* Favorites tab */}
        {!isLoadingProjects && !error && activeTab === "favorites" && (
          filteredFavorites.length === 0 ? (
            <div className={styles.emptyState}>
              <div className={styles.emptyIcon}><StarOutlineIcon /></div>
              <p>{query ? "No matches found" : "No favorites yet"}</p>
              <span>
                {query
                  ? `No favorite projects match "${searchQuery}".`
                  : "Star a project in All Projects to pin it here."}
              </span>
            </div>
          ) : (
            <ul className={styles.projectList}>
              {filteredFavorites.map((project) => {
                const isThisLoading = loadingProjectId === project.id;
                const anyLoading = loadingProjectId !== null;
                return (
                  <li key={project.id}>
                    <button
                      className={`${styles.projectItem} ${styles.projectItemClickable} ${anyLoading && !isThisLoading ? styles.projectItemDisabled : ""}`}
                      onClick={() => handleProjectClick(project)}
                      disabled={anyLoading && !isThisLoading}
                    >
                      {isThisLoading ? (
                        <span className={styles.inlineSpinner} />
                      ) : (
                        <ProjectAvatar projectKey={project.key} id={project.id} />
                      )}
                      <div className={styles.projectInfo}>
                        <span className={styles.projectKey}>{project.key}</span>
                        <span className={styles.projectId}>#{project.id}</span>
                      </div>
                      <span className={styles.projectChevron}>›</span>
                    </button>
                  </li>
                );
              })}
            </ul>
          )
        )}

        {/* All Projects tab */}
        {!isLoadingProjects && !error && activeTab === "all" && (
          filteredAll.length === 0 ? (
            <div className={styles.emptyState}>
              <div className={styles.emptyIcon}><EmptyFolderIcon /></div>
              <p>{query ? "No matches found" : "No projects found"}</p>
              <span>
                {query
                  ? `No projects match "${searchQuery}".`
                  : "Your Jira projects will appear here."}
              </span>
            </div>
          ) : (
            <ul className={styles.projectList}>
              {filteredAll.map((project) => {
                const favorited = isFavorite(project.id);
                const updating = !!isFavoriteUpdating[project.id];
                return (
                  <li key={project.id} className={styles.projectItem}>
                    <ProjectAvatar projectKey={project.key} id={project.id} />
                    <div className={styles.projectInfo}>
                      <span className={styles.projectKey}>{project.key}</span>
                      <span className={styles.projectId}>#{project.id}</span>
                    </div>
                    <button
                      className={`${styles.favoriteBtn} ${favorited ? styles.favorited : ""}`}
                      onClick={() => handleToggleFavorite(project)}
                      disabled={updating}
                      title={favorited ? "Remove from favorites" : "Add to favorites"}
                    >
                      {updating ? (
                        <span className={styles.miniSpinner} />
                      ) : favorited ? (
                        <StarFilledIcon />
                      ) : (
                        <StarOutlineIcon />
                      )}
                    </button>
                  </li>
                );
              })}
            </ul>
          )
        )}

      </div>
    </div>
  );
};

export default JiraTool;











































