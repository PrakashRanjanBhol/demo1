/* Light mode additions */
:root,
[data-theme='light'] {
  /* existing variables ... */

  --settings-panel-shadow: 0 1px 2px rgba(0, 0, 0, 0.04), 0 4px 20px rgba(79, 70, 229, 0.07);
  --settings-panel-shadow-hover: 0 4px 12px rgba(0, 0, 0, 0.06), 0 8px 32px rgba(79, 70, 229, 0.13);
  --settings-panel-border-hover: rgba(79, 70, 229, 0.38);
}

/* Dark mode additions */
[data-theme='dark'] {
  /* existing variables ... */

  --settings-panel-shadow: 0 1px 2px rgba(0, 0, 0, 0.2), 0 4px 20px rgba(139, 92, 246, 0.1);
  --settings-panel-shadow-hover: 0 4px 12px rgba(0, 0, 0, 0.3), 0 8px 32px rgba(139, 92, 246, 0.18);
  --settings-panel-border-hover: rgba(139, 92, 246, 0.5);
}









@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.layout {
  display: flex;
  flex: 1;
  overflow: hidden;
  gap: 10px;
  padding: 0 10px;
  background: var(--settings-app-bg);
}

.sidebar {
  width: 300px;
  background: var(--settings-sidebar-bg);
  border: 1px solid var(--settings-panel-border-color);
  border-radius: 12px;
  display: flex;
  flex-direction: column;
  padding: 24px 12px;
  gap: 4px;
  position: relative;
  overflow: hidden;
  box-shadow: var(--settings-panel-shadow);
  transition: box-shadow 0.25s ease, border-color 0.25s ease, background 0.25s ease;
  animation: slideUp 0.45s cubic-bezier(0.16, 1, 0.3, 1) both;

  &:hover {
    box-shadow: var(--settings-panel-shadow-hover);
    border-color: var(--settings-panel-border-hover);
  }

  &::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(124, 58, 237, 0.18) 15%,
      rgba(99,  60, 220, 0.38) 36%,
      rgba(79,  70, 229, 0.42) 50%,
      rgba(37,  99, 235, 0.32) 68%,
      rgba(14, 165, 233, 0.18) 85%,
      transparent 100%
    );
    pointer-events: none;
  }
}

.sidebarHeader {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 4px 12px 20px;
  border-bottom: 1px solid var(--settings-border-color);
  margin-bottom: 12px;

  .headerIcon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--settings-gradient);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;

    svg {
      width: 20px;
      height: 20px;
      color: #fff;
    }
  }

  .headerText {
    display: flex;
    flex-direction: column;
    gap: 2px;

    .headerTitle {
      font-size: 1rem;
      font-weight: 700;
      color: var(--settings-text-primary);
      letter-spacing: -0.1px;
    }

    .headerSub {
      font-size: 0.78125rem;
      color: var(--settings-text-tertiary);
    }
  }
}

.sectionLabel {
  font-size: 0.65625rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--settings-text-tertiary);
  padding: 8px 14px 4px;
  margin-top: 4px;
}

.navList {
  display: flex;
  flex-direction: column;
  gap: 4px;
  position: relative;
}

.navLink {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 14px;
  margin: 0 8px;
  border-radius: 10px;
  text-decoration: none;
  font-size: 0.95rem;
  font-weight: 500;
  color: var(--settings-text-secondary);
  position: relative;
  z-index: 1;
  transition: color 0.25s ease;

  &::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 10px;
    background: transparent;
    z-index: -1;
    transition:
      background 0.25s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 0.25s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    transform: scaleX(0.92) scaleY(0.88);
  }

  &:hover {
    color: var(--settings-text-primary);

    &::before {
      background: var(--settings-hover-bg);
      opacity: 1;
      transform: scaleX(1) scaleY(1);
    }

    .navIcon {
      color: var(--settings-accent);
      border-color: var(--settings-accent-border);
      background: var(--settings-accent-light);
    }
  }

  &.active {
    color: var(--settings-accent);
    font-weight: 600;

    &::before {
      background: var(--settings-active-bg);
      opacity: 1;
      transform: scaleX(1) scaleY(1);
      box-shadow: var(--settings-active-shadow);
    }

    .navIcon {
      color: var(--settings-accent);
      border-color: var(--settings-accent-border);
      background: var(--settings-sidebar-bg);
      box-shadow: 0 1px 4px var(--settings-box-shadow);
    }

    .activePill {
      opacity: 1;
      transform: scale(1);
    }
  }
}

.navIcon {
  width: 34px;
  height: 34px;
  border-radius: 8px;
  background: var(--settings-app-bg);
  border: 1px solid var(--settings-border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: var(--settings-text-tertiary);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 1px 2px var(--settings-box-shadow);

  svg {
    width: 15px;
    height: 15px;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }
}

.navLink:hover .navIcon svg,
.navLink.active .navIcon svg {
  transform: scale(1.1);
}

.navLabel {
  flex: 1;
  transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.navLink.active .navLabel {
  transform: translateX(2px);
}

.activePill {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--settings-active-pill);
  opacity: 0;
  transform: scale(0.5);
  transition:
    opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1),
    transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  flex-shrink: 0;
}

.content {
  flex: 1;
  overflow: auto;
  padding: 36px 44px;
  background: var(--settings-content-bg);
  border-radius: 12px;
  border: 1px solid var(--settings-panel-border-color);
  position: relative;
  overflow: hidden;
  box-shadow: var(--settings-panel-shadow);
  transition: box-shadow 0.25s ease, border-color 0.25s ease, background 0.25s ease;
  animation: slideUp 0.45s cubic-bezier(0.16, 1, 0.3, 1) 0.05s both;

  &:hover {
    box-shadow: var(--settings-panel-shadow-hover);
    border-color: var(--settings-panel-border-hover);
  }

  &::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(124, 58, 237, 0.18) 15%,
      rgba(99,  60, 220, 0.38) 36%,
      rgba(79,  70, 229, 0.42) 50%,
      rgba(37,  99, 235, 0.32) 68%,
      rgba(14, 165, 233, 0.18) 85%,
      transparent 100%
    );
    pointer-events: none;
  }
}

@media (min-width: 1400px) {
  .sidebar {
    width: 320px;
  }

  .content {
    padding: 40px 56px;
  }

  .navLink {
    font-size: 1rem;
    padding: 12px 16px;
  }

  .navIcon {
    width: 38px;
    height: 38px;

    svg {
      width: 17px;
      height: 17px;
    }
  }

  .sidebarHeader {
    .headerIcon {
      width: 44px;
      height: 44px;
      border-radius: 11px;

      svg {
        width: 22px;
        height: 22px;
      }
    }

    .headerTitle {
      font-size: 1.0625rem;
    }

    .headerSub {
      font-size: 0.8125rem;
    }
  }

  .sectionLabel {
    font-size: 0.6875rem;
  }
}



