import React, { useState } from "react";
import { useDispatch, useSelector } from "react-redux";
import type { AppDispatch, RootState } from "../../store";
import { connectAtlassian, clearError } from "./atlassianSlice";
import styles from "./AtlassianConnect.module.scss";

import atlassianIcon from "../../assets/icons/atlassian.png";
import jiraIcon from "../../assets/icons/jira.png";
import confluenceIcon from "../../assets/icons/confluence.webp";

interface AtlassianConnectProps {
  toolId: "jira" | "confluence";
  onBack: () => void;
}

const toolMeta = {
  jira: {
    name: "Jira",
    icon: jiraIcon,
    description: "Connect your Jira account to query issues, track sprints, and generate reports.",
  },
  confluence: {
    name: "Confluence",
    icon: confluenceIcon,
    description: "Connect your Confluence account to search pages, summarize docs, and extract insights.",
  },
};

export const AtlassianConnect: React.FC<AtlassianConnectProps> = ({
  toolId,
  onBack,
}) => {
  const dispatch = useDispatch<AppDispatch>();
  const { isLoading, error } = useSelector((state: RootState) => state.atlassian);

  const [username, setUsername] = useState("");
  const [password, setPassword] = useState("");

  const tool = toolMeta[toolId];

  const handleConnect = () => {
    if (!username.trim() || !password.trim()) return;
    dispatch(clearError());
    dispatch(connectAtlassian({ username, password }));
  };

  const handleKeyDown = (e: React.KeyboardEvent) => {
    if (e.key === "Enter") handleConnect();
  };

  return (
    <div className={styles.wrapper}>
      <button className={styles.backBtn} onClick={onBack}>
        <span className={styles.backArrow}>←</span>
        <span>All tools</span>
      </button>

      {/* Header */}
      <div className={styles.header}>
        <div className={styles.headerIcons}>
          <img
            src={atlassianIcon}
            alt="Atlassian"
            className={styles.atlassianIcon}
            width={28}
            height={28}
          />
          <span className={styles.iconDivider} />
          <img
            src={tool.icon}
            alt={tool.name}
            className={styles.toolIcon}
            width={28}
            height={28}
          />
        </div>
        <div className={styles.headerText}>
          <h2 className={styles.title}>Connect {tool.name}</h2>
          <p className={styles.subtitle}>{tool.description}</p>
        </div>
      </div>

      {/* Form */}
      <div className={styles.form}>
        <div className={styles.field}>
          <label className={styles.label} htmlFor="username">
            Username
          </label>
          <input
            id="username"
            type="text"
            className={styles.input}
            placeholder="your@email.com"
            value={username}
            onChange={(e) => setUsername(e.target.value)}
            onKeyDown={handleKeyDown}
            autoComplete="username"
          />
        </div>

        <div className={styles.field}>
          <label className={styles.label} htmlFor="password">
            API Token / Password
          </label>
          <input
            id="password"
            type="password"
            className={styles.input}
            placeholder="••••••••••••"
            value={password}
            onChange={(e) => setPassword(e.target.value)}
            onKeyDown={handleKeyDown}
            autoComplete="current-password"
          />
        </div>

        {error && <p className={styles.error}>{error}</p>}

        <button
          className={styles.connectBtn}
          onClick={handleConnect}
          disabled={isLoading || !username.trim() || !password.trim()}
        >
          {isLoading ? (
            <span className={styles.spinner} />
          ) : (
            `Connect ${tool.name}`
          )}
        </button>
      </div>
    </div>
  );
};

export default AtlassianConnect;













