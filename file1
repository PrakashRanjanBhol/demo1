// ─── Pulsing dot ──────────────────────────────────────────────────────────────

function PulsingDot() {
  return (
    <span className={styles.dot} aria-hidden="true">
      <span className={styles.dotRing} />
      <span className={styles.dotCore} />
    </span>
  );
}

// ─── Component ────────────────────────────────────────────────────────────────

interface ContextModeIndicatorProps {
  activeTool: ActiveTool;
  className?: string;
}

export default function ContextModeIndicator({
  activeTool,
  className,
}: ContextModeIndicatorProps) {
  const [displayed, setDisplayed] = useState<ActiveTool>(activeTool);
  const [phase, setPhase] = useState<"idle" | "exit" | "enter">("idle");
  const prev = useRef<ActiveTool>(activeTool);

  useEffect(() => {
    if (activeTool === prev.current) return;
    prev.current = activeTool;

    // exit → swap → enter
    setPhase("exit");
    const t1 = setTimeout(() => { setDisplayed(activeTool); setPhase("enter"); }, 180);
    const t2 = setTimeout(() => setPhase("idle"), 180 + 240);
    return () => { clearTimeout(t1); clearTimeout(t2); };
  }, [activeTool]);

  const cfg = TOOL_CONFIG[displayed] ?? TOOL_CONFIG.GENERAL;

  return (
    <div
      className={[
        styles.badge,
        cfg.accentClass,
        phase === "exit"  ? styles.exit  : "",
        phase === "enter" ? styles.enter : "",
        className,
      ].filter(Boolean).join(" ")}
      role="status"
      aria-live="polite"
      aria-label={`Active mode: ${cfg.label}`}
    >
      <PulsingDot />
      <span className={styles.icon}>{cfg.icon}</span>
      <span className={styles.label}>{cfg.label}</span>
    </div>
  );
}













// ─── CSS Variables ────────────────────────────────────────────────────────────
// Light → page bg #FFFFFF    Dark → page bg #111113

:root {
