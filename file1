import axios from "axios";

const LOCAL_STORAGE_KEY = "ATLASIAN_CONNECTION";

// ── Helpers ───────────────────────────────────────────

const getAuthHeader = () => {
  const token = localStorage.getItem(LOCAL_STORAGE_KEY) ?? "";
  return { Authorization: `Bearer ${token}` };
};

// ── 498 Session-expired interceptor ───────────────────
// Store dispatch is injected at app startup via setupAtlassianInterceptor()

type VoidDispatch = (action: any) => void;

let _dispatch: VoidDispatch | null = null;

export const setupAtlassianInterceptor = (dispatch: VoidDispatch) => {
  _dispatch = dispatch;
};

axios.interceptors.response.use(
  (response) => response,
  (error) => {
    if (error?.response?.status === 498) {
      localStorage.removeItem(LOCAL_STORAGE_KEY);
      if (_dispatch) {
        // Dynamically imported to avoid circular dependency
        import("./atlassianSlice").then(({ forceDisconnect }) => {
          _dispatch!(forceDisconnect());
        });
      }
    }
    return Promise.reject(error);
  }
);

// ── Types ─────────────────────────────────────────────

export interface ConnectPayload {
  username: string;
  password: string;
}

export interface ConnectResponse {
  status: string;
  result: string;
}

export interface DisconnectResponse {
  status: string;
  result: string;
}

export interface JiraProject {
  key: string;
  id: string;
  type: "project";
  icon: string;
}

export interface ProjectsResult {
  [id: string]: JiraProject;
}

export interface ProjectsResponse {
  status: string;
  result: ProjectsResult;
}

export interface JiraTicket {
  type: string;
  summary: string;
  key: string;
}

export interface JiraIssueGroup {
  icon: string;
  tickets: JiraTicket[];
}

export interface ProjectDataResult {
  [issueType: string]: JiraIssueGroup;
}

export interface ProjectDataResponse {
  status: string;
  result: ProjectDataResult;
}

export interface FavoritePayload {
  project_key: string;
}

export interface FavoriteResponse {
  status: string;
  result: string;
}

// ── Confluence Types ──────────────────────────────────

export interface ConfluenceSpace {
  key: string;
  id: string;
  type: "space";
  icon: string;
}

export interface SpacesResult {
  [id: string]: ConfluenceSpace;
}

export interface SpacesResponse {
  status: string;
  result: SpacesResult;
}

export interface SpaceFavoritePayload {
  space_key: string;
}

export interface ConfluencePage {
  page_id: string;
  key: string;
  title: string;
  url: string;
  last_modified: string;
  children: ConfluencePage[];
}

export interface SpaceDataResponse {
  status: string;
  result: ConfluencePage[];
}

// ── Service ───────────────────────────────────────────

export const atlassianService = {
  // Auth
  connect: async (payload: ConnectPayload): Promise<ConnectResponse> => {
    const credentials = btoa(`${payload.username}:${payload.password}`);
    const response = await axios.post<ConnectResponse>(
      "/api/atlassian/connect",
      payload,
      {
        headers: {
          Authorization: `Basic ${credentials}`,
        },
      }
    );
    return response.data;
  },

  disconnect: async (): Promise<DisconnectResponse> => {
    const response = await axios.put<DisconnectResponse>(
      "/api/atlassian/disconnect",
      {},
      { headers: getAuthHeader() }
    );
    return response.data;
  },

  // Jira Projects
  fetchAllProjects: async (): Promise<ProjectsResponse> => {
    const response = await axios.get<ProjectsResponse>(
      "/api/jira/projects",
      { headers: getAuthHeader() }
    );
    return response.data;
  },

  fetchFavoriteProjects: async (): Promise<ProjectsResponse> => {
    const response = await axios.get<ProjectsResponse>(
      "/api/jira/projects/favorites",
      { headers: getAuthHeader() }
    );
    return response.data;
  },

  addFavoriteProject: async (
    payload: FavoritePayload
  ): Promise<FavoriteResponse> => {
    const response = await axios.post<FavoriteResponse>(
      "/api/jira/projects/favorites",
      payload,
      { headers: getAuthHeader() }
    );
    return response.data;
  },

  removeFavoriteProject: async (
    payload: FavoritePayload
  ): Promise<FavoriteResponse> => {
    const response = await axios.delete<FavoriteResponse>(
      "/api/jira/projects/favorites",
      {
        headers: getAuthHeader(),
        data: payload,
      }
    );
    return response.data;
  },

  fetchProjectData: async (id: string): Promise<ProjectDataResponse> => {
    const response = await axios.get<ProjectDataResponse>(
      `/api/jira/get_project_data/${id}`,
      { headers: getAuthHeader() }
    );
    return response.data;
  },

  // ── Confluence Spaces ───────────────────────────────

  fetchAllSpaces: async (): Promise<SpacesResponse> => {
    const response = await axios.get<SpacesResponse>(
      "/api/confluence/spaces",
      { headers: getAuthHeader() }
    );
    return response.data;
  },

  fetchFavoriteSpaces: async (): Promise<SpacesResponse> => {
    const response = await axios.get<SpacesResponse>(
      "/api/confluence/spaces/favorites",
      { headers: getAuthHeader() }
    );
    return response.data;
  },

  addFavoriteSpace: async (
    payload: SpaceFavoritePayload
  ): Promise<FavoriteResponse> => {
    const response = await axios.post<FavoriteResponse>(
      "/api/confluence/spaces/favorites",
      payload,
      { headers: getAuthHeader() }
    );
    return response.data;
  },

  removeFavoriteSpace: async (
    payload: SpaceFavoritePayload
  ): Promise<FavoriteResponse> => {
    const response = await axios.delete<FavoriteResponse>(
      "/api/confluence/spaces/favorites",
      {
        headers: getAuthHeader(),
        data: payload,
      }
    );
    return response.data;
  },

  fetchSpaceData: async (key: string): Promise<SpaceDataResponse> => {
    const response = await axios.get<SpaceDataResponse>(
      `/api/confluence/get_space_data/${key}`,
      { headers: getAuthHeader() }
    );
    return response.data;
  },
};



























import { createSlice, createAsyncThunk } from "@reduxjs/toolkit";
import { atlassianService } from "./atlassianService";

const LOCAL_STORAGE_KEY = "ATLASIAN_CONNECTION";

export interface AtlassianState {
  token: string | null;
  isConnected: boolean;
  isLoading: boolean;
  error: string | null;
}

const loadFromStorage = (): string | null => {
  try {
    return localStorage.getItem(LOCAL_STORAGE_KEY);
  } catch {
    return null;
  }
};

const initialState: AtlassianState = {
  token: loadFromStorage(),
  isConnected: !!loadFromStorage(),
  isLoading: false,
  error: null,
};

// ── Connect ───────────────────────────────────────────
export const connectAtlassian = createAsyncThunk(
  "atlassian/connect",
  async (
    payload: { username: string; password: string },
    { rejectWithValue }
  ) => {
    try {
      const data = await atlassianService.connect(payload);

      if (data.status !== "Success") {
        return rejectWithValue("Connection failed. Please check your credentials.");
      }

      localStorage.setItem(LOCAL_STORAGE_KEY, data.result);
      return data.result;
    } catch (error: any) {
      return rejectWithValue(
        error?.response?.data?.message ?? "Connection failed. Please try again."
      );
    }
  }
);

// ── Disconnect ────────────────────────────────────────
export const disconnectAtlassian = createAsyncThunk(
  "atlassian/disconnect",
  async (_, { rejectWithValue }) => {
    try {
      const data = await atlassianService.disconnect();

      if (data.status !== "Success") {
        return rejectWithValue("Disconnect failed. Please try again.");
      }

      localStorage.removeItem(LOCAL_STORAGE_KEY);
      return true;
    } catch (error: any) {
      return rejectWithValue(
        error?.response?.data?.message ?? "Disconnect failed. Please try again."
      );
    }
  }
);

const atlassianSlice = createSlice({
  name: "atlassian",
  initialState,
  reducers: {
    clearError(state) {
      state.error = null;
    },
    forceDisconnect(state) {
      state.isConnected = false;
      state.token = null;
      state.error = null;
    },
  },
  extraReducers: (builder) => {
    // Connect
    builder
      .addCase(connectAtlassian.pending, (state) => {
        state.isLoading = true;
        state.error = null;
      })
      .addCase(connectAtlassian.fulfilled, (state, action) => {
        state.isLoading = false;
        state.isConnected = true;
        state.token = action.payload;
      })
      .addCase(connectAtlassian.rejected, (state, action) => {
        state.isLoading = false;
        state.error = action.payload as string;
      });

    // Disconnect
    builder
      .addCase(disconnectAtlassian.pending, (state) => {
        state.isLoading = true;
        state.error = null;
      })
      .addCase(disconnectAtlassian.fulfilled, (state) => {
        state.isLoading = false;
        state.isConnected = false;
        state.token = null;
      })
      .addCase(disconnectAtlassian.rejected, (state, action) => {
        state.isLoading = false;
        state.error = action.payload as string;
      });
  },
});

export const { clearError, forceDisconnect } = atlassianSlice.actions;
export default atlassianSlice.reducer;













import React, { useEffect, useState } from "react";
import { useDispatch, useSelector } from "react-redux";
import type { AppDispatch, RootState } from "../../store";
import styles from "./PanelTools.module.scss";

import { AtlassianConnect } from "./AtlassianConnect";
import { JiraTool } from "./JiraTool";
import { ConfluenceTool } from "./ConfluenceTool";
import { setActiveTool, clearActiveTool } from "./toolSlice";
import type { ToolId } from "./toolSlice";
import { setupAtlassianInterceptor } from "./atlassianService";

import jiraIcon from "../../assets/icons/jira.png";
import confluenceIcon from "../../assets/icons/confluence.webp";

interface Tool {
  id: ToolId;
  name: string;
  description: string;
  icon: string;
}

const tools: Tool[] = [
  {
    id: "jira",
    name: "Jira",
    description: "Project issues in context",
    icon: jiraIcon,
  },
  {
    id: "confluence",
    name: "Confluence",
    description: "Team knowledge base",
    icon: confluenceIcon,
  },
];

// ── Plus icon ─────────────────────────────────────────

const PlusIcon = () => (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="9"
    height="9"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    strokeWidth="3"
    strokeLinecap="round"
    strokeLinejoin="round"
  >
    <line x1="12" y1="5" x2="12" y2="19" />
    <line x1="5" y1="12" x2="19" y2="12" />
  </svg>
);

export const PanelTools: React.FC = () => {
  const dispatch = useDispatch<AppDispatch>();
  const [selectedToolId, setSelectedToolId] = useState<ToolId>(null);

  const isExpanded: boolean = useSelector(
    (state: RootState) => state.layout.isRightPanelOpen
  );
  const isConnected: boolean = useSelector(
    (state: RootState) => state.atlassian.isConnected
  );
  const activeTool = useSelector(
    (state: RootState) => state.tool.activeTool
  );

  // Register the 498 interceptor once with store dispatch
  useEffect(() => {
    setupAtlassianInterceptor(dispatch);
  }, [dispatch]);

  // When 498 fires, forceDisconnect sets isConnected=false.
  // If a tool was active, keep selectedToolId set so the user
  // lands directly on the connect page for that tool.
  useEffect(() => {
    if (!isConnected && selectedToolId === null && activeTool) {
      setSelectedToolId(activeTool);
    }
  }, [isConnected]);

  const handleSelect = (id: NonNullable<ToolId>) => {
    setSelectedToolId(id);
    dispatch(setActiveTool(id));
  };

  const handleBack = () => {
    setSelectedToolId(null);
    dispatch(clearActiveTool());
  };

  // ── Collapsed: icon strip ─────────────────────────────
  if (!isExpanded) {
    return (
      <div className={styles.panelCollapsed}>
        {tools.map((tool) => (
          <button
            key={tool.id}
            className={styles.collapsedBtn}
            onClick={() => handleSelect(tool.id)}
            title={tool.name}
          >
            <img
              src={tool.icon}
              alt={tool.name}
              className={styles.collapsedIcon}
              width={20}
              height={20}
            />
            <span className={styles.collapsedPlus}>
              <PlusIcon />
            </span>
          </button>
        ))}
      </div>
    );
  }

  // ── Expanded: tool selected ───────────────────────────
  if (selectedToolId) {
    if (!isConnected) {
      return (
        <div className={styles.panel}>
          <AtlassianConnect toolId={selectedToolId} onBack={handleBack} />
        </div>
      );
    }

    if (selectedToolId === "jira") {
      return (
        <div className={styles.panel}>
          <JiraTool onBack={handleBack} />
        </div>
      );
    }

    if (selectedToolId === "confluence") {
      return (
        <div className={styles.panel}>
          <ConfluenceTool onBack={handleBack} />
        </div>
      );
    }
  }

  // ── Expanded: tool grid ───────────────────────────────
  return (
    <div className={styles.panel}>
      <div className={styles.panelHeader}>
        <span className={styles.panelTitle}>Tools</span>
      </div>
      <div className={styles.toolGrid}>
        {tools.map((tool) => (
          <button
            key={tool.id}
            className={styles.toolCard}
            onClick={() => handleSelect(tool.id)}
          >
            <div className={styles.cardTop}>
              <div className={styles.cardIconWrap}>
                <img
                  src={tool.icon}
                  alt={tool.name}
                  className={styles.cardIcon}
                  width={22}
                  height={22}
                />
              </div>
              <span className={styles.cardPlus}>
                <PlusIcon />
              </span>
            </div>
            <span className={styles.cardName}>{tool.name}</span>
            <span className={styles.cardDesc}>{tool.description}</span>
          </button>
        ))}
      </div>
    </div>
  );
};

export default PanelTools;
