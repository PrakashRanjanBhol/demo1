  flex-shrink: 0;
  position: relative;
  overflow: hidden;

  // Decorative accent line
  &::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(180deg, $jira-blue 0%, $jira-blue-dark 100%);
    border-radius: 0 2px 2px 0;
  }
}

.toolIcon {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  border: 1px solid rgba($jira-blue, 0.2);
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 1px 4px rgba($jira-blue, 0.15), 0 0 0 3px rgba($jira-blue, 0.05);
}

.img {
  object-fit: contain;
  display: block;
}

.toolMeta {
  flex: 1;
  display: flex;
  flex-direction: column;
