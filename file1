// Add to state declarations
const [isFormInitialized, setIsFormInitialized] = useState(false);

// Update isDirty to require initialization
const isDirty =
  isFormInitialized &&
  settings !== null &&
  (Number(form.file_size_limit) !== settings.file_size_limit ||
    Number(form.no_of_file_upload) !== settings.no_of_file_upload);

// Update the settings sync useEffect to set initialized AFTER form is set
useEffect(() => {
  if (settings) {
    setForm({
      file_size_limit: String(settings.file_size_limit),
      no_of_file_upload: String(settings.no_of_file_upload),
    });
    setIsFormInitialized(true);
  }
}, [settings]);
