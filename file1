import { createSlice } from "@reduxjs/toolkit";

export type ToolId = "jira" | "confluence" | null;

export interface ToolState {
  activeTool: ToolId;
  selectedTool: ToolId; // persists through panel collapse/expand
}

const initialState: ToolState = {
  activeTool: null,
  selectedTool: null,
};

const toolSlice = createSlice({
  name: "tool",
  initialState,
  reducers: {
    setActiveTool(state, action: { payload: NonNullable<ToolId> }) {
      state.activeTool = action.payload;
      state.selectedTool = action.payload;
    },
    clearActiveTool(state) {
      state.activeTool = null;
      state.selectedTool = null;
    },
    // Called by 498 interceptor — clears selection without clearing active
    // so the connect page re-opens for the right tool
    forceToolReconnect(state) {
      // keep selectedTool so PanelTools knows which tool to reconnect
    },
  },
});

export const { setActiveTool, clearActiveTool } = toolSlice.actions;
export default toolSlice.reducer;
