// ─── SCSS Variables ───────────────────────────────────────────────────────────

$radius-card:        12px;
$radius-icon:        8px;
$radius-action-btn:  7px;

$icon-wrapper-size:  38px;
$action-btn-size:    28px;

// Spinning border gradient — STARTED / PENDING only
$gradient-purple:    #7f77dd;
$gradient-blue:      #378add;
$gradient-teal:      #1d9e75;

// Job type colours
$translation-bg:     #e6f1fb;
$translation-color:  #378add;
$summary-bg:         #eeedfe;
$summary-color:      #7f77dd;

// Status colours
$failure-bg:         #faece7;
$failure-color:      #d85a30;
$failure-ring:       rgba(216, 90, 48, 0.25);
$success-ring:       rgba(29, 158, 117, 0.25);

// Action button
$action-hover-bg:    #eeedfe;
$action-hover-color: #534ab7;

// Dotted ring
$dotted-ring-color:  #7f77dd;
$dotted-ring-offset: 3px;

// Timing
$transition-fast:    0.15s;
$transition-medium:  0.3s;
$spin-duration:      2s;
$pulse-duration:     1.4s;


// ─── CSS Custom Properties ────────────────────────────────────────────────────

:root {
  --gc-container-bg:    #ffffff;
  --gc-card-bg-hover:   #f7f7f5;

  --gc-text-primary:    #111111;
  --gc-text-secondary:  #666666;
  --gc-text-tertiary:   #999999;
  --gc-text-error:      #{$failure-color};

  --gc-border:          rgba(0, 0, 0, 0.12);
  --gc-mask-color:      #ffffff;

  // Glow — soft warm white emanating from card center
  --gc-glow-color:      rgba(180, 160, 255, 0.18);
  --gc-glow-color-mid:  rgba(150, 180, 255, 0.10);
}

[data-theme='dark'] {
  --gc-container-bg:    #111113;
  --gc-card-bg-hover:   #18181b;

  --gc-text-primary:    #f0f0f0;
  --gc-text-secondary:  #a0a0a0;
  --gc-text-tertiary:   #606060;
  --gc-text-error:      #f0997b;

  --gc-border:          rgba(255, 255, 255, 0.08);
  --gc-mask-color:      #111113;

  // Glow — more vivid in dark mode, purple-blue tint
  --gc-glow-color:      rgba(140, 120, 255, 0.22);
  --gc-glow-color-mid:  rgba(80, 120, 255, 0.10);
}


// ─── Animations ───────────────────────────────────────────────────────────────

@property --angle {
  syntax: '<angle>';
  initial-value: 0deg;
  inherits: false;
}

// Spinning border for STARTED / PENDING
@keyframes spin {
  to { --angle: 360deg; }
}

// Pulsing icon ring
@keyframes pulse-ring {
  0%   { transform: scale(0.92); opacity: 0.6; }
  50%  { transform: scale(1.08); opacity: 1;   }
  100% { transform: scale(0.92); opacity: 0.6; }
}

// Glow breathes in softly on hover-enter, then holds
@keyframes glow-breathe {
  0%   { opacity: 0;    transform: scale(0.88); }
  60%  { opacity: 1;    transform: scale(1.02); }
  100% { opacity: 0.85; transform: scale(1);    }
}


// ─── Card ─────────────────────────────────────────────────────────────────────
.generatedCard {
  position: relative;
  display: flex;
  align-items: center;
  padding: 0.75rem;
  background-color: transparent;
  border-radius: $radius-card;
  overflow: visible; // glow bleeds slightly outside — looks more natural
  cursor: pointer;
  transition: background-color $transition-medium ease;

  // ── Border pseudo-elements ────────────────────────────────────────────
  &::before,
  &::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: $radius-card;
    -webkit-mask:
      linear-gradient(var(--gc-mask-color) 0 0) content-box,
      linear-gradient(var(--gc-mask-color) 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    padding: 1px;
    pointer-events: none;
    z-index: 0;
  }

  // Static border — always visible at rest
  &::before {
    background: var(--gc-border);
    transition: opacity $transition-medium;
  }

  // Spinning gradient border — animating always, shown only for STARTED/PENDING
  &::after {
    background: conic-gradient(
      from var(--angle) at 50% 50%,
      transparent       0deg,
      transparent       150deg,
      $gradient-purple  185deg,
      $gradient-blue    215deg,
      $gradient-teal    240deg,
      transparent       265deg
    );
    opacity: 0;
    animation: spin $spin-duration linear infinite;
    transition: opacity $transition-medium;
  }

  // ── Glow layer — sits behind the card, bleeds through border radius ───
  .glow {
    position: absolute;
    // slightly larger than card so glow peeks outside the border
    inset: -6px;
    border-radius: calc($radius-card + 6px);
    pointer-events: none;
    z-index: -1; // behind card background
    opacity: 0;
    transition: opacity $transition-medium ease;
    background: radial-gradient(
      ellipse 90% 80% at 50% 50%,
      var(--gc-glow-color)      0%,
      var(--gc-glow-color-mid)  45%,
      transparent               75%
    );
  }

  // ── Hover — glow breathes in, border subtly brightens ────────────────
  &:hover {
    background-color: var(--gc-card-bg-hover);

    &::before {
      // border brightens slightly on hover — reinforces the "lit from within" feel
      background: linear-gradient(
        135deg,
        rgba(150, 130, 255, 0.35),
        rgba(80,  140, 255, 0.25),
        rgba(30,  158, 117, 0.20)
      );
      opacity: 1;
    }

    .glow {
      opacity: 1;
      animation: glow-breathe 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .cardActions { opacity: 1; }
  }

  // ── STARTED / PENDING — spinning gradient border ──────────────────────
  &.STARTED,
  &.PENDING {
    &::before { opacity: 0; }
    &::after  { opacity: 1; }
  }

  // Collapsed icon-only state
  &:global(.w-min) { width: min-content; }
  &:global(.p-1)   { padding: 4px; }
}


// ─── Icon + status wrapper ────────────────────────────────────────────────────
.iconStatusWrapper {
  position: relative;
  z-index: 1;
  width: $icon-wrapper-size;
  height: $icon-wrapper-size;
  flex-shrink: 0;
  border-radius: $radius-icon;
  display: flex;
  align-items: center;
  justify-content: center;

  :global(.content-bg) {
    width: 100%;
    height: 100%;
    border-radius: $radius-icon;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  &.translation :global(.content-bg) {
    background: $translation-bg;
    color: $translation-color;
  }

  &.summary :global(.content-bg) {
    background: $summary-bg;
    color: $summary-color;
  }

  &.SUCCESS :global(.content-bg) {
    box-shadow: inset 0 0 0 1.5px $success-ring;
  }

  &.FAILURE :global(.content-bg) {
    background: $failure-bg;
    color: $failure-color;
    box-shadow: inset 0 0 0 1.5px $failure-ring;
  }

  &.STARTED :global(.content-bg),
  &.PENDING :global(.content-bg) {
    opacity: 0.7;
  }
}

.dottedRing {
  position: absolute;
  inset: -#{$dotted-ring-offset};
  width: calc(100% + #{$dotted-ring-offset * 2});
  height: calc(100% + #{$dotted-ring-offset * 2});
  animation: pulse-ring $pulse-duration ease-in-out infinite;
  color: $dotted-ring-color;
  pointer-events: none;
}


// ─── File info ────────────────────────────────────────────────────────────────
.fileInfo {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.fileName {
  font-size: 12px;
  font-weight: 500;
  color: var(--gc-text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.4;
}

.fileData {
  font-size: 11px;
  color: var(--gc-text-tertiary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.textError {
  color: var(--gc-text-error);
}


// ─── Card actions ─────────────────────────────────────────────────────────────
.cardActions {
  position: relative;
  z-index: 1;
  flex-shrink: 0;
  opacity: 0;
  transition: opacity $transition-fast;
}

.menuWarpper {
  position: relative;
  display: flex;
  align-items: center;
}

.actionBtn {
  width: $action-btn-size;
  height: $action-btn-size;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: $radius-action-btn;
  border: none;
  background: transparent;
  cursor: pointer;
  color: var(--gc-text-secondary);
  transition:
    background  $transition-fast,
    transform   0.12s,
    color       $transition-fast;

  &:hover {
    background: $action-hover-bg;
    color: $action-hover-color;
    transform: scale(1.1);
  }

  &:active {
    transform: scale(0.96);
  }
}
