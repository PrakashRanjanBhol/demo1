/* Select All Checkbox */
.select-all-checkbox {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    cursor: pointer;
    margin-right: 8px;
}

.select-all-checkbox .checkbox-inner {
    width: 20px;
    height: 20px;
    border: 2px solid var(--border-color);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    background: var(--bg-color);
}

.select-all-checkbox .checkbox-inner.checked {
    background: linear-gradient(135deg, #ef4444, #dc2626);
    border-color: #ef4444;
}

.select-all-checkbox .checkbox-inner svg {
    width: 14px;
    height: 14px;
    stroke: white;
}

/* Delete Mode Button */
.delete-mode-btn {
    width: 32px;
    height: 32px;
    background: linear-gradient(135deg, var(--primary-gradient-light-start), var(--primary-gradient-light-end));
    border: 1.5px solid var(--primary-border-color);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    flex-shrink: 0;
}

.delete-mode-btn svg {
    width: 18px;
    height: 18px;
    stroke: var(--primary-color);
    transition: all 0.3s ease;
}

.delete-mode-btn:hover {
    background: linear-gradient(135deg, var(--primary-gradient-medium-start), var(--primary-gradient-medium-end));
    border-color: var(--primary-color);
    box-shadow: 0 2px 8px var(--primary-shadow-light);
}

.delete-mode-btn.active {
    background: linear-gradient(135deg, #ef4444, #dc2626);
    border-color: #ef4444;
}

.delete-mode-btn.active svg {
    stroke: white;
}

/* Delete Action Bar */
.delete-action-bar {
    background: linear-gradient(135deg, rgba(239, 68, 68, 0.1), rgba(220, 38, 38, 0.1));
    border-bottom: 1px solid rgba(239, 68, 68, 0.3);
    padding: 12px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    animation: slideDown 0.3s ease;
}

.delete-action-info {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
}

.delete-action-info .info-icon {
    width: 20px;
    height: 20px;
    stroke: #ef4444;
    flex-shrink: 0;
}

.delete-action-info span {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-color);
}

.delete-action-buttons {
    display: flex;
    gap: 10px;
    flex-shrink: 0;
}

.cancel-delete-btn,
.confirm-delete-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
}

.cancel-delete-btn {
    background: transparent;
    color: var(--text-color);
    border: 1.5px solid var(--border-color);
}

.cancel-delete-btn:hover {
    background: rgba(107, 114, 128, 0.1);
    border-color: #6b7280;
}

.cancel-delete-btn svg {
    width: 16px;
    height: 16px;
}

.confirm-delete-btn {
    background: linear-gradient(135deg, #ef4444, #dc2626);
    color: white;
    border: 1.5px solid #ef4444;
}

.confirm-delete-btn:hover:not(:disabled) {
    box-shadow: 0 4px 12px rgba(239, 68, 68, 0.4);
    transform: translateY(-2px);
}

.confirm-delete-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.confirm-delete-btn svg {
    width: 16px;
    height: 16px;
}

/* Delete Checkbox */
.delete-checkbox {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    cursor: pointer;
}

.delete-checkbox .checkbox-inner {
    width: 20px;
    height: 20px;
    border: 2px solid var(--border-color);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    background: var(--bg-color);
}

.delete-checkbox .checkbox-inner.checked {
    background: linear-gradient(135deg, #ef4444, #dc2626);
    border-color: #ef4444;
}

.delete-checkbox .checkbox-inner svg {
    width: 14px;
    height: 14px;
    stroke: white;
}

/* Delete Selected State */
.history-item.delete-selected {
    background: linear-gradient(135deg, rgba(239, 68, 68, 0.1), rgba(220, 38, 38, 0.1));
    border-color: rgba(239, 68, 68, 0.4);
}

/* Delete Confirmation Modal */
.modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    animation: fadeIn 0.2s ease;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
}

.modal-container {
    background: var(--bg-color);
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    max-width: 480px;
    width: 90%;
    animation: modalSlideIn 0.3s ease;
    border: 1px solid var(--border-color);
}

@keyframes modalSlideIn {
    from {
        opacity: 0;
        transform: translateY(-20px) scale(0.95);
    }
    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

.modal-header {
    padding: 24px 24px 16px 24px;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    align-items: flex-start;
    gap: 12px;
    position: relative;
}

.modal-icon {
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, rgba(239, 68, 68, 0.1), rgba(220, 38, 38, 0.1));
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.modal-icon svg {
    width: 28px;
    height: 28px;
    stroke: #ef4444;
}

.modal-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-color);
    margin: 0;
    padding-top: 8px;
    flex: 1;
}

.modal-close-btn {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 32px;
    height: 32px;
    background: transparent;
    border: none;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
}

.modal-close-btn:hover {
    background: rgba(239, 68, 68, 0.1);
}

.modal-close-btn svg {
    width: 18px;
    height: 18px;
    stroke: var(--text-color);
    opacity: 0.6;
}

.modal-body {
    padding: 24px;
}

.modal-message {
    font-size: 14px;
    color: var(--text-color);
    margin: 0 0 12px 0;
    line-height: 1.6;
}

.modal-message strong {
    color: #ef4444;
    font-weight: 700;
}

.modal-warning {
    font-size: 13px;
    color: var(--text-color);
    opacity: 0.7;
    margin: 0;
    line-height: 1.5;
    padding: 12px;
    background: rgba(239, 68, 68, 0.05);
    border-left: 3px solid #ef4444;
    border-radius: 4px;
}

.modal-footer {
    padding: 16px 24px 24px 24px;
    display: flex;
    gap: 12px;
    justify-content: flex-end;
}

.modal-cancel-btn,
.modal-confirm-btn {
    padding: 10px 20px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
    display: flex;
    align-items: center;
    gap: 8px;
}

.modal-cancel-btn {
    background: transparent;
    color: var(--text-color);
    border: 1.5px solid var(--border-color);
}

.modal-cancel-btn:hover {
    background: rgba(107, 114, 128, 0.1);
    border-color: #6b7280;
}

.modal-confirm-btn {
    background: linear-gradient(135deg, #ef4444, #dc2626);
    color: white;
    border: 1.5px solid #ef4444;
}

.modal-confirm-btn:hover {
    box-shadow: 0 4px 12px rgba(239, 68, 68, 0.4);
    transform: translateY(-2px);
}

.modal-confirm-btn svg {
    width: 18px;
    height: 18px;
}

/* Responsive Delete Styles */
@media screen and (max-width: 1400px) {
    .select-all-checkbox {
        width: 20px;
        height: 20px;
        margin-right: 6px;
    }

    .select-all-checkbox .checkbox-inner {
        width: 18px;
        height: 18px;
    }

    .select-all-checkbox .checkbox-inner svg {
        width: 12px;
        height: 12px;
    }

    .delete-mode-btn {
        width: 28px;
        height: 28px;
    }

    .delete-mode-btn svg {
        width: 16px;
        height: 16px;
    }

    .delete-action-bar {
        padding: 10px 16px;
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
    }

    .delete-action-buttons {
        width: 100%;
        justify-content: flex-end;
    }

    .cancel-delete-btn,
    .confirm-delete-btn {
        padding: 7px 12px;
        font-size: 12px;
    }

    .delete-checkbox {
        width: 20px;
        height: 20px;
    }

    .delete-checkbox .checkbox-inner {
        width: 18px;
        height: 18px;
    }

    .delete-checkbox .checkbox-inner svg {
        width: 12px;
        height: 12px;
    }

    .modal-container {
        max-width: 90%;
    }

    .modal-header {
        padding: 20px 20px 12px 20px;
    }

    .modal-icon {
        width: 40px;
        height: 40px;
    }

    .modal-icon svg {
        width: 24px;
        height: 24px;
    }

    .modal-title {
        font-size: 16px;
    }

    .modal-body {
        padding: 20px;
    }

    .modal-footer {
        padding: 12px 20px 20px 20px;
        flex-direction: column;
    }

    .modal-cancel-btn,
    .modal-confirm-btn {
        width: 100%;
        justify-content: center;
    }
}
