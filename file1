import axios from "axios";

const LOCAL_STORAGE_KEY = "ATLASIAN_CONNECTION";

// ── Helpers ───────────────────────────────────────────

const getAuthHeader = () => {
  const token = localStorage.getItem(LOCAL_STORAGE_KEY) ?? "";
  return { Authorization: `Bearer ${token}` };
};

// ── Types ─────────────────────────────────────────────

export interface ConnectPayload {
  username: string;
  password: string;
}

export interface ConnectResponse {
  status: string;
  result: string;
}

export interface DisconnectResponse {
  status: string;
  result: string;
}

export interface JiraProject {
  key: string;
  id: string;
  type: "project";
  icon: string;
}

export interface ProjectsResult {
  [id: string]: JiraProject;
}

export interface ProjectsResponse {
  status: string;
  result: ProjectsResult;
}

export interface FavoritePayload {
  project_key: string;
}

export interface FavoriteResponse {
  status: string;
  result: string;
}

// ── Service ───────────────────────────────────────────

export const atlassianService = {
  // Auth
  connect: async (payload: ConnectPayload): Promise<ConnectResponse> => {
    const credentials = btoa(`${payload.username}:${payload.password}`);
    const response = await axios.post<ConnectResponse>(
      "/api/atlassian/connect",
      payload,
      {
        headers: {
          Authorization: `Basic ${credentials}`,
        },
      }
    );
    return response.data;
  },

  disconnect: async (): Promise<DisconnectResponse> => {
    const response = await axios.put<DisconnectResponse>(
      "/api/atlassian/disconnect",
      {},
      { headers: getAuthHeader() }
    );
    return response.data;
  },

  // Jira Projects
  fetchAllProjects: async (): Promise<ProjectsResponse> => {
    const response = await axios.get<ProjectsResponse>(
      "/api/jira/projects",
      { headers: getAuthHeader() }
    );
    return response.data;
  },

  fetchFavoriteProjects: async (): Promise<ProjectsResponse> => {
    const response = await axios.get<ProjectsResponse>(
      "/api/jira/projects/favorites",
      { headers: getAuthHeader() }
    );
    return response.data;
  },

  addFavoriteProject: async (
    payload: FavoritePayload
  ): Promise<FavoriteResponse> => {
    const response = await axios.post<FavoriteResponse>(
      "/api/jira/projects/favorites",
      payload,
      { headers: getAuthHeader() }
    );
    return response.data;
  },

  removeFavoriteProject: async (
    payload: FavoritePayload
  ): Promise<FavoriteResponse> => {
    const response = await axios.delete<FavoriteResponse>(
      "/api/jira/projects/favorites",
      {
        headers: getAuthHeader(),
        data: payload,
      }
    );
    return response.data;
  },
};














import { createSlice, createAsyncThunk } from "@reduxjs/toolkit";
import {
  atlassianService,
  type JiraProject,
  type ProjectsResult,
} from "./atlassianService";

export interface JiraState {
  allProjects: ProjectsResult;
  favoriteProjects: ProjectsResult;
  isLoadingProjects: boolean;
  isFavoriteUpdating: Record<string, boolean>; // keyed by project id
  error: string | null;
}

const initialState: JiraState = {
  allProjects: {},
  favoriteProjects: {},
  isLoadingProjects: false,
  isFavoriteUpdating: {},
  error: null,
};

// ── Thunks ────────────────────────────────────────────

export const fetchJiraProjects = createAsyncThunk(
  "jira/fetchProjects",
  async (_, { rejectWithValue }) => {
    try {
      const [allRes, favRes] = await Promise.all([
        atlassianService.fetchAllProjects(),
        atlassianService.fetchFavoriteProjects(),
      ]);

      if (allRes.status !== "Success") {
        return rejectWithValue("Failed to fetch projects.");
      }
      if (favRes.status !== "Success") {
        return rejectWithValue("Failed to fetch favorite projects.");
      }

      return {
        allProjects: allRes.result,
        favoriteProjects: favRes.result,
      };
    } catch (error: any) {
      return rejectWithValue(
        error?.response?.data?.message ?? "Failed to load Jira projects."
      );
    }
  }
);

export const addFavoriteProject = createAsyncThunk(
  "jira/addFavorite",
  async (project: JiraProject, { rejectWithValue }) => {
    try {
      const res = await atlassianService.addFavoriteProject({
        project_key: project.id,
      });

      if (res.status !== "Success") {
        return rejectWithValue("Failed to add favorite.");
      }

      return project;
    } catch (error: any) {
      return rejectWithValue(
        error?.response?.data?.message ?? "Failed to add favorite."
      );
    }
  }
);

export const removeFavoriteProject = createAsyncThunk(
  "jira/removeFavorite",
  async (project: JiraProject, { rejectWithValue }) => {
    try {
      const res = await atlassianService.removeFavoriteProject({
        project_key: project.id,
      });

      if (res.status !== "Success") {
        return rejectWithValue("Failed to remove favorite.");
      }

      return project;
    } catch (error: any) {
      return rejectWithValue(
        error?.response?.data?.message ?? "Failed to remove favorite."
      );
    }
  }
);

// ── Slice ─────────────────────────────────────────────

const jiraSlice = createSlice({
  name: "jira",
  initialState,
  reducers: {
    clearJiraError(state) {
      state.error = null;
    },
    resetJiraState() {
      return initialState;
    },
  },
  extraReducers: (builder) => {
    // Fetch projects
    builder
      .addCase(fetchJiraProjects.pending, (state) => {
        state.isLoadingProjects = true;
        state.error = null;
      })
      .addCase(fetchJiraProjects.fulfilled, (state, action) => {
        state.isLoadingProjects = false;
        state.allProjects = action.payload.allProjects;
        state.favoriteProjects = action.payload.favoriteProjects;
      })
      .addCase(fetchJiraProjects.rejected, (state, action) => {
        state.isLoadingProjects = false;
        state.error = action.payload as string;
      });

    // Add favorite
    builder
      .addCase(addFavoriteProject.pending, (state, action) => {
        state.isFavoriteUpdating[action.meta.arg.id] = true;
      })
      .addCase(addFavoriteProject.fulfilled, (state, action) => {
        const project = action.payload;
        state.isFavoriteUpdating[project.id] = false;
        state.favoriteProjects[project.id] = project;
      })
      .addCase(addFavoriteProject.rejected, (state, action) => {
        state.isFavoriteUpdating[action.meta.arg.id] = false;
        state.error = action.payload as string;
      });

    // Remove favorite
    builder
      .addCase(removeFavoriteProject.pending, (state, action) => {
        state.isFavoriteUpdating[action.meta.arg.id] = true;
      })
      .addCase(removeFavoriteProject.fulfilled, (state, action) => {
        const project = action.payload;
        state.isFavoriteUpdating[project.id] = false;
        delete state.favoriteProjects[project.id];
      })
      .addCase(removeFavoriteProject.rejected, (state, action) => {
        state.isFavoriteUpdating[action.meta.arg.id] = false;
        state.error = action.payload as string;
      });
  },
});

export const { clearJiraError, resetJiraState } = jiraSlice.actions;
export default jiraSlice.reducer;


















import React, { useEffect, useState } from "react";
import { useDispatch, useSelector } from "react-redux";
import type { AppDispatch, RootState } from "../../store";
import { disconnectAtlassian } from "./atlassianSlice";
import {
  fetchJiraProjects,
  addFavoriteProject,
  removeFavoriteProject,
} from "./jiraSlice";
import type { JiraProject } from "./atlassianService";
import styles from "./JiraTool.module.scss";

import jiraIcon from "../../assets/icons/jira.png";

interface JiraToolProps {
  onBack: () => void;
}

type Tab = "favorites" | "all";

const StarFilledIcon = () => (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="14"
    height="14"
    viewBox="0 0 24 24"
    fill="currentColor"
  >
    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
  </svg>
);

const StarOutlineIcon = () => (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="14"
    height="14"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    strokeWidth="2"
    strokeLinecap="round"
    strokeLinejoin="round"
  >
    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
  </svg>
);

const LogoutIcon = () => (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="15"
    height="15"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    strokeWidth="2"
    strokeLinecap="round"
    strokeLinejoin="round"
  >
    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
    <polyline points="16 17 21 12 16 7" />
    <line x1="21" y1="12" x2="9" y2="12" />
  </svg>
);

export const JiraTool: React.FC<JiraToolProps> = ({ onBack }) => {
  const dispatch = useDispatch<AppDispatch>();

  const { isLoading: isDisconnecting } = useSelector(
    (state: RootState) => state.atlassian
  );
  const { allProjects, favoriteProjects, isLoadingProjects, isFavoriteUpdating, error } =
    useSelector((state: RootState) => state.jira);

  const [activeTab, setActiveTab] = useState<Tab>("favorites");

  // Fetch projects on mount
  useEffect(() => {
    dispatch(fetchJiraProjects());
  }, [dispatch]);

  const handleDisconnect = () => {
    dispatch(disconnectAtlassian());
  };

  const isFavorite = (projectId: string) => !!favoriteProjects[projectId];

  const handleToggleFavorite = (project: JiraProject) => {
    if (isFavoriteUpdating[project.id]) return;
    if (isFavorite(project.id)) {
      dispatch(removeFavoriteProject(project));
    } else {
      dispatch(addFavoriteProject(project));
    }
  };

  const allProjectsList = Object.values(allProjects);
  const favoriteProjectsList = Object.values(favoriteProjects);

  return (
    <div className={styles.wrapper}>
      {/* ── Top header ───────────────────────────────── */}
      <div className={styles.header}>
        <button className={styles.backBtn} onClick={onBack}>
          <span className={styles.backArrow}>←</span>
          <span>All tools</span>
        </button>
        <button
          className={styles.logoutBtn}
          onClick={handleDisconnect}
          disabled={isDisconnecting}
          title="Disconnect"
        >
          <LogoutIcon />
        </button>
      </div>

      {/* ── Tool identity ─────────────────────────────── */}
      <div className={styles.toolHeader}>
        <div className={styles.toolIcon}>
          <img src={jiraIcon} alt="Jira" width={24} height={24} className={styles.img} />
        </div>
        <div className={styles.toolMeta}>
          <h2 className={styles.toolName}>Jira</h2>
          <span className={styles.connectedBadge}>● Connected</span>
        </div>
      </div>

      {/* ── Tabs ──────────────────────────────────────── */}
      <div className={styles.tabs}>
        <button
          className={`${styles.tab} ${activeTab === "favorites" ? styles.activeTab : ""}`}
          onClick={() => setActiveTab("favorites")}
        >
          Favorite Projects
          {favoriteProjectsList.length > 0 && (
            <span className={styles.tabCount}>{favoriteProjectsList.length}</span>
          )}
        </button>
        <button
          className={`${styles.tab} ${activeTab === "all" ? styles.activeTab : ""}`}
          onClick={() => setActiveTab("all")}
        >
          All Projects
          {allProjectsList.length > 0 && (
            <span className={styles.tabCount}>{allProjectsList.length}</span>
          )}
        </button>
      </div>

      {/* ── Content ───────────────────────────────────── */}
      <div className={styles.content}>
        {/* Loading state */}
        {isLoadingProjects && (
          <div className={styles.loadingState}>
            <span className={styles.spinner} />
            <span>Loading projects…</span>
          </div>
        )}

        {/* Error state */}
        {!isLoadingProjects && error && (
          <div className={styles.errorState}>{error}</div>
        )}

        {/* Favorite Projects tab */}
        {!isLoadingProjects && !error && activeTab === "favorites" && (
          <>
            {favoriteProjectsList.length === 0 ? (
              <div className={styles.emptyState}>
                <StarOutlineIcon />
                <p>No favorite projects yet.</p>
                <span>Go to All Projects to add favorites.</span>
              </div>
            ) : (
              <ul className={styles.projectList}>
                {favoriteProjectsList.map((project) => (
                  <li key={project.id} className={styles.projectItem}>
                    <img
                      src={project.icon}
                      alt={project.key}
                      className={styles.projectIcon}
                      width={28}
                      height={28}
                      onError={(e) => {
                        (e.target as HTMLImageElement).style.display = "none";
                      }}
                    />
                    <div className={styles.projectInfo}>
                      <span className={styles.projectKey}>{project.key}</span>
                      <span className={styles.projectId}>ID: {project.id}</span>
                    </div>
                  </li>
                ))}
              </ul>
            )}
          </>
        )}

        {/* All Projects tab */}
        {!isLoadingProjects && !error && activeTab === "all" && (
          <>
            {allProjectsList.length === 0 ? (
              <div className={styles.emptyState}>
                <p>No projects found.</p>
              </div>
            ) : (
              <ul className={styles.projectList}>
                {allProjectsList.map((project) => {
                  const favorited = isFavorite(project.id);
                  const updating = !!isFavoriteUpdating[project.id];

                  return (
                    <li key={project.id} className={styles.projectItem}>
                      <img
                        src={project.icon}
                        alt={project.key}
                        className={styles.projectIcon}
                        width={28}
                        height={28}
                        onError={(e) => {
                          (e.target as HTMLImageElement).style.display = "none";
                        }}
                      />
                      <div className={styles.projectInfo}>
                        <span className={styles.projectKey}>{project.key}</span>
                        <span className={styles.projectId}>ID: {project.id}</span>
                      </div>
                      <button
                        className={`${styles.favoriteBtn} ${favorited ? styles.favorited : ""}`}
                        onClick={() => handleToggleFavorite(project)}
                        disabled={updating}
                        title={favorited ? "Remove from favorites" : "Add to favorites"}
                      >
                        {updating ? (
                          <span className={styles.miniSpinner} />
                        ) : favorited ? (
                          <StarFilledIcon />
                        ) : (
                          <StarOutlineIcon />
                        )}
                      </button>
                    </li>
                  );
                })}
              </ul>
            )}
          </>
        )}
      </div>
    </div>
  );
};

export default JiraTool;


















