.projectKey {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.projectId {
  font-size: 0.7rem;
  color: var(--text-tertiary);
}

// ── Favorite button ───────────────────────────────────

.favoriteBtn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  border-radius: 6px;
  border: 1px solid transparent;
  background: transparent;
  color: var(--text-tertiary);
  cursor: pointer;
  flex-shrink: 0;
  transition: all 0.15s ease;

  &:hover:not(:disabled) {
    background: var(--bg-surface);
    border-color: var(--border-subtle);
    color: #f59e0b;
  }

  &.favorited {
    color: #f59e0b;

    &:hover:not(:disabled) {
      background: #fffbeb;
      border-color: #fde68a;
      color: #d97706;
    }
  }

  &:disabled {
    cursor: not-allowed;
    opacity: 0.6;
  }
}

// ── Spinners ──────────────────────────────────────────

.spinner {
  width: 16px;
  height: 16px;
  border: 2px solid var(--border-subtle);
  border-top-color: var(--accent-primary);
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
  display: inline-block;
  flex-shrink: 0;
}

.miniSpinner {
  width: 10px;
  height: 10px;
  border: 1.5px solid var(--border-subtle);
  border-top-color: #f59e0b;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
  display: inline-block;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
