// ── File list ─────────────────────────────────────────

.fileList {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0;
}

// ── File item (fileRow design) ────────────────────────

.fileItem {
  display: flex;
  align-items: center;
  padding: 6px 0.5rem;
  border-radius: 8px;
  position: relative;
  transition: background-color 0.2s ease;
  border: none;
  background: transparent;
  cursor: pointer;
  animation: itemIn 0.18s ease both;

  @for $i from 1 through 20 {
    &:nth-child(#{$i}) { animation-delay: #{$i * 0.04}s; }
  }

  // row separator
  & + .fileItem {
    border-top: 1px solid var(--excel-analytics-row-sep);
  }

  // suppress separator when neighbour is hovered/selected
  &:hover + .fileItem,
  &.fileItemSelected + .fileItem {
    border-top-color: transparent;
  }

  // ── hover ──────────────────────────────────────────
  &:hover:not(.fileItemDisabled) {
    background-color: var(--excel-analytics-row-bg-hover);

    .fileTypeIcon { color: var(--excel-analytics-row-icon-hover); }
    .fileName     { color: var(--excel-analytics-row-text-hover); }
    .fileSize     { color: var(--excel-analytics-row-text-hover); }
  }

  // ── selected ───────────────────────────────────────
  &.fileItemSelected {
    background-color: var(--excel-analytics-row-bg-selected);

    &::before {
      content: '';
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 3px;
      height: 18px;
      border-radius: 0 3px 3px 0;
      background: var(--excel-analytics-row-indicator);
      animation: dotIn 0.25s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }

    .fileTypeIcon { color: var(--excel-analytics-row-icon-hover); }

    .fileName {
      color: var(--excel-analytics-row-text-selected);
      font-weight: 600;
      animation: nameSelect 0.32s cubic-bezier(0.22, 1, 0.36, 1) both;
      will-change: transform, opacity, filter;
    }

    .fileSize {
      color: var(--excel-analytics-row-accent);
      opacity: 0.7;
    }
  }

  // ── deselecting ────────────────────────────────────
  &.fileItemDeselecting {
    .fileName {
      animation: nameDeselect 0.25s ease both;
    }
  }

  &.fileItemDisabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
}

// ── Checkbox wrapper ──────────────────────────────────

.fileCheckbox {
  display: flex;
  align-items: center;
  cursor: pointer;
  margin-right: 12px;
  flex-shrink: 0;

  input[type='checkbox'] {
    cursor: pointer;
    width: 16px;
    height: 16px;
    accent-color: var(--excel-analytics-row-checkbox-accent);
    margin: 0;

    &:disabled { cursor: not-allowed; }
  }
}

// ── File type icon ────────────────────────────────────

.fileTypeIcon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 26px;
  height: 26px;
  border-radius: 7px;
  flex-shrink: 0;
  margin-right: 12px;
  background: transparent;
  transition: color 0.22s ease;
  color: var(--text-secondary);
}

.fileTypeIconXlsx {
  background: var(--xlsx-bg);
  color: var(--xlsx-color);
  border: 1px solid var(--xlsx-border);
}

.fileTypeIconCsv {
  background: var(--csv-bg);
  color: var(--csv-color);
  border: 1px solid var(--csv-border);
}

// ── File info ─────────────────────────────────────────

.fileInfo {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 6px;
  min-width: 0;
}

.fileName {
  font-size: 0.8125rem;
  font-weight: 500;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  letter-spacing: -0.01em;
  flex: 1;
  min-width: 0;
  transition: color 0.22s ease;
  will-change: transform, opacity, filter;
}

.fileMeta {
  display: flex;
  align-items: center;
  gap: 4px;
  flex-shrink: 0;
}

.fileSize {
  font-size: 0.7rem;
  color: var(--text-secondary);
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
  transition: color 0.22s ease, opacity 0.22s ease;
}

// ── Empty state ───────────────────────────────────────

.emptyState {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 40px 20px;
  text-align: center;

  p {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
  }

  span {
    font-size: 0.75rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }
}

.emptyIcon {
  width: 42px;
  height: 42px;
  border-radius: 11px;
  background: var(--card-excel-hover-bg);
  border: 1px solid var(--card-excel-hover-border);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--card-excel-accent);
  margin-bottom: 4px;
}

// ── State banners ─────────────────────────────────────

.warningState {
  padding: 10px 12px;
  font-size: 0.7875rem;
  color: $warning-color;
  background: $warning-bg;
  border: 1px solid $warning-border;
  border-radius: 8px;
  line-height: 1.5;
}

.errorState {
  padding: 10px 12px;
  font-size: 0.7875rem;
  color: $error-red;
  background: $error-bg;
  border: 1px solid $error-border;
  border-radius: 8px;
  line-height: 1.5;
}
