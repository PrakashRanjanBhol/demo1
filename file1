// ── Tool card base — position relative for pseudo ──────
.toolCard {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8px;
  padding: 0 12px;
  height: 56px;
  border-radius: 12px;
  border: 1px solid var(--border-color);
  background: var(--app-bg);
  cursor: pointer;
  text-align: left;
  position: relative;        /* ← required */
  overflow: hidden;          /* ← clips the pseudo */
  z-index: 0;
  transition: background 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;

  &:active {
    transform: translateY(0);
    box-shadow: none;
  }

  /* ── Animated gradient border layer ── */
  &::before {
    content: '';
    position: absolute;
    inset: -2px;               /* slightly outside the card */
    border-radius: 13px;       /* radius + 1 to match outer */
    background: conic-gradient(
      from var(--angle, 0deg),
      transparent   0%,
      transparent  35%,
      currentColor 45%,        /* leading glow uses currentColor */
      currentColor 55%,
      transparent  65%,
      transparent 100%
    );
    z-index: -1;
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  /* Inner mask — punches out the card body so only border shows */
  &::after {
    content: '';
    position: absolute;
    inset: 1.5px;
    border-radius: 11px;
    background: var(--app-bg);
    z-index: -1;
    transition: background 0.15s ease;
  }

  &:hover::before {
    opacity: 1;
    animation: borderSpin 2s linear infinite;
  }
}

@property --angle {
  syntax: '<angle>';
  initial-value: 0deg;
  inherits: false;
}

@keyframes borderSpin {
  to { --angle: 360deg; }
}






.toolCard__jira:hover        { color: var(--card-jira-accent); }
.toolCard__confluence:hover  { color: var(--card-confluence-accent); }
.toolCard__summary:hover     { color: var(--card-summary-accent); }

