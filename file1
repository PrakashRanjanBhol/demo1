/* ═══════════════════════════════════════
   Poll Bar — Dark Mode Overrides
═══════════════════════════════════════ */
:host-context(.dark),
:host-context([data-theme="dark"]),
:host-context(body.dark-mode) {

  .poll-bar {
    background: rgba(55, 138, 221, 0.15);
    border-bottom-color: rgba(55, 138, 221, 0.3);
  }

  .pulse-dot {
    background: #93c5fd;
  }

  .poll-text {
    color: #93c5fd;
  }

  .poll-text strong {
    color: #bfdbfe;
  }
}
