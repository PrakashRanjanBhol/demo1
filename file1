/* Top shimmer ‚Äî full violet‚Üíindigo‚Üísky sweep */
.panel::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(
    90deg,
    transparent           0%,
    rgba(124,58,237,0.18) 15%,
    rgba(99,60,220,0.38)  36%,
    rgba(79,70,229,0.42)  50%,
    rgba(37,99,235,0.32)  68%,
    rgba(14,165,233,0.18) 85%,
    transparent           100%
  );
  pointer-events: none;
}
