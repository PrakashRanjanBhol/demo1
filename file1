.selectWrapper {
  position: relative;
  display: flex;
  align-items: center;
  border: 1px solid var(--gs-border);
  border-radius: 11px;
  background: var(--gs-select-bg);
  overflow: hidden;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;

  &:focus-within {
    border-color: transparent;
    box-shadow:
      0 0 0 1.5px var(--gs-accent),
      0 0 0 4px rgba(79, 70, 229, 0.08);
  }

  &.error {
    border-color: transparent;
    box-shadow:
      0 0 0 1.5px var(--gs-error-color),
      0 0 0 4px var(--gs-error-bg);
  }
}

.select {
  flex: 1;
  border: none;
  outline: none;
  padding: 10px 36px 10px 13px;
  font-size: 0.8125rem;
  font-family: 'DM Sans', system-ui, sans-serif;
  color: var(--gs-select-color);
  background: transparent;
  cursor: pointer;
  appearance: none;
  -webkit-appearance: none;

  option {
    background: var(--gs-bg);
    color: var(--gs-text);
  }
}

.selectIcon {
  position: absolute;
  right: 11px;
  pointer-events: none;
  color: var(--gs-accent);
  display: flex;
  align-items: center;

  svg {
    width: 14px;
    height: 14px;
  }
}

