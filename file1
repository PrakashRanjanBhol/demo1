// ── Helpers ───────────────────────────────────────────

const formatFileSize = (bytes: number): string => {
  if (bytes < 1024) return `${bytes} B`;
  if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
  return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
};

// ── Mock data (replace with store data) ──────────────

const MOCK_FILES: FileItem[] = [
  {
    created_at: "2026-03-20T06:32:26.696061+00:00",
    file_job_id: "abcd",
    file_name: "sample3.txt",
    file_size: 1815,
    file_type: "txt",
    state_id: "38hksdhcsdj",
    status: "SUCCESS",
  },
  {
    created_at: "2026-03-20T06:32:26.696061+00:00",
    file_job_id: "fdds",
    file_name: "sample4.xlsx",
    file_size: 1815,
    file_type: "xlsx",
    state_id: "38hksdhcsdj",
    status: "SUCCESS",
  },
  {
    created_at: "2026-03-20T06:32:26.696061+00:00",
    file_job_id: "dfdsf",
    file_name: "sample5.csv",
    file_size: 1815,
    file_type: "csv",
    state_id: "38hksdhcsdj",
    status: "SUCCESS",
  },
];

// ── Main component ────────────────────────────────────

export const ExcelAnalysisTool: React.FC<ExcelAnalysisToolProps> = ({ onBack }) => {
  const dispatch = useDispatch<AppDispatch>();

  // Replace MOCK_FILES with your store data when ready
  const files: FileItem[] = MOCK_FILES;

  const [selectedJobId, setSelectedJobId] = useState<string | null>(null);
  const [deselecting, setDeselecting]     = useState<string | null>(null);
  const [warning, setWarning]             = useState<string | null>(null);
  const [error, setError]                 = useState<string | null>(null);
  const [activeFilter, setActiveFilter]   = useState<"all" | "xlsx" | "csv">("all");

  const excelFiles = files.filter(
    (f) => f.file_type === "xlsx" || f.file_type === "csv"
  );

  const filteredFiles = activeFilter === "all"
    ? excelFiles
    : excelFiles.filter((f) => f.file_type === activeFilter);

  const xlsxCount = excelFiles.filter((f) => f.file_type === "xlsx").length;
  const csvCount  = excelFiles.filter((f) => f.file_type === "csv").length;

  // ── Your original handleToggle — unchanged logic ───
  // Wraps the deselect path in a short animation delay so
  // the nameDeselect keyframe plays before state clears.
  const handleToggle = (file_job_id: string) => {
    const fileId = selectedJobId === file_job_id ? null : file_job_id;

    if (fileId === null) {
      // play deselect animation, then commit state
      setDeselecting(file_job_id);
      setTimeout(() => {
        setDeselecting(null);
        setSelectedJobId(null);
        dispatch(updateLLMRequest({ id: file_job_id, activeTool: "EXCEL_ANALYTICS", selection: false }));
      }, 250);
    } else {
      setSelectedJobId(fileId);
      dispatch(updateLLMRequest({ id: file_job_id, activeTool: "EXCEL_ANALYTICS", selection: true }));
    }

    setError(null);
    setWarning(null);
  };

  return (
    <div className={styles.wrapper}>

      {/* ── Header ── */}
      <div className={styles.toolHeader}>
        <div className={styles.toolHeaderTop}>
          <div className={styles.breadcrumb}>
            <button className={styles.breadcrumbLink} onClick={onBack}>Tools</button>
            <span className={styles.breadcrumbSep}>›</span>
            <span className={styles.breadcrumbCurrent}>Excel Analysis</span>
          </div>
        </div>
        <div className={styles.toolHeaderBottom}>
          <div className={styles.toolIcon}>
            <img src={excelAnalysisIcon} alt="Excel Analysis" width={22} height={22} className={styles.img} />
          </div>
          <div className={styles.toolMeta}>
            <h2 className={styles.toolName}>Excel Analysis</h2>
          </div>
        </div>
      </div>

      {/* ── Body ── */}
      <div className={styles.body}>

        <p className={styles.description}>
          Select an Excel or CSV file to analyse. Only one file can be selected at a time.
        </p>

        {excelFiles.length === 0 ? (
          <div className={styles.emptyState}>
            <div className={styles.emptyIcon}><EmptyIcon /></div>
            <p>No Excel or CSV files available</p>
            <span>Upload an .xlsx or .csv file to get started.</span>
          </div>
        ) : (
          <>
            {/* ── File type filter ── */}
            <div className={styles.filterRow}>
              <button
                className={`${styles.filterBtn} ${activeFilter === "all" ? styles.filterBtnActive : ""}`}
                onClick={() => setActiveFilter("all")}
              >
                All
                <span className={styles.filterCount}>{excelFiles.length}</span>
              </button>
              <button
                className={`${styles.filterBtn} ${styles.filterBtnXlsx} ${activeFilter === "xlsx" ? styles.filterBtnActive : ""}`}
                onClick={() => setActiveFilter("xlsx")}
                disabled={xlsxCount === 0}
              >
                XLSX
                <span className={styles.filterCount}>{xlsxCount}</span>
              </button>
              <button
                className={`${styles.filterBtn} ${styles.filterBtnCsv} ${activeFilter === "csv" ? styles.filterBtnActive : ""}`}
                onClick={() => setActiveFilter("csv")}
                disabled={csvCount === 0}
              >
                CSV
                <span className={styles.filterCount}>{csvCount}</span>
              </button>
            </div>

            {/* ── File list ── */}
            {filteredFiles.length === 0 ? (
              <div className={styles.emptyStateInline}>
                <span>No {activeFilter.toUpperCase()} files found.</span>
              </div>
            ) : (
              <ul className={styles.fileList}>
                {filteredFiles.map((file) => {
                  const isSelected    = selectedJobId === file.file_job_id;
                  const isDeselecting = deselecting === file.file_job_id;
                  const isDisabled    = selectedJobId !== null && !isSelected && deselecting === null;
                  const isXlsx        = file.file_type === "xlsx";

                  return (
                    <li key={file.file_job_id}>
                      <label
                        className={[
                          styles.fileItem,
                          isSelected    ? styles.fileItemSelected    : "",
                          isDeselecting ? styles.fileItemDeselecting : "",
                          isDisabled    ? styles.fileItemDisabled    : "",
                        ].filter(Boolean).join(" ")}
                      >
                        {/* ── Checkbox (fileRow wrapper style) ── */}
                        <span className={styles.fileCheckbox}>
                          <input
                            type="checkbox"
                            checked={isSelected || isDeselecting}
                            disabled={isDisabled}
                            onChange={() => handleToggle(file.file_job_id)}
                          />
                        </span>

                        {/* ── File type icon ── */}
                        <span className={`${styles.fileTypeIcon} ${isXlsx ? styles.fileTypeIconXlsx : styles.fileTypeIconCsv}`}>
                          {isXlsx ? <XlsxIcon /> : <CsvIcon />}
                        </span>

                        {/* ── File info ── */}
                        <div className={styles.fileInfo}>
                          <span className={styles.fileName}>{file.file_name}</span>
                          <span className={styles.fileMeta}>
                            <span className={styles.fileSize}>{formatFileSize(file.file_size)}</span>
                          </span>
                        </div>
                      </label>
                    </li>
                  );
                })}
              </ul>
            )}
          </>
        )}

        {/* Warning */}
        {warning && (
          <div className={styles.warningState}>{warning}</div>
        )}

        {/* Error */}
        {error && (
          <div className={styles.errorState}>{error}</div>
        )}

      </div>
    </div>
  );
};

export default ExcelAnalysisTool;












