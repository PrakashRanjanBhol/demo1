import axios from "axios";

interface ConnectPayload {
  username: string;
  password: string;
}

interface ConnectResponse {
  status: string;
  result: string;
}

interface DisconnectResponse {
  status: string;
  result: string;
}

export const atlassianService = {
  connect: async (payload: ConnectPayload): Promise<ConnectResponse> => {
    const response = await axios.post<ConnectResponse>(
      "/api/atlassian/connect",
      payload
    );
    return response.data;
  },

  disconnect: async (): Promise<DisconnectResponse> => {
    const response = await axios.put<DisconnectResponse>(
      "/api/atlassian/disconnect"
    );
    return response.data;
  },
};









import { createSlice, createAsyncThunk } from "@reduxjs/toolkit";
import { atlassianService } from "./atlassianService";

const LOCAL_STORAGE_KEY = "ATLASIAN_CONNECTION";

export interface AtlassianState {
  token: string | null;
  isConnected: boolean;
  isLoading: boolean;
  error: string | null;
}

const loadFromStorage = (): string | null => {
  try {
    return localStorage.getItem(LOCAL_STORAGE_KEY);
  } catch {
    return null;
  }
};

const initialState: AtlassianState = {
  token: loadFromStorage(),
  isConnected: !!loadFromStorage(),
  isLoading: false,
  error: null,
};

// ── Connect ───────────────────────────────────────────
export const connectAtlassian = createAsyncThunk(
  "atlassian/connect",
  async (
    payload: { username: string; password: string },
    { rejectWithValue }
  ) => {
    try {
      const data = await atlassianService.connect(payload);

      if (data.status !== "Success") {
        return rejectWithValue("Connection failed. Please check your credentials.");
      }

      localStorage.setItem(LOCAL_STORAGE_KEY, data.result);
      return data.result;
    } catch (error: any) {
      return rejectWithValue(
        error?.response?.data?.message ?? "Connection failed. Please try again."
      );
    }
  }
);

// ── Disconnect ────────────────────────────────────────
export const disconnectAtlassian = createAsyncThunk(
  "atlassian/disconnect",
  async (_, { rejectWithValue }) => {
    try {
      const data = await atlassianService.disconnect();

      if (data.status !== "Success") {
        return rejectWithValue("Disconnect failed. Please try again.");
      }

      localStorage.removeItem(LOCAL_STORAGE_KEY);
      return true;
    } catch (error: any) {
      return rejectWithValue(
        error?.response?.data?.message ?? "Disconnect failed. Please try again."
      );
    }
  }
);

const atlassianSlice = createSlice({
  name: "atlassian",
  initialState,
  reducers: {
    clearError(state) {
      state.error = null;
    },
  },
  extraReducers: (builder) => {
    // Connect
    builder
      .addCase(connectAtlassian.pending, (state) => {
        state.isLoading = true;
        state.error = null;
      })
      .addCase(connectAtlassian.fulfilled, (state, action) => {
        state.isLoading = false;
        state.isConnected = true;
        state.token = action.payload;
      })
      .addCase(connectAtlassian.rejected, (state, action) => {
        state.isLoading = false;
        state.error = action.payload as string;
      });

    // Disconnect
    builder
      .addCase(disconnectAtlassian.pending, (state) => {
        state.isLoading = true;
        state.error = null;
      })
      .addCase(disconnectAtlassian.fulfilled, (state) => {
        state.isLoading = false;
        state.isConnected = false;
        state.token = null;
      })
      .addCase(disconnectAtlassian.rejected, (state, action) => {
        state.isLoading = false;
        state.error = action.payload as string;
      });
  },
});

export const { clearError } = atlassianSlice.actions;
export default atlassianSlice.reducer;
