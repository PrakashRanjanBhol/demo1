// Light mode
[data-theme='light'] {
    --sources-modal-bg:                 #ffffff;
    --sources-modal-border:             #e5e7eb;

    --sources-dropzone-bg:              #f9fafb;
    --sources-dropzone-bg-hover:        #f0f0ff;
    --sources-dropzone-border:          #d1d5db;
    --sources-dropzone-border-hover:    #4f46e5;
    --sources-dropzone-icon:            #9ca3af;
    --sources-dropzone-icon-hover:      #4f46e5;

    --sources-text-primary:             #111827;
    --sources-text-secondary:           #6b7280;

    --sources-divider-color:            #d1d5db;

    --sources-alt-btn-bg:               #f9fafb;
    --sources-alt-btn-bg-hover:         #f0f0ff;
    --sources-alt-btn-border:           #d1d5db;
    --sources-alt-btn-border-hover:     #4f46e5;
    --sources-alt-btn-shadow-hover:     rgba(79, 70, 229, 0.15);

    --sources-error-bg:                 #fef2f2;
    --sources-error-border:             #fecaca;
    --sources-error-text:               #dc2626;

    --sources-textarea-border:          #d1d5db;
    --sources-textarea-border-focus:    #4f46e5;
    --sources-textarea-bg:              #ffffff;
    --sources-textarea-text:            #111827;
    --sources-textarea-placeholder:     #9ca3af;

    --sources-back-btn-color:           #6b7280;
    --sources-back-btn-bg-hover:        #f0f0ff;
    --sources-back-btn-color-hover:     #4f46e5;

    --sources-insert-btn-bg:            linear-gradient(135deg, #7c3aed 0%, #4f46e5 35%, #2563eb 65%, #0ea5e9 100%);
    --sources-insert-btn-bg-hover:      linear-gradient(135deg, #6d28d9 0%, #4338ca 35%, #1d4ed8 65%, #0284c7 100%);
    --sources-insert-btn-bg-disabled:   linear-gradient(135deg, #c4b5fd 0%, #a5b4fc 35%, #93c5fd 65%, #7dd3fc 100%);
    --sources-insert-btn-text:          #ffffff;

    --sources-icon-youtube:             #ff0000;
    --sources-icon-website:             #2563eb;
    --sources-icon-text:                #7c3aed;

    --sources-btn-gradient:             linear-gradient(135deg, #7c3aed 0%, #4f46e5 35%, #2563eb 65%, #0ea5e9 100%);
    --sources-btn-gradient-hover:       linear-gradient(135deg, #6d28d9 0%, #4338ca 35%, #1d4ed8 65%, #0284c7 100%);
    --sources-btn-gradient-border:      #4f46e5;
    --sources-btn-gradient-shadow:      rgba(79, 70, 229, 0.2);
}

// Dark mode
[data-theme='dark'] {
    --sources-modal-bg:                 #0a0a0b;
    --sources-modal-border:             #27272a;

    --sources-dropzone-bg:              #18181b;
    --sources-dropzone-bg-hover:        #1e1b4b;
    --sources-dropzone-border:          #3f3f46;
    --sources-dropzone-border-hover:    #6d28d9;
    --sources-dropzone-icon:            #71717a;
    --sources-dropzone-icon-hover:      #818cf8;

    --sources-text-primary:             #f4f4f5;
    --sources-text-secondary:           #a1a1aa;

    --sources-divider-color:            #3f3f46;

    --sources-alt-btn-bg:               #18181b;
    --sources-alt-btn-bg-hover:         #1e1b4b;
    --sources-alt-btn-border:           #3f3f46;
    --sources-alt-btn-border-hover:     #6d28d9;
    --sources-alt-btn-shadow-hover:     rgba(124, 58, 237, 0.25);

    --sources-error-bg:                 #2d1515;
    --sources-error-border:             #7f1d1d;
    --sources-error-text:               #f87171;

    --sources-textarea-border:          #3f3f46;
    --sources-textarea-border-focus:    #6d28d9;
    --sources-textarea-bg:              #18181b;
    --sources-textarea-text:            #f4f4f5;
    --sources-textarea-placeholder:     #52525b;

    --sources-back-btn-color:           #a1a1aa;
    --sources-back-btn-bg-hover:        #1e1b4b;
    --sources-back-btn-color-hover:     #818cf8;

    --sources-insert-btn-bg:            linear-gradient(135deg, #7c3aed 0%, #4f46e5 35%, #2563eb 65%, #0ea5e9 100%);
    --sources-insert-btn-bg-hover:      linear-gradient(135deg, #6d28d9 0%, #4338ca 35%, #1d4ed8 65%, #0284c7 100%);
    --sources-insert-btn-bg-disabled:   linear-gradient(135deg, #3b1f6e 0%, #312e81 35%, #1e3a5f 65%, #0c4a6e 100%);
    --sources-insert-btn-text:          #ffffff;

    --sources-icon-youtube:             #ff4444;
    --sources-icon-website:             #60a5fa;
    --sources-icon-text:                #a78bfa;

    --sources-btn-gradient:             linear-gradient(135deg, #7c3aed 0%, #4f46e5 35%, #2563eb 65%, #0ea5e9 100%);
    --sources-btn-gradient-hover:       linear-gradient(135deg, #6d28d9 0%, #4338ca 35%, #1d4ed8 65%, #0284c7 100%);
    --sources-btn-gradient-border:      #6d28d9;
    --sources-btn-gradient-shadow:      rgba(124, 58, 237, 0.3);
}
















@use 'variables';

.modalContent {
    padding: 1.5rem;
    background-color: var(--sources-modal-bg);
    border-radius: 8px;
    border: 1px solid var(--sources-modal-border);
}

.dropZone {
    border: 2px dashed var(--sources-dropzone-border);
    border-radius: 8px;
    padding: 2.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: var(--sources-dropzone-bg);
    cursor: pointer;
    transition: all 0.2s ease;

    &:hover,
    &.dragging {
        background-color: var(--sources-dropzone-bg-hover);
        border-color: var(--sources-dropzone-border-hover);

        .cloudIcon {
            color: var(--sources-dropzone-icon-hover);
        }
    }

    .cloudIcon {
        color: var(--sources-dropzone-icon);
        margin-bottom: 12px;
        transition: color 0.2s ease;
    }

    .dropTitle {
        margin: 0 0 4px 0;
        font-weight: 500;
        color: var(--sources-text-primary);
    }

    .dropSubtitle {
        margin: 0;
        font-size: 0.85rem;
        color: var(--sources-text-secondary);
    }
}

.uploadErrorMsg {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    background-color: var(--sources-error-bg);
    border: 1px solid var(--sources-error-border);
    border-radius: 8px;
    padding: 10px 12px;

    span {
        font-size: 0.85rem;
        color: var(--sources-error-text);
    }
}

.dismissErrorBtn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 2px;
    color: var(--sources-error-text);
    display: flex;
    align-items: center;
    flex-shrink: 0;

    &:hover {
        opacity: 0.7;
    }
}

.modalDivider {
    display: flex;
    align-items: center;
    text-align: center;
    margin: 1.5rem 0;
    color: var(--sources-text-secondary);
    font-size: 0.85rem;

    &::before,
    &::after {
        content: '';
        flex: 1;
        border-bottom: 1px solid var(--sources-divider-color);
    }

    span {
        padding: 0 10px;
    }
}

.alternativeSourceGrid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
}

.altSourceBtn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background-color: var(--sources-alt-btn-bg);
    border: 1px solid var(--sources-alt-btn-border);
    border-radius: 8px;
    padding: 1rem 0.5rem;
    cursor: pointer;
    transition: all 0.2s ease;
    position: relative;

    span {
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--sources-text-primary);
        transition: color 0.2s ease;
    }

    &:hover {
        background-color: var(--sources-alt-btn-bg-hover);
        border-color: var(--sources-alt-btn-border-hover);
        box-shadow: 0 0 0 3px var(--sources-btn-gradient-shadow);

        span {
            background: var(--sources-btn-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
    }
}

.altIcon {
    &.youtube { color: var(--sources-icon-youtube); }
    &.website { color: var(--sources-icon-website); }
    &.text    { color: var(--sources-icon-text); }
}

// URL view
.urlViewHeader {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 1rem;
}

.backBtn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--sources-back-btn-color);
    padding: 4px 8px;
    display: flex;
    align-items: center;
    gap: 6px;
    border-radius: 6px;
    transition: all 0.2s ease;

    span {
        font-size: 0.85rem;
    }

    &:hover {
        background-color: var(--sources-back-btn-bg-hover);
        color: var(--sources-back-btn-color-hover);
    }
}

.urlViewTitle {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    color: var(--sources-text-primary);
}

.urlViewSubtitle {
    font-size: 0.85rem;
    color: var(--sources-text-secondary);
    margin: 0 0 1rem 0;
    line-height: 1.5;
}

.urlTextarea {
    width: 100%;
    min-height: 140px;
    border: 1px solid var(--sources-textarea-border);
    border-radius: 8px;
    padding: 12px;
    font-size: 0.9rem;
    color: var(--sources-textarea-text);
    background-color: var(--sources-textarea-bg);
    resize: vertical;
    box-sizing: border-box;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s ease;

    &::placeholder {
        color: var(--sources-textarea-placeholder);
    }

    &:focus {
        border-color: var(--sources-textarea-border-focus);
        box-shadow: 0 0 0 3px var(--sources-btn-gradient-shadow);
    }
}

.urlInsertRow {
    display: flex;
    justify-content: flex-end;
    margin-top: 1rem;
}

.insertBtn {
    background: var(--sources-btn-gradient);
    color: var(--sources-insert-btn-text);
    border: none;
    border-radius: 8px;
    padding: 0.5rem 1.25rem;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    position: relative;

    &:hover:not(:disabled) {
        background: var(--sources-btn-gradient-hover);
        box-shadow: 0 4px 12px var(--sources-btn-gradient-shadow);
        transform: translateY(-1px);
    }

    &:active:not(:disabled) {
        transform: translateY(0);
    }

    &:disabled {
        background: var(--sources-insert-btn-bg-disabled);
        cursor: not-allowed;
        opacity: 0.7;
    }
}
