              width={22}
              height={22}
            />
          </button>
        ))}
      </div>
    );
  }

  // ── Expanded: tool selected ───────────────────────────
  if (selectedToolId) {
    // Not connected → show connection page for this tool
    if (!isConnected) {
      return (
        <div className={styles.panel}>
          <AtlassianConnect toolId={selectedToolId} onBack={handleBack} />
        </div>
      );
    }

    // Connected → show the tool's own detail page
    if (selectedToolId === "jira") {
      return (
        <div className={styles.panel}>
          <JiraTool onBack={handleBack} />
        </div>
      );
    }

    if (selectedToolId === "confluence") {
      return (
        <div className={styles.panel}>
          <ConfluenceTool onBack={handleBack} />
        </div>
      );
    }
  }

  // ── Expanded: tool list ───────────────────────────────
  return (
    <div className={styles.panel}>
      <div className={styles.toolList}>
        {tools.map((tool) => (
          <button
            key={tool.id}
            className={styles.toolCard}
            onClick={() => setSelectedToolId(tool.id)}
          >
            <div className={styles.toolIcon}>
              <img
                src={tool.icon}
                alt={tool.name}
                className={styles.toolIconImg}
                width={20}
                height={20}
              />
            </div>
            <div className={styles.toolInfo}>
              <span className={styles.toolName}>{tool.name}</span>
              <span className={styles.toolDesc}>{tool.description}</span>
            </div>
            <div className={styles.toolMeta}>
              <span className={styles.chevron}>›</span>
            </div>
          </button>
        ))}
      </div>
    </div>
  );
};

export default PanelTools;






