// ── Panel wrapper ─────────────────────────────────────

.panel {
  width: 100%;
  height: 100%;
  background: var(--sidebar-bg);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  font-family: "DM Sans", "Segoe UI", sans-serif;
}

// ── Panel header ──────────────────────────────────────

.panelHeader {
  padding: 14px 14px 8px;
  flex-shrink: 0;
}

.panelTitle {
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-secondary);
}

// ── Expanded: 2-column grid ───────────────────────────

.toolGrid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  padding: 4px 10px 12px;
  overflow-y: auto;

  &::-webkit-scrollbar { width: 3px; }
  &::-webkit-scrollbar-track { background: transparent; }
  &::-webkit-scrollbar-thumb {
    background: var(--border-color);
    border-radius: 2px;
  }
}

// ── Tool card ─────────────────────────────────────────

.toolCard {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 12px 11px;
  border: 1px solid var(--border-color);
  border-radius: 12px;
  cursor: pointer;
  text-align: left;
  transition: all 0.18s ease;
  box-shadow: 0 1px 2px var(--box-shadow);
  position: relative;
  overflow: hidden;
  min-height: 84px;

  &:hover {
    box-shadow: 0 4px 14px var(--box-shadow);
    transform: translateY(-2px);

    .cardViewBtn {
      background: var(--btn-bg);
      color: var(--btn-text);
      border-color: var(--btn-bg);
    }
  }

  &:active {
    transform: translateY(0);
    box-shadow: 0 1px 3px var(--box-shadow);
  }
}

// ── Per-tool gradient backgrounds ─────────────────────
// Gradients are set via data-tool attribute on each card
// so they work independently of CSS Modules scoping.

.toolCard__jira {
  background: var(--card-jira-gradient);
  border-color: var(--card-jira-border);

  &:hover {
    border-color: var(--card-jira-border-hover);
    box-shadow: 0 4px 14px var(--card-jira-shadow);
  }

  .cardIconWrap {
    background: var(--card-jira-icon-bg);
    border-color: var(--card-jira-border);
  }

  .cardViewBtn {
    background: var(--card-jira-icon-bg);
    border-color: var(--card-jira-border);
    color: var(--card-jira-accent);
  }
}

.toolCard__confluence {
  background: var(--card-confluence-gradient);
  border-color: var(--card-confluence-border);

  &:hover {
    border-color: var(--card-confluence-border-hover);
    box-shadow: 0 4px 14px var(--card-confluence-shadow);
  }

  .cardIconWrap {
    background: var(--card-confluence-icon-bg);
    border-color: var(--card-confluence-border);
  }

  .cardViewBtn {
    background: var(--card-confluence-icon-bg);
    border-color: var(--card-confluence-border);
    color: var(--card-confluence-accent);
  }
}


// ── Card top row: icon + view btn ─────────────────────

.cardTop {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  width: 100%;
  margin-bottom: 12px;
}

.cardIconWrap {
  width: 36px;
  height: 36px;
  border-radius: 9px;
  border: 1px solid var(--border-color);
  background: var(--sidebar-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: border-color 0.18s ease;
  box-shadow: 0 1px 2px var(--box-shadow);
}

.cardIcon {
  object-fit: contain;
  display: block;
}

.cardViewBtn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  border: 1.5px solid var(--border-color);
  background: var(--sidebar-bg);
  color: var(--text-secondary);
  flex-shrink: 0;
  transition: all 0.18s ease;
  margin-top: 1px;
}

// ── Card name only (no description) ──────────────────

.cardName {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.2;
  letter-spacing: -0.01em;
}

// ── Collapsed: icon strip ─────────────────────────────

.panelCollapsed {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8px 0;
  gap: 6px;
}

.collapsedBtn {
  position: relative;
  width: 36px;
  height: 36px;
  border-radius: 10px;
  border: 1px solid var(--border-color);
  background: var(--app-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.15s ease;
  box-shadow: 0 1px 2px var(--box-shadow);

  &:hover {
    background: var(--hover-bg);
    border-color: var(--btn-bg);
    box-shadow: 0 2px 6px var(--box-shadow);

    .collapsedView {
      background: var(--btn-bg);
      color: var(--btn-text);
      border-color: var(--btn-bg);
    }
  }

  &:active {
    background: var(--app-bg);
    transform: scale(0.95);
  }
}

.collapsedIcon {
  object-fit: contain;
  display: block;
}

.collapsedView {
  position: absolute;
  top: -5px;
  right: -5px;
  width: 14px;
  height: 14px;
  border-radius: 50%;
  border: 1.5px solid var(--border-color);
  background: var(--sidebar-bg);
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.15s ease;
}













/* ── Tool card gradient tokens ───────────────────────────
   Paste these into your existing :root.light-theme and
   .dark-theme blocks respectively.
   ──────────────────────────────────────────────────── */

:root.light-theme {
  /* Jira card — sky blue → soft indigo wash */
  --card-jira-gradient:      linear-gradient(145deg, #eef4ff 0%, #e6effd 50%, #ede9fb 100%);
  --card-jira-border:        #d4e2fb;
  --card-jira-border-hover:  #a5bef8;
  --card-jira-shadow:        rgba(59, 96, 220, 0.14);
  --card-jira-icon-bg:       rgba(255, 255, 255, 0.80);
  --card-jira-accent:        #5b7ee5;

  /* Confluence card — teal mint → pale sky blue */
  --card-confluence-gradient:      linear-gradient(145deg, #edfbf9 0%, #e2f4fd 50%, #e8f5fe 100%);
  --card-confluence-border:        #c8e9f8;
  --card-confluence-border-hover:  #7dd3ed;
  --card-confluence-shadow:        rgba(14, 142, 190, 0.13);
  --card-confluence-icon-bg:       rgba(255, 255, 255, 0.80);
  --card-confluence-accent:        #2aa8d4;
}

.dark-theme {
  /* Jira card — deep midnight with a breath of indigo */
  --card-jira-gradient:      linear-gradient(145deg, #12182a 0%, #111727 50%, #131420 100%);
  --card-jira-border:        #1e2a45;
  --card-jira-border-hover:  #2e4270;
  --card-jira-shadow:        rgba(59, 96, 220, 0.22);
  --card-jira-icon-bg:       rgba(30, 42, 72, 0.65);
  --card-jira-accent:        #7b9cdf;

  /* Confluence card — near-black with a faint teal-cyan breath */
  --card-confluence-gradient:      linear-gradient(145deg, #0d1e22 0%, #0b1c23 50%, #0e1b20 100%);
  --card-confluence-border:        #163140;
  --card-confluence-border-hover:  #1b4a5e;
  --card-confluence-shadow:        rgba(14, 142, 190, 0.20);
  --card-confluence-icon-bg:       rgba(14, 42, 57, 0.65);
  --card-confluence-accent:        #4ab5d4;
}
