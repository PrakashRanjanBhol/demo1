import { useState, useEffect, useRef } from "react";
import styles from "./ContextModeIndicator.module.scss";

// ─── Types ────────────────────────────────────────────────────────────────────

export type ActiveTool = "GENERAL" | "RAG" | "JIRA" | "CONFLUENCE" | "EXCEL_ANALYSIS";

interface ToolConfig {
  panel: "left" | "right";
  panelLabel: string;
  typeLabel: string;
  hint: string;
  accentClass: string;
}

// ─── Config ───────────────────────────────────────────────────────────────────

const TOOL_CONFIG: Record<ActiveTool, ToolConfig> = {
  GENERAL: {
    panel: "left",
    panelLabel: "Source Panel",
    typeLabel: "General Chat",
    hint: "No file context — general conversation mode",
    accentClass: styles.accentTeal,
  },
  RAG: {
    panel: "left",
    panelLabel: "Source Panel",
    typeLabel: "Source Files",
    hint: "Asking questions on your uploaded files",
    accentClass: styles.accentTeal,
  },
  JIRA: {
    panel: "right",
    panelLabel: "Tool Panel",
    typeLabel: "Jira",
    hint: "Queries routed to your Jira tickets & issues",
    accentClass: styles.accentBlue,
  },
  CONFLUENCE: {
    panel: "right",
    panelLabel: "Tool Panel",
    typeLabel: "Confluence",
    hint: "Queries routed to your Confluence workspace",
    accentClass: styles.accentPurple,
  },
  EXCEL_ANALYSIS: {
    panel: "right",
    panelLabel: "Tool Panel",
    typeLabel: "Excel Analytics",
    hint: "Queries routed to your Excel spreadsheets",
    accentClass: styles.accentGreen,
  },
};

// ─── Icons ────────────────────────────────────────────────────────────────────

function ArrowIcon({ direction }: { direction: "left" | "right" }) {
  const d =
    direction === "left"
      ? "M13 9H5M8 5.5L4.5 9L8 12.5"
      : "M5 9h8M10 5.5L13.5 9L10 12.5";
  return (
    <svg
      className={styles.arrowIcon}
      width="15"
      height="15"
      viewBox="0 0 18 18"
      fill="none"
      aria-hidden="true"
    >
      <path
        d={d}
        stroke="currentColor"
        strokeWidth="1.9"
        strokeLinecap="round"
        strokeLinejoin="round"
      />
    </svg>
  );
}

function PulsingDot() {
  return (
    <span className={styles.dot} aria-hidden="true">
      <span className={styles.dotRing} />
      <span className={styles.dotCore} />
    </span>
  );
}

function ToolIcon({ tool }: { tool: ActiveTool }) {
  if (tool === "JIRA")
    return (
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M11.571 11.429 6 5.857 11.571.286l5.572 5.571L11.57 11.43Z" fill="currentColor" opacity=".45" />
        <path d="M17.143 17 11.57 11.43 17.143 5.857 22.714 11.43 17.143 17Z" fill="currentColor" opacity=".72" />
        <path d="M11.571 22.571 6 17l5.571-5.571L17.143 17l-5.572 5.571Z" fill="currentColor" />
      </svg>
    );

  if (tool === "CONFLUENCE")
    return (
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M2.5 17.5c3-4 6.5-6 9.5-6s6.5 2 9.5 6" stroke="currentColor" strokeWidth="2.3" strokeLinecap="round" />
        <path d="M2.5 6.5c3 4 6.5 6 9.5 6s6.5-2 9.5-6" stroke="currentColor" strokeWidth="2.3" strokeLinecap="round" />
      </svg>
    );

  if (tool === "EXCEL_ANALYSIS")
    return (
      <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <rect x="1" y="1" width="14" height="14" rx="2" stroke="currentColor" strokeWidth="1.4" />
        <path d="M1 6h14M1 10h14M5.5 1v14" stroke="currentColor" strokeWidth="1.2" />
      </svg>
    );

  return (
    <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path
        d="M9 1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V6L9 1Z"
        stroke="currentColor" strokeWidth="1.4" strokeLinejoin="round"
      />
      <path d="M9 1v5h5" stroke="currentColor" strokeWidth="1.4" strokeLinejoin="round" />
      <path d="M5 10h6M5 12.5h4" stroke="currentColor" strokeWidth="1.2" strokeLinecap="round" />
    </svg>
  );
}

function InfoIcon() {
  return (
    <svg
      className={styles.infoIcon}
      width="13"
      height="13"
      viewBox="0 0 16 16"
      fill="none"
      aria-hidden="true"
    >
      <circle cx="8" cy="8" r="6.5" stroke="currentColor" strokeWidth="1.3" />
      <path d="M8 7.5v4" stroke="currentColor" strokeWidth="1.4" strokeLinecap="round" />
      <circle cx="8" cy="5.25" r="0.85" fill="currentColor" />
    </svg>
  );
}

// ─── Component ────────────────────────────────────────────────────────────────

interface ContextModeIndicatorProps {
  /** Driven by your store */
  activeTool: ActiveTool;
  className?: string;
}

export default function ContextModeIndicator({
  activeTool,
  className,
}: ContextModeIndicatorProps) {
  const [displayed, setDisplayed] = useState<ActiveTool>(activeTool);
  const [visible, setVisible] = useState(true);
  const prev = useRef<ActiveTool>(activeTool);

  useEffect(() => {
    if (activeTool === prev.current) return;
    prev.current = activeTool;
    setVisible(false);
    const t = setTimeout(() => {
      setDisplayed(activeTool);
      setVisible(true);
    }, 160);
    return () => clearTimeout(t);
  }, [activeTool]);

  const cfg = TOOL_CONFIG[displayed] ?? TOOL_CONFIG.RAG;
  const isLeft = cfg.panel === "left";

  return (
    <div
      className={[
        styles.wrapper,
        cfg.accentClass,
        visible ? styles.visible : styles.hidden,
        className,
      ]
        .filter(Boolean)
        .join(" ")}
      role="status"
      aria-live="polite"
      aria-label={`Active context: ${cfg.typeLabel} on ${cfg.panelLabel}`}
    >
      {/* Pill */}
      <div className={styles.pill}>

        {/* Arrow + panel label */}
        <div className={styles.panelSection}>
          <ArrowIcon direction={isLeft ? "left" : "right"} />
          <span className={styles.panelLabel}>{cfg.panelLabel}</span>
        </div>

        {/* Divider */}
        <span className={styles.divider} aria-hidden="true" />

        {/* Type badge */}
        <div className={styles.badge}>
          <PulsingDot />
          <ToolIcon tool={displayed} />
          <span className={styles.badgeLabel}>{cfg.typeLabel}</span>
        </div>

        {/* Divider */}
        <span className={styles.divider} aria-hidden="true" />

        {/* Info icon + tooltip */}
        <div className={styles.infoWrapper}>
          <InfoIcon />
          <div className={styles.tooltip} role="tooltip">
            <span className={styles.tooltipText}>{cfg.hint}</span>
            <span className={styles.tooltipArrow} aria-hidden="true" />
          </div>
        </div>

      </div>
    </div>
  );
}














// ─── CSS Variables ────────────────────────────────────────────────────────────
// Light → page bg #FFFFFF    Dark → page bg #111113

