//  Keyframes
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

@keyframes fadeSlideIn {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes itemIn {
  from { opacity: 0; transform: translateX(-4px); }
  to   { opacity: 1; transform: translateX(0); }
}

@keyframes nameSelect {
  0%   { opacity: 0.4; transform: translateX(-6px); filter: blur(2px); }
  60%  { opacity: 1;   transform: translateX(2px);  filter: blur(0);   }
  100% { opacity: 1;   transform: translateX(0);    filter: blur(0);   }
}

@keyframes nameDeselect {
  0%   { opacity: 0.4; transform: translateX(4px); filter: blur(1.5px); }
  100% { opacity: 1;   transform: translateX(0);   filter: blur(0);    }
}

@keyframes dotIn {
  from { opacity: 0; transform: translateY(-50%) scaleY(0.3); }
  to   { opacity: 1; transform: translateY(-50%) scaleY(1);   }
}

