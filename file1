// Add these properties with other inference properties
selectAllPendingInference: boolean = false;
selectAllCompletedInference: boolean = false;

// Add these methods for inference select all

// Toggle select all pending files for inference
toggleSelectAllPendingInference(): void {
  if (this.selectAllPendingInference) {
    // Deselect all pending
    this.filteredPendingFiles.forEach(item => {
      this.selectedInferenceItems.delete(item.id);
    });
    this.selectAllPendingInference = false;
  } else {
    // Select all pending
    this.filteredPendingFiles.forEach(item => {
      this.selectedInferenceItems.add(item.id);
    });
    this.selectAllPendingInference = true;
  }
}

// Toggle select all completed files for inference
toggleSelectAllCompletedInference(): void {
  if (this.selectAllCompletedInference) {
    // Deselect all completed
    this.filteredCompletedFiles.forEach(item => {
      this.selectedInferenceItems.delete(item.id);
    });
    this.selectAllCompletedInference = false;
  } else {
    // Select all completed
    this.filteredCompletedFiles.forEach(item => {
      this.selectedInferenceItems.add(item.id);
    });
    this.selectAllCompletedInference = true;
  }
}

// Check if all pending files are selected for inference
areAllPendingSelectedForInference(): boolean {
  if (this.filteredPendingFiles.length === 0) return false;
  return this.filteredPendingFiles.every(item => this.selectedInferenceItems.has(item.id));
}

// Check if all completed files are selected for inference
areAllCompletedSelectedForInference(): boolean {
  if (this.filteredCompletedFiles.length === 0) return false;
  return this.filteredCompletedFiles.every(item => this.selectedInferenceItems.has(item.id));
}

// Update toggleInferenceMode to reset select all states
toggleInferenceMode(): void {
  this.isInferenceMode = !this.isInferenceMode;
  if (!this.isInferenceMode) {
    this.selectedInferenceItems.clear();
    this.selectAllPendingInference = false;
    this.selectAllCompletedInference = false;
  }
  // Exit delete mode if active
  if (this.isInferenceMode && this.isDeleteMode) {
    this.isDeleteMode = false;
    this.selectedDeleteItems.clear();
    this.selectAllPending = false;
    this.selectAllCompleted = false;
  }
}

// Update toggleInferenceSelection to update select all checkboxes
toggleInferenceSelection(itemId: string, event: Event): void {
  event.stopPropagation();
  
  if (this.selectedInferenceItems.has(itemId)) {
    this.selectedInferenceItems.delete(itemId);
  } else {
    this.selectedInferenceItems.add(itemId);
  }

  // Update select all checkboxes
  this.selectAllPendingInference = this.areAllPendingSelectedForInference();
  this.selectAllCompletedInference = this.areAllCompletedSelectedForInference();
}

// Update cancelMultipleInference to reset select all states
cancelMultipleInference(): void {
  this.selectedInferenceItems.clear();
  this.isInferenceMode = false;
  this.selectAllPendingInference = false;
  this.selectAllCompletedInference = false;
}







<!-- Pending Files Section -->
<div class="content-section-header" (click)="!isDeleteMode && !isInferenceMode && togglePendingSection()">
    <!-- Select All Checkbox for Delete Mode -->
    <div class="select-all-checkbox" *ngIf="isDeleteMode" (click)="$event.stopPropagation(); toggleSelectAllPending()">
        <div class="checkbox-inner" [class.checked]="areAllPendingSelected()">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" *ngIf="areAllPendingSelected()">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
        </div>
    </div>

    <!-- Select All Checkbox for Inference Mode -->
    <div class="select-all-checkbox-inference" *ngIf="isInferenceMode" (click)="$event.stopPropagation(); toggleSelectAllPendingInference()">
        <div class="checkbox-inner" [class.checked]="areAllPendingSelectedForInference()">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" *ngIf="areAllPendingSelectedForInference()">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
        </div>
    </div>
    
    <div class="content-header-icon">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
            stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round"
                d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
    </div>
    <h3 class="content-header-title">Pending Results</h3>
    <span class="content-count">{{ (isLoading || isRefreshing) ? '...' : filteredPendingFiles.length }} files</span>
    <button class="collapse-toggle-btn" [class.collapsed]="!isPendingExpanded" *ngIf="!isDeleteMode && !isInferenceMode">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2"
            stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
        </svg>
    </button>
</div>














