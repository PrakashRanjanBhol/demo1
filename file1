/* ===========================
   LIGHT MODE
=========================== */
:root,
[data-theme='light'] {

  /* Backgrounds */
  --settings-app-bg: #f5f7fb;
  --settings-sidebar-bg: #ffffff;
  --settings-content-bg: #ffffff;

  /* Text */
  --settings-text-primary: #1f2937;
  --settings-text-secondary: #6b7280;
  --settings-text-tertiary: #9ca3af;

  /* Borders */
  --settings-border-color: rgba(79, 70, 229, 0.11);
  --settings-panel-border-color: rgba(79, 70, 229, 0.24);

  /* Shadows */
  --settings-box-shadow: rgba(0, 0, 0, 0.08);
  --settings-panel-box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04), 0 4px 20px rgba(79, 70, 229, 0.07);

  /* Table */
  --settings-table-thead-bg: #f1f5f9;
  --settings-table-row-even: #ffffff;
  --settings-table-row-odd: #f9fafb;

  /* Hover */
  --settings-hover-bg: #eef2ff;
  --settings-hover-color: #4f46e5;

  /* Gradient */
  --settings-gradient: linear-gradient(135deg, #7c3aed 0%, #4f46e5 35%, #2563eb 65%, #0ea5e9 100%);
  --settings-gradient-hover: linear-gradient(135deg, #0891b2 0%, #2563eb 50%, #4f46e5 100%);

  /* Buttons */
  --settings-btn-bg: linear-gradient(135deg, #7c3aed 0%, #4f46e5 50%, #2563eb 100%);
  --settings-btn-text: #ffffff;
  --settings-btn-cancel-bg: #e5e7eb;
  --settings-btn-cancel-hover-bg: #d1d5db;
  --settings-btn-cancel-text: #1f2937;

  /* Accent */
  --settings-accent: #4f46e5;
  --settings-accent-light: #eef2ff;
  --settings-accent-border: rgba(79, 70, 229, 0.3);

  /* Status */
  --settings-success-bg: #f0fdf4;
  --settings-success-color: #16a34a;
  --settings-success-border: rgba(22, 163, 74, 0.2);
  --settings-error-bg: #fef2f2;
  --settings-error-color: #dc2626;
  --settings-error-border: #fecaca;

  /* Scrollbar */
  --settings-scrollbar-thumb: rgba(79, 70, 229, 0.2);
  --settings-scrollbar-thumb-hover: rgba(79, 70, 229, 0.4);

  /* Nav active pill */
  --settings-active-pill: #4f46e5;
  --settings-active-bg: #eef2ff;
  --settings-active-shadow: 0 2px 8px rgba(79, 70, 229, 0.12), inset 0 0 0 1px rgba(79, 70, 229, 0.15);
}

/* ===========================
   DARK MODE
=========================== */
[data-theme='dark'] {

  /* Backgrounds */
  --settings-app-bg: #111113;
  --settings-sidebar-bg: #18181b;
  --settings-content-bg: #1c1c1f;

  /* Text */
  --settings-text-primary: #f4f4f5;
  --settings-text-secondary: #a1a1aa;
  --settings-text-tertiary: #71717a;

  /* Borders */
  --settings-border-color: rgba(139, 92, 246, 0.15);
  --settings-panel-border-color: rgba(139, 92, 246, 0.25);

  /* Shadows */
  --settings-box-shadow: rgba(0, 0, 0, 0.3);
  --settings-panel-box-shadow: 0 1px 2px rgba(0, 0, 0, 0.2), 0 4px 20px rgba(139, 92, 246, 0.1);

  /* Table */
  --settings-table-thead-bg: #1e1e22;
  --settings-table-row-even: #1c1c1f;
  --settings-table-row-odd: #202024;

  /* Hover */
  --settings-hover-bg: rgba(99, 102, 241, 0.12);
  --settings-hover-color: #818cf8;

  /* Gradient */
  --settings-gradient: linear-gradient(135deg, #7c3aed 0%, #6366f1 35%, #3b82f6 65%, #0ea5e9 100%);
  --settings-gradient-hover: linear-gradient(135deg, #0891b2 0%, #3b82f6 50%, #6366f1 100%);

  /* Buttons */
  --settings-btn-bg: linear-gradient(135deg, #7c3aed 0%, #6366f1 50%, #3b82f6 100%);
  --settings-btn-text: #ffffff;
  --settings-btn-cancel-bg: #27272a;
  --settings-btn-cancel-hover-bg: #3f3f46;
  --settings-btn-cancel-text: #f4f4f5;

  /* Accent */
  --settings-accent: #818cf8;
  --settings-accent-light: rgba(99, 102, 241, 0.12);
  --settings-accent-border: rgba(99, 102, 241, 0.35);

  /* Status */
  --settings-success-bg: rgba(22, 163, 74, 0.1);
  --settings-success-color: #4ade80;
  --settings-success-border: rgba(74, 222, 128, 0.2);
  --settings-error-bg: rgba(220, 38, 38, 0.1);
  --settings-error-color: #f87171;
  --settings-error-border: rgba(248, 113, 113, 0.3);

  /* Scrollbar */
  --settings-scrollbar-thumb: rgba(99, 102, 241, 0.25);
  --settings-scrollbar-thumb-hover: rgba(99, 102, 241, 0.45);

  /* Nav active pill */
  --settings-active-pill: #818cf8;
  --settings-active-bg: rgba(99, 102, 241, 0.12);
  --settings-active-shadow: 0 2px 8px rgba(99, 102, 241, 0.15), inset 0 0 0 1px rgba(99, 102, 241, 0.2);
}






















SettingsLayout.module.scss
--------------------------



.layout {
  display: flex;
  flex: 1;
  overflow: hidden;
  gap: 10px;
  padding: 0 10px;
  background: var(--settings-app-bg);
}

.sidebar {
  width: 300px;
  background: var(--settings-sidebar-bg);
  border: 1px solid var(--settings-panel-border-color);
  border-radius: 12px;
  display: flex;
  flex-direction: column;
  padding: 24px 12px;
  gap: 4px;
  position: relative;
  box-shadow: var(--settings-panel-box-shadow);
}

.sidebarHeader {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 4px 12px 20px;
  border-bottom: 1px solid var(--settings-border-color);
  margin-bottom: 12px;

  .headerIcon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--settings-gradient);
    display: flex;
    align-items: center;
    justify-content: center;

    svg {
      width: 20px;
      height: 20px;
      color: #fff;
    }
  }

  .headerText {
    display: flex;
    flex-direction: column;
    gap: 2px;

    .headerTitle {
      font-size: 1rem;
      font-weight: 700;
      color: var(--settings-text-primary);
      letter-spacing: -0.1px;
    }

    .headerSub {
      font-size: 0.78125rem;
      color: var(--settings-text-tertiary);
    }
  }
}

.sectionLabel {
  font-size: 0.65625rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--settings-text-tertiary);
  padding: 8px 14px 4px;
  margin-top: 4px;
}

.navList {
  display: flex;
  flex-direction: column;
  gap: 4px;
  position: relative;
}

.navLink {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 14px;
  margin: 0 8px;
  border-radius: 10px;
  text-decoration: none;
  font-size: 0.95rem;
  font-weight: 500;
  color: var(--settings-text-secondary);
  position: relative;
  z-index: 1;
  transition: color 0.25s ease;

  &::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 10px;
    background: transparent;
    z-index: -1;
    transition:
      background 0.25s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 0.25s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    transform: scaleX(0.92) scaleY(0.88);
  }

  &:hover {
    color: var(--settings-text-primary);

    &::before {
      background: var(--settings-hover-bg);
      opacity: 1;
      transform: scaleX(1) scaleY(1);
    }

    .navIcon {
      color: var(--settings-accent);
      border-color: var(--settings-accent-border);
      background: var(--settings-accent-light);
    }
  }

  &.active {
    color: var(--settings-accent);
    font-weight: 600;

    &::before {
      background: var(--settings-active-bg);
      opacity: 1;
      transform: scaleX(1) scaleY(1);
      box-shadow: var(--settings-active-shadow);
    }

    .navIcon {
      color: var(--settings-accent);
      border-color: var(--settings-accent-border);
      background: var(--settings-sidebar-bg);
      box-shadow: 0 1px 4px var(--settings-box-shadow);
    }

    .activePill {
      opacity: 1;
      transform: scale(1);
    }
  }
}

.navIcon {
  width: 34px;
  height: 34px;
  border-radius: 8px;
  background: var(--settings-app-bg);
  border: 1px solid var(--settings-border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: var(--settings-text-tertiary);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 1px 2px var(--settings-box-shadow);

  svg {
    width: 15px;
    height: 15px;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }
}

.navLink:hover .navIcon svg,
.navLink.active .navIcon svg {
  transform: scale(1.1);
}

.navLabel {
  flex: 1;
  transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.navLink.active .navLabel {
  transform: translateX(2px);
}

.activePill {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--settings-active-pill);
  opacity: 0;
  transform: scale(0.5);
  transition:
    opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1),
    transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  flex-shrink: 0;
}

.content {
  flex: 1;
  overflow: auto;
  padding: 36px 44px;
  background: var(--settings-content-bg);
  border-radius: 12px;
  border: 1px solid var(--settings-panel-border-color);
  box-shadow: var(--settings-panel-box-shadow);
}

@media (min-width: 1400px) {
  .sidebar {
    width: 320px;
  }

  .content {
    padding: 40px 56px;
  }

  .navLink {
    font-size: 1rem;
    padding: 12px 16px;
  }

  .navIcon {
    width: 38px;
    height: 38px;

    svg {
      width: 17px;
      height: 17px;
    }
  }

  .sidebarHeader {
    .headerIcon {
      width: 44px;
      height: 44px;
      border-radius: 11px;

      svg {
        width: 22px;
        height: 22px;
      }
    }

    .headerTitle {
      font-size: 1.0625rem;
    }

    .headerSub {
      font-size: 0.8125rem;
    }
  }

  .sectionLabel {
    font-size: 0.6875rem;
  }
}



















