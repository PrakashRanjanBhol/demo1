import { createAsyncThunk, createSlice, PayloadAction } from '@reduxjs/toolkit';
import {
  Department,
  fetchTeamAccessApi,
  updateEmployeeAccessApi,
  updateTeamAccessApi,
} from '../../api/accessManagementApi';

interface AccessManagementState {
  departments: Department[];
  loading: boolean;
  error: string | null;
  updatingTeam: string | null;
  updatingEmployee: string | null;
}

const initialState: AccessManagementState = {
  departments: [],
  loading: false,
  error: null,
  updatingTeam: null,
  updatingEmployee: null,
};

export const fetchTeamAccess = createAsyncThunk(
  'accessManagement/fetchTeamAccess',
  async (_, { rejectWithValue }) => {
    try {
      return await fetchTeamAccessApi();
    } catch (err: unknown) {
      const message = err instanceof Error ? err.message : 'Failed to fetch team access';
      return rejectWithValue(message);
    }
  }
);

export const updateTeamAccess = createAsyncThunk(
  'accessManagement/updateTeamAccess',
  async (
    payload: { dept_name: string; allowed: boolean },
    { rejectWithValue }
  ) => {
    try {
      await updateTeamAccessApi(payload);
      return payload;
    } catch (err: unknown) {
      const message = err instanceof Error ? err.message : 'Failed to update team access';
      return rejectWithValue(message);
    }
  }
);

export const updateEmployeeAccess = createAsyncThunk(
  'accessManagement/updateEmployeeAccess',
  async (
    payload: { name: string; allowed: boolean; dept_name: string },
    { rejectWithValue }
  ) => {
    try {
      await updateEmployeeAccessApi({ name: payload.name, allowed: payload.allowed });
      return payload;
    } catch (err: unknown) {
      const message = err instanceof Error ? err.message : 'Failed to update employee access';
      return rejectWithValue(message);
    }
  }
);

const accessManagementSlice = createSlice({
  name: 'accessManagement',
  initialState,
  reducers: {},
  extraReducers: (builder) => {
    builder
      // fetch
      .addCase(fetchTeamAccess.pending, (state) => {
        state.loading = true;
        state.error = null;
      })
      .addCase(fetchTeamAccess.fulfilled, (state, action: PayloadAction<Department[]>) => {
        state.loading = false;
        state.departments = action.payload;
      })
      .addCase(fetchTeamAccess.rejected, (state, action) => {
        state.loading = false;
        state.error = action.payload as string;
      })
      // update team
      .addCase(updateTeamAccess.pending, (state, action) => {
        state.updatingTeam = action.meta.arg.dept_name;
      })
      .addCase(updateTeamAccess.fulfilled, (state, action) => {
        state.updatingTeam = null;
        const { dept_name, allowed } = action.payload;
        const dept = state.departments.find((d) => d.dept_name === dept_name);
        if (dept) {
          dept.allowed = allowed;
          // if team allowed, set all members to true
          if (allowed) {
            dept.members = dept.members.map((m) => ({ ...m, allowed: true }));
          }
        }
      })
      .addCase(updateTeamAccess.rejected, (state) => {
        state.updatingTeam = null;
      })
      // update employee
      .addCase(updateEmployeeAccess.pending, (state, action) => {
        state.updatingEmployee = action.meta.arg.name;
      })
      .addCase(updateEmployeeAccess.fulfilled, (state, action) => {
        state.updatingEmployee = null;
        const { name, allowed, dept_name } = action.payload;
        const dept = state.departments.find((d) => d.dept_name === dept_name);
        if (dept) {
          const member = dept.members.find((m) => m.name === name);
          if (member) member.allowed = allowed;
        }
      })
      .addCase(updateEmployeeAccess.rejected, (state) => {
        state.updatingEmployee = null;
      });
  },
});

export default accessManagementSlice.reducer;















