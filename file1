    .pageHeader {
      padding-bottom: 24px;
      margin-bottom: 28px;

      .title {
        font-size: 1.5rem;
      }

      .description {
        font-size: 0.9375rem;
      }
    }
  }
}


















DataTable.module.scss
---------------------



.wrapper {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-radius: 12px;
  border: 1px solid var(--settings-panel-border-color);
  box-shadow: var(--settings-panel-box-shadow);
  background: var(--settings-content-bg);
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 20px;
  border-bottom: 1px solid var(--settings-border-color);
  background: var(--settings-content-bg);
  flex-shrink: 0;
  gap: 12px;

  .searchBox {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--settings-app-bg);
    border: 1px solid var(--settings-border-color);
    border-radius: 8px;
    padding: 8px 12px;
    width: 260px;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;

    &:focus-within {
      border-color: var(--settings-accent-border);
      box-shadow: 0 0 0 3px var(--settings-accent-light);
    }

    svg {
      width: 15px;
      height: 15px;
      color: var(--settings-text-tertiary);
      flex-shrink: 0;
    }

    input {
      border: none;
      background: transparent;
      outline: none;
      font-size: 0.84375rem;
      font-family: system-ui, sans-serif;
      color: var(--settings-text-primary);
      width: 100%;

      &::placeholder {
        color: var(--settings-text-tertiary);
      }
    }
  }

  .rowCount {
    font-size: 0.78125rem;
    color: var(--settings-text-secondary);
    white-space: nowrap;
    background: var(--settings-app-bg);
    border: 1px solid var(--settings-border-color);
    border-radius: 6px;
    padding: 5px 10px;
  }
}

.tableScroll {
  flex: 1;
  overflow-y: auto;

  &::-webkit-scrollbar {
    width: 5px;
  }

  &::-webkit-scrollbar-track {
    background: transparent;
  }

  &::-webkit-scrollbar-thumb {
    background: var(--settings-scrollbar-thumb);
    border-radius: 999px;

    &:hover {
      background: var(--settings-scrollbar-thumb-hover);
    }
  }
}

table {
  width: auto;
  min-width: 100%;
  border-collapse: collapse;
}

thead {
  position: sticky;
  top: 0;
  z-index: 2;
  background: var(--settings-table-thead-bg);

  th {
    padding: 11px 20px;
    text-align: left;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--settings-text-secondary);
    border-bottom: 1px solid var(--settings-border-color);
    white-space: nowrap;
    cursor: pointer;
    user-select: none;
    transition: color 0.15s ease;

    &:hover {
      color: var(--settings-text-primary);
    }

    .thInner {
      display: inline-flex;
      align-items: center;
      gap: 5px;
    }

    .sortIcon {
      display: inline-flex;
      flex-direction: column;
      gap: 1.5px;

      span {
        display: block;
        width: 0;
        height: 0;
        border-left: 3.5px solid transparent;
        border-right: 3.5px solid transparent;

        &.up {
          border-bottom: 4px solid var(--settings-text-tertiary);

          &.active {
            border-bottom-color: var(--settings-accent);
          }
        }

        &.down {
          border-top: 4px solid var(--settings-text-tertiary);

          &.active {
            border-top-color: var(--settings-accent);
          }
        }
      }
    }
  }
}

tbody {
  tr {
    border-bottom: 1px solid var(--settings-border-color);
    transition: background 0.12s ease;

    &:last-child {
      border-bottom: none;
    }

    &:nth-child(odd) {
      background: var(--settings-table-row-odd);
    }

    &:nth-child(even) {
      background: var(--settings-table-row-even);
    }

    &:hover {
      background: var(--settings-hover-bg);
    }
  }

  td {
    padding: 13px 20px;
    font-size: 0.95rem;
    color: var(--settings-text-secondary);
    white-space: nowrap;
  }
}

.emptyState {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 56px 20px;
  gap: 10px;

  svg {
    width: 36px;
    height: 36px;
    color: var(--settings-text-tertiary);
    opacity: 0.5;
  }

  p {
    margin: 0;
    font-size: 0.875rem;
    color: var(--settings-text-tertiary);
  }
}

.pagination {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 20px;
  border-top: 1px solid var(--settings-border-color);
  background: var(--settings-table-thead-bg);
  flex-shrink: 0;

  .pageInfo {
    font-size: 0.78125rem;
    color: var(--settings-text-secondary);
  }

  .pageControls {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .navBtn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: 1px solid var(--settings-border-color);
    background: var(--settings-content-bg);
    color: var(--settings-text-secondary);
    cursor: pointer;
    transition: all 0.15s ease;

    svg {
      width: 16px;
      height: 16px;
      display: block;
    }

    &:hover:not(:disabled) {
      background: var(--settings-hover-bg);
      border-color: var(--settings-accent-border);
      color: var(--settings-accent);
    }

    &:disabled {
      opacity: 0.35;
      cursor: not-allowed;
    }
  }

  .pageDots {
    font-size: 0.8125rem;
    color: var(--settings-text-tertiary);
    padding: 0 2px;
    user-select: none;
  }

  .pageBtn {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 32px;
    height: 32px;
    padding: 0 6px;
    border-radius: 8px;
    border: 1px solid var(--settings-border-color);
    background: var(--settings-content-bg);
    color: var(--settings-text-secondary);
    font-size: 0.8125rem;
    font-family: system-ui, sans-serif;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s ease;

    &:hover:not(.activePage) {
      background: var(--settings-hover-bg);
      border-color: var(--settings-accent-border);
      color: var(--settings-accent);
    }

    &.activePage {
      background: var(--settings-gradient);
      border-color: transparent;
      color: var(--settings-btn-text);
      font-weight: 700;
      box-shadow: 0 2px 8px var(--settings-box-shadow);
    }
  }
}

@media (min-width: 1400px) {
  .toolbar {
    padding: 16px 24px;

    .searchBox {
      width: 300px;
    }

    .rowCount {
      font-size: 0.8125rem;
    }
  }

  thead th {
    padding: 13px 24px;
    font-size: 0.8125rem;
  }

  tbody td {
    padding: 15px 24px;
    font-size: 1rem;
  }

  .pagination {
    padding: 14px 24px;

    .pageInfo {
      font-size: 0.8125rem;
    }

    .navBtn,
    .pageBtn {
      width: 36px;
      height: 36px;
    }
  }
}














DataTableSkeleton.module.scss
-----------------------------



.wrapper {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-radius: 12px;
  border: 1px solid var(--settings-panel-border-color);
  box-shadow: var(--settings-panel-box-shadow);
  background: var(--settings-content-bg);
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 20px;
  border-bottom: 1px solid var(--settings-border-color);
  background: var(--settings-content-bg);
  flex-shrink: 0;
}

.tableScroll {
  flex: 1;
  overflow: hidden;
}

table {
  width: 100%;
  border-collapse: collapse;
}

thead {
  background: var(--settings-table-thead-bg);

  th {
    padding: 11px 20px;
    border-bottom: 1px solid var(--settings-border-color);
  }
}

tbody {
  tr {
    border-bottom: 1px solid var(--settings-border-color);

    &:nth-child(odd) { background: var(--settings-table-row-odd); }
    &:nth-child(even) { background: var(--settings-table-row-even); }

    &:last-child {
      border-bottom: none;
    }
  }

  td {
    padding: 14px 20px;
  }
}

.footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 20px;
  border-top: 1px solid var(--settings-border-color);
  background: var(--settings-table-thead-bg);
  flex-shrink: 0;
}

.skeletonBase {
  border-radius: 6px;
  background: linear-gradient(
    90deg,
    var(--settings-table-row-odd) 25%,
    var(--settings-border-color) 50%,
    var(--settings-table-row-odd) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.4s ease-in-out infinite;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.skeletonSearch {
  composes: skeletonBase;
  height: 36px;
  width: 260px;
  border-radius: 8px;
}

.skeletonCount {
  composes: skeletonBase;
  height: 28px;
  width: 80px;
  border-radius: 6px;
}

.skeletonHeader {
  composes: skeletonBase;
  height: 12px;
  width: 70%;
  border-radius: 4px;
}

.skeletonCell {
  composes: skeletonBase;
  height: 13px;
  border-radius: 4px;
}

.skeletonBadge {
  composes: skeletonBase;
  height: 24px;
  width: 60px;
  border-radius: 20px;
}

.skeletonAction {
  composes: skeletonBase;
  height: 32px;
  width: 32px;
  border-radius: 8px;
}

.skeletonPage {
  composes: skeletonBase;
  height: 28px;
  width: 60px;
  border-radius: 6px;
}

