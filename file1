:root {
  --hint-container-bg: #ffffff;
}

[data-theme='dark'] {
  --hint-container-bg: #111113;
}

.hintList {
  list-style: none;
  margin: 0.25rem 0 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  max-width: 440px;
  width: 100%;
  background-color: var(--hint-container-bg);
}

.hintItem {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  background-color: var(--app-bg);
  border: 0.5px solid var(--border-color);
  border-radius: 10px;
  padding: 0.7rem 1rem;
  text-align: left;
  position: relative;
  overflow: hidden;

  &::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--btn-bg) 14%, transparent) 0%,
      transparent 65%
    );
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  transition:
    border-color 0.22s ease,
    transform 0.22s cubic-bezier(0.34, 1.4, 0.64, 1),
    box-shadow 0.22s ease,
    background-color 0.22s ease;

  &:hover {
    border-color: var(--panel-border-hover);
    transform: translateX(5px);
    box-shadow: -4px 0 0 0 var(--panel-border-hover);
    background-color: var(--app-bg-subtle, var(--app-bg));

    &::after {
      opacity: 1;
    }

    .hintIcon {
      transform: scale(1.2);
      color: var(--btn-bg);
      background-color: color-mix(in srgb, var(--btn-bg) 14%, transparent);
    }

    .hintText {
      color: var(--text-primary);
    }
  }
}

.hintIcon {
  color: var(--text-secondary);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  border-radius: 7px;
  background-color: color-mix(in srgb, var(--border-color) 50%, transparent);
  transition:
    transform 0.22s cubic-bezier(0.34, 1.4, 0.64, 1),
    color 0.22s ease,
    background-color 0.22s ease;
}

.hintText {
  font-size: 0.84rem;
  color: var(--text-secondary);
  line-height: 1.45;
  letter-spacing: 0.01em;
  transition: color 0.22s ease;
}
