.wrapper {
  display: flex;
  flex-direction: column;
  height: 100%;
  padding: 0 0 24px;
}

.backBtn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin: 16px 20px 20px;
  padding: 6px 12px;
  background: var(--sidebar-bg);
  border: 1px solid var(--border-color);
  border-radius: 7px;
  color: var(--text-secondary);
  font-size: 0.7875rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.15s ease;
  align-self: flex-start;
  box-shadow: 0 1px 3px var(--box-shadow);

  &:hover {
    background: var(--accent-light);
    color: var(--accent-primary);
    border-color: var(--accent-primary);

    .backArrow {
      transform: translateX(-2px);
    }
  }
}

.backArrow {
  font-size: 0.875rem;
  transition: transform 0.15s ease;
  display: inline-block;
}

// ── Header ────────────────────────────────────────────

.header {
  padding: 0 20px 20px;
  border-bottom: 1px solid var(--border-color);
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.headerIcons {
  display: flex;
  align-items: center;
  gap: 8px;
}

.atlassianIcon,
.toolIcon {
  object-fit: contain;
  display: block;
  flex-shrink: 0;
}

.iconDivider {
  width: 1px;
  height: 20px;
  background: var(--border-color);
}

.headerText {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.title {
  font-size: 0.9625rem;
  font-weight: 700;
  color: var(--text-primary);
  margin: 0;
  letter-spacing: -0.02em;
}

.subtitle {
  font-size: 0.7875rem;
  color: var(--text-secondary);
  margin: 0;
  line-height: 1.5;
}

// ── Form ──────────────────────────────────────────────

.form {
  display: flex;
  flex-direction: column;
  gap: 14px;
  padding: 20px 20px 0;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.label {
  font-size: 0.7875rem;
  font-weight: 600;
  color: var(--text-secondary);
}

.input {
  padding: 8px 12px;
  border: 1px solid var(--border-color);
  border-radius: 8px;
  background: var(--sidebar-bg);
  color: var(--text-primary);
  font-size: 0.875rem;
  outline: none;
  transition: border-color 0.15s ease, box-shadow 0.15s ease;

  &::placeholder {
    color: var(--text-secondary);
  }

  &:focus {
    border-color: var(--accent-primary);
    box-shadow: 0 0 0 3px var(--accent-light);
  }
}

.error {
  font-size: 0.7875rem;
  color: #dc2626;
  background: #fef2f2;
  border: 1px solid #fecaca;
  border-radius: 7px;
  padding: 8px 12px;
  margin: 0;
}

.connectBtn {
  padding: 10px 0;
  border: none;
  border-radius: 8px;
  background: var(--accent-primary);
  color: #fff;
  font-size: 0.875rem;
  font-weight: 700;
  cursor: pointer;
  transition: background 0.15s ease, transform 0.1s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 40px;
  box-shadow: 0 4px 6px var(--box-shadow);

  &:hover:not(:disabled) {
    background: var(--accent-hover);
  }

  &:active:not(:disabled) {
    transform: scale(0.98);
  }

  &:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
}

// ── Spinner ───────────────────────────────────────────

.spinner {
  width: 16px;
  height: 16px;
  border: 2px solid rgba(255, 255, 255, 0.35);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
  display: inline-block;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}















