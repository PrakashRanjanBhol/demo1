.pageTreeWrapper {
  flex: 1;
  overflow-y: auto;
  padding: 8px 4px 16px;

  &::-webkit-scrollbar { width: 3px; }
  &::-webkit-scrollbar-track { background: transparent; }
  &::-webkit-scrollbar-thumb {
    background: var(--border-color);
    border-radius: 2px;
    &:hover { background: var(--conf-scrollbar-hover); }
  }
}

.childList {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 1px;
  margin-top: 1px;
  padding-left: 10px;          /* ← reduced from 20px */
  border-left: 1.5px solid var(--conf-tree-indent);
  margin-left: 8px;            /* ← reduced from 11px */
}

.pageRow {
  display: flex;
  align-items: center;
  gap: 4px;                    /* ← reduced from 6px */
  padding: 4px 6px;            /* ← reduced from 6px 8px */
  border-radius: 7px;
  border: 1px solid transparent;
  transition: all 0.12s ease;
  cursor: default;

  &:hover {
    background: var(--conf-row-hover);
    border-color: var(--conf-row-hover-border);
  }
}

