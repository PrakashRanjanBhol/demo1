  --dt-bg: #ffffff;
  --dt-bg2: #f5f4ff;
  --dt-s2: #f7f6ff;
  --dt-s3: #eeecff;
  --dt-border: rgba(79, 70, 229, 0.11);
  --dt-border-h: rgba(79, 70, 229, 0.24);
  --dt-text: #0f0c1d;
  --dt-text2: #3d3656;
  --dt-text3: #7a738f;
  --dt-text4: #b0abc4;
  --dt-sp: 0 1px 2px rgba(0,0,0,0.04), 0 4px 12px rgba(0,0,0,0.05), 0 8px 32px rgba(79,70,229,0.08);
  --dt-sh: 0 2px 6px rgba(0,0,0,0.07), 0 10px 32px rgba(79,70,229,0.13);
  --dt-accent: #4f46e5;
  --dt-accent-light: #eef2ff;
  --dt-grad: linear-gradient(135deg, #7c3aed 0%, #4f46e5 35%, #2563eb 65%, #0ea5e9 100%);
  --dt-thead: #f7f6ff;
  --dt-row-odd: #fdfcff;
  --dt-row-even: #ffffff;
  --dt-hover: #eef2ff;
}

:global([data-theme='dark']) {
  --dt-bg: #121214;
  --dt-bg2: #111113;
  --dt-s2: #18171f;
  --dt-s3: #1f1e2a;
  --dt-border: rgba(124, 58, 237, 0.13);
  --dt-border-h: rgba(124, 58, 237, 0.30);
  --dt-text: #f2eeff;
  --dt-text2: #c4bbdd;
  --dt-text3: #7b6f9a;
  --dt-text4: #4a4264;
  --dt-sp: 0 1px 0 rgba(124,58,237,0.09) inset, 0 0 0 1px rgba(124,58,237,0.06) inset, 0 8px 36px rgba(0,0,0,0.55);
  --dt-sh: 0 1px 0 rgba(124,58,237,0.16) inset, 0 16px 52px rgba(0,0,0,0.70);
  --dt-accent: #a78bfa;
  --dt-accent-light: rgba(124, 58, 237, 0.14);
  --dt-grad: linear-gradient(135deg, #7c3aed 0%, #4f46e5 35%, #2563eb 65%, #0ea5e9 100%);
  --dt-thead: #18171f;
  --dt-row-odd: #141316;
  --dt-row-even: #121214;
  --dt-hover: rgba(124, 58, 237, 0.10);
}

.wrapper {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-radius: 14px;
  border: 1px solid var(--dt-border);
  box-shadow: var(--dt-sp);
  background: var(--dt-bg);
  transition: box-shadow 0.25s, border-color 0.25s;
  position: relative;

  &:hover {
    box-shadow: var(--dt-sh);
    border-color: var(--dt-border-h);
  }

  // shimmer line
  &::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(124, 58, 237, 0.18) 15%,
      rgba(99,  60, 220, 0.38) 36%,
      rgba(79,  70, 229, 0.42) 50%,
      rgba(37,  99, 235, 0.32) 68%,
      rgba(14, 165, 233, 0.18) 85%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 2;
  }
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  border-bottom: 1px solid var(--dt-border);
  background: var(--dt-bg);
  flex-shrink: 0;
  gap: 12px;

  .searchBox {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--dt-s2);
    border: 1px solid var(--dt-border);
    border-radius: 10px;
    padding: 7px 12px;
    width: 260px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;

    &:focus-within {
      background: var(--dt-bg);
      border-color: rgba(79, 70, 229, 0.4);
      box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.08);
    }

    svg {
      width: 13px;
      height: 13px;
      color: var(--dt-text4);
      flex-shrink: 0;
      transition: color 0.2s ease;
    }

    &:focus-within svg { color: var(--dt-accent); }

    input {
      border: none;
      background: transparent;
      outline: none;
      font-size: 0.8rem;
      font-family: 'DM Sans', system-ui, sans-serif;
      color: var(--dt-text);
      width: 100%;

      &::placeholder { color: var(--dt-text4); }
    }
  }

  .rowCount {
    font-size: 0.6875rem;
    color: var(--dt-text4);
    white-space: nowrap;
    background: var(--dt-s2);
    border: 1px solid var(--dt-border);
    border-radius: 999px;
    padding: 4px 10px;
    font-weight: 500;
  }
}

.tableScroll {
  flex: 1;
  overflow-y: auto;

  &::-webkit-scrollbar { width: 3px; }
  &::-webkit-scrollbar-track { background: transparent; }
  &::-webkit-scrollbar-thumb {
    background: rgba(124, 58, 237, 0.18);
    border-radius: 2px;
  }
}

table {
  width: auto;
  min-width: 100%;
  border-collapse: collapse;
}

thead {
  position: sticky;
  top: 0;
  z-index: 2;
  background: var(--dt-thead);

  // gradient underline
  &::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1.5px;
    background: linear-gradient(90deg, #7c3aed 0%, #4f46e5 35%, #2563eb 65%, #0ea5e9 100%);
  }

  th {
    padding: 10px 18px;
    text-align: left;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--dt-text3);
    border-bottom: 1px solid var(--dt-border);
    white-space: nowrap;
    cursor: pointer;
    user-select: none;
    transition: color 0.15s ease;

    &:hover { color: var(--dt-accent); }

    .thInner {
      display: inline-flex;
      align-items: center;
      gap: 5px;
    }

    .sortIcon {
      display: inline-flex;
      flex-direction: column;
      gap: 1.5px;

      span {
        display: block;
        width: 0; height: 0;
        border-left: 3px solid transparent;
        border-right: 3px solid transparent;

        &.up {
          border-bottom: 3.5px solid var(--dt-text4);
          &.active { border-bottom-color: var(--dt-accent); }
        }

        &.down {
          border-top: 3.5px solid var(--dt-text4);
          &.active { border-top-color: var(--dt-accent); }
        }
      }
    }
  }
}

tbody {
  tr {
    border-bottom: 1px solid var(--dt-border);
    transition: background 0.14s ease, box-shadow 0.14s ease;

    &:last-child { border-bottom: none; }
    &:nth-child(odd)  { background: var(--dt-row-odd); }
    &:nth-child(even) { background: var(--dt-row-even); }

    &:hover {
      background: var(--dt-hover);
      box-shadow: inset 2.5px 0 0 var(--dt-accent);
    }
  }

  td {
    padding: 11px 18px;
    font-size: 0.8125rem;
    color: var(--dt-text2);
    white-space: nowrap;
    transition: color 0.14s ease;
  }

  tr:hover td { color: var(--dt-text); }

  td:first-child {
    font-weight: 500;
    color: var(--dt-text);
  }
}

.emptyState {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px 20px;
  gap: 10px;

  svg {
    width: 36px;
    height: 36px;
    color: var(--dt-text4);
    opacity: 0.5;
  }

  p {
    margin: 0;
    font-size: 0.75rem;
    color: var(--dt-text4);
  }
}

.pagination {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 16px;
  border-top: 1px solid var(--dt-border);
  background: var(--dt-thead);
  flex-shrink: 0;

  .pageInfo {
    font-size: 0.6875rem;
    color: var(--dt-text3);
  }

  .pageControls {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .navBtn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 7px;
    border: 1px solid var(--dt-border);
    background: var(--dt-bg);
    color: var(--dt-text3);
    cursor: pointer;
    transition: all 0.15s ease;

    svg { width: 14px; height: 14px; display: block; }

    &:hover:not(:disabled) {
      background: var(--dt-hover);
      border-color: var(--dt-border-h);
      color: var(--dt-accent);
      box-shadow: 0 2px 6px rgba(79, 70, 229, 0.14);
    }

    &:disabled { opacity: 0.28; cursor: not-allowed; }
  }

  .pageDots {
    font-size: 0.6875rem;
    color: var(--dt-text4);
    padding: 0 2px;
    user-select: none;
  }

