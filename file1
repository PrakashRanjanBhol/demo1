  .formCard {
  background: var(--gs-bg);
  border: 1px solid var(--gs-border);
  border-radius: 16px;
  padding: 28px;
  box-shadow: var(--gs-sp);
  max-width: 860px;        // wider to fit 2 columns
  display: flex;
  flex-direction: column;
  gap: 24px;
  transition: box-shadow 0.25s, border-color 0.25s;
  animation: fadeUp 0.4s ease both;
  position: relative;
  margin-top: 4px;

  &:hover {
    box-shadow: var(--gs-sh);
    border-color: var(--gs-border-h);
  }

  &::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    border-radius: 16px 16px 0 0;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(124, 58, 237, 0.18) 15%,
      rgba(79, 70, 229, 0.42) 50%,
      rgba(14, 165, 233, 0.18) 85%,
      transparent 100%
    );
    pointer-events: none;
  }
}

.fieldRow {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  align-items: start;
}










