/* ═══════════════════════════════════════════════════════════════════════════
   Component styles
   ═══════════════════════════════════════════════════════════════════════════ */

.sldc-dashboard {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  padding: 1.5rem 0;
  font-family: 'DM Sans', system-ui, sans-serif;
  background: var(--sldc-statistics-bg-page);
}

/* ── Card ───────────────────────────────────────────────────────────────────── */
.sldc-card {
  background: var(--sldc-statistics-bg-card);
  border: 1px solid var(--sldc-statistics-border-card);
  border-radius: var(--sldc-statistics-radius-card);
  padding: 1.25rem 1.5rem;
}

.sldc-card__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 1rem;
  margin-bottom: 1.25rem;
}

/* ── Section labels ─────────────────────────────────────────────────────────── */
.sldc-section-label {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--sldc-statistics-text-tertiary);
  margin: 0 0 4px;
}

.sldc-section-title {
  font-size: 16px;
  font-weight: 500;
  color: var(--sldc-statistics-text-primary);
  margin: 0;
}

/* ── Divider ────────────────────────────────────────────────────────────────── */
.sldc-divider {
  height: 1px;
  background: var(--sldc-statistics-border-divider);
  margin-bottom: 1.25rem;
}

/* ── Date row ───────────────────────────────────────────────────────────────── */
.sldc-date-row {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.sldc-date-group {
  display: flex;
  align-items: center;
  gap: 6px;
}

.sldc-date-label {
  font-size: 12px;
  color: var(--sldc-statistics-text-secondary);
  white-space: nowrap;
}

.sldc-date-sep {
  font-size: 12px;
  color: var(--sldc-statistics-text-tertiary);
}

.sldc-date-input {
  font-family: inherit;
  font-size: 13px;
  padding: 5px 9px;
  border: 1px solid var(--sldc-statistics-border-input);
  border-radius: var(--sldc-statistics-radius-element);
  background: var(--sldc-statistics-bg-input);
  color: var(--sldc-statistics-text-primary);
  outline: none;
  cursor: pointer;
  transition: border-color 0.15s;
}

.sldc-date-input:focus {
  border-color: var(--sldc-statistics-accent-bar);
}

/* ── Apply button ───────────────────────────────────────────────────────────── */
.sldc-apply-btn {
  font-family: inherit;
  font-size: 13px;
  font-weight: 500;
  padding: 5px 16px;
  border-radius: var(--sldc-statistics-radius-element);
  border: 1px solid var(--sldc-statistics-border-btn);
  background: var(--sldc-statistics-btn-bg);
  color: var(--sldc-statistics-btn-text);
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  white-space: nowrap;
  transition: background 0.15s, transform 0.1s;
  min-width: 68px;
  justify-content: center;
}

.sldc-apply-btn:hover:not(:disabled) {
  background: var(--sldc-statistics-btn-bg-hover);
}

.sldc-apply-btn:active:not(:disabled) {
  transform: scale(0.97);
}

.sldc-apply-btn:disabled {
  opacity: 0.55;
  cursor: not-allowed;
}

/* ── Spinner ────────────────────────────────────────────────────────────────── */
.sldc-spinner {
  display: inline-block;
  width: 14px;
  height: 14px;
  border: 1.5px solid var(--sldc-statistics-border-input);
  border-top-color: var(--sldc-statistics-text-primary);
  border-radius: 50%;
  animation: sldc-spin 0.7s linear infinite;
}

@keyframes sldc-spin {
  to { transform: rotate(360deg); }
}

/* ── Error banner ───────────────────────────────────────────────────────────── */
.sldc-error-banner {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: var(--sldc-statistics-error-text);
  background: var(--sldc-statistics-error-bg);
  border: 1px solid var(--sldc-statistics-error-border);
  border-radius: var(--sldc-statistics-radius-element);
  padding: 8px 12px;
  margin-bottom: 1rem;
}

/* ── Metric grid ────────────────────────────────────────────────────────────── */
.sldc-grid {
  display: grid;
  gap: 10px;
}

.sldc-grid--2 {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.sldc-grid--4 {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

/* ── Metric card ────────────────────────────────────────────────────────────── */
.sldc-metric {
  background: var(--sldc-statistics-bg-metric);
  border-radius: var(--sldc-statistics-radius-element);
  padding: 14px 16px;
}

.sldc-metric__label {
  font-size: 12px;
  color: var(--sldc-statistics-text-label);
  margin: 0 0 6px;
  line-height: 1.4;
}

.sldc-metric__value {
  font-size: 26px;
  font-weight: 500;
  color: var(--sldc-statistics-text-primary);
  margin: 0;
  line-height: 1;
}

/* ── Badges ─────────────────────────────────────────────────────────────────── */
.sldc-badge {
  display: inline-block;
  font-size: 11px;
  font-weight: 500;
  padding: 2px 8px;
  border-radius: var(--sldc-statistics-radius-badge);
  margin-top: 8px;
}

.sldc-badge--blue {
  background: var(--sldc-statistics-badge-blue-bg);
  color: var(--sldc-statistics-badge-blue-text);
}

.sldc-badge--green {
  background: var(--sldc-statistics-badge-green-bg);
  color: var(--sldc-statistics-badge-green-text);
}

/* ── Progress bar ───────────────────────────────────────────────────────────── */
.sldc-bar-track {
  height: 5px;
  background: var(--sldc-statistics-border-divider);
  border-radius: 20px;
  overflow: hidden;
  margin-top: 10px;
}

.sldc-bar-fill {
  height: 100%;
  border-radius: 20px;
  background: var(--sldc-statistics-accent-bar);
  transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ── Info note ──────────────────────────────────────────────────────────────── */
.sldc-info-note {
  display: flex;
  align-items: flex-start;
  gap: 6px;
  font-size: 12px;
  color: var(--sldc-statistics-info-text);
  margin-top: 1rem;
  padding-top: 1rem;
  border-top: 1px solid var(--sldc-statistics-info-border);
}

/* ── Responsive ─────────────────────────────────────────────────────────────── */
@media (max-width: 640px) {
  .sldc-grid--4 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .sldc-card__header {
    flex-direction: column;
  }

  .sldc-date-row {
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
  }

  .sldc-date-input {
    width: 100%;
  }

  .sldc-apply-btn {
    width: 100%;
  }
}

@media (max-width: 400px) {
  .sldc-grid--2 {
    grid-template-columns: 1fr;
  }
}

































import { Injectable } from '@angular/core';
import { HttpClient, HttpParams } from '@angular/common/http';
import { Observable } from 'rxjs';

// ── Response interfaces ────────────────────────────────────────────────────────

export interface ApiResponse<T> {
  status: 'Success' | 'Error';
  result: T;
}

export interface QaResult {
  jira_count: number;
  confluence_count: number;
}

export interface BitbucketResult {
  date_range: { start_date: string; end_date: string };
  pr_reviewed_ratio: number;
  pr_summary_ratio: number;
  info: string;
}

export interface PrCommentsResult {
  total_prs: number;
  comment_count: number;
  ai_comments: number;
  ratio: number;
  info: string;
}

export interface DateRange {
  start: string;
  end: string;
}

// ── Service ────────────────────────────────────────────────────────────────────

@Injectable({ providedIn: 'root' })
export class StatisticsService {
  // Replace with your actual base URL (e.g. from environment.ts)
  private readonly baseUrl = '/api';

  constructor(private http: HttpClient) {}

  getQaStats(range: DateRange): Observable<ApiResponse<QaResult>> {
    const params = new HttpParams()
      .set('start', range.start)
      .set('end', range.end);
    return this.http.get<ApiResponse<QaResult>>(`${this.baseUrl}/qa-stats`, { params });
  }

  getBitbucketAnalysis(range: DateRange): Observable<ApiResponse<BitbucketResult>> {
    const params = new HttpParams()
      .set('start', range.start)
      .set('end', range.end);
    return this.http.get<ApiResponse<BitbucketResult>>(`${this.baseUrl}/bitbucket-analysis`, { params });
  }

  getPrComments(range: DateRange): Observable<ApiResponse<PrCommentsResult>> {
    const params = new HttpParams()
      .set('start', range.start)
      .set('end', range.end);
    return this.http.get<ApiResponse<PrCommentsResult>>(`${this.baseUrl}/pr-comments`, { params });
  }
}
