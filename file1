    <div class="sldc-card__header">
      <div class="sldc-card__title-block">
        <span class="sldc-card__label">Repository</span>
        <h2 class="sldc-card__title">Bitbucket Analysis</h2>
      </div>
      <div class="sldc-date-row">
        <div class="sldc-date-group">
          <label class="sldc-date-label">From</label>
          <p-datepicker
            [(ngModel)]="bitbucket.dateRange.start"
            [maxDate]="bitbucket.dateRange.end ?? today"
            dateFormat="dd-mm-yy"
            [showIcon]="true"
            appendTo="body"
            placeholder="Start date"
            styleClass="sldc-datepicker"
          />
        </div>
        <span class="sldc-date-sep">—</span>
        <div class="sldc-date-group">
          <label class="sldc-date-label">To</label>
          <p-datepicker
            [(ngModel)]="bitbucket.dateRange.end"
            [minDate]="bitbucket.dateRange.start ?? undefined"
            [maxDate]="today"
            dateFormat="dd-mm-yy"
            [showIcon]="true"
            appendTo="body"
            placeholder="End date"
            styleClass="sldc-datepicker"
          />
        </div>
        <p-button
          label="Apply"
          [loading]="isLoading(bitbucket.loadState)"
          [disabled]="!bitbucket.dateRange.start || !bitbucket.dateRange.end"
          (onClick)="fetchBitbucket()"
          styleClass="sldc-apply-btn"
          size="small"
        />
      </div>
    </div>

    <div class="sldc-divider"></div>

    <div class="sldc-error" *ngIf="isError(bitbucket.loadState)">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
        <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.2"/>
