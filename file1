.panel {
  background-color: #ffffff;
  box-shadow:
    0 0 0 1.5px rgba(0, 0, 0, 0.08),
    0 2px 8px rgba(0, 0, 0, 0.04);
  transition: box-shadow 0.3s ease;
}

.panel:hover {
  box-shadow:
    0 0 0 1.5px rgba(236, 72, 153, 0.35),
    0 0 20px rgba(249, 115, 22, 0.12),
    0 0 40px rgba(236, 72, 153, 0.10),
    0 0 60px rgba(168, 85, 247, 0.10),
    0 8px 24px rgba(0, 0, 0, 0.06);
}
