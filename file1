const handleToggleSelect = (
  event: React.ChangeEvent<HTMLInputElement>,
  idToToggle: string,
  fileId: string
) => {
  const selection = event.target.checked;

  if (MAX_FILES_TO_SELECT && (llmRequest.RAG.ids.length <= MAX_FILES_TO_SELECT - 1 || !selection)) {
    const newSources: EmbeddingFile[] = sources.map((s) =>
      s.state_id === idToToggle ? { ...s, isSelected: !s.isSelected } : s,
    );
    setSources(newSources);
    setMainSources(newSources);
    dispatch(setRagFiles(newSources));
    dispatch(updateLLMRequest({ id: fileId, activeTool: 'RAG', selection }));

    // ── animation: deselecting class for exit animation ──
    if (!selection) {
      setDeselecting((prev) => new Set(prev).add(idToToggle));
      setTimeout(() => {
        setDeselecting((prev) => {
          const next = new Set(prev);
          next.delete(idToToggle);
          return next;
        });
      }, 280);
    }
  } else {
    console.error('Error');
  }
};



const [deselecting, setDeselecting] = useState<Set<string>>(new Set());


<div
  className={[
    styles.fileRow,
    source.isSelected ? styles.selected : '',
    deselecting.has(source.state_id) ? styles.deselecting : '',
  ]
    .filter(Boolean)
    .join(' ')}
>
