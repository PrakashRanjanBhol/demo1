<!-- Delete Confirmation Modal -->
<div class="modal-overlay" *ngIf="isDeleteConfirmationVisible">
    <div class="modal-container" (click)="$event.stopPropagation()">
        <div class="modal-header">
            <div class="modal-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                </svg>
            </div>
            <h3 class="modal-title">Confirm Deletion</h3>
            <button class="modal-close-btn" (click)="closeDeleteConfirmation()" [disabled]="isProcessingDelete">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
        <div class="modal-body">
            <p class="modal-message">
                Are you sure you want to delete <strong>{{ selectedDeleteItems.size }} file(s)</strong>?
            </p>
            <p class="modal-warning">
                This action cannot be undone. All associated data will be permanently removed.
            </p>
        </div>
        <div class="modal-footer">
            <button class="modal-cancel-btn" (click)="closeDeleteConfirmation()" [disabled]="isProcessingDelete">
                Cancel
            </button>
            <button class="modal-confirm-btn" (click)="confirmMultipleDelete()" [disabled]="isProcessingDelete">
                <svg class="delete-spinner" *ngIf="isProcessingDelete" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <svg *ngIf="!isProcessingDelete" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                </svg>
                <span *ngIf="!isProcessingDelete">Delete Files</span>
                <span *ngIf="isProcessingDelete">Deleting...</span>
            </button>
        </div>
    </div>
</div>











// Update the startMultipleDelete method
private startMultipleDelete(): void {
  // Don't close modal, keep it open during delete
  // this.isDeleteConfirmationVisible will stay true
  
  const fileIdsToDelete = Array.from(this.selectedDeleteItems).map(id => Number(id));
  this.selectedDeleteItems.clear();

  // Call delete API
  this.historyService.deleteFiles(fileIdsToDelete).subscribe({
    next: (response) => {
      console.log('Delete response:', response);
      
      if (response.status === 'success') {
        // Remove deleted items from historyItems
        this.historyItems = this.historyItems.filter(item => 
          !fileIdsToDelete.includes(Number(item.id))
        );
        
        // Clear selection if deleted item was selected
        if (this.selectedHistoryItem && fileIdsToDelete.includes(Number(this.selectedHistoryItem.id))) {
          this.selectedHistoryItem = null;
        }
        
        // Clear added to generation if deleted
        if (this.addedToGenerationId && fileIdsToDelete.includes(Number(this.addedToGenerationId))) {
          this.addedToGenerationId = null;
        }
        
        alert(`Successfully deleted ${fileIdsToDelete.length} file(s)`);
      } else {
        alert('Failed to delete files. Please try again.');
      }
      
      this.isProcessingDelete = false;
      this.isDeleteConfirmationVisible = false; // Close modal after completion
      this.isDeleteMode = false;
    },
    error: (error) => {
      console.error('Delete error:', error);
      alert('An error occurred while deleting files. Please try again.');
      this.isProcessingDelete = false;
      this.isDeleteConfirmationVisible = false; // Close modal on error
      this.isDeleteMode = false;
    }
  });
}










/* Delete Confirmation Modal */
.modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    animation: fadeIn 0.2s ease;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    /* Remove pointer-events to prevent outside clicks */
}

.modal-container {
    background: var(--bg-color);
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    max-width: 480px;
    width: 90%;
    animation: modalSlideIn 0.3s ease;
    border: 1px solid var(--border-color);
    /* Prevent click events from propagating to overlay */
    pointer-events: auto;
}

@keyframes modalSlideIn {
    from {
        opacity: 0;
        transform: translateY(-20px) scale(0.95);
    }
    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

.modal-header {
    padding: 24px 24px 16px 24px;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    align-items: flex-start;
    gap: 12px;
    position: relative;
}

.modal-icon {
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, rgba(239, 68, 68, 0.1), rgba(220, 38, 38, 0.1));
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.modal-icon svg {
    width: 28px;
    height: 28px;
    stroke: #ef4444;
}

.modal-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-color);
    margin: 0;
    padding-top: 8px;
    flex: 1;
}

.modal-close-btn {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 32px;
    height: 32px;
    background: transparent;
    border: none;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
}

.modal-close-btn:hover:not(:disabled) {
    background: rgba(239, 68, 68, 0.1);
}

.modal-close-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.modal-close-btn svg {
    width: 18px;
    height: 18px;
    stroke: var(--text-color);
    opacity: 0.6;
}

.modal-body {
    padding: 24px;
}

.modal-message {
    font-size: 14px;
    color: var(--text-color);
    margin: 0 0 12px 0;
    line-height: 1.6;
}

.modal-message strong {
    color: #ef4444;
    font-weight: 700;
}

.modal-warning {
    font-size: 13px;
    color: var(--text-color);
    opacity: 0.7;
    margin: 0;
    line-height: 1.5;
    padding: 12px;
    background: rgba(239, 68, 68, 0.05);
    border-left: 3px solid #ef4444;
    border-radius: 4px;
}

.modal-footer {
    padding: 16px 24px 24px 24px;
    display: flex;
    gap: 12px;
    justify-content: flex-end;
}

.modal-cancel-btn,
.modal-confirm-btn {
    padding: 10px 20px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
    display: flex;
    align-items: center;
    gap: 8px;
}

.modal-cancel-btn {
    background: transparent;
    color: var(--text-color);
    border: 1.5px solid var(--border-color);
}

.modal-cancel-btn:hover:not(:disabled) {
    background: rgba(107, 114, 128, 0.1);
    border-color: #6b7280;
}

.modal-cancel-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.modal-confirm-btn {
    background: linear-gradient(135deg, #ef4444, #dc2626);
    color: white;
    border: 1.5px solid #ef4444;
}

.modal-confirm-btn:hover:not(:disabled) {
    box-shadow: 0 4px 12px rgba(239, 68, 68, 0.4);
    transform: translateY(-2px);
}

.modal-confirm-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
}

.modal-confirm-btn:disabled:hover {
    transform: none;
    box-shadow: none;
}

.modal-confirm-btn svg {
    width: 18px;
    height: 18px;
}

/* Delete Spinner */
.delete-spinner {
    width: 18px;
    height: 18px;
    animation: spin 1s linear infinite;
}

/* Responsive */
@media screen and (max-width: 1400px) {
    .modal-container {
        max-width: 90%;
    }

    .modal-header {
        padding: 20px 20px 12px 20px;
    }

    .modal-icon {
        width: 40px;
        height: 40px;
    }

    .modal-icon svg {
        width: 24px;
        height: 24px;
    }

    .modal-title {
        font-size: 16px;
    }

    .modal-body {
        padding: 20px;
    }

    .modal-footer {
        padding: 12px 20px 20px 20px;
        flex-direction: column;
    }

    .modal-cancel-btn,
    .modal-confirm-btn {
        width: 100%;
        justify-content: center;
    }
}


