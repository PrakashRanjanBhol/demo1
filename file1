const handleMouseMove = (e: React.MouseEvent<HTMLDivElement>) => {
  const rect = e.currentTarget.getBoundingClientRect();
  const x = e.clientX - rect.left;
  const y = e.clientY - rect.top;
  e.currentTarget.style.setProperty('--gc-mouse-x', `${x}px`);
  e.currentTarget.style.setProperty('--gc-mouse-y', `${y}px`);
};

// In JSX:
<div
  className={`${styles.generatedCard} ${styles[file.status]} ${!isExpanded ? 'w-min p-1' : ''}`}
  title={file.file_name}
  onMouseMove={handleMouseMove}
>
  <div className={styles.spotlight} />
  <div className={`${styles.iconStatusWrapper} ${styles[file.job_type]} ${styles[file.status]}`}>
    ...
  </div>
  ...
</div>






// ─── SCSS Variables ───────────────────────────────────────────────────────────

$radius-card:        12px;
$radius-icon:        8px;
$radius-action-btn:  7px;

$icon-wrapper-size:  38px;
$action-btn-size:    28px;

// Spinning border gradient — STARTED / PENDING only
$gradient-purple:    #7f77dd;
$gradient-blue:      #378add;
$gradient-teal:      #1d9e75;

// Job type colours
$translation-bg:     #e6f1fb;
$translation-color:  #378add;
$summary-bg:         #eeedfe;
$summary-color:      #7f77dd;

// Status colours
$failure-bg:         #faece7;
$failure-color:      #d85a30;
$failure-ring:       rgba(216, 90, 48, 0.25);
$success-ring:       rgba(29, 158, 117, 0.25);

// Action button
$action-hover-bg:    #eeedfe;
$action-hover-color: #534ab7;

// Dotted ring (STARTED / PENDING icon)
$dotted-ring-color:  #7f77dd;
$dotted-ring-offset: 3px;

// Timing
$transition-fast:    0.15s;
$transition-medium:  0.25s;
$spin-duration:      2s;
$pulse-duration:     1.4s;


// ─── CSS Custom Properties ────────────────────────────────────────────────────

:root {
  --gc-container-bg:   #ffffff;
  --gc-card-bg-hover:  #f0f0ee;

  --gc-text-primary:   #111111;
  --gc-text-secondary: #666666;
  --gc-text-tertiary:  #999999;
  --gc-text-error:     #{$failure-color};

  --gc-border:         rgba(0, 0, 0, 0.12);
  --gc-mask-color:     #ffffff;

  // Spotlight — warm white radial glow
  --gc-spot-color:     rgba(255, 255, 255, 0.55);
  --gc-spot-size:      140px;

  // Mouse position (set via JS on mousemove)
  --gc-mouse-x:        50%;
  --gc-mouse-y:        50%;
}

[data-theme='dark'] {
  --gc-container-bg:   #111113;
  --gc-card-bg-hover:  #1e1e21;

  --gc-text-primary:   #f0f0f0;
  --gc-text-secondary: #a0a0a0;
  --gc-text-tertiary:  #606060;
  --gc-text-error:     #f0997b;

  --gc-border:         rgba(255, 255, 255, 0.08);
  --gc-mask-color:     #111113;

  // Spotlight — cool white glow, more restrained in dark
  --gc-spot-color:     rgba(255, 255, 255, 0.07);
  --gc-spot-size:      160px;
}


// ─── Animations ───────────────────────────────────────────────────────────────

@property --angle {
  syntax: '<angle>';
  initial-value: 0deg;
  inherits: false;
}

@keyframes spin {
  to { --angle: 360deg; }
}

@keyframes pulse-ring {
  0%   { transform: scale(0.92); opacity: 0.6; }
  50%  { transform: scale(1.08); opacity: 1;   }
  100% { transform: scale(0.92); opacity: 0.6; }
}

// Spotlight fade-in when entering the card
@keyframes spot-enter {
  from { opacity: 0; }
  to   { opacity: 1; }
}


// ─── Card ─────────────────────────────────────────────────────────────────────
.generatedCard {
  position: relative;
  display: flex;
  align-items: center;
  padding: 0.75rem;
  background-color: transparent;
  border-radius: $radius-card;
  overflow: hidden;
  cursor: pointer;
  transition: background-color $transition-fast;

  // ── Border pseudo-elements ────────────────────────────────────────────
  &::before,
  &::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: $radius-card;
    -webkit-mask:
      linear-gradient(var(--gc-mask-color) 0 0) content-box,
      linear-gradient(var(--gc-mask-color) 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    padding: 1px;
    pointer-events: none;
    z-index: 0;
  }

  // Static border
  &::before {
    background: var(--gc-border);
    transition: opacity $transition-medium;
  }

  // Spinning gradient border — always animating, hidden until STARTED/PENDING
  &::after {
    background: conic-gradient(
      from var(--angle) at 50% 50%,
      transparent       0deg,
      transparent       150deg,
      $gradient-purple  185deg,
      $gradient-blue    215deg,
      $gradient-teal    240deg,
      transparent       265deg
    );
    opacity: 0;
    animation: spin $spin-duration linear infinite;
    transition: opacity $transition-medium;
  }

  // ── Spotlight layer ───────────────────────────────────────────────────
  // Follows mouse position via --gc-mouse-x / --gc-mouse-y set in JS
  .spotlight {
    position: absolute;
    inset: 0;
    border-radius: $radius-card;
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    transition: opacity 0.3s ease;
    background: radial-gradient(
      circle var(--gc-spot-size) at var(--gc-mouse-x) var(--gc-mouse-y),
      var(--gc-spot-color),
      transparent 80%
    );
  }

  // ── Hover ─────────────────────────────────────────────────────────────
  &:hover {
    background-color: var(--gc-card-bg-hover);

    .spotlight {
      opacity: 1;
      animation: spot-enter 0.25s ease forwards;
    }

    .cardActions { opacity: 1; }
  }

  // ── STARTED / PENDING — spinning gradient border ──────────────────────
  &.STARTED,
  &.PENDING {
    &::before { opacity: 0; }
    &::after  { opacity: 1; }
  }

  // Collapsed icon-only state
  &:global(.w-min) { width: min-content; }
  &:global(.p-1)   { padding: 4px; }
}


// ─── Icon + status wrapper ────────────────────────────────────────────────────
.iconStatusWrapper {
  position: relative;
  z-index: 1;
  width: $icon-wrapper-size;
  height: $icon-wrapper-size;
  flex-shrink: 0;
  border-radius: $radius-icon;
  display: flex;
  align-items: center;
  justify-content: center;

  :global(.content-bg) {
    width: 100%;
    height: 100%;
    border-radius: $radius-icon;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  &.translation :global(.content-bg) {
    background: $translation-bg;
    color: $translation-color;
  }

  &.summary :global(.content-bg) {
    background: $summary-bg;
    color: $summary-color;
  }

  &.SUCCESS :global(.content-bg) {
    box-shadow: inset 0 0 0 1.5px $success-ring;
  }

  &.FAILURE :global(.content-bg) {
    background: $failure-bg;
    color: $failure-color;
    box-shadow: inset 0 0 0 1.5px $failure-ring;
  }

  &.STARTED :global(.content-bg),
  &.PENDING :global(.content-bg) {
    opacity: 0.7;
  }
}

.dottedRing {
  position: absolute;
  inset: -#{$dotted-ring-offset};
  width: calc(100% + #{$dotted-ring-offset * 2});
  height: calc(100% + #{$dotted-ring-offset * 2});
  animation: pulse-ring $pulse-duration ease-in-out infinite;
  color: $dotted-ring-color;
  pointer-events: none;
}


// ─── File info ────────────────────────────────────────────────────────────────
.fileInfo {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.fileName {
  font-size: 12px;
  font-weight: 500;
  color: var(--gc-text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.4;
}

.fileData {
  font-size: 11px;
  color: var(--gc-text-tertiary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.textError {
  color: var(--gc-text-error);
}


// ─── Card actions ─────────────────────────────────────────────────────────────
.cardActions {
  position: relative;
  z-index: 1;
  flex-shrink: 0;
  opacity: 0;
  transition: opacity $transition-fast;
}

.menuWarpper {
  position: relative;
  display: flex;
  align-items: center;
}

.actionBtn {
  width: $action-btn-size;
  height: $action-btn-size;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: $radius-action-btn;
  border: none;
  background: transparent;
  cursor: pointer;
  color: var(--gc-text-secondary);
  transition:
    background  $transition-fast,
    transform   0.12s,
    color       $transition-fast;

  &:hover {
    background: $action-hover-bg;
    color: $action-hover-color;
    transform: scale(1.1);
  }

  &:active {
    transform: scale(0.96);
  }
}
