<button
    className={styles.backBtn}
    onClick={() => { setActiveView('upload'); setUrlInput(''); setErrorMessage(null); }}>
    <IconArrowLeft size={18} />
    <span>{t('sources.back')}</span>
</button>


{/* Upload view */}
<p className={styles.dropTitle}>{t('sources.drag_drop')}</p>
<p className={styles.dropSubtitle}>
    {ALLOWED_EXTENSIONS.map((item) => item.toUpperCase()).join(', ')} {t('sources.file_size_limit', { size: MAX_FILE_EACH_FILE })}
</p>

<div className={styles.modalDivider}>
    <span>{t('sources.or_add_from')}</span>
</div>

<button ... onClick={() => { setActiveView('youtube'); setErrorMessage(null); }}>
    <IconYoutube size={20} className={`${styles.altIcon} ${styles.youtube}`} />
    <span>{t('sources.youtube_url')}</span>
</button>
<button ... onClick={() => { setActiveView('website'); setErrorMessage(null); }}>
    <IconLink size={20} className={`${styles.altIcon} ${styles.website}`} />
    <span>{t('sources.website_url')}</span>
</button>
<button className={styles.altSourceBtn}>
    <IconText size={20} className={`${styles.altIcon} ${styles.text}`} />
    <span>{t('sources.text_content')}</span>
</button>

{/* URL view */}
<h3 className={styles.urlViewTitle}>
    {activeView === 'youtube' ? t('sources.youtube_url') : t('sources.website_url')}
</h3>

<p className={styles.urlViewSubtitle}>
    {activeView === 'youtube'
        ? t('sources.youtube_url_hint')
        : t('sources.website_url_hint')}
</p>

<textarea
    className={styles.urlTextarea}
    placeholder={activeView === 'youtube'
        ? t('sources.youtube_url_placeholder')
        : t('sources.website_url_placeholder')}
    value={urlInput}
    onChange={(e) => setUrlInput(e.target.value)}
/>

<button
    className={styles.insertBtn}
    disabled={!urlInput.trim()}
    onClick={handleUrlInsert}>
    {t('sources.insert')}
</button>













