<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Three Panels</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html,
    body {
      min-height: 100vh;
    }

    body {
      background-color: #0a0a0b;
      background-image:
        radial-gradient(ellipse 60% 50% at 0% 0%, rgba(6, 182, 212, 0.06) 0%, transparent 70%),
        radial-gradient(ellipse 50% 60% at 100% 50%, rgba(99, 102, 241, 0.07) 0%, transparent 70%),
        radial-gradient(ellipse 70% 40% at 50% 100%, rgba(59, 130, 246, 0.06) 0%, transparent 70%);
      background-size: 100% 100%;
      background-attachment: fixed;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px 20px;
    }

    .layout {
      display: flex;
      flex-direction: row;
      gap: 16px;
      width: 100%;
      max-width: 1200px;
      height: 85vh;
    }

    .panel {
      background-color: #111113;
      border-radius: 14px;
      padding: 24px;
      flex: 1;
      box-shadow: 0 0 0 1.5px rgba(255, 255, 255, 0.08);
      transition: box-shadow 0.3s ease;
    }

    .panel:hover {
      box-shadow: 0 0 0 1.5px rgba(59, 130, 246, 0.6);
    }

    .panel-header {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 20px;
      padding-bottom: 16px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .panel-icon {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      background: linear-gradient(135deg, rgba(6, 182, 212, 0.2), rgba(99, 102, 241, 0.2));
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .panel-title {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 13px;
      font-weight: 500;
      color: rgba(255, 255, 255, 0.7);
      letter-spacing: 0.3px;
    }

    .panel-content {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .placeholder-line {
      height: 10px;
      border-radius: 6px;
      background: rgba(255, 255, 255, 0.04);
    }

    .placeholder-line.short {
      width: 60%;
    }

    .placeholder-line.medium {
      width: 80%;
    }

    .placeholder-line.full {
      width: 100%;
    }
  </style>
</head>

<body>

  <div class="layout">

    <!-- Panel 1 - Source -->
    <div class="panel">
      <div class="panel-header">
        <div class="panel-icon">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 2.5h7l3.5 3.5V17a.5.5 0 0 1-.5.5H5a.5.5 0 0 1-.5-.5V3a.5.5 0 0 1 .5-.5z"
              stroke="rgba(6,182,212,0.9)" stroke-width="1.4" stroke-linejoin="round" />
            <path d="M12 2.5V6h3.5" stroke="rgba(6,182,212,0.9)" stroke-width="1.4" stroke-linejoin="round" />
            <line x1="7" y1="9" x2="13" y2="9" stroke="rgba(6,182,212,0.9)" stroke-width="1.4" stroke-linecap="round" />
            <line x1="7" y1="12" x2="13" y2="12" stroke="rgba(6,182,212,0.9)" stroke-width="1.4"
              stroke-linecap="round" />
            <line x1="7" y1="15" x2="10.5" y2="15" stroke="rgba(6,182,212,0.9)" stroke-width="1.4"
              stroke-linecap="round" />
          </svg>
        </div>
        <span class="panel-title">Source</span>
      </div>
      <div class="panel-content">
        <div class="placeholder-line full"></div>
        <div class="placeholder-line medium"></div>
        <div class="placeholder-line short"></div>
        <div class="placeholder-line full"></div>
        <div class="placeholder-line medium"></div>
        <div class="placeholder-line full"></div>
        <div class="placeholder-line short"></div>
      </div>
    </div>

    <!-- Panel 2 - Chat -->
    <div class="panel">
      <div class="panel-header">
        <div class="panel-icon">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 4.5A1.5 1.5 0 0 1 4.5 3h11A1.5 1.5 0 0 1 17 4.5v8A1.5 1.5 0 0 1 15.5 14H7l-4 3V4.5z"
              stroke="rgba(59,130,246,0.9)" stroke-width="1.4" stroke-linejoin="round" />
            <line x1="6.5" y1="7.5" x2="13.5" y2="7.5" stroke="rgba(59,130,246,0.9)" stroke-width="1.4"
              stroke-linecap="round" />
            <line x1="6.5" y1="10.5" x2="11" y2="10.5" stroke="rgba(59,130,246,0.9)" stroke-width="1.4"
              stroke-linecap="round" />
          </svg>
        </div>
        <span class="panel-title">Chat</span>
      </div>
      <div class="panel-content">
        <div class="placeholder-line medium"></div>
        <div class="placeholder-line full"></div>
        <div class="placeholder-line short"></div>
        <div class="placeholder-line full"></div>
        <div class="placeholder-line medium"></div>
        <div class="placeholder-line short"></div>
        <div class="placeholder-line full"></div>
      </div>
    </div>

    <!-- Panel 3 - Tools -->
    <div class="panel">
      <div class="panel-header">
        <div class="panel-icon">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path
              d="M13.5 2a3.5 3.5 0 0 0-3.4 4.2L3.7 12.6a1.5 1.5 0 1 0 2.1 2.1l6.4-6.4A3.5 3.5 0 0 0 17 4.8l-2.2 2.2-1.4-.4-.4-1.4L15.2 3A3.5 3.5 0 0 0 13.5 2z"
              stroke="rgba(99,102,241,0.9)" stroke-width="1.4" stroke-linejoin="round" />
          </svg>
        </div>
        <span class="panel-title">Tools</span>
      </div>
      <div class="panel-content">
        <div class="placeholder-line short"></div>
        <div class="placeholder-line full"></div>
        <div class="placeholder-line medium"></div>
        <div class="placeholder-line full"></div>
        <div class="placeholder-line short"></div>
        <div class="placeholder-line medium"></div>
        <div class="placeholder-line full"></div>
      </div>
    </div>

  </div>

</body>

</html>
