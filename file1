import axios from "axios";

interface ConnectPayload {
  username: string;
  password: string;
}

interface ConnectResponse {
  status: string;
  result: string;
}

interface DisconnectResponse {
  status: string;
  result: string;
}

export const atlassianService = {
  connect: async (payload: ConnectPayload): Promise<ConnectResponse> => {
    const credentials = btoa(`${payload.username}:${payload.password}`);
    const response = await axios.post<ConnectResponse>(
      "/api/atlassian/connect",
      payload,
      {
        headers: {
          Authorization: `Basic ${credentials}`,
        },
      }
    );
    return response.data;
  },

  disconnect: async (): Promise<DisconnectResponse> => {
    const response = await axios.put<DisconnectResponse>(
      "/api/atlassian/disconnect"
    );
    return response.data;
  },
};
