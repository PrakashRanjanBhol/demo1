<!-- ── Atlassian Connection Gate ──────────────────────────────────────────────── -->
<div *ngIf="!isConnected" class="sldc-connect-overlay">
  <div class="sldc-connect-card">

    <!-- Icon placeholder — replace src with your Atlassian icon -->
    <div class="sldc-connect-icon">
      <img src="assets/atlassian-icon.png" alt="Atlassian" class="sldc-connect-icon__img" />
    </div>

    <h2 class="sldc-connect-title">Connect to Atlassian</h2>
    <p class="sldc-connect-subtitle">Enter your Atlassian credentials to load your dashboard data.</p>

    <!-- Error banner -->
    <div *ngIf="connectState === 'error'" class="sldc-error-banner sldc-connect-error">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.2"/><path d="M8 5v4M8 11v.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
      {{ connectError }}
    </div>

    <!-- Form -->
    <div class="sldc-connect-form">
      <div class="sldc-connect-field">
        <label class="sldc-connect-label" for="atlassian-username">Username</label>
        <input
          id="atlassian-username"
          type="text"
          class="sldc-connect-input"
          placeholder="your@email.com"
          [(ngModel)]="connectUsername"
          [disabled]="connectState === 'loading'"
          (keydown.enter)="connect()"
        />
      </div>
      <div class="sldc-connect-field">
        <label class="sldc-connect-label" for="atlassian-password">Password</label>
        <input
          id="atlassian-password"
          type="password"
          class="sldc-connect-input"
          placeholder="••••••••"
          [(ngModel)]="connectPassword"
          [disabled]="connectState === 'loading'"
          (keydown.enter)="connect()"
        />
      </div>
      <button
        class="sldc-connect-btn"
        [disabled]="connectState === 'loading'"
        (click)="connect()"
      >
        <span *ngIf="connectState !== 'loading'">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" style="margin-right:6px;vertical-align:-2px;">
            <path d="M10 2H6a1 1 0 0 0-1 1v1H3a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V5a1 1 0 0 0-1-1h-2V3a1 1 0 0 0-1-1z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
            <path d="M8 8v3M8 8l-1.5 1.5M8 8l1.5 1.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
          Connect
        </span>
        <span *ngIf="connectState === 'loading'" class="sldc-spinner" aria-hidden="true"></span>
      </button>
    </div>

  </div>
</div>

<!-- ── Dashboard (shown only when connected) ──────────────────────────────────── -->
<ng-container *ngIf="isConnected">

<!-- ── Dashboard Header ──────────────────────────────────────────────────────── -->
<div class="sldc-header">
  <div class="sldc-header__icon">
    <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Grid of dots representing a dashboard -->
      <rect x="3" y="3" width="11" height="11" rx="2.5" fill="currentColor" opacity="0.9"/>
      <rect x="18" y="3" width="11" height="11" rx="2.5" fill="currentColor" opacity="0.6"/>
      <rect x="3" y="18" width="11" height="11" rx="2.5" fill="currentColor" opacity="0.6"/>
      <rect x="18" y="18" width="11" height="11" rx="2.5" fill="currentColor" opacity="0.35"/>
      <!-- Activity line on bottom-right tile -->
      <path d="M20.5 26.5l2.5-3 2 2 3-4.5" stroke="white" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>

  <div class="sldc-header__body">
    <h1 class="sldc-header__title">AI Metrics Dashboard</h1>
    <p class="sldc-header__desc">
      A unified view of your team's AI activity across five domains —
      <span class="sldc-header__tag">Q&amp;A Coverage</span>
      <span class="sldc-header__tag">Bitbucket Analysis</span>
      <span class="sldc-header__tag">PR Comments</span>
      <span class="sldc-header__tag">SLDC Generation</span>
      <span class="sldc-header__tag">AHSI Coding Stats</span>
    </p>
  </div>
</div>

<div class="sldc-dashboard">

  <!-- ── Q&A Coverage ──────────────────────────────────────────────────────── -->
  <div class="sldc-card">
    <div class="sldc-card__header">
      <div class="sldc-card__title-block">
        <p class="sldc-section-label">Q&amp;A Coverage</p>
        <p class="sldc-section-title">Total Questions Tracked</p>
      </div>
      <div class="sldc-date-row">
        <div class="sldc-date-group">
          <label class="sldc-date-label" for="qa-start">From</label>
          <input id="qa-start" type="date" class="sldc-date-input" [(ngModel)]="qaRange.start" [max]="qaRange.end" />
        </div>
        <span class="sldc-date-sep">—</span>
        <div class="sldc-date-group">
          <label class="sldc-date-label" for="qa-end">To</label>
          <input id="qa-end" type="date" class="sldc-date-input" [(ngModel)]="qaRange.end" [min]="qaRange.start" [max]="today" />
        </div>
        <button class="sldc-apply-btn" [disabled]="qaState === 'loading'" (click)="loadQa()">
          <span *ngIf="qaState !== 'loading'">Apply</span>
          <span *ngIf="qaState === 'loading'" class="sldc-spinner" aria-hidden="true"></span>
        </button>
      </div>
    </div>
    <div class="sldc-divider"></div>

    <!-- Skeleton -->
    <div *ngIf="qaState === 'loading'" class="sldc-skeleton-wrap">
      <div class="sldc-skel-banner">
        <div class="sldc-skel-banner__item">
          <div class="sldc-skel sldc-skel--value"></div>
          <div class="sldc-skel sldc-skel--label"></div>
        </div>
        <div class="sldc-skel-banner__divider"></div>
        <div class="sldc-skel-banner__item">
          <div class="sldc-skel sldc-skel--value"></div>
          <div class="sldc-skel sldc-skel--label"></div>
        </div>
        <div class="sldc-skel-banner__divider"></div>
        <div class="sldc-skel-banner__item">
          <div class="sldc-skel sldc-skel--value"></div>
          <div class="sldc-skel sldc-skel--label"></div>
        </div>
      </div>
    </div>

    <!-- Content -->
    <ng-container *ngIf="qaState !== 'loading'">
      <div *ngIf="qaState === 'error'" class="sldc-error-banner">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.2"/><path d="M8 5v4M8 11v.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
        {{ qaError }}
      </div>

      <div class="sldc-gen-banner">

        <!-- Total -->
        <div class="sldc-gen-banner__item sldc-qa-item--total">
          <span class="sldc-gen-banner__value sldc-qa-value--total">{{ qaTotal > 0 ? qaTotal : '—' }}</span>
          <span class="sldc-gen-banner__label">Total</span>
        </div>

        <div class="sldc-gen-banner__divider"></div>

        <!-- Jira -->
        <div class="sldc-gen-banner__item">
          <span class="sldc-gen-banner__value sldc-qa-value--jira">{{ qaData?.jira_count ?? '—' }}</span>
          <span class="sldc-gen-banner__label">Jira</span>
        </div>

        <div class="sldc-gen-banner__divider"></div>

        <!-- Confluence -->
        <div class="sldc-gen-banner__item">
          <span class="sldc-gen-banner__value sldc-qa-value--confluence">{{ qaData?.confluence_count ?? '—' }}</span>
          <span class="sldc-gen-banner__label">Confluence</span>
        </div>

      </div>
    </ng-container>
  </div>

  <!-- ── Bitbucket Analysis ──────────────────────────────────────────────────── -->
  <div class="sldc-card">
    <div class="sldc-card__header">
      <div class="sldc-card__title-block">
        <p class="sldc-section-label">Repository</p>
        <p class="sldc-section-title">Bitbucket Analysis</p>
      </div>
      <div class="sldc-date-row">
        <div class="sldc-date-group">
          <label class="sldc-date-label" for="bb-start">From</label>
          <input id="bb-start" type="date" class="sldc-date-input" [(ngModel)]="bbRange.start" [max]="bbRange.end" />
        </div>
        <span class="sldc-date-sep">—</span>
        <div class="sldc-date-group">
          <label class="sldc-date-label" for="bb-end">To</label>
          <input id="bb-end" type="date" class="sldc-date-input" [(ngModel)]="bbRange.end" [min]="bbRange.start" [max]="today" />
        </div>
        <button class="sldc-apply-btn" [disabled]="bbState === 'loading'" (click)="loadBitbucket()">
          <span *ngIf="bbState !== 'loading'">Apply</span>
          <span *ngIf="bbState === 'loading'" class="sldc-spinner" aria-hidden="true"></span>
        </button>
      </div>
    </div>
    <div class="sldc-divider"></div>

    <!-- Skeleton -->
    <div *ngIf="bbState === 'loading'" class="sldc-skeleton-wrap">
      <div class="sldc-skel-rate-row">
        <div class="sldc-skel-rate-row__meta">
          <div class="sldc-skel sldc-skel--dot"></div>
          <div class="sldc-skel sldc-skel--text-md"></div>
        </div>
        <div class="sldc-skel sldc-skel--bar"></div>
      </div>
      <div class="sldc-skel-rate-row">
        <div class="sldc-skel-rate-row__meta">
          <div class="sldc-skel sldc-skel--dot"></div>
          <div class="sldc-skel sldc-skel--text-md"></div>
        </div>
        <div class="sldc-skel sldc-skel--bar"></div>
      </div>
    </div>

    <!-- Content -->
    <ng-container *ngIf="bbState !== 'loading'">
      <div *ngIf="bbState === 'error'" class="sldc-error-banner">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.2"/><path d="M8 5v4M8 11v.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
        {{ bbError }}
      </div>
      <div class="sldc-rate-section">
        <div class="sldc-rate-row">
          <div class="sldc-rate-row__meta">
            <span class="sldc-rate-row__label"><span class="sldc-rate-dot sldc-rate-dot--accent"></span>PR reviewed ratio</span>
            <span class="sldc-rate-row__value sldc-rate-row__value--accent">{{ formatPct(bbData?.pr_reviewed_ratio) }}</span>
          </div>
          <div class="sldc-rate-track"><div class="sldc-rate-fill sldc-rate-fill--accent" [style.width]="barWidth(bbData?.pr_reviewed_ratio)"></div></div>
        </div>
        <div class="sldc-rate-row">
          <div class="sldc-rate-row__meta">
            <span class="sldc-rate-row__label"><span class="sldc-rate-dot sldc-rate-dot--teal"></span>PR summary ratio</span>
            <span class="sldc-rate-row__value sldc-rate-row__value--teal">{{ formatPct(bbData?.pr_summary_ratio) }}</span>
          </div>
          <div class="sldc-rate-track"><div class="sldc-rate-fill sldc-rate-fill--teal" [style.width]="barWidth(bbData?.pr_summary_ratio)"></div></div>
        </div>
      </div>
      <div *ngIf="bbData?.info" class="sldc-info-note">
        <span class="sldc-info-note__badge"><svg width="11" height="11" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.3"/><path d="M8 7v5M8 5.5v-.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>Info</span>
        {{ bbData?.info }}
      </div>
    </ng-container>
  </div>

  <!-- ── PR Comments Analysis ───────────────────────────────────────────────── -->
  <div class="sldc-card">
    <div class="sldc-card__header">
      <div class="sldc-card__title-block">
        <p class="sldc-section-label">Code Review</p>
        <p class="sldc-section-title">PR Comments Analysis</p>
      </div>
      <div class="sldc-date-row">
        <div class="sldc-date-group">
          <label class="sldc-date-label" for="pr-start">From</label>
          <input id="pr-start" type="date" class="sldc-date-input" [(ngModel)]="prRange.start" [max]="prRange.end" />
        </div>
        <span class="sldc-date-sep">—</span>
        <div class="sldc-date-group">
          <label class="sldc-date-label" for="pr-end">To</label>
          <input id="pr-end" type="date" class="sldc-date-input" [(ngModel)]="prRange.end" [min]="prRange.start" [max]="today" />
        </div>
        <button class="sldc-apply-btn" [disabled]="prState === 'loading'" (click)="loadPr()">
          <span *ngIf="prState !== 'loading'">Apply</span>
          <span *ngIf="prState === 'loading'" class="sldc-spinner" aria-hidden="true"></span>
        </button>
      </div>
    </div>
    <div class="sldc-divider"></div>

    <!-- Skeleton -->
    <div *ngIf="prState === 'loading'" class="sldc-skeleton-wrap">
      <div class="sldc-skel-banner" style="margin-bottom: 14px;">
        <div class="sldc-skel-banner__item">
          <div class="sldc-skel sldc-skel--value"></div>
          <div class="sldc-skel sldc-skel--label"></div>
        </div>
        <div class="sldc-skel-banner__divider"></div>
        <div class="sldc-skel-banner__item">
          <div class="sldc-skel sldc-skel--value"></div>
          <div class="sldc-skel sldc-skel--label"></div>
        </div>
        <div class="sldc-skel-banner__divider"></div>
        <div class="sldc-skel-banner__item">
          <div class="sldc-skel sldc-skel--value"></div>
          <div class="sldc-skel sldc-skel--label"></div>
        </div>
      </div>
      <div class="sldc-skel-rate-row">
        <div class="sldc-skel-rate-row__meta">
          <div class="sldc-skel sldc-skel--dot"></div>
          <div class="sldc-skel sldc-skel--text-md"></div>
        </div>
        <div class="sldc-skel sldc-skel--bar"></div>
      </div>
    </div>

    <!-- Content -->
    <ng-container *ngIf="prState !== 'loading'">
      <div *ngIf="prState === 'error'" class="sldc-error-banner">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.2"/><path d="M8 5v4M8 11v.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
        {{ prError }}
      </div>
      <div class="sldc-gen-banner" style="margin-bottom: 14px;">
        <div class="sldc-gen-banner__item">
          <span class="sldc-gen-banner__value">{{ prData?.total_prs ?? '—' }}</span>
          <span class="sldc-gen-banner__label">Total PRs</span>
        </div>
        <div class="sldc-gen-banner__divider"></div>
        <div class="sldc-gen-banner__item">
          <span class="sldc-gen-banner__value">{{ prData?.comment_count ?? '—' }}</span>
          <span class="sldc-gen-banner__label">Comments</span>
        </div>
        <div class="sldc-gen-banner__divider"></div>
        <div class="sldc-gen-banner__item">
          <span class="sldc-gen-banner__value sldc-gen-banner__value--success">{{ prData?.ai_comments ?? '—' }}</span>
          <span class="sldc-gen-banner__label">AI Comments</span>
        </div>
      </div>
      <div class="sldc-rate-section">
        <div class="sldc-rate-row">
          <div class="sldc-rate-row__meta">
            <span class="sldc-rate-row__label"><span class="sldc-rate-dot sldc-rate-dot--success"></span>AI comment ratio</span>
            <span class="sldc-rate-row__value sldc-rate-row__value--success">{{ formatPct(prData?.ratio) }}</span>
          </div>
          <div class="sldc-rate-track"><div class="sldc-rate-fill sldc-rate-fill--success" [style.width]="barWidth(prData?.ratio)"></div></div>
        </div>
      </div>
      <div *ngIf="prData?.info" class="sldc-info-note">
        <span class="sldc-info-note__badge"><svg width="11" height="11" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.3"/><path d="M8 7v5M8 5.5v-.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>Info</span>
        {{ prData?.info }}
      </div>
    </ng-container>
  </div>

  <!-- ── SLDC Analysis ──────────────────────────────────────────────────────── -->
  <div class="sldc-card">
    <div class="sldc-card__header">
      <div class="sldc-card__title-block">
        <p class="sldc-section-label">AI Generation</p>
        <p class="sldc-section-title">SLDC Analysis</p>
      </div>
      <div class="sldc-date-row">
        <div class="sldc-date-group">
          <label class="sldc-date-label" for="sldc-start">From</label>
          <input id="sldc-start" type="date" class="sldc-date-input" [(ngModel)]="sldcRange.start" [max]="sldcRange.end" />
        </div>
        <span class="sldc-date-sep">—</span>
        <div class="sldc-date-group">
          <label class="sldc-date-label" for="sldc-end">To</label>
          <input id="sldc-end" type="date" class="sldc-date-input" [(ngModel)]="sldcRange.end" [min]="sldcRange.start" [max]="today" />
        </div>
        <button class="sldc-apply-btn" [disabled]="sldcState === 'loading'" (click)="loadSldc()">
          <span *ngIf="sldcState !== 'loading'">Apply</span>
          <span *ngIf="sldcState === 'loading'" class="sldc-spinner" aria-hidden="true"></span>
        </button>
      </div>
    </div>
    <div class="sldc-divider"></div>

    <!-- Skeleton -->
    <div *ngIf="sldcState === 'loading'" class="sldc-skeleton-wrap">
      <div class="sldc-skel sldc-skel--pill" style="margin-bottom: 14px;"></div>
      <div class="sldc-skel-banner" style="margin-bottom: 14px;">
        <div class="sldc-skel-banner__item">
          <div class="sldc-skel sldc-skel--value"></div>
          <div class="sldc-skel sldc-skel--label"></div>
        </div>
        <div class="sldc-skel-banner__divider"></div>
        <div class="sldc-skel-banner__item">
          <div class="sldc-skel sldc-skel--value"></div>
          <div class="sldc-skel sldc-skel--label"></div>
        </div>
        <div class="sldc-skel-banner__divider"></div>
        <div class="sldc-skel-banner__item">
          <div class="sldc-skel sldc-skel--value"></div>
          <div class="sldc-skel sldc-skel--label"></div>
        </div>
      </div>
      <div class="sldc-skel-rate-row">
        <div class="sldc-skel-rate-row__meta">
          <div class="sldc-skel sldc-skel--dot"></div>
          <div class="sldc-skel sldc-skel--text-md"></div>
        </div>
        <div class="sldc-skel sldc-skel--bar"></div>
      </div>
      <div class="sldc-skel-rate-row" style="margin-bottom: 14px;">
        <div class="sldc-skel-rate-row__meta">
          <div class="sldc-skel sldc-skel--dot"></div>
          <div class="sldc-skel sldc-skel--text-md"></div>
        </div>
        <div class="sldc-skel sldc-skel--bar"></div>
      </div>
      <div class="sldc-skel-ratio-grid">
        <div class="sldc-skel sldc-skel--ratio-item"></div>
        <div class="sldc-skel sldc-skel--ratio-item"></div>
        <div class="sldc-skel sldc-skel--ratio-item"></div>
      </div>
    </div>

    <!-- Content -->
    <ng-container *ngIf="sldcState !== 'loading'">
      <div *ngIf="sldcState === 'error'" class="sldc-error-banner">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.2"/><path d="M8 5v4M8 11v.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
        {{ sldcError }}
      </div>
      <div *ngIf="sldcData?.project" class="sldc-project-pill">
        <svg width="12" height="12" viewBox="0 0 16 16" fill="none">
          <rect x="2" y="2" width="5" height="5" rx="1" fill="currentColor" opacity="0.7"/>
          <rect x="9" y="2" width="5" height="5" rx="1" fill="currentColor"/>
          <rect x="2" y="9" width="5" height="5" rx="1" fill="currentColor"/>
          <rect x="9" y="9" width="5" height="5" rx="1" fill="currentColor" opacity="0.7"/>
        </svg>
        {{ sldcData?.project }}
      </div>
      <div class="sldc-gen-banner">
        <div class="sldc-gen-banner__item">
          <span class="sldc-gen-banner__value">{{ sldcData?.overall?.generated ?? '—' }}</span>
          <span class="sldc-gen-banner__label">Generated</span>
        </div>
        <div class="sldc-gen-banner__divider"></div>
        <div class="sldc-gen-banner__item">
          <span class="sldc-gen-banner__value sldc-gen-banner__value--success">{{ sldcData?.overall?.accepted ?? '—' }}</span>
          <span class="sldc-gen-banner__label">Accepted</span>
        </div>
        <div class="sldc-gen-banner__divider"></div>
        <div class="sldc-gen-banner__item">
          <span class="sldc-gen-banner__value sldc-gen-banner__value--danger">{{ sldcData?.overall?.rejected ?? '—' }}</span>
          <span class="sldc-gen-banner__label">Rejected</span>
        </div>
      </div>
      <div class="sldc-rate-section">
        <div class="sldc-rate-row">
          <div class="sldc-rate-row__meta">
            <span class="sldc-rate-row__label"><span class="sldc-rate-dot sldc-rate-dot--success"></span>Acceptance rate</span>
            <span class="sldc-rate-row__value sldc-rate-row__value--success">{{ formatPct(sldcData?.acceptance_rate) }}</span>
          </div>
          <div class="sldc-rate-track"><div class="sldc-rate-fill sldc-rate-fill--success" [style.width]="barWidth(sldcData?.acceptance_rate)"></div></div>
        </div>
        <div class="sldc-rate-row">
          <div class="sldc-rate-row__meta">
            <span class="sldc-rate-row__label"><span class="sldc-rate-dot sldc-rate-dot--danger"></span>Rejection rate</span>
            <span class="sldc-rate-row__value sldc-rate-row__value--danger">{{ formatPct(sldcData?.rejection_rate) }}</span>
          </div>
          <div class="sldc-rate-track"><div class="sldc-rate-fill sldc-rate-fill--danger" [style.width]="barWidth(sldcData?.rejection_rate)"></div></div>
        </div>
      </div>
      <div class="sldc-ratio-grid">
        <div class="sldc-ratio-item">
          <div class="sldc-ratio-item__top">
            <span class="sldc-ratio-item__label">CRS</span>
            <span class="sldc-ratio-item__value">{{ formatPct(sldcData?.crs_ratio) }}</span>
          </div>
          <div class="sldc-rate-track"><div class="sldc-rate-fill sldc-rate-fill--accent" [style.width]="barWidth(sldcData?.crs_ratio)"></div></div>
        </div>
        <div class="sldc-ratio-item">
          <div class="sldc-ratio-item__top">
            <span class="sldc-ratio-item__label">SRS</span>
            <span class="sldc-ratio-item__value">{{ formatPct(sldcData?.srs_ratio) }}</span>
          </div>
          <div class="sldc-rate-track"><div class="sldc-rate-fill sldc-rate-fill--accent" [style.width]="barWidth(sldcData?.srs_ratio)"></div></div>
        </div>
        <div class="sldc-ratio-item">
          <div class="sldc-ratio-item__top">
            <span class="sldc-ratio-item__label">Task</span>
            <span class="sldc-ratio-item__value">{{ formatPct(sldcData?.task_ratio) }}</span>
          </div>
          <div class="sldc-rate-track"><div class="sldc-rate-fill sldc-rate-fill--accent" [style.width]="barWidth(sldcData?.task_ratio)"></div></div>
        </div>
      </div>
      <div *ngIf="sldcData?.info" class="sldc-info-note">
        <span class="sldc-info-note__badge"><svg width="11" height="11" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.3"/><path d="M8 7v5M8 5.5v-.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>Info</span>
        {{ sldcData?.info }}
      </div>
    </ng-container>
  </div>

  <!-- ── AHSI Coding Stats ──────────────────────────────────────────────────── -->
  <div class="sldc-card">
    <div class="sldc-card__header">
      <div class="sldc-card__title-block">
        <p class="sldc-section-label">Code Intelligence</p>
        <p class="sldc-section-title">AHSI Coding Stats</p>
      </div>
      <div class="sldc-date-row">
        <div class="sldc-date-group">
          <label class="sldc-date-label" for="ahsi-start">From</label>
          <input id="ahsi-start" type="date" class="sldc-date-input" [(ngModel)]="ahsiRange.start" [max]="ahsiRange.end" />
        </div>
        <span class="sldc-date-sep">—</span>
        <div class="sldc-date-group">
          <label class="sldc-date-label" for="ahsi-end">To</label>
          <input id="ahsi-end" type="date" class="sldc-date-input" [(ngModel)]="ahsiRange.end" [min]="ahsiRange.start" [max]="today" />
        </div>
        <button class="sldc-apply-btn" [disabled]="ahsiState === 'loading'" (click)="loadAhsi()">
          <span *ngIf="ahsiState !== 'loading'">Apply</span>
          <span *ngIf="ahsiState === 'loading'" class="sldc-spinner" aria-hidden="true"></span>
        </button>
      </div>
    </div>
    <div class="sldc-divider"></div>

    <!-- Skeleton -->
    <div *ngIf="ahsiState === 'loading'" class="sldc-skeleton-wrap">
      <div class="sldc-skel-banner" style="margin-bottom: 14px;">
        <div class="sldc-skel-banner__item">
          <div class="sldc-skel sldc-skel--value"></div>
          <div class="sldc-skel sldc-skel--label"></div>
        </div>
        <div class="sldc-skel-banner__divider"></div>
        <div class="sldc-skel-banner__item">
          <div class="sldc-skel sldc-skel--value"></div>
          <div class="sldc-skel sldc-skel--label"></div>
        </div>
        <div class="sldc-skel-banner__divider"></div>
        <div class="sldc-skel-banner__item">
          <div class="sldc-skel sldc-skel--value"></div>
          <div class="sldc-skel sldc-skel--label"></div>
        </div>
      </div>
      <div class="sldc-skel-rate-row" style="margin-bottom: 14px;">
        <div class="sldc-skel-rate-row__meta">
          <div class="sldc-skel sldc-skel--dot"></div>
          <div class="sldc-skel sldc-skel--text-md"></div>
        </div>
        <div class="sldc-skel sldc-skel--bar"></div>
      </div>
      <div class="sldc-skel-ratio-grid sldc-skel-ratio-grid--3col">
        <div class="sldc-skel sldc-skel--ratio-item"></div>
        <div class="sldc-skel sldc-skel--ratio-item"></div>
        <div class="sldc-skel sldc-skel--ratio-item"></div>
      </div>
    </div>

    <!-- Content -->
    <ng-container *ngIf="ahsiState !== 'loading'">
      <div *ngIf="ahsiState === 'error'" class="sldc-error-banner">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.2"/><path d="M8 5v4M8 11v.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
        {{ ahsiError }}
      </div>
      <div class="sldc-gen-banner" style="margin-bottom: 14px;">
        <div class="sldc-gen-banner__item">
          <span class="sldc-gen-banner__value">{{ ahsiData?.pr_analyzed ?? '—' }}</span>
          <span class="sldc-gen-banner__label">PRs Analyzed</span>
        </div>
        <div class="sldc-gen-banner__divider"></div>
        <div class="sldc-gen-banner__item">
          <span class="sldc-gen-banner__value">{{ formatDecimal(ahsiData?.ahsi) }}</span>
          <span class="sldc-gen-banner__label">AHSI Score</span>
        </div>
        <div class="sldc-gen-banner__divider"></div>
        <div class="sldc-gen-banner__item">
          <span class="sldc-gen-banner__value">{{ formatDecimal(ahsiData?.avg_similarity, 3) }}</span>
          <span class="sldc-gen-banner__label">Avg Similarity</span>
        </div>
      </div>
      <div class="sldc-rate-section" style="margin-bottom: 14px;">
        <div class="sldc-rate-row">
          <div class="sldc-rate-row__meta">
            <span class="sldc-rate-row__label"><span class="sldc-rate-dot sldc-rate-dot--accent"></span>Coverage</span>
            <span class="sldc-rate-row__value">{{ formatPct(ahsiData?.coverage != null ? ahsiData!.coverage * 100 : null) }}</span>
          </div>
          <div class="sldc-rate-track"><div class="sldc-rate-fill sldc-rate-fill--accent" [style.width]="barWidth(ahsiData?.coverage != null ? ahsiData!.coverage * 100 : null)"></div></div>
        </div>
      </div>
      <div class="sldc-ratio-grid sldc-ratio-grid--3col">
        <div class="sldc-ratio-item">
          <div class="sldc-ratio-item__top">
            <span class="sldc-ratio-item__label">Matched blocks</span>
            <span class="sldc-ratio-item__value">{{ ahsiData?.matched_blocks ?? '—' }}</span>
          </div>
        </div>
        <div class="sldc-ratio-item">
          <div class="sldc-ratio-item__top">
            <span class="sldc-ratio-item__label">Human blocks</span>
            <span class="sldc-ratio-item__value">{{ ahsiData?.total_human_blocks ?? '—' }}</span>
          </div>
        </div>
        <div class="sldc-ratio-item">
          <div class="sldc-ratio-item__top">
            <span class="sldc-ratio-item__label">AI blocks</span>
            <span class="sldc-ratio-item__value sldc-ratio-item__value--success">{{ ahsiData?.total_ai_blocks ?? '—' }}</span>
          </div>
        </div>
      </div>
      <div *ngIf="ahsiData?.info" class="sldc-info-note">
        <span class="sldc-info-note__badge"><svg width="11" height="11" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.3"/><path d="M8 7v5M8 5.5v-.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>Info</span>
        {{ ahsiData?.info }}
      </div>
    </ng-container>
  </div>

</div>

</ng-container>












/* ═══════════════════════════════════════════════════════════════════════════
   Dashboard Header
   ═══════════════════════════════════════════════════════════════════════════ */

.sldc-header {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1.25rem 1.75rem;
  margin-bottom: 0.25rem;
  background: var(--sldc-statistics-bg-card);
  border: 1px solid var(--sldc-statistics-border-card);
  border-radius: var(--sldc-statistics-radius-card);
  font-family: 'DM Sans', system-ui, sans-serif;
}

.sldc-header__icon {
  width: 52px;
  height: 52px;
  border-radius: 14px;
  background: var(--sldc-statistics-theme-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  flex-shrink: 0;
}

.sldc-header__body {
  display: flex;
  flex-direction: column;
  gap: 5px;
  min-width: 0;
}

.sldc-header__title {
  font-size: 18px;
  font-weight: 600;
  color: var(--sldc-statistics-text-primary);
  margin: 0;
  line-height: 1.2;
}

.sldc-header__desc {
  font-size: 13px;
  color: var(--sldc-statistics-text-tertiary);
  margin: 0;
  line-height: 1.6;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 4px;
}

.sldc-header__desc::before {
  content: '';
}

.sldc-header__tag {
  display: inline-flex;
  align-items: center;
  font-size: 11px;
  font-weight: 500;
  color: var(--sldc-statistics-text-secondary);
  background: var(--sldc-statistics-bg-metric);
  border: 1px solid var(--sldc-statistics-border-divider);
  border-radius: 20px;
  padding: 1px 9px;
  white-space: nowrap;
}

@media (max-width: 700px) {
  .sldc-header {
    padding: 1rem 1.25rem;
  }

  .sldc-header__icon {
    width: 42px;
    height: 42px;
    border-radius: 11px;
  }

  .sldc-header__title {
    font-size: 16px;
  }
}

/* ═══════════════════════════════════════════════════════════════════════════
   Atlassian Connection Page
   ═══════════════════════════════════════════════════════════════════════════ */

.sldc-connect-overlay {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 2rem;
  background: var(--sldc-statistics-bg-page);
  font-family: 'DM Sans', system-ui, sans-serif;
}

.sldc-connect-card {
  width: 100%;
  max-width: 400px;
  background: var(--sldc-statistics-bg-card);
  border: 1px solid var(--sldc-statistics-border-card);
  border-radius: 16px;
  padding: 2.5rem 2rem 2rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
}

/* Icon */
.sldc-connect-icon {
  width: 64px;
  height: 64px;
  border-radius: 16px;
  background: var(--sldc-statistics-bg-metric);
  border: 1px solid var(--sldc-statistics-border-divider);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1.25rem;
  overflow: hidden;
}

.sldc-connect-icon__img {
  width: 40px;
  height: 40px;
  object-fit: contain;
}

/* Titles */
.sldc-connect-title {
  font-size: 20px;
  font-weight: 600;
  color: var(--sldc-statistics-text-primary);
  margin: 0 0 0.5rem;
  text-align: center;
}

.sldc-connect-subtitle {
  font-size: 13px;
  color: var(--sldc-statistics-text-tertiary);
  text-align: center;
  margin: 0 0 1.5rem;
  line-height: 1.5;
}

/* Error banner inside connect card */
.sldc-connect-error {
  width: 100%;
  margin-bottom: 1rem;
}

/* Form */
.sldc-connect-form {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  width: 100%;
}

.sldc-connect-field {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.sldc-connect-label {
  font-size: 12px;
  font-weight: 500;
  color: var(--sldc-statistics-text-secondary);
}

.sldc-connect-input {
  font-family: inherit;
  font-size: 14px;
  padding: 9px 12px;
  border: 1px solid var(--sldc-statistics-border-input);
  border-radius: var(--sldc-statistics-radius-element);
  background: var(--sldc-statistics-bg-input);
  color: var(--sldc-statistics-text-primary);
  outline: none;
  transition: border-color 0.15s, box-shadow 0.15s;
  width: 100%;
  box-sizing: border-box;
}

.sldc-connect-input::placeholder {
  color: var(--sldc-statistics-text-tertiary);
}

.sldc-connect-input:focus {
  border-color: var(--sldc-statistics-accent-bar);
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--sldc-statistics-accent-bar) 15%, transparent);
}

.sldc-connect-input:disabled {
  opacity: 0.55;
  cursor: not-allowed;
}

/* Connect button — full width, gradient */
.sldc-connect-btn {
  font-family: inherit;
  font-size: 14px;
  font-weight: 500;
  padding: 10px 20px;
  border-radius: var(--sldc-statistics-radius-element);
  border: none;
  background: var(--sldc-statistics-theme-gradient);
  color: #ffffff;
  cursor: pointer;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 42px;
  margin-top: 0.25rem;
  transition: opacity 0.15s, transform 0.1s;
}

.sldc-connect-btn:hover:not(:disabled) {
  opacity: 0.88;
}

.sldc-connect-btn:active:not(:disabled) {
  transform: scale(0.98);
}

.sldc-connect-btn:disabled {
  opacity: 0.55;
  cursor: not-allowed;
}

/* ═══════════════════════════════════════════════════════════════════════════
   SLDC Statistics — CSS Custom Properties
   Light mode (default)
   ═══════════════════════════════════════════════════════════════════════════ */
:root,
[data-theme="light"] {
  /* Surfaces */
  --sldc-statistics-bg-page:          #f4f4f5;
  --sldc-statistics-bg-card:          #ffffff;
  --sldc-statistics-bg-metric:        #f9f9f9;
  --sldc-statistics-bg-input:         #f4f4f5;

  /* Borders */
  --sldc-statistics-border-card:      #bfbfbf;
  --sldc-statistics-border-input:     #bfbfbf;
  --sldc-statistics-border-divider:   #e5e5e5;
  --sldc-statistics-border-btn:       #bfbfbf;

  /* Text */
  --sldc-statistics-text-primary:     #0a0a0a;
  --sldc-statistics-text-secondary:   #52525b;
  --sldc-statistics-text-tertiary:    #71717a;
  --sldc-statistics-text-label:       #71717a;

  /* Accent — progress bar */
  --sldc-statistics-accent-bar:       #2563eb;

  /* Badge — blue (Jira / Confluence) */
  --sldc-statistics-badge-blue-bg:    #dbeafe;
  --sldc-statistics-badge-blue-text:  #1e40af;

  /* Badge — green (AI) */
  --sldc-statistics-badge-green-bg:   #dcfce7;
  --sldc-statistics-badge-green-text: #166534;

  /* Error */
  --sldc-statistics-error-bg:         #fef2f2;
  --sldc-statistics-error-border:     #fca5a5;
  --sldc-statistics-error-text:       #991b1b;

  /* Info note */
  --sldc-statistics-info-text:        #71717a;
  --sldc-statistics-info-border:      #d4d4d8;

  /* Apply button */
  --sldc-statistics-btn-bg:           #ffffff;
  --sldc-statistics-btn-bg-hover:     #f4f4f5;
  --sldc-statistics-btn-text:         #0a0a0a;

  /* Theme gradient — button, badges, bar fill */
  --sldc-statistics-theme-gradient:   linear-gradient(135deg, #6366f1, #8b5cf6, #a855f7);
  --sldc-statistics-theme-text:       #ffffff;

  /* Success metric */
  --sldc-statistics-success-bg:       #f0fdf4;
  --sldc-statistics-success-text:     #16a34a;
  --sldc-statistics-success-bar:      #22c55e;

  /* Danger metric */
  --sldc-statistics-danger-bg:        #fff7f7;
  --sldc-statistics-danger-text:      #dc2626;
  --sldc-statistics-danger-bar:       #ef4444;

  /* Misc */
  --sldc-statistics-radius-card:      14px;
  --sldc-statistics-radius-element:   8px;
  --sldc-statistics-radius-badge:     20px;
}

