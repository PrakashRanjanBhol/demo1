<input
    type="text"
    className={styles.urlInput}
    placeholder={activeView === 'youtube'
        ? t('sources.youtube_url_placeholder')
        : t('sources.website_url_placeholder')}
    value={urlInput}
    onChange={(e) => handleUrlChange(e.target.value)}
/>


const handleUrlChange = (value: string) => {
    // strip any newlines or spaces (prevent paste of multiple urls)
    const sanitized = value.replace(/[\n\r\s]+/g, '');
    setUrlInput(sanitized);
};



.urlInput {
    width: 100%;
    height: 48px;
    border: 1px solid var(--sources-textarea-border);
    border-radius: 8px;
    padding: 0 12px;
    font-size: 0.9rem;
    color: var(--sources-textarea-text);
    background-color: var(--sources-textarea-bg);
    box-sizing: border-box;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s ease;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;

    &::placeholder {
        color: var(--sources-textarea-placeholder);
    }

    &:focus {
        border-color: var(--sources-textarea-border-focus);
        box-shadow: 0 0 0 3px var(--sources-btn-gradient-shadow);
    }
}
