interface QueueItem {
  id: string;
  name: string;
  status: 'queued' | 'processing' | 'completed' | 'failed';
  progress: number;
}








export class HistoryComponent implements OnInit, OnChanges {
  // ... existing properties ...
  
  // Multiple inference properties
  selectedInferenceItems: Set<string> = new Set();
  isInferenceMode: boolean = false;
  isProcessingInference: boolean = false;
  inferenceQueue: QueueItem[] = [];
  currentInferenceItem: QueueItem | null = null;
  private inferenceProgressSubscription: Subscription | null = null;

  // ... rest of existing code ...










// Toggle inference mode
toggleInferenceMode(): void {
  this.isInferenceMode = !this.isInferenceMode;
  if (!this.isInferenceMode) {
    this.selectedInferenceItems.clear();
  }
}

// Toggle item selection for inference
toggleInferenceSelection(itemId: string, event: Event): void {
  event.stopPropagation();
  
  if (this.selectedInferenceItems.has(itemId)) {
    this.selectedInferenceItems.delete(itemId);
  } else {
    this.selectedInferenceItems.add(itemId);
  }
}

// Check if item is selected for inference
isSelectedForInference(itemId: string): boolean {
  return this.selectedInferenceItems.has(itemId);
}

// Check if item is in queue
isInQueue(itemId: string): boolean {
  return this.inferenceQueue.some(item => item.id === itemId);
}

// Get queue position for an item
getQueuePosition(itemId: string): number {
  const index = this.inferenceQueue.findIndex(item => item.id === itemId);
  return index >= 0 ? index + 1 : 0;
}

// Get item status in queue
getItemQueueStatus(itemId: string): 'queued' | 'processing' | 'completed' | 'failed' | null {
  const queueItem = this.inferenceQueue.find(item => item.id === itemId);
  return queueItem ? queueItem.status : null;
}

// Start multiple inference
startMultipleInference(): void {
  if (this.selectedInferenceItems.size === 0) {
    alert('Please select at least one file for inference');
    return;
  }

  // Create queue from selected items
  this.inferenceQueue = Array.from(this.selectedInferenceItems).map(itemId => {
    const item = this.historyItems.find(i => i.id === itemId);
    return {
      id: itemId,
      name: item?.name || '',
      status: 'queued' as const,
      progress: 0
    };
  });

  this.isProcessingInference = true;
  this.isInferenceMode = false;
  this.selectedInferenceItems.clear();

  // Start processing the queue
  this.processNextInQueue();
}

// Cancel multiple inference
cancelMultipleInference(): void {
  this.selectedInferenceItems.clear();
  this.isInferenceMode = false;
}

// Process next item in queue
private processNextInQueue(): void {
  // Find next queued item
  const nextItem = this.inferenceQueue.find(item => item.status === 'queued');
  
  if (!nextItem) {
    // All items processed
    this.completeMultipleInference();
    return;
  }

  // Set as current item
  this.currentInferenceItem = nextItem;
  nextItem.status = 'processing';

  // Start generation for this item
  this.startInferenceForItem(nextItem);
}

// Start inference for a specific item
private startInferenceForItem(queueItem: QueueItem): void {
  const item = this.historyItems.find(i => i.id === queueItem.id);
  if (!item) {
    queueItem.status = 'failed';
    this.processNextInQueue();
    return;
  }

  // Emit processing status
  this.onProcessingStatusChange.emit({
    isProcessing: true,
    id: Number(queueItem.id)
  });

  const request = {
    fileID: Number(queueItem.id),
    model_name: 'ABC',
    optional_prompt: '',
    summary_prompt: item.summary_prompt || '',
    faq_prompt: item.faq_prompt || ''
  };

  this.uploadGenerateService.generateAnalysis(request).subscribe({
    next: (response: any) => {
      console.log('Generation API response for item:', queueItem.name, response);
      
      if (response.status === 'Success') {
        // Start progress polling for this item
        this.startInferenceProgressPolling(Number(queueItem.id));
      } else {
        // Generation failed to start
        queueItem.status = 'failed';
        this.onProcessingStatusChange.emit({
          isProcessing: false,
          id: null
        });
        this.processNextInQueue();
      }
    },
    error: (error) => {
      console.error('Generation error for item:', queueItem.name, error);
      queueItem.status = 'failed';
      this.onProcessingStatusChange.emit({
        isProcessing: false,
        id: null
      });
      
      // Emit failure to parent
      this.onGenerationComplete.emit({
        id: Number(queueItem.id),
        status: 'Failure',
        summary_prompt: item?.summary_prompt,
        faq_prompt: item?.faq_prompt
      });
      
      this.processNextInQueue();
    }
  });
}

// Start progress polling for inference item
private startInferenceProgressPolling(fileId: number): void {
  // Stop any existing polling
  this.stopInferenceProgressPolling();

  const queueItem = this.inferenceQueue.find(item => item.id === fileId.toString());
  if (!queueItem) return;

  // Create a polling observable that checks every 10 seconds
  this.inferenceProgressSubscription = interval(10000)
    .pipe(
      switchMap(() => this.uploadGenerateService.getGenerationProgress(fileId)),
      takeWhile((response: any) => {
        // Continue polling while progress is between 0 and 99
        return response.status === 'Success' && response.progress >= 0 && response.progress < 100;
      }, true)
    )
    .subscribe({
      next: (response: any) => {
        console.log('Progress update for item:', queueItem.name, response);

        if (response.status === 'Success') {
          const progress = response.progress;

          if (progress === -1) {
            // Generation failed
            queueItem.status = 'failed';
            queueItem.progress = 0;
            
            this.onProcessingStatusChange.emit({
              isProcessing: false,
              id: null
            });
            
            // Emit failure to parent
            const item = this.historyItems.find(i => i.id === queueItem.id);
            this.onGenerationComplete.emit({
              id: fileId,
              status: 'Failure',
              summary_prompt: item?.summary_prompt,
              faq_prompt: item?.faq_prompt
            });
            
            this.stopInferenceProgressPolling();
            this.processNextInQueue();
          } else if (progress === 100) {
            // Generation completed successfully
            queueItem.status = 'completed';
            queueItem.progress = 100;
            
            this.onProcessingStatusChange.emit({
              isProcessing: false,
              id: null
            });
            
            // Emit success to parent
            const item = this.historyItems.find(i => i.id === queueItem.id);
            this.onGenerationComplete.emit({
              id: fileId,
              status: 'Success',
              summary_prompt: item?.summary_prompt,
              faq_prompt: item?.faq_prompt
            });
            
            this.stopInferenceProgressPolling();
            
            // Wait a bit then process next
            setTimeout(() => {
              this.processNextInQueue();
            }, 1000);
          } else if (progress >= 0 && progress < 100) {
            // Update progress
            queueItem.progress = progress;
          }
        } else {
          // Unexpected status
          queueItem.status = 'failed';
          this.stopInferenceProgressPolling();
          this.processNextInQueue();
        }
      },
      error: (error) => {
        console.error('Progress polling error for item:', queueItem.name, error);
        queueItem.status = 'failed';
        this.stopInferenceProgressPolling();
        this.processNextInQueue();
      }
    });
}

// Stop inference progress polling
private stopInferenceProgressPolling(): void {
  if (this.inferenceProgressSubscription) {
    this.inferenceProgressSubscription.unsubscribe();
    this.inferenceProgressSubscription = null;
  }
}

// Complete multiple inference
private completeMultipleInference(): void {
  this.isProcessingInference = false;
  this.currentInferenceItem = null;
  
  // Keep queue for a moment to show results
  setTimeout(() => {
    this.inferenceQueue = [];
  }, 5000);
}

// Add to ngOnDestroy
ngOnDestroy(): void {
  this.stopInferenceProgressPolling();
}











@Output() onProcessingStatusChange = new EventEmitter<{ isProcessing: boolean; id: number | null }>();
@Output() onGenerationComplete = new EventEmitter<{
  id: number;
  status: 'Success' | 'Failure';
  summary_prompt?: string;
  faq_prompt?: string;
}>();








