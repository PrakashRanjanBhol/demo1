// Add these properties with other delete properties
selectAllPending: boolean = false;
selectAllCompleted: boolean = false;

// Add these methods

// Toggle select all pending files
toggleSelectAllPending(): void {
  if (this.selectAllPending) {
    // Deselect all pending
    this.filteredPendingFiles.forEach(item => {
      this.selectedDeleteItems.delete(item.id);
    });
    this.selectAllPending = false;
  } else {
    // Select all pending
    this.filteredPendingFiles.forEach(item => {
      this.selectedDeleteItems.add(item.id);
    });
    this.selectAllPending = true;
  }
}

// Toggle select all completed files
toggleSelectAllCompleted(): void {
  if (this.selectAllCompleted) {
    // Deselect all completed
    this.filteredCompletedFiles.forEach(item => {
      this.selectedDeleteItems.delete(item.id);
    });
    this.selectAllCompleted = false;
  } else {
    // Select all completed
    this.filteredCompletedFiles.forEach(item => {
      this.selectedDeleteItems.add(item.id);
    });
    this.selectAllCompleted = true;
  }
}

// Check if all pending files are selected
areAllPendingSelected(): boolean {
  if (this.filteredPendingFiles.length === 0) return false;
  return this.filteredPendingFiles.every(item => this.selectedDeleteItems.has(item.id));
}

// Check if all completed files are selected
areAllCompletedSelected(): boolean {
  if (this.filteredCompletedFiles.length === 0) return false;
  return this.filteredCompletedFiles.every(item => this.selectedDeleteItems.has(item.id));
}

// Update toggleDeleteMode to reset select all states
toggleDeleteMode(): void {
  this.isDeleteMode = !this.isDeleteMode;
  if (!this.isDeleteMode) {
    this.selectedDeleteItems.clear();
    this.selectAllPending = false;
    this.selectAllCompleted = false;
  }
  // Exit inference mode if active
  if (this.isDeleteMode && this.isInferenceMode) {
    this.isInferenceMode = false;
    this.selectedInferenceItems.clear();
  }
}

// Update toggleDeleteSelection to update select all checkboxes
toggleDeleteSelection(itemId: string, event: Event): void {
  event.stopPropagation();
  
  if (this.selectedDeleteItems.has(itemId)) {
    this.selectedDeleteItems.delete(itemId);
  } else {
    this.selectedDeleteItems.add(itemId);
  }

  // Update select all checkboxes
  this.selectAllPending = this.areAllPendingSelected();
  this.selectAllCompleted = this.areAllCompletedSelected();
}

// Update cancelMultipleDelete to reset select all states
cancelMultipleDelete(): void {
  this.selectedDeleteItems.clear();
  this.isDeleteMode = false;
  this.selectAllPending = false;
  this.selectAllCompleted = false;
}

// Show delete confirmation modal instead of browser confirm
showDeleteConfirmation(): void {
  if (this.selectedDeleteItems.size === 0) {
    alert('Please select at least one file to delete');
    return;
  }
  
  // Show custom modal
  this.isDeleteConfirmationVisible = true;
}

// Add property for modal
isDeleteConfirmationVisible: boolean = false;

// Update confirmMultipleDelete
confirmMultipleDelete(): void {
  this.isDeleteConfirmationVisible = false;
  this.startMultipleDelete();
}

// Close delete confirmation modal
closeDeleteConfirmation(): void {
  this.isDeleteConfirmationVisible = false;
}







