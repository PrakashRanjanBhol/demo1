/* Inference Mode Button */
.inference-mode-btn {
    width: 32px;
    height: 32px;
    background: linear-gradient(135deg, var(--primary-gradient-light-start), var(--primary-gradient-light-end));
    border: 1.5px solid var(--primary-border-color);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    flex-shrink: 0;
}

.inference-mode-btn svg {
    width: 18px;
    height: 18px;
    stroke: var(--primary-color);
    transition: all 0.3s ease;
}

.inference-mode-btn:hover:not(:disabled) {
    background: linear-gradient(135deg, var(--primary-gradient-medium-start), var(--primary-gradient-medium-end));
    border-color: var(--primary-color);
    box-shadow: 0 2px 8px var(--primary-shadow-light);
}

.inference-mode-btn.active {
    background: linear-gradient(135deg, #f59e0b, #f97316);
    border-color: #f59e0b;
}

.inference-mode-btn.active svg {
    stroke: white;
}

.inference-mode-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    background: linear-gradient(135deg, var(--primary-gradient-light-start), var(--primary-gradient-light-end));
    border-color: var(--primary-border-color);
}

.inference-mode-btn:disabled svg {
    stroke: var(--primary-color);
}

.inference-mode-btn:disabled:hover {
    box-shadow: none;
    transform: none;
}

/* Delete Mode Button */
.delete-mode-btn {
    width: 32px;
    height: 32px;
    background: linear-gradient(135deg, var(--primary-gradient-light-start), var(--primary-gradient-light-end));
    border: 1.5px solid var(--primary-border-color);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    flex-shrink: 0;
}

.delete-mode-btn svg {
    width: 18px;
    height: 18px;
    stroke: var(--primary-color);
    transition: all 0.3s ease;
}

.delete-mode-btn:hover:not(:disabled) {
    background: linear-gradient(135deg, var(--primary-gradient-medium-start), var(--primary-gradient-medium-end));
    border-color: var(--primary-color);
    box-shadow: 0 2px 8px var(--primary-shadow-light);
}

.delete-mode-btn.active {
    background: linear-gradient(135deg, #ef4444, #dc2626);
    border-color: #ef4444;
}

.delete-mode-btn.active svg {
    stroke: white;
}

.delete-mode-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    background: linear-gradient(135deg, var(--primary-gradient-light-start), var(--primary-gradient-light-end));
    border-color: var(--primary-border-color);
}

.delete-mode-btn:disabled svg {
    stroke: var(--primary-color);
}

.delete-mode-btn:disabled:hover {
    box-shadow: none;
    transform: none;
}















@media screen and (max-width: 1400px) {
    /* ... other responsive styles ... */

    .inference-mode-btn {
        width: 28px;
        height: 28px;
    }

    .inference-mode-btn svg {
        width: 16px;
        height: 16px;
    }

    .delete-mode-btn {
        width: 28px;
        height: 28px;
    }

    .delete-mode-btn svg {
        width: 16px;
        height: 16px;
    }
}
