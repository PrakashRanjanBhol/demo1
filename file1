  height: 40px;
  width: 100%;
  border-radius: 11px;
  background: linear-gradient(
    90deg,
    var(--gs-s2) 25%,
    var(--gs-border) 50%,
    var(--gs-s2) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.4s ease-in-out infinite;
}









