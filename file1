  </div>

  <!-- ── PR Comments Analysis ── -->
  <div class="sldc-card">
    <div class="sldc-card__header">
      <div class="sldc-card__title-block">
        <span class="sldc-card__label">Code Review</span>
        <h2 class="sldc-card__title">PR Comments Analysis</h2>
      </div>
      <div class="sldc-date-row">
        <div class="sldc-date-group">
          <label class="sldc-date-label">From</label>
          <p-datepicker
            [(ngModel)]="pr.dateRange.start"
            [maxDate]="pr.dateRange.end ?? today"
            dateFormat="dd-mm-yy"
            [showIcon]="true"
            appendTo="body"
            placeholder="Start date"
            styleClass="sldc-datepicker"
          />
        </div>
        <span class="sldc-date-sep">—</span>
        <div class="sldc-date-group">
          <label class="sldc-date-label">To</label>
          <p-datepicker
            [(ngModel)]="pr.dateRange.end"
            [minDate]="pr.dateRange.start ?? undefined"
            [maxDate]="today"
            dateFormat="dd-mm-yy"
            [showIcon]="true"
            appendTo="body"
            placeholder="End date"
            styleClass="sldc-datepicker"
          />
        </div>
        <p-button
          label="Apply"
          [loading]="isLoading(pr.loadState)"
          [disabled]="!pr.dateRange.start || !pr.dateRange.end"
          (onClick)="fetchPr()"
          styleClass="sldc-apply-btn"
          size="small"
        />
      </div>
    </div>

    <div class="sldc-divider"></div>

    <div class="sldc-error" *ngIf="isError(pr.loadState)">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
        <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.2"/>
        <path d="M8 5v4M8 11v.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
      Failed to load PR comments data. Please try again.
    </div>

    <div class="sldc-metrics-grid sldc-metrics-grid--4">
      <div class="sldc-metric">
        <p class="sldc-metric__label">Total PRs</p>
        <p class="sldc-metric__value">{{ pr.data?.total_prs ?? '—' }}</p>
      </div>
      <div class="sldc-metric">
        <p class="sldc-metric__label">Total comments</p>
        <p class="sldc-metric__value">{{ pr.data?.comment_count ?? '—' }}</p>
      </div>
      <div class="sldc-metric">
        <p class="sldc-metric__label">AI comments</p>
        <p class="sldc-metric__value">{{ pr.data?.ai_comments ?? '—' }}</p>
        <span class="sldc-badge sldc-badge--green">AI</span>
      </div>
      <div class="sldc-metric">
        <p class="sldc-metric__label">AI comment ratio</p>
        <p class="sldc-metric__value">{{ formatPct(pr.data?.ratio) }}</p>
        <div class="sldc-bar-track">
          <div class="sldc-bar-fill" [style.width.%]="pr.data?.ratio ?? 0"></div>
        </div>
      </div>
    </div>

    <div class="sldc-info-note" *ngIf="pr.data?.info">
      <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
        <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.1"/>
        <path d="M8 7v5M8 5.5v-.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      {{ pr.data?.info }}
    </div>
  </div>

</div>




































// ─────────────────────────────────────────────────────────────
// SLDC Statistics — CSS Custom Properties
// Light mode (default)
// ─────────────────────────────────────────────────────────────
:root {
  // Layout
  --sldc-statistics-bg-card:            #ffffff;
  --sldc-statistics-bg-metric:          #f5f5f5;
  --sldc-statistics-bg-page:            #fafafa;

  // Borders
  --sldc-statistics-border-card:        #bfbfbf;
  --sldc-statistics-border-divider:     #e5e5e5;
  --sldc-statistics-border-input:       #bfbfbf;

  // Text
  --sldc-statistics-text-primary:       #111113;
  --sldc-statistics-text-secondary:     #555558;
  --sldc-statistics-text-tertiary:      #8f8f93;
  --sldc-statistics-text-label:         #8f8f93;

  // Accent — bar fill
  --sldc-statistics-accent-bar:         #378add;

  // Badges
  --sldc-statistics-badge-blue-bg:      #dbeafe;
  --sldc-statistics-badge-blue-text:    #1e40af;
  --sldc-statistics-badge-green-bg:     #dcfce7;
  --sldc-statistics-badge-green-text:   #166534;

  // Error
  --sldc-statistics-error-bg:           #fef2f2;
  --sldc-statistics-error-border:       #fca5a5;
  --sldc-statistics-error-text:         #b91c1c;

  // PrimeNG datepicker overrides (scoped via styleClass)
  --sldc-statistics-input-bg:           #ffffff;
  --sldc-statistics-input-text:         #111113;

  // Button
  --sldc-statistics-btn-bg:             #ffffff;
  --sldc-statistics-btn-border:         #bfbfbf;
  --sldc-statistics-btn-text:           #111113;
  --sldc-statistics-btn-hover-bg:       #f5f5f5;
}

// ─────────────────────────────────────────────────────────────
// Dark mode
// ─────────────────────────────────────────────────────────────
[data-theme='dark'],
.p-dark,
@media (prefers-color-scheme: dark) {
  :root {
    // Layout
    --sldc-statistics-bg-card:            #111113;
    --sldc-statistics-bg-metric:          #1c1c1f;
    --sldc-statistics-bg-page:            #0a0a0b;

    // Borders
    --sldc-statistics-border-card:        #27272a;
    --sldc-statistics-border-divider:     #27272a;
    --sldc-statistics-border-input:       #27272a;

    // Text
    --sldc-statistics-text-primary:       #f4f4f5;
    --sldc-statistics-text-secondary:     #a1a1aa;
    --sldc-statistics-text-tertiary:      #71717a;
    --sldc-statistics-text-label:         #71717a;

    // Accent
    --sldc-statistics-accent-bar:         #60a5fa;

    // Badges
    --sldc-statistics-badge-blue-bg:      #1e3a5f;
    --sldc-statistics-badge-blue-text:    #93c5fd;
    --sldc-statistics-badge-green-bg:     #14532d;
    --sldc-statistics-badge-green-text:   #86efac;

    // Error
    --sldc-statistics-error-bg:           #2d1515;
    --sldc-statistics-error-border:       #7f1d1d;
    --sldc-statistics-error-text:         #fca5a5;

    // PrimeNG datepicker overrides
    --sldc-statistics-input-bg:           #1c1c1f;
    --sldc-statistics-input-text:         #f4f4f5;

    // Button
    --sldc-statistics-btn-bg:             #111113;
    --sldc-statistics-btn-border:         #27272a;
    --sldc-statistics-btn-text:           #f4f4f5;
    --sldc-statistics-btn-hover-bg:       #1c1c1f;
  }
}

// ─────────────────────────────────────────────────────────────
// Dashboard layout
// ─────────────────────────────────────────────────────────────
.sldc-dashboard {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  padding: 1.5rem 0;
  background: var(--sldc-statistics-bg-page);
}

// ─────────────────────────────────────────────────────────────
// Card
// ─────────────────────────────────────────────────────────────
.sldc-card {
  background: var(--sldc-statistics-bg-card);
  border: 1px solid var(--sldc-statistics-border-card);
  border-radius: 14px;
  padding: 1.25rem 1.5rem;

  &__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  &__label {
    display: block;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sldc-statistics-text-label);
    margin-bottom: 4px;
  }

  &__title {
    font-size: 16px;
    font-weight: 500;
    color: var(--sldc-statistics-text-primary);
    margin: 0;
  }
}

.sldc-divider {
  height: 1px;
  background: var(--sldc-statistics-border-divider);
  margin-bottom: 1.25rem;
}

// ─────────────────────────────────────────────────────────────
// Date row
// ─────────────────────────────────────────────────────────────
.sldc-date-row {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}

.sldc-date-group {
  display: flex;
  align-items: center;
  gap: 6px;
}

.sldc-date-label {
  font-size: 12px;
  color: var(--sldc-statistics-text-secondary);
  white-space: nowrap;
}

.sldc-date-sep {
  font-size: 13px;
  color: var(--sldc-statistics-text-tertiary);
}

// ─────────────────────────────────────────────────────────────
// PrimeNG DatePicker overrides — scoped via styleClass
// ─────────────────────────────────────────────────────────────
:host ::ng-deep .sldc-datepicker {
  .p-datepicker-input {
    font-size: 13px;
    height: 34px;
    padding: 0 10px;
    background: var(--sldc-statistics-input-bg);
    border: 1px solid var(--sldc-statistics-border-input);
    border-radius: 8px;
    color: var(--sldc-statistics-input-text);
    width: 140px;
    transition: border-color 0.15s;

    &::placeholder {
      color: var(--sldc-statistics-text-tertiary);
    }

    &:focus {
      outline: none;
      border-color: var(--sldc-statistics-accent-bar);
      box-shadow: 0 0 0 2px color-mix(in srgb, var(--sldc-statistics-accent-bar) 20%, transparent);
    }
  }

  .p-datepicker-dropdown {
    background: var(--sldc-statistics-input-bg);
    border: 1px solid var(--sldc-statistics-border-input);
    border-left: none;
    border-radius: 0 8px 8px 0;
    color: var(--sldc-statistics-text-secondary);
    height: 34px;
    width: 34px;

    &:hover {
      background: var(--sldc-statistics-bg-metric);
    }
  }

  &.p-inputwrapper-focus .p-datepicker-input,
  &.p-inputwrapper-focus .p-datepicker-dropdown {
    border-color: var(--sldc-statistics-accent-bar);
  }
}

// ─────────────────────────────────────────────────────────────
// Apply Button overrides
// ─────────────────────────────────────────────────────────────
:host ::ng-deep .sldc-apply-btn.p-button {
  background: var(--sldc-statistics-btn-bg);
  border: 1px solid var(--sldc-statistics-btn-border);
  color: var(--sldc-statistics-btn-text);
  font-size: 13px;
  font-weight: 500;
  height: 34px;
  padding: 0 16px;
  border-radius: 8px;
  transition: background 0.15s, transform 0.1s;

  &:not(:disabled):hover {
    background: var(--sldc-statistics-btn-hover-bg);
  }

  &:not(:disabled):active {
    transform: scale(0.97);
  }

  &:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .p-button-label {
    font-weight: 500;
  }
}

// ─────────────────────────────────────────────────────────────
// Error banner
// ─────────────────────────────────────────────────────────────
.sldc-error {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: var(--sldc-statistics-error-text);
  background: var(--sldc-statistics-error-bg);
  border: 1px solid var(--sldc-statistics-error-border);
  border-radius: 8px;
  padding: 8px 12px;
  margin-bottom: 1rem;
}

// ─────────────────────────────────────────────────────────────
// Metric grid
// ─────────────────────────────────────────────────────────────
.sldc-metrics-grid {
  display: grid;
  gap: 10px;

  &--2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  &--4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
}

// ─────────────────────────────────────────────────────────────
// Metric card
// ─────────────────────────────────────────────────────────────
.sldc-metric {
  background: var(--sldc-statistics-bg-metric);
  border-radius: 8px;
  padding: 14px 16px;

  &__label {
    font-size: 12px;
    color: var(--sldc-statistics-text-secondary);
    margin: 0 0 6px;
    line-height: 1.4;
  }

  &__value {
    font-size: 26px;
    font-weight: 500;
    color: var(--sldc-statistics-text-primary);
    line-height: 1;
    margin: 0;
  }
}

// ─────────────────────────────────────────────────────────────
// Badge
// ─────────────────────────────────────────────────────────────
.sldc-badge {
  display: inline-block;
  font-size: 11px;
  font-weight: 500;
  padding: 2px 8px;
  border-radius: 20px;
  margin-top: 8px;

  &--blue {
    background: var(--sldc-statistics-badge-blue-bg);
    color: var(--sldc-statistics-badge-blue-text);
  }

  &--green {
    background: var(--sldc-statistics-badge-green-bg);
    color: var(--sldc-statistics-badge-green-text);
  }
}

// ─────────────────────────────────────────────────────────────
// Progress bar
// ─────────────────────────────────────────────────────────────
.sldc-bar-track {
  height: 5px;
  background: var(--sldc-statistics-border-divider);
  border-radius: 20px;
  overflow: hidden;
  margin-top: 10px;
}

.sldc-bar-fill {
  height: 100%;
  border-radius: 20px;
  background: var(--sldc-statistics-accent-bar);
  transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

// ─────────────────────────────────────────────────────────────
// Info note
// ─────────────────────────────────────────────────────────────
.sldc-info-note {
  display: flex;
  align-items: flex-start;
  gap: 6px;
  font-size: 12px;
  color: var(--sldc-statistics-text-tertiary);
  margin-top: 1rem;
  padding-top: 1rem;
  border-top: 1px solid var(--sldc-statistics-border-divider);
}

// ─────────────────────────────────────────────────────────────
// Responsive
// ─────────────────────────────────────────────────────────────
@media (max-width: 768px) {
  .sldc-metrics-grid--4 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 540px) {
  .sldc-card {
    padding: 1rem;

    &__header {
      flex-direction: column;
    }
  }

  .sldc-date-row {
    flex-direction: column;
    align-items: flex-start;
  }

  .sldc-metrics-grid--2,
  .sldc-metrics-grid--4 {
    grid-template-columns: 1fr;
  }
}





















import { Injectable } from '@angular/core';
import { HttpClient, HttpParams } from '@angular/common/http';
import { Observable } from 'rxjs';
import { environment } from '../../environments/environment';
import {
  ApiResponse,
  QaStatsResult,
  BitbucketResult,
  PrCommentsResult,
} from '../core/models/stats.models';

@Injectable({ providedIn: 'root' })
export class StatsService {
  private readonly base = environment.apiBaseUrl;

  constructor(private http: HttpClient) {}

  private params(start: string, end: string): HttpParams {
    return new HttpParams().set('start_date', start).set('end_date', end);
  }

  getQaStats(
    start: string,
    end: string
  ): Observable<ApiResponse<QaStatsResult>> {
    return this.http.get<ApiResponse<QaStatsResult>>(
      `${this.base}/qa-stats`,
      { params: this.params(start, end) }
    );
  }

  getBitbucketAnalysis(
    start: string,
    end: string
  ): Observable<ApiResponse<BitbucketResult>> {
    return this.http.get<ApiResponse<BitbucketResult>>(
      `${this.base}/bitbucket-analysis`,
      { params: this.params(start, end) }
    );
  }

  getPrCommentsAnalysis(
    start: string,
    end: string
  ): Observable<ApiResponse<PrCommentsResult>> {
    return this.http.get<ApiResponse<PrCommentsResult>>(
      `${this.base}/pr-comments-analysis`,
      { params: this.params(start, end) }
    );
  }
}





export interface ApiResponse<T> {
  status: 'Success' | 'Error';
  result: T;
}

export interface QaStatsResult {
  jira_count: number;
  confluence_count: number;
}

export interface BitbucketResult {
  date_range: { start_date: string; end_date: string };
  pr_reviewed_ratio: number;
  pr_summary_ratio: number;
  info: string;
}

export interface PrCommentsResult {
  total_prs: number;
  comment_count: number;
  ai_comments: number;
  ratio: number;
  info: string;
}

export interface DateRange {
  start: Date | null;
  end: Date | null;
}

export type LoadState = 'idle' | 'loading' | 'error' | 'success';























