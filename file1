/* ═══════════════════════════════════════════════════════════════════════════
   SLDC Statistics — CSS Custom Properties
   Light mode (default)
   ═══════════════════════════════════════════════════════════════════════════ */
:root,
[data-theme="light"] {
  /* Surfaces */
  --sldc-statistics-bg-page:          #f4f4f5;
  --sldc-statistics-bg-card:          #ffffff;
  --sldc-statistics-bg-metric:        #f9f9f9;
  --sldc-statistics-bg-input:         #f4f4f5;

  /* Borders */
  --sldc-statistics-border-card:      #bfbfbf;
  --sldc-statistics-border-input:     #bfbfbf;
  --sldc-statistics-border-divider:   #e5e5e5;
  --sldc-statistics-border-btn:       #bfbfbf;

  /* Text */
  --sldc-statistics-text-primary:     #0a0a0a;
  --sldc-statistics-text-secondary:   #52525b;
  --sldc-statistics-text-tertiary:    #a1a1aa;
  --sldc-statistics-text-label:       #71717a;

  /* Accent — progress bar */
  --sldc-statistics-accent-bar:       #2563eb;

  /* Badge — blue (Jira / Confluence) */
  --sldc-statistics-badge-blue-bg:    #dbeafe;
  --sldc-statistics-badge-blue-text:  #1e40af;

  /* Badge — green (AI) */
  --sldc-statistics-badge-green-bg:   #dcfce7;
  --sldc-statistics-badge-green-text: #166534;

  /* Error */
  --sldc-statistics-error-bg:         #fef2f2;
  --sldc-statistics-error-border:     #fca5a5;
  --sldc-statistics-error-text:       #991b1b;

  /* Info note */
  --sldc-statistics-info-text:        #a1a1aa;
  --sldc-statistics-info-border:      #e5e5e5;

  /* Apply button */
  --sldc-statistics-btn-bg:           #ffffff;
  --sldc-statistics-btn-bg-hover:     #f4f4f5;
  --sldc-statistics-btn-text:         #0a0a0a;

  /* Theme gradient — button, badges, bar fill */
  --sldc-statistics-theme-gradient:   linear-gradient(135deg, #6366f1, #8b5cf6, #a855f7);
  --sldc-statistics-theme-text:       #ffffff;

  /* Misc */
  --sldc-statistics-radius-card:      14px;
  --sldc-statistics-radius-element:   8px;
  --sldc-statistics-radius-badge:     20px;
}

/* ═══════════════════════════════════════════════════════════════════════════
   Dark mode
   ═══════════════════════════════════════════════════════════════════════════ */
[data-theme="dark"],
@media (prefers-color-scheme: dark) {
  :root {
    --sldc-statistics-bg-page:          #0d0d0f;
    --sldc-statistics-bg-card:          #111113;
    --sldc-statistics-bg-metric:        #1c1c1f;
    --sldc-statistics-bg-input:         #1c1c1f;

    --sldc-statistics-border-card:      #27272a;
    --sldc-statistics-border-input:     #27272a;
    --sldc-statistics-border-divider:   #27272a;
    --sldc-statistics-border-btn:       #27272a;

    --sldc-statistics-text-primary:     #fafafa;
    --sldc-statistics-text-secondary:   #a1a1aa;
    --sldc-statistics-text-tertiary:    #52525b;
    --sldc-statistics-text-label:       #71717a;

    --sldc-statistics-accent-bar:       #3b82f6;

    --sldc-statistics-badge-blue-bg:    #1e3a5f;
    --sldc-statistics-badge-blue-text:  #93c5fd;

    --sldc-statistics-badge-green-bg:   #14532d;
    --sldc-statistics-badge-green-text: #86efac;

    --sldc-statistics-error-bg:         #3b0f0f;
    --sldc-statistics-error-border:     #7f1d1d;
    --sldc-statistics-error-text:       #fca5a5;

    --sldc-statistics-info-text:        #52525b;
    --sldc-statistics-info-border:      #27272a;

    --sldc-statistics-btn-bg:           #111113;
    --sldc-statistics-btn-bg-hover:     #1c1c1f;
    --sldc-statistics-btn-text:         #fafafa;
  }
}

/* Override with explicit attribute (takes precedence over media query) */
[data-theme="dark"] {
  --sldc-statistics-bg-page:          #0d0d0f;
  --sldc-statistics-bg-card:          #111113;
  --sldc-statistics-bg-metric:        #1c1c1f;
  --sldc-statistics-bg-input:         #1c1c1f;

  --sldc-statistics-border-card:      #27272a;
  --sldc-statistics-border-input:     #27272a;
  --sldc-statistics-border-divider:   #27272a;
  --sldc-statistics-border-btn:       #27272a;

  --sldc-statistics-text-primary:     #fafafa;
  --sldc-statistics-text-secondary:   #a1a1aa;
  --sldc-statistics-text-tertiary:    #52525b;
  --sldc-statistics-text-label:       #71717a;

  --sldc-statistics-accent-bar:       #3b82f6;

  --sldc-statistics-badge-blue-bg:    #1e3a5f;
  --sldc-statistics-badge-blue-text:  #93c5fd;

  --sldc-statistics-badge-green-bg:   #14532d;
  --sldc-statistics-badge-green-text: #86efac;

  --sldc-statistics-error-bg:         #3b0f0f;
  --sldc-statistics-error-border:     #7f1d1d;
  --sldc-statistics-error-text:       #fca5a5;

  --sldc-statistics-info-text:        #52525b;
