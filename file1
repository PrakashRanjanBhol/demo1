:root {
  --hint-container-bg: #ffffff;
}

[data-theme='dark'] {
  --hint-container-bg: #111113;
}

.hintList {
  list-style: none;
  margin: 0.25rem 0 0;
  padding: 6px;
  display: flex;
  flex-direction: column;
  gap: 3px;
  max-width: 440px;
  width: 100%;
  background-color: var(--hint-container-bg);
  border: 0.5px solid var(--border-color);
  border-radius: 14px;
}

.hintItem {
  display: flex;
  align-items: center;
  gap: 12px;
  background: transparent;
  border: 0.5px solid transparent;
  border-radius: 9px;
  padding: 10px 12px;
  text-align: left;
  position: relative;
  overflow: hidden;

  transition:
    background 0.2s ease,
    border-color 0.2s ease,
    transform 0.25s cubic-bezier(0.34, 1.45, 0.64, 1);

  // Animated left accent bar
  &::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    border-radius: 0 2px 2px 0;
    background: var(--btn-bg);
    opacity: 0;
    transform: scaleY(0.3);
    transition:
      opacity 0.2s ease,
      transform 0.25s cubic-bezier(0.34, 1.45, 0.64, 1);
  }

  &:hover {
    background: color-mix(in srgb, var(--btn-bg) 8%, transparent);
    border-color: color-mix(in srgb, var(--btn-bg) 30%, transparent);
    transform: translateX(4px);

    &::before {
      opacity: 1;
      transform: scaleY(1);
    }

    .hintIcon {
      transform: scale(1.18) rotate(-6deg);
      background: color-mix(in srgb, var(--btn-bg) 18%, transparent);
      color: var(--btn-bg);
    }

    .hintText {
      color: var(--text-primary);
    }

    .hintArrow {
      opacity: 1;
      transform: translateX(0);
    }
  }
}

.hintIcon {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  border-radius: 8px;
  background: var(--app-bg);
  color: var(--text-secondary);

  transition:
    transform 0.25s cubic-bezier(0.34, 1.45, 0.64, 1),
    background 0.2s ease,
    color 0.2s ease;
}

.hintText {
  flex: 1;
  font-size: 0.84rem;
  color: var(--text-secondary);
  line-height: 1.4;
  transition: color 0.2s ease;
}

// Optional: arrow icon that slides in on hover
.hintArrow {
  flex-shrink: 0;
  width: 14px;
  height: 14px;
  color: var(--btn-bg);
  opacity: 0;
  transform: translateX(-4px);
  transition: opacity 0.2s ease, transform 0.2s ease;
}
