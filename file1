        <div class="sldc-bar-track">
          <div class="sldc-bar-fill" [style.width.%]="bitbucket.data?.pr_reviewed_ratio ?? 0"></div>
        </div>
      </div>
      <div class="sldc-metric">
        <p class="sldc-metric__label">PR summary ratio</p>
        <p class="sldc-metric__value">{{ formatPct(bitbucket.data?.pr_summary_ratio) }}</p>
        <div class="sldc-bar-track">
          <div class="sldc-bar-fill" [style.width.%]="bitbucket.data?.pr_summary_ratio ?? 0"></div>
        </div>
