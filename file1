import React, { useState } from "react";
import styles from "./TranslationTool.module.scss";

import translationIcon from "../../assets/icons/translation.png";

interface TranslationToolProps {
  onBack: () => void;
  fileJobId: string;
}

type Language = "ENGLISH" | "KOREAN";

const LANGUAGES: { value: Language; label: string; flag: string }[] = [
  { value: "ENGLISH", label: "English", flag: "🇺🇸" },
  { value: "KOREAN",  label: "Korean",  flag: "🇰🇷" },
];

// ── Icons ─────────────────────────────────────────────

const SparkleIcon = () => (
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
    <path d="M15 4V2" /><path d="M15 16v-2" /><path d="M8 9h2" /><path d="M20 9h2" />
    <path d="M17.8 11.8 19 13" /><path d="M15 9h.01" /><path d="M17.8 6.2 19 5" />
    <path d="m3 21 9-9" /><path d="M12.2 6.2 11 5" />
  </svg>
);

const ChevronIcon = () => (
  <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round">
    <polyline points="6 9 12 15 18 9" />
  </svg>
);

const CheckIcon = () => (
  <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round">
    <polyline points="20 6 9 17 4 12" />
  </svg>
);

const SwapIcon = () => (
  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
    <path d="M7 16V4m0 0L3 8m4-4 4 4" />
    <path d="M17 8v12m0 0 4-4m-4 4-4-4" />
  </svg>
);

// ── Language dropdown ─────────────────────────────────

interface LangDropdownProps {
  label: string;
  value: Language;
  onChange: (v: Language) => void;
}

const LangDropdown: React.FC<LangDropdownProps> = ({ label, value, onChange }) => {
  const [open, setOpen] = useState(false);
  const selected = LANGUAGES.find((l) => l.value === value)!;

  return (
    <div className={styles.dropdownWrap}>
      <span className={styles.dropdownLabel}>{label}</span>
      <button
        className={`${styles.dropdown} ${open ? styles.dropdownOpen : ""}`}
        onClick={() => setOpen((p) => !p)}
      >
        <span className={styles.dropdownSelected}>
          <span className={styles.dropdownFlag}>{selected.flag}</span>
          <span className={styles.dropdownText}>{selected.label}</span>
        </span>
        <span className={`${styles.dropdownChevron} ${open ? styles.dropdownChevronOpen : ""}`}>
          <ChevronIcon />
        </span>
      </button>

      {open && (
        <ul className={styles.dropdownMenu}>
          {LANGUAGES.map((lang) => (
            <li key={lang.value}>
              <button
                className={`${styles.dropdownOption} ${lang.value === value ? styles.dropdownOptionActive : ""}`}
                onClick={() => { onChange(lang.value); setOpen(false); }}
              >
                <span className={styles.dropdownFlag}>{lang.flag}</span>
                <span className={styles.dropdownText}>{lang.label}</span>
                {lang.value === value && (
                  <span className={styles.dropdownCheck}><CheckIcon /></span>
                )}
              </button>
            </li>
          ))}
        </ul>
      )}
    </div>
  );
};

// ── Main component ────────────────────────────────────

export const TranslationTool: React.FC<TranslationToolProps> = ({ onBack, fileJobId }) => {
  const [sourceLang, setSourceLang] = useState<Language>("ENGLISH");
  const [targetLang, setTargetLang] = useState<Language>("KOREAN");
  const [isLoading, setIsLoading]   = useState(false);
  const [error, setError]           = useState<string | null>(null);
  const [success, setSuccess]       = useState(false);

  const handleSwap = () => {
    setSourceLang(targetLang);
    setTargetLang(sourceLang);
  };

  const handleTranslate = async () => {
    setIsLoading(true);
    setError(null);
    setSuccess(false);

    try {
      const res = await fetch("/api/translation/generate", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          file_job_id:     fileJobId,
          tool_type_id:    6,
          target_language: targetLang,
          source_Language: sourceLang,
        }),
      });

      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        throw new Error(data?.message ?? "Failed to generate translation.");
      }

      setSuccess(true);
    } catch (err: any) {
      setError(err?.message ?? "Something went wrong.");
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <div className={styles.wrapper}>

      {/* ── Header ── */}
      <div className={styles.toolHeader}>
        <div className={styles.toolHeaderTop}>
          <div className={styles.breadcrumb}>
            <button className={styles.breadcrumbLink} onClick={onBack}>Tools</button>
            <span className={styles.breadcrumbSep}>›</span>
            <span className={styles.breadcrumbCurrent}>Translation</span>
          </div>
        </div>
        <div className={styles.toolHeaderBottom}>
          <div className={styles.toolIcon}>
            <img src={translationIcon} alt="Translation" width={22} height={22} className={styles.img} />
          </div>
          <div className={styles.toolMeta}>
            <h2 className={styles.toolName}>Translation</h2>
          </div>
        </div>
      </div>

      {/* ── Body ── */}
      <div className={styles.body}>

        <p className={styles.description}>
          Choose source and target languages, then translate the current file.
        </p>

        {/* Language selectors */}
        <div className={styles.langRow}>
          <LangDropdown
            label="Source"
            value={sourceLang}
            onChange={setSourceLang}
          />

          <button className={styles.swapBtn} onClick={handleSwap} title="Swap languages">
            <SwapIcon />
          </button>

          <LangDropdown
            label="Target"
            value={targetLang}
            onChange={setTargetLang}
          />
        </div>

        {/* Error */}
        {error && (
          <div className={styles.errorState}>{error}</div>
        )}

        {/* Success */}
        {success && !error && (
          <div className={styles.successState}>
            Translation generated successfully!
          </div>
        )}

        {/* Translate button */}
        <button
          className={styles.translateBtn}
          onClick={handleTranslate}
          disabled={isLoading}
        >
          {isLoading ? (
            <>
              <span className={styles.spinner} />
              <span>Translating…</span>
            </>
          ) : (
            <>
              <SparkleIcon />
              <span>Translate</span>
            </>
          )}
        </button>

      </div>
    </div>
  );
};

export default TranslationTool;




















// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//  SCSS-only palette
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

