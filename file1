/* Inference Mode Button */
.inference-mode-btn {
    width: 32px;
    height: 32px;
    background: linear-gradient(135deg, var(--primary-gradient-light-start), var(--primary-gradient-light-end));
    border: 1.5px solid var(--primary-border-color);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    flex-shrink: 0;
}

.inference-mode-btn svg {
    width: 18px;
    height: 18px;
    stroke: var(--primary-color);
    transition: all 0.3s ease;
}

.inference-mode-btn:hover {
    background: linear-gradient(135deg, var(--primary-gradient-medium-start), var(--primary-gradient-medium-end));
    border-color: var(--primary-color);
    box-shadow: 0 2px 8px var(--primary-shadow-light);
}

.inference-mode-btn.active {
    background: linear-gradient(135deg, #f59e0b, #f97316);
    border-color: #f59e0b;
}

.inference-mode-btn.active svg {
    stroke: white;
}

/* Inference Action Bar */
.inference-action-bar {
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.1), rgba(249, 115, 22, 0.1));
    border-bottom: 1px solid rgba(245, 158, 11, 0.3);
    padding: 12px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    animation: slideDown 0.3s ease;
}

.inference-action-info {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
}

.inference-action-info .info-icon {
    width: 20px;
    height: 20px;
    stroke: #f59e0b;
    flex-shrink: 0;
}

.inference-action-info span {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-color);
}

.inference-action-buttons {
    display: flex;
    gap: 10px;
    flex-shrink: 0;
}

.cancel-inference-btn,
.start-inference-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
}

.cancel-inference-btn {
    background: transparent;
    color: var(--text-color);
    border: 1.5px solid var(--border-color);
}

.cancel-inference-btn:hover {
    background: rgba(239, 68, 68, 0.1);
    border-color: #ef4444;
    color: #ef4444;
}

.cancel-inference-btn svg {
    width: 16px;
    height: 16px;
}

.start-inference-btn {
    background: linear-gradient(135deg, #f59e0b, #f97316);
    color: white;
    border: 1.5px solid #f59e0b;
}

.start-inference-btn:hover:not(:disabled) {
    box-shadow: 0 4px 12px rgba(245, 158, 11, 0.4);
    transform: translateY(-2px);
}

.start-inference-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.start-inference-btn svg {
    width: 16px;
    height: 16px;
}

/* Inference Checkbox */
.inference-checkbox {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    cursor: pointer;
}

.checkbox-inner {
    width: 20px;
    height: 20px;
    border: 2px solid var(--border-color);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    background: var(--bg-color);
}

.checkbox-inner.checked {
    background: linear-gradient(135deg, #f59e0b, #f97316);
    border-color: #f59e0b;
}

.checkbox-inner svg {
    width: 14px;
    height: 14px;
    stroke: white;
}

/* Inference Selected State */
.history-item.inference-selected {
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.1), rgba(249, 115, 22, 0.1));
    border-color: rgba(245, 158, 11, 0.4);
}

/* In Queue State */
.history-item.in-queue {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.08), rgba(96, 165, 250, 0.08));
    border-color: rgba(59, 130, 246, 0.3);
}

/* Queue Badge */
.queue-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 10px;
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.15), rgba(96, 165, 250, 0.15));
    border: 1px solid rgba(59, 130, 246, 0.4);
    border-radius: 12px;
    font-size: 11px;
    font-weight: 600;
    color: #3b82f6;
    animation: fadeInBadge 0.3s ease;
    flex-shrink: 0;
}

.queue-badge svg {
    width: 14px;
    height: 14px;
}

/* Queue Progress */
.queue-progress {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 6px;
}

.queue-progress-bar {
    flex: 1;
    height: 4px;
    background: rgba(59, 130, 246, 0.2);
    border-radius: 2px;
    overflow: hidden;
}

.queue-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #3b82f6, #60a5fa);
    border-radius: 2px;
    transition: width 0.3s ease;
}

.queue-progress-text {
    font-size: 11px;
    font-weight: 600;
    color: #3b82f6;
    flex-shrink: 0;
}

/* Responsive */
@media screen and (max-width: 1400px) {
    .inference-mode-btn {
        width: 28px;
        height: 28px;
    }

    .inference-mode-btn svg {
        width: 16px;
        height: 16px;
    }

    .inference-action-bar {
        padding: 10px 16px;
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
    }

    .inference-action-buttons {
        width: 100%;
        justify-content: flex-end;
    }

    .cancel-inference-btn,
    .start-inference-btn {
        padding: 7px 12px;
        font-size: 12px;
    }

    .inference-checkbox {
        width: 20px;
        height: 20px;
    }

    .checkbox-inner {
        width: 18px;
        height: 18px;
    }

    .checkbox-inner svg {
        width: 12px;
        height: 12px;
    }

    .queue-badge {
        gap: 4px;
        padding: 2px 8px;
        font-size: 10px;
    }

    .queue-badge svg {
        width: 12px;
        height: 12px;
    }
}




















<div class="panel">
    <div class="panel-header">
        <h3 class="panel-title">History</h3>
        <div class="header-right-group">
            <div class="date-range">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                    stroke="currentColor" class="date-icon">
                    <path stroke-linecap="round" stroke-linejoin="round"
                        d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                </svg>
                <span class="date-text">{{ startDate }}</span>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2"
                    stroke="currentColor" class="arrow-icon">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                    stroke="currentColor" class="date-icon">
                    <path stroke-linecap="round" stroke-linejoin="round"
                        d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                </svg>
                <span class="date-text">{{ endDate }}</span>
            </div>
            <button class="filter-toggle-btn" 
                    (click)="toggleFilter()"
                    [class.active]="isFilterVisible"
                    title="Toggle filters">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round"
                        d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z" />
                </svg>
            </button>
            <!-- Inference Mode Button -->
            <button class="inference-mode-btn" 
                    *ngIf="hasAnyFiles && !isProcessingInference"
                    [class.active]="isInferenceMode"
                    (click)="toggleInferenceMode()"
                    [title]="isInferenceMode ? 'Exit inference mode' : 'Inference mode'">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
                </svg>
            </button>
            <!-- Delete Mode Button -->
            <button class="delete-mode-btn" 
                    *ngIf="hasAnyFiles && !isProcessingDelete"
                    [class.active]="isDeleteMode"
                    (click)="toggleDeleteMode()"
                    [title]="isDeleteMode ? 'Exit delete mode' : 'Delete mode'">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                </svg>
            </button>
        </div>
    </div>

    <!-- Filter Section -->
    <div class="filter-section" *ngIf="isFilterVisible">
        <div class="filter-container">
            <!-- Date Range Filter -->
            <div class="filter-group">
                <label class="filter-label">Date Range</label>
                <div class="date-filter">
                    <div class="date-input-wrapper">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                            stroke="currentColor" class="input-icon">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                        </svg>
                        <input type="date" 
                               class="date-input" 
                               [(ngModel)]="filterFromDate"
                               placeholder="From Date">
                    </div>
                    <span class="date-separator">to</span>
                    <div class="date-input-wrapper">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                            stroke="currentColor" class="input-icon">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                        </svg>
                        <input type="date" 
                               class="date-input" 
                               [(ngModel)]="filterToDate"
                               placeholder="To Date">
                    </div>
                    <button class="refresh-btn" 
                            (click)="applyDateFilter()"
                            [disabled]="isRefreshing"
                            title="Apply date filter">
                        <svg xmlns="http://www.w3.org/2000/svg" 
                             fill="none" 
                             viewBox="0 0 24 24" 
                             stroke-width="2"
                             stroke="currentColor"
                             [class.spinning]="isRefreshing">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Text Search Filter -->
            <div class="filter-group">
                <label class="filter-label">Search</label>
                <div class="search-input-wrapper">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                        stroke="currentColor" class="input-icon">
                        <path stroke-linecap="round" stroke-linejoin="round"
                            d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                    </svg>
                    <input type="text" 
                           class="search-input" 
                           [(ngModel)]="searchText"
                           (ngModelChange)="onSearchChange()"
                           placeholder="Search by file name or ID">
                    <button class="clear-search-btn" 
                            *ngIf="searchText"
                            (click)="clearSearch()"
                            title="Clear search">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2"
                            stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Multiple Inference Action Bar -->
    <div class="inference-action-bar" *ngIf="isInferenceMode && !isProcessingInference">
        <div class="inference-action-info">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="info-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" />
            </svg>
            <span>{{ selectedInferenceItems.size }} file(s) selected for inference</span>
        </div>
        <div class="inference-action-buttons">
            <button class="cancel-inference-btn" (click)="cancelMultipleInference()">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
                Cancel
            </button>
            <button class="start-inference-btn" 
                    (click)="startMultipleInference()"
                    [disabled]="selectedInferenceItems.size === 0">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
                </svg>
                Start Inference ({{ selectedInferenceItems.size }})
            </button>
        </div>
    </div>

    <!-- Multiple Delete Action Bar -->
    <div class="delete-action-bar" *ngIf="isDeleteMode && !isProcessingDelete">
        <div class="delete-action-info">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="info-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
            <span>{{ selectedDeleteItems.size }} file(s) selected for deletion</span>
        </div>
        <div class="delete-action-buttons">
            <button class="cancel-delete-btn" (click)="cancelMultipleDelete()">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
                Cancel
            </button>
            <button class="confirm-delete-btn" 
                    (click)="confirmMultipleDelete()"
                    [disabled]="selectedDeleteItems.size === 0">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                </svg>
                Delete ({{ selectedDeleteItems.size }})
            </button>
        </div>
    </div>

    <div class="panel-content">
        <!-- Empty State - No Files Available -->
        <div class="empty-state" *ngIf="!isLoading && !isRefreshing && !hasAnyFiles">
            <div class="empty-state-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
                </svg>
            </div>
            <h3 class="empty-state-title">No History Available</h3>
            <p class="empty-state-description">Get started by uploading your first file and generating content</p>
            
            <!-- Separator with Cross Icon -->
            <div class="section-separator">
                <div class="separator-line"></div>
                <div class="separator-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                    </svg>
                </div>
            </div>
            
            <div class="user-guide">
                <h4 class="user-guide-title">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="guide-title-icon">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    How History Works
                </h4>
                <div class="guide-steps">
                    <div class="guide-step">
                        <div class="step-number">1</div>
                        <div class="step-content">
                            <h5 class="step-title">Upload File</h5>
                            <p class="step-description">First, upload your .VTT or .SRT file in the <strong>Upload & Generate Section</strong></p>
                        </div>
                    </div>
                    
                    <div class="guide-step">
                        <div class="step-number">2</div>
                        <div class="step-content">
                            <h5 class="step-title">File Appears in History</h5>
                            <p class="step-description">On successful upload, your files will appear in the <strong>History Section</strong></p>
                        </div>
                    </div>
                    
                    <div class="guide-step">
                        <div class="step-number">3</div>
                        <div class="step-content">
