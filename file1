  font-size: 0.8125rem;
  color: #16a34a;
  font-weight: 500;

  svg {
    width: 15px;
    height: 15px;
  }
}

.saveErrMsg {
  font-size: 0.8125rem;
  color: #dc2626;
}

.spinner {
  display: inline-block;
  width: 15px;
  height: 15px;
  border: 2px solid rgba(255, 255, 255, 0.4);
  border-top-color: var(--btn-text);
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.skeletonCard {
  background: var(--content-bg);
  border: 1px solid var(--border-color);
  border-radius: 14px;
  padding: 32px;
  box-shadow: 0 1px 2px var(--box-shadow);
  max-width: 540px;
  display: flex;
  flex-direction: column;
  gap: 28px;
}

.skeletonField {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.skeletonLabel {
  height: 13px;
  width: 140px;
  border-radius: 4px;
  background: linear-gradient(90deg, var(--table-row-odd) 25%, var(--border-color) 50%, var(--table-row-odd) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s ease-in-out infinite;
}

.skeletonInput {
  height: 42px;
  border-radius: 9px;
  background: linear-gradient(90deg, var(--table-row-odd) 25%, var(--border-color) 50%, var(--table-row-odd) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s ease-in-out infinite;
}

.skeletonBtn {
  height: 40px;
  width: 130px;
  border-radius: 9px;
  background: linear-gradient(90deg, var(--table-row-odd) 25%, var(--border-color) 50%, var(--table-row-odd) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s ease-in-out infinite;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
