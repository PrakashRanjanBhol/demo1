const HEADER_MESSAGES = [
    { line1: t('sources.header_upload_line1'), line2: t('sources.header_upload_line2') },
    { line1: t('sources.header_youtube_line1'), line2: t('sources.header_youtube_line2') },
    { line1: t('sources.header_website_line1'), line2: t('sources.header_website_line2') },
];

const [headerIndex, setHeaderIndex] = useState(0);
const [headerFading, setHeaderFading] = useState(false);

useEffect(() => {
    const interval = setInterval(() => {
        setHeaderFading(true);
        setTimeout(() => {
            setHeaderIndex((prev) => (prev + 1) % HEADER_MESSAGES.length);
            setHeaderFading(false);
        }, 400);
    }, 3000);
    return () => clearInterval(interval);
}, []);



<div className={styles.modalHeader}>
    <div className={`${styles.headerText} ${headerFading ? styles.headerFading : ''}`}>
        <span className={styles.headerLine1}>
            {HEADER_MESSAGES[headerIndex].line1}
        </span>
        <span className={styles.headerLine2}>
            {HEADER_MESSAGES[headerIndex].line2}
        </span>
    </div>
    <button className={styles.closeModalBtn} onClick={() => setIsModalOpen(false)}>
        <IconX size={18} />
    </button>
</div>










