import { useEffect, useState } from 'react';
import { useTranslation } from 'react-i18next';
import { useDispatch, useSelector } from 'react-redux';
import type { AppDispatch, RootState } from '../store';
import {
  clearSaveStatus,
  fetchAdminSettings,
  saveAdminSettings,
} from '../store/slices/generalSettingsSlice';
import styles from './GeneralSettings.module.scss';
import pageStyles from './PageShell.module.scss';

interface FormValues {
  file_size_limit: string;
  no_of_file_upload: string;
}

interface FormErrors {
  file_size_limit?: string;
  no_of_file_upload?: string;
}

export default function GeneralSettings() {
  const { t } = useTranslation();
  const dispatch = useDispatch<AppDispatch>();
  const { settings, loading, saving, error, saveSuccess, saveError } = useSelector(
    (state: RootState) => state.generalSettings
  );

  const [form, setForm] = useState<FormValues>({
    file_size_limit: '',
    no_of_file_upload: '',
  });
  const [errors, setErrors] = useState<FormErrors>({});

  useEffect(() => {
    dispatch(fetchAdminSettings());
  }, [dispatch]);

  // sync form when settings load
  useEffect(() => {
    if (settings) {
      setForm({
        file_size_limit: String(settings.file_size_limit),
        no_of_file_upload: String(settings.no_of_file_upload),
      });
    }
  }, [settings]);

  // auto-clear save status after 3s
  useEffect(() => {
    if (saveSuccess || saveError) {
      const timer = setTimeout(() => dispatch(clearSaveStatus()), 3000);
      return () => clearTimeout(timer);
    }
  }, [saveSuccess, saveError, dispatch]);

  const validate = (): boolean => {
    const newErrors: FormErrors = {};
    const fileSize = Number(form.file_size_limit);
    const fileCount = Number(form.no_of_file_upload);

    if (!form.file_size_limit || isNaN(fileSize) || fileSize < 1 || fileSize > 20) {
      newErrors.file_size_limit = 'Value must be between 1 and 20 MB.';
    }
    if (!form.no_of_file_upload || isNaN(fileCount) || fileCount < 1 || fileCount > 20) {
      newErrors.no_of_file_upload = 'Value must be between 1 and 20.';
    }

    setErrors(newErrors);
    return Object.keys(newErrors).length === 0;
  };

  const handleChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    const { name, value } = e.target;
    setForm((prev) => ({ ...prev, [name]: value }));
    setErrors((prev) => ({ ...prev, [name]: undefined }));
    dispatch(clearSaveStatus());
  };

  const handleSave = () => {
    if (!validate()) return;
    dispatch(
      saveAdminSettings({
        file_size_limit: Number(form.file_size_limit),
        no_of_file_upload: Number(form.no_of_file_upload),
      })
    );
  };

  if (loading) {
    return (
      <div className={pageStyles.page}>
        <div className={pageStyles.pageHeader}>
          <h1 className={pageStyles.title}>{t('settings.generalSettings.title')}</h1>
          <p className={pageStyles.description}>{t('settings.generalSettings.description')}</p>
        </div>
        <div className={pageStyles.pageContent}>
          <div className={styles.skeletonCard}>
            {[1, 2].map((i) => (
              <div key={i} className={styles.skeletonField}>
                <div className={styles.skeletonLabel} />
                <div className={styles.skeletonInput} />
              </div>
            ))}
            <div className={styles.skeletonBtn} />
          </div>
        </div>
      </div>
    );
  }

  if (error) {
    return (
      <div className={pageStyles.page}>
        <div className={pageStyles.pageHeader}>
          <h1 className={pageStyles.title}>{t('settings.generalSettings.title')}</h1>
          <p className={pageStyles.description}>{t('settings.generalSettings.description')}</p>
        </div>
        <div className={pageStyles.pageContent}>
          <div className={styles.formCard}>
            <p className={styles.saveErrMsg}>{t('settings.generalSettings.status.error')}</p>
            <button className={styles.saveBtn} onClick={() => dispatch(fetchAdminSettings())}>
              {t('settings.generalSettings.status.retry')}
            </button>
          </div>
        </div>
      </div>
    );
  }

  return (
    <div className={pageStyles.page}>
      <div className={pageStyles.pageHeader}>
        <h1 className={pageStyles.title}>{t('settings.generalSettings.title')}</h1>
        <p className={pageStyles.description}>{t('settings.generalSettings.description')}</p>
      </div>
      <div className={pageStyles.pageContent}>
        <div className={styles.formCard}>

          {/* File Size Limit */}
          <div className={styles.fieldGroup}>
            <div className={styles.labelRow}>
              <label className={styles.label}>
                {t('settings.generalSettings.fileSizeLimit.label')}
              </label>
              <span className={styles.hint}>
                {t('settings.generalSettings.fileSizeLimit.hint')}
              </span>
            </div>
            <div className={`${styles.inputWrapper} ${errors.file_size_limit ? styles.error : ''}`}>
              <input
                className={styles.input}
                type="number"
                name="file_size_limit"
                min={1}
                max={20}
                value={form.file_size_limit}
                onChange={handleChange}
                placeholder={t('settings.generalSettings.fileSizeLimit.placeholder')}
              />
              <span className={styles.unit}>
                {t('settings.generalSettings.fileSizeLimit.unit')}
              </span>
            </div>
            {errors.file_size_limit && (
              <span className={styles.errorText}>{errors.file_size_limit}</span>
            )}
          </div>

          {/* Number of File Uploads */}
          <div className={styles.fieldGroup}>
            <div className={styles.labelRow}>
              <label className={styles.label}>
                {t('settings.generalSettings.noOfFileUpload.label')}
              </label>
              <span className={styles.hint}>
                {t('settings.generalSettings.noOfFileUpload.hint')}
              </span>
            </div>
            <div className={`${styles.inputWrapper} ${errors.no_of_file_upload ? styles.error : ''}`}>
              <input
                className={styles.input}
                type="number"
                name="no_of_file_upload"
                min={1}
                max={20}
                value={form.no_of_file_upload}
                onChange={handleChange}
                placeholder={t('settings.generalSettings.noOfFileUpload.placeholder')}
              />
            </div>
            {errors.no_of_file_upload && (
              <span className={styles.errorText}>{errors.no_of_file_upload}</span>
            )}
          </div>

          <div className={styles.divider} />

          {/* Footer */}
          <div className={styles.footer}>
            <button
              className={styles.saveBtn}
              onClick={handleSave}
              disabled={saving}
            >
              {saving ? (
                <>
                  <span className={styles.spinner} />
                  {t('settings.generalSettings.saving')}
                </>
              ) : (
                <>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
                    <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" />
                    <polyline points="17 21 17 13 7 13 7 21" />
                    <polyline points="7 3 7 8 15 8" />
                  </svg>
                  {t('settings.generalSettings.saveButton')}
                </>
              )}
            </button>

            {saveSuccess && (
              <span className={styles.successMsg}>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                {t('settings.generalSettings.status.saveSuccess')}
              </span>
            )}

            {saveError && (
              <span className={styles.saveErrMsg}>
                {t('settings.generalSettings.status.saveError')}
              </span>
            )}
          </div>

        </div>
      </div>
    </div>
  );
}












