  // Start multiple delete
  private startMultipleDelete(): void {
    this.isProcessingDelete = true;
    this.isDeleteMode = false;
    
    const fileIdsToDelete = Array.from(this.selectedDeleteItems).map(id => Number(id));
    this.selectedDeleteItems.clear();

    // Call delete API
    this.historyService.deleteFiles(fileIdsToDelete).subscribe({
      next: (response) => {
        console.log('Delete response:', response);
        
        if (response.status === 'success') {
          // Remove deleted items from historyItems
          this.historyItems = this.historyItems.filter(item => 
            !fileIdsToDelete.includes(Number(item.id))
          );
          
          // Clear selection if deleted item was selected
          if (this.selectedHistoryItem && fileIdsToDelete.includes(Number(this.selectedHistoryItem.id))) {
            this.selectedHistoryItem = null;
          }
          
          // Clear added to generation if deleted
          if (this.addedToGenerationId && fileIdsToDelete.includes(Number(this.addedToGenerationId))) {
            this.addedToGenerationId = null;
          }
          
          alert(`Successfully deleted ${fileIdsToDelete.length} file(s)`);
        } else {
          alert('Failed to delete files. Please try again.');
        }
        
        this.isProcessingDelete = false;
      },
      error: (error) => {
        console.error('Delete error:', error);
        alert('An error occurred while deleting files. Please try again.');
        this.isProcessingDelete = false;
      }
    });
  }

