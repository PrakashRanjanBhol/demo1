  onToggle: (pageId: string) => void;
}

const PageNode: React.FC<PageNodeProps> = ({ page, depth, checkedSet, atLimit, onToggle }) => {
  const [expanded, setExpanded] = useState(false);
  const hasChildren = page.children && page.children.length > 0;
  const isChecked = checkedSet.has(page.page_id);
  // Disable unchecked pages once limit is hit
  const isDisabled = atLimit && !isChecked;

  const formattedDate = (() => {
    try {
      return new Date(page.last_modified).toLocaleDateString(undefined, {
        month: "short", day: "numeric", year: "numeric",
      });
    } catch {
      return "";
    }
  })();

  return (
    <li className={styles.pageNode} style={{ "--depth": depth } as React.CSSProperties}>
      <div className={`${styles.pageRow} ${isDisabled ? styles.pageRowDisabled : ""}`}>
        {/* Expand toggle */}
        <button
          className={`${styles.expandBtn} ${!hasChildren ? styles.expandBtnHidden : ""} ${expanded ? styles.expandBtnOpen : ""}`}
          onClick={() => hasChildren && setExpanded((p) => !p)}
          tabIndex={hasChildren ? 0 : -1}
        >
          <ChevronIcon />
        </button>

        {/* Checkbox — disabled when at limit and not already checked */}
        <input
          type="checkbox"
          className={styles.pageCheckbox}
          checked={isChecked}
          onChange={() => onToggle(page.page_id)}
          disabled={isDisabled}
        />

        {/* Page icon */}
        <span className={styles.pageIcon}><PageIcon /></span>

        {/* Page info */}
        <div className={styles.pageInfo}>
          <a
            href={page.url}
            target="_blank"
            rel="noopener noreferrer"
            className={styles.pageTitle}
            onClick={(e) => e.stopPropagation()}
          >
            {page.title}
          </a>
          {formattedDate && (
            <span className={styles.pageDate}>{formattedDate}</span>
          )}
        </div>
      </div>

      {/* Children — pass atLimit down through the tree */}
      {expanded && hasChildren && (
        <ul className={styles.childList}>
          {page.children.map((child) => (
            <PageNode
              key={child.page_id}
              page={child}
              depth={depth + 1}
              checkedSet={checkedSet}
              atLimit={atLimit}
              onToggle={onToggle}
            />
          ))}
        </ul>
      )}
    </li>
  );
};

// ── Space detail panel ────────────────────────────────

interface SpaceDetailPanelProps {
  space: ConfluenceSpace;
  onBack: () => void;
}

const SpaceDetailPanel: React.FC<SpaceDetailPanelProps> = ({ space, onBack }) => {
  const dispatch = useDispatch<AppDispatch>();
  const { spaceData, loadingSpaceId, checkedPages, error } = useSelector(
    (state: RootState) => state.confluence
  );

  const data = spaceData[space.id];
  const isLoading = loadingSpaceId === space.id;
  const checkedSet = new Set(checkedPages);
  const atLimit = checkedPages.length >= MAX_SELECTION;

  useEffect(() => {
    if (!data) {
      dispatch(fetchSpaceData(space));
    }
    return () => {
      dispatch(clearCheckedPages());
    };
  }, [space.id]);

  const handleToggle = (pageId: string) => {
    dispatch(togglePage(pageId));
  };

  return (
    <div className={styles.spaceDetailPanel}>
      {/* Panel header */}
      <div className={styles.spaceDetailHeader}>
        <div className={styles.spaceDetailTitle}>
          <SpaceAvatar spaceKey={space.key} id={space.id} size="md" />
          <span className={styles.spaceDetailName}>{space.key}</span>
        </div>
        <div className={styles.spaceDetailActions}>
          {/* Selection counter badge */}
          <span
            className={`${styles.selectionBadge} ${atLimit ? styles.selectionBadgeAtLimit : ""}`}
            title={atLimit ? `Maximum ${MAX_SELECTION} pages selected` : `${checkedPages.length} of ${MAX_SELECTION} selected`}
          >
            {checkedPages.length}/{MAX_SELECTION}
          </span>
          <button className={styles.spaceDetailBack} onClick={onBack}>
            <BackIcon />
            <span>Spaces</span>
          </button>
        </div>
      </div>

      {/* Loading */}
      {isLoading && (
        <div className={styles.loadingState}>
          <span className={styles.spinner} />
          <span>Loading pages…</span>
        </div>
      )}

      {/* Error */}
      {!isLoading && error && (
        <div className={styles.errorState}>{error}</div>
      )}

      {/* Page tree */}
      {!isLoading && !error && data && (
        <div className={styles.pageTreeWrapper}>
          {data.length === 0 ? (
            <div className={styles.emptyState}>
              <div className={styles.emptyIcon}><EmptyFolderIcon /></div>
              <p>No pages found</p>
              <span>This space has no pages yet.</span>
            </div>
          ) : (
            <ul className={styles.pageTree}>
              {data.map((page) => (
                <PageNode
                  key={page.page_id}
                  page={page}
                  depth={0}
                  checkedSet={checkedSet}
                  atLimit={atLimit}
                  onToggle={handleToggle}
                />
              ))}
            </ul>
          )}
        </div>
      )}
    </div>
  );
};

// ── Main component ────────────────────────────────────

export const ConfluenceTool: React.FC<ConfluenceToolProps> = ({ onBack }) => {
  const dispatch = useDispatch<AppDispatch>();

  const { isLoading: isDisconnecting } = useSelector(
    (state: RootState) => state.atlassian
  );
  const {
    allSpaces,
    favoriteSpaces,
    isLoadingSpaces,
    isFavoriteUpdating,
    loadingSpaceId,
    selectedSpaceId,
    activeTab,
    searchQuery,
    spacesError,
  } = useSelector((state: RootState) => state.confluence);

  const selectedSpace = selectedSpaceId
    ? (allSpaces[selectedSpaceId] ?? favoriteSpaces[selectedSpaceId] ?? null)
    : null;

  useEffect(() => {
    dispatch(fetchConfluenceSpaces());
  }, [dispatch]);

  const handleDisconnect = () => dispatch(disconnectAtlassian());
  const isFavorite = (id: string) => !!favoriteSpaces[id];

  const handleToggleFavorite = (space: ConfluenceSpace) => {
    if (isFavoriteUpdating[space.id]) return;
    if (isFavorite(space.id)) {
      dispatch(removeFavoriteSpace(space));
    } else {
      dispatch(addFavoriteSpace(space));
    }
  };

  const handleTabChange = (tab: Tab) => dispatch(setConfluenceTab(tab));

  const handleSpaceClick = (space: ConfluenceSpace) => {
    if (loadingSpaceId !== null) return;
    dispatch(setSelectedSpace(space.id));
    dispatch(fetchSpaceData(space));
  };

  const allSpacesList = Object.values(allSpaces);
  const favoriteSpacesList = Object.values(favoriteSpaces);

  const query = searchQuery.toLowerCase().trim();
  const filteredAll = query
    ? allSpacesList.filter(
        (s) => s.key.toLowerCase().includes(query) || s.id.includes(query)
      )
    : allSpacesList;

  const filteredFavorites = query
    ? favoriteSpacesList.filter(
        (s) => s.key.toLowerCase().includes(query) || s.id.includes(query)
      )
    : favoriteSpacesList;

  // ── Shared tool header ────────────────────────────
  const ToolHeader = () => (
    <div className={styles.toolHeader}>
      <div className={styles.toolHeaderTop}>
        <div className={styles.breadcrumb}>
          <button className={styles.breadcrumbLink} onClick={onBack}>Tools</button>
          <span className={styles.breadcrumbSep}>›</span>
          <span className={styles.breadcrumbCurrent}>Confluence</span>
        </div>
        <button
          className={styles.logoutBtn}
          onClick={handleDisconnect}
          disabled={isDisconnecting}
          title="Disconnect Confluence"
        >
          <LogoutIcon />
        </button>
      </div>
      <div className={styles.toolHeaderBottom}>
        <div className={styles.toolIcon}>
          <img src={confluenceIcon} alt="Confluence" width={22} height={22} className={styles.img} />
        </div>
        <div className={styles.toolMeta}>
          <h2 className={styles.toolName}>Confluence</h2>
        </div>
        <span className={styles.connectedBadge}>● Connected</span>
      </div>
    </div>
  );

  // ── Space detail view ─────────────────────────────
  if (selectedSpace) {
    return (
      <div className={styles.wrapper}>
        <ToolHeader />
        <SpaceDetailPanel
          space={selectedSpace}
          onBack={() => dispatch(setSelectedSpace(null))}
        />
      </div>
    );
  }

  // ── Space list view ───────────────────────────────
  return (
    <div className={styles.wrapper}>
      <ToolHeader />

      {/* Tabs */}
      <div className={styles.tabs}>
        <button
          className={`${styles.tab} ${activeTab === "favorites" ? styles.activeTab : ""}`}
          onClick={() => handleTabChange("favorites")}
        >
          Favorite Spaces
          {favoriteSpacesList.length > 0 && (
            <span className={styles.tabCount}>{favoriteSpacesList.length}</span>
          )}
        </button>
        <button
          className={`${styles.tab} ${activeTab === "all" ? styles.activeTab : ""}`}
          onClick={() => handleTabChange("all")}
        >
          All Spaces
          {allSpacesList.length > 0 && (
            <span className={styles.tabCount}>{allSpacesList.length}</span>
          )}
        </button>
      </div>

      {/* Search */}
      {!isLoadingSpaces && !spacesError && (
        <div className={styles.searchBar}>
          <span className={styles.searchIcon}><SearchIcon /></span>
          <input
            type="text"
            className={styles.searchInput}
            placeholder="Search spaces…"
            value={searchQuery}
            onChange={(e) => dispatch(setConfluenceSearch(e.target.value))}
          />
          {searchQuery && (
            <button className={styles.clearBtn} onClick={() => dispatch(setConfluenceSearch(""))} title="Clear">
              <ClearIcon />
            </button>
          )}
        </div>
      )}

      {/* Content */}
      <div className={styles.content}>

        {isLoadingSpaces && (
          <div className={styles.loadingState}>
            <span className={styles.spinner} />
            <span>Loading spaces…</span>
          </div>
        )}

        {!isLoadingSpaces && spacesError && (
          <div className={styles.errorState}>{spacesError}</div>
        )}

        {/* Favorite Spaces tab */}
        {!isLoadingSpaces && !spacesError && activeTab === "favorites" && (
          filteredFavorites.length === 0 ? (
            <div className={styles.emptyState}>
              <div className={styles.emptyIcon}><StarOutlineIcon /></div>
              <p>{query ? "No matches found" : "No favorite spaces yet"}</p>
              <span>
                {query
                  ? `No favorite spaces match "${searchQuery}".`
                  : "Star a space in All Spaces to pin it here."}
              </span>
            </div>
          ) : (
            <ul className={styles.spaceList}>
              {filteredFavorites.map((space) => {
                const isThisLoading = loadingSpaceId === space.id;
                const anyLoading = loadingSpaceId !== null;
                return (
                  <li key={space.id}>
                    <button
                      className={`${styles.spaceItem} ${styles.spaceItemClickable} ${anyLoading && !isThisLoading ? styles.spaceItemDisabled : ""}`}
                      onClick={() => handleSpaceClick(space)}
                      disabled={anyLoading && !isThisLoading}
                    >
                      {isThisLoading ? (
                        <span className={styles.inlineSpinner} />
                      ) : (
                        <SpaceAvatar spaceKey={space.key} id={space.id} />
                      )}
                      <div className={styles.spaceInfo}>
                        <span className={styles.spaceKey}>{space.key}</span>
                        <span className={styles.spaceId}>#{space.id}</span>
                      </div>
                      <span className={styles.spaceChevron}>›</span>
                    </button>
                  </li>
                );
              })}
            </ul>
          )
        )}

        {/* All Spaces tab */}
        {!isLoadingSpaces && !spacesError && activeTab === "all" && (
          filteredAll.length === 0 ? (
            <div className={styles.emptyState}>
              <div className={styles.emptyIcon}><EmptyFolderIcon /></div>
              <p>{query ? "No matches found" : "No spaces found"}</p>
              <span>
                {query
                  ? `No spaces match "${searchQuery}".`
                  : "Your Confluence spaces will appear here."}
              </span>
            </div>
          ) : (
            <ul className={styles.spaceList}>
              {filteredAll.map((space) => {
                const favorited = isFavorite(space.id);
                const updating = !!isFavoriteUpdating[space.id];
                return (
                  <li key={space.id} className={styles.spaceItem}>
                    <SpaceAvatar spaceKey={space.key} id={space.id} />
                    <div className={styles.spaceInfo}>
                      <span className={styles.spaceKey}>{space.key}</span>
                      <span className={styles.spaceId}>#{space.id}</span>
                    </div>
                    <button
                      className={`${styles.favoriteBtn} ${favorited ? styles.favorited : ""}`}
                      onClick={() => handleToggleFavorite(space)}
                      disabled={updating}
                      title={favorited ? "Remove from favorites" : "Add to favorites"}
                    >
                      {updating ? (
                        <span className={styles.miniSpinner} />
                      ) : favorited ? (
                        <StarFilledIcon />
                      ) : (
                        <StarOutlineIcon />
                      )}
                    </button>
                  </li>
                );
              })}
            </ul>
          )
        )}

      </div>
    </div>
  );
};

export default ConfluenceTool;
