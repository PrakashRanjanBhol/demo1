<div class="history-item" 
     *ngFor="let item of filteredPendingFiles"
     [attr.data-item-id]="item.id"
     [class.selected]="selectedHistoryItem?.id === item.id"
     [class.processing]="isProcessing(item.id)"
     [class.in-queue]="isInQueue(item.id)"
     [class.inference-selected]="isInferenceMode && isSelectedForInference(item.id)"
     (click)="isInferenceMode ? toggleInferenceSelection(item.id, $event) : onHistoryItemClick(item.id)">
    
    <!-- Inference Checkbox -->
    <div class="inference-checkbox" *ngIf="isInferenceMode" (click)="toggleInferenceSelection(item.id, $event)">
        <div class="checkbox-inner" [class.checked]="isSelectedForInference(item.id)">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" *ngIf="isSelectedForInference(item.id)">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
        </div>
    </div>
    
    <div class="history-item-icon">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
            stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round"
                d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" />
        </svg>
    </div>
    <div class="history-item-details">
        <h4 class="history-item-name">
            <span class="file-id">#{{ item.id }}</span>
            <span class="file-name">{{ item.name }}</span>
            <!-- Processing Badge -->
            <span class="processing-badge" *ngIf="isProcessing(item.id)">
                <svg class="processing-spinner" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                Processing
            </span>
            <!-- Queue Badge -->
            <span class="queue-badge" *ngIf="isInQueue(item.id) && !isProcessing(item.id)">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 010 3.75H5.625a1.875 1.875 0 010-3.75z" />
                </svg>
                Queue #{{ getQueuePosition(item.id) }}
            </span>
        </h4>
        <p class="history-item-date">{{ item.displayDate }}</p>
        <!-- Queue Progress -->
        <div class="queue-progress" *ngIf="getItemQueueStatus(item.id) === 'processing'">
            <div class="queue-progress-bar">
                <div class="queue-progress-fill" [style.width.%]="inferenceQueue.find(qi => qi.id === item.id)?.progress || 0"></div>
            </div>
            <span class="queue-progress-text">{{ inferenceQueue.find(qi => qi.id === item.id)?.progress || 0 }}%</span>
        </div>
    </div>
    <div class="history-item-actions" *ngIf="!isInferenceMode">
        <button class="add-to-generation-btn" 
                [class.added]="isAddedToGeneration(item.id)"
                [class.disabled-by-processing]="isButtonsDisabled()"
                (click)="onAddToGeneration($event, item)"
                [title]="isFileUploading ? 'Please wait, a file is being uploaded' : (isAnyProcessing() ? 'Please wait, a file is being processed' : (isAddedToGeneration(item.id) ? 'Remove from content generation' : 'Add to content generation'))">
            <div class="btn-icon-wrapper">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2"
                    stroke="currentColor" class="plus-icon" *ngIf="!isAddedToGeneration(item.id)">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2"
                    stroke="currentColor" class="minus-icon" *ngIf="isAddedToGeneration(item.id)">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12h-15" />
                </svg>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                    stroke="currentColor" class="arrow-left-icon" *ngIf="!isAddedToGeneration(item.id)">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
                </svg>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                    stroke="currentColor" class="arrow-right-icon" *ngIf="isAddedToGeneration(item.id)">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
            </div>
        </button>
    </div>
</div>














/* Inference Mode Button */
.inference-mode-btn {
    width: 32px;
    height: 32px;
    background: linear-gradient(135deg, var(--primary-gradient-light-start), var(--primary-gradient-light-end));
    border: 1.5px solid var(--primary-border-color);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    flex-shrink: 0;
}

.inference-mode-btn svg {
    width: 18px;
    height: 18px;
    stroke: var(--primary-color);
    transition: all 0.3s ease;
}

.inference-mode-btn:hover {
    background: linear-gradient(135deg, var(--primary-gradient-medium-start), var(--primary-gradient-medium-end));
    border-color: var(--primary-color);
    box-shadow: 0 2px 8px var(--primary-shadow-light);
}

.inference-mode-btn.active {
    background: linear-gradient(135deg, #f59e0b, #f97316);
    border-color: #f59e0b;
}

.inference-mode-btn.active svg {
    stroke: white;
}

/* Inference Action Bar */
.inference-action-bar {
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.1), rgba(249, 115, 22, 0.1));
    border-bottom: 1px solid rgba(245, 158, 11, 0.3);
    padding: 12px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    animation: slideDown 0.3s ease;
}

.inference-action-info {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
}

.inference-action-info .info-icon {
    width: 20px;
    height: 20px;
    stroke: #f59e0b;
    flex-shrink: 0;
}

.inference-action-info span {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-color);
}

.inference-action-buttons {
    display: flex;
    gap: 10px;
    flex-shrink: 0;
}

.cancel-inference-btn,
.start-inference-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
}

.cancel-inference-btn {
    background: transparent;
    color: var(--text-color);
    border: 1.5px solid var(--border-color);
}

.cancel-inference-btn:hover {
    background: rgba(239, 68, 68, 0.1);
    border-color: #ef4444;
    color: #ef4444;
}

.cancel-inference-btn svg {
    width: 16px;
    height: 16px;
}

.start-inference-btn {
    background: linear-gradient(135deg, #f59e0b, #f97316);
    color: white;
    border: 1.5px solid #f59e0b;
}

.start-inference-btn:hover:not(:disabled) {
    box-shadow: 0 4px 12px rgba(245, 158, 11, 0.4);
    transform: translateY(-2px);
}

.start-inference-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.start-inference-btn svg {
    width: 16px;
    height: 16px;
}

/* Inference Checkbox */
.inference-checkbox {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    cursor: pointer;
}

.checkbox-inner {
    width: 20px;
    height: 20px;
    border: 2px solid var(--border-color);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    background: var(--bg-color);
}

.checkbox-inner.checked {
    background: linear-gradient(135deg, #f59e0b, #f97316);
    border-color: #f59e0b;
}

.checkbox-inner svg {
    width: 14px;
    height: 14px;
    stroke: white;
}

/* Inference Selected State */
.history-item.inference-selected {
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.1), rgba(249, 115, 22, 0.1));
    border-color: rgba(245, 158, 11, 0.4);
}

/* In Queue State */
.history-item.in-queue {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.08), rgba(96, 165, 250, 0.08));
    border-color: rgba(59, 130, 246, 0.3);
}

/* Queue Badge */
.queue-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 10px;
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.15), rgba(96, 165, 250, 0.15));
    border: 1px solid rgba(59, 130, 246, 0.4);
    border-radius: 12px;
    font-size: 11px;
    font-weight: 600;
    color: #3b82f6;
    animation: fadeInBadge 0.3s ease;
    flex-shrink: 0;
}

.queue-badge svg {
    width: 14px;
    height: 14px;
}

/* Queue Progress */
.queue-progress {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 6px;
}

.queue-progress-bar {
    flex: 1;
    height: 4px;
    background: rgba(59, 130, 246, 0.2);
    border-radius: 2px;
    overflow: hidden;
}

.queue-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #3b82f6, #60a5fa);
    border-radius: 2px;
    transition: width 0.3s ease;
}

.queue-progress-text {
    font-size: 11px;
    font-weight: 600;
    color: #3b82f6;
    flex-shrink: 0;
}

/* Responsive */
@media screen and (max-width: 1400px) {
    .inference-mode-btn {
        width: 28px;
        height: 28px;
    }

    .inference-mode-btn svg {
        width: 16px;
        height: 16px;
    }

    .inference-action-bar {
        padding: 10px 16px;
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
    }

    .inference-action-buttons {
        width: 100%;
        justify-content: flex-end;
    }

    .cancel-inference-btn,
    .start-inference-btn {
        padding: 7px 12px;
        font-size: 12px;
    }

    .inference-checkbox {
        width: 20px;
        height: 20px;
    }

    .checkbox-inner {
        width: 18px;
        height: 18px;
    }

    .checkbox-inner svg {
        width: 12px;
        height: 12px;
    }

    .queue-badge {
        gap: 4px;
        padding: 2px 8px;
        font-size: 10px;
    }

    .queue-badge svg {
        width: 12px;
        height: 12px;
    }
}

