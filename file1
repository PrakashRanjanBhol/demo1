import { Component, OnInit, OnDestroy } from '@angular/core';
import { Subject } from 'rxjs';
import { takeUntil, finalize } from 'rxjs/operators';
import {
  StatisticsService,
  QaResult,
  BitbucketResult,
  PrCommentsResult,
  DateRange,
} from './statistics.service';

type SectionState = 'idle' | 'loading' | 'error';

function toIsoDate(d: Date): string {
  return d.toISOString().slice(0, 10);
}

function defaultRange(): DateRange {
  const end = new Date();
  const start = new Date();
  start.setFullYear(start.getFullYear() - 1);
  return { start: toIsoDate(start), end: toIsoDate(end) };
}

@Component({
  selector: 'app-stats-dashboard',
  templateUrl: './stats-dashboard.component.html',
  styleUrls: ['./stats-dashboard.component.css'],
})
export class StatsDashboardComponent implements OnInit, OnDestroy {
  private destroy$ = new Subject<void>();

  today = toIsoDate(new Date());

  // ── QA ──────────────────────────────────────────────────────────────────────
  qaRange: DateRange = defaultRange();
  qaData: QaResult | null = null;
  qaState: SectionState = 'idle';
  qaError = '';

  // ── Bitbucket ────────────────────────────────────────────────────────────────
  bbRange: DateRange = defaultRange();
  bbData: BitbucketResult | null = null;
  bbState: SectionState = 'idle';
  bbError = '';

  // ── PR Comments ──────────────────────────────────────────────────────────────
  prRange: DateRange = defaultRange();
  prData: PrCommentsResult | null = null;
  prState: SectionState = 'idle';
  prError = '';

  constructor(private statsService: StatisticsService) {}

  ngOnInit(): void {
    // Optionally auto-load on init — comment out if you prefer manual Apply
    this.loadQa();
    this.loadBitbucket();
    this.loadPr();
  }

  ngOnDestroy(): void {
    this.destroy$.next();
    this.destroy$.complete();
  }

  // ── Fetch methods ────────────────────────────────────────────────────────────

  loadQa(): void {
    this.qaState = 'loading';
    this.qaError = '';
    this.statsService
      .getQaStats(this.qaRange)
      .pipe(
        takeUntil(this.destroy$),
        finalize(() => {
          if (this.qaState === 'loading') this.qaState = 'idle';
        })
      )
      .subscribe({
        next: (res) => {
          if (res.status !== 'Success') {
            this.qaState = 'error';
            this.qaError = 'API returned a non-success status.';
            return;
          }
          this.qaData = res.result;
          this.qaState = 'idle';
        },
        error: () => {
          this.qaState = 'error';
          this.qaError = 'Failed to load questions data. Please try again.';
        },
      });
  }

  loadBitbucket(): void {
    this.bbState = 'loading';
    this.bbError = '';
    this.statsService
      .getBitbucketAnalysis(this.bbRange)
      .pipe(
        takeUntil(this.destroy$),
        finalize(() => {
          if (this.bbState === 'loading') this.bbState = 'idle';
        })
      )
      .subscribe({
        next: (res) => {
          if (res.status !== 'Success') {
            this.bbState = 'error';
            this.bbError = 'API returned a non-success status.';
            return;
          }
          this.bbData = res.result;
          this.bbState = 'idle';
        },
        error: () => {
          this.bbState = 'error';
          this.bbError = 'Failed to load Bitbucket data. Please try again.';
        },
      });
  }

  loadPr(): void {
    this.prState = 'loading';
    this.prError = '';
    this.statsService
      .getPrComments(this.prRange)
      .pipe(
        takeUntil(this.destroy$),
        finalize(() => {
          if (this.prState === 'loading') this.prState = 'idle';
        })
      )
      .subscribe({
        next: (res) => {
          if (res.status !== 'Success') {
            this.prState = 'error';
            this.prError = 'API returned a non-success status.';
            return;
          }
          this.prData = res.result;
          this.prState = 'idle';
        },
        error: () => {
          this.prState = 'error';
          this.prError = 'Failed to load PR comments data. Please try again.';
        },
      });
  }

  // ── Utilities ─────────────────────────────────────────────────────────────────

  formatPct(value: number | null | undefined): string {
    if (value == null) return '—';
    return `${Math.round(value)}%`;
  }

  barWidth(value: number | null | undefined): string {
    if (value == null) return '0%';
    return `${Math.min(Math.round(value), 100)}%`;
  }
}



































<div class="sldc-dashboard">

  <!-- ── Questions Overview ─────────────────────────────────────────────────── -->
