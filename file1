  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round">
    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
  </svg>
);

// ── Gradient palette ──────────────────────────────────

const GRADIENTS: [string, string][] = [
  ["#6366f1", "#8b5cf6"],
  ["#0ea5e9", "#2684ff"],
  ["#10b981", "#06b6d4"],
  ["#f59e0b", "#ef4444"],
  ["#ec4899", "#8b5cf6"],
  ["#14b8a6", "#3b82f6"],
  ["#f97316", "#eab308"],
  ["#6366f1", "#ec4899"],
  ["#84cc16", "#10b981"],
  ["#8b5cf6", "#06b6d4"],
];

const getGradient = (key: string, id: string): [string, string] => {
  const combined = `${key}_${id}`;
  let hash = 0;
  for (let i = 0; i < combined.length; i++) {
    hash = combined.charCodeAt(i) + ((hash << 5) - hash);
  }
  return GRADIENTS[Math.abs(hash) % GRADIENTS.length];
};

// ── Project avatar ────────────────────────────────────

const ProjectAvatar: React.FC<{ projectKey: string; id: string }> = ({ projectKey, id }) => {
  const [from, to] = getGradient(projectKey, id);
  return (
    <div
      className={styles.projectAvatar}
      style={{ background: `linear-gradient(135deg, ${from} 0%, ${to} 100%)` }}
    >
      {projectKey.charAt(0).toUpperCase()}
    </div>
  );
};

// ── Main component ────────────────────────────────────

export const JiraTool: React.FC<JiraToolProps> = ({ onBack }) => {
  const dispatch = useDispatch<AppDispatch>();

  const { isLoading: isDisconnecting } = useSelector(
    (state: RootState) => state.atlassian
  );
  const {
    allProjects,
    favoriteProjects,
    isLoadingProjects,
    isFavoriteUpdating,
    error,
  } = useSelector((state: RootState) => state.jira);

  const [activeTab, setActiveTab] = useState<Tab>("favorites");
  const [searchQuery, setSearchQuery] = useState("");

  useEffect(() => {
    dispatch(fetchJiraProjects());
  }, [dispatch]);

  const handleDisconnect = () => dispatch(disconnectAtlassian());

  const isFavorite = (id: string) => !!favoriteProjects[id];

  const handleToggleFavorite = (project: JiraProject) => {
    if (isFavoriteUpdating[project.id]) return;
    if (isFavorite(project.id)) {
      dispatch(removeFavoriteProject(project));
    } else {
      dispatch(addFavoriteProject(project));
    }
  };

  const handleTabChange = (tab: Tab) => {
    setActiveTab(tab);
    setSearchQuery("");
  };

  const allProjectsList = Object.values(allProjects);
  const favoriteProjectsList = Object.values(favoriteProjects);

  const query = searchQuery.toLowerCase().trim();
  const filteredAll = query
    ? allProjectsList.filter(
        (p) =>
          p.key.toLowerCase().includes(query) ||
          p.id.includes(query)
      )
    : allProjectsList;

  const filteredFavorites = query
    ? favoriteProjectsList.filter(
        (p) =>
          p.key.toLowerCase().includes(query) ||
          p.id.includes(query)
      )
    : favoriteProjectsList;

  const activeList = activeTab === "all" ? filteredAll : filteredFavorites;

  return (
    <div className={styles.wrapper}>

      {/* ── Nav bar ─────────────────────────────────── */}
      <div className={styles.header}>
        <button className={styles.backBtn} onClick={onBack}>
          <span className={styles.backArrow}>←</span>
          <span>All tools</span>
        </button>
        <button
          className={styles.logoutBtn}
          onClick={handleDisconnect}
          disabled={isDisconnecting}
          title="Disconnect Jira"
        >
          <LogoutIcon />
        </button>
      </div>

      {/* ── Tool identity strip ──────────────────────── */}
      <div className={styles.toolHeader}>
        <div className={styles.toolIcon}>
          <img src={jiraIcon} alt="Jira" width={24} height={24} className={styles.img} />
        </div>
        <div className={styles.toolMeta}>
          <h2 className={styles.toolName}>Jira</h2>
          <span className={styles.connectedBadge}>● Connected</span>
        </div>
      </div>

      {/* ── Tabs ─────────────────────────────────────── */}
      <div className={styles.tabs}>
        <button
          className={`${styles.tab} ${activeTab === "favorites" ? styles.activeTab : ""}`}
          onClick={() => handleTabChange("favorites")}
        >
          Favorites
          {favoriteProjectsList.length > 0 && (
            <span className={styles.tabCount}>{favoriteProjectsList.length}</span>
          )}
        </button>
        <button
          className={`${styles.tab} ${activeTab === "all" ? styles.activeTab : ""}`}
          onClick={() => handleTabChange("all")}
        >
          All Projects
          {allProjectsList.length > 0 && (
            <span className={styles.tabCount}>{allProjectsList.length}</span>
          )}
        </button>
      </div>

      {/* ── Search bar ───────────────────────────────── */}
      {!isLoadingProjects && !error && (
        <div className={styles.searchBar}>
          <span className={styles.searchIcon}>
            <SearchIcon />
          </span>
          <input
            type="text"
            className={styles.searchInput}
            placeholder="Search projects…"
            value={searchQuery}
            onChange={(e) => setSearchQuery(e.target.value)}
          />
          {searchQuery && (
            <button
              className={styles.clearBtn}
              onClick={() => setSearchQuery("")}
              title="Clear search"
            >
              <ClearIcon />
            </button>
          )}
        </div>
      )}

      {/* ── Content ──────────────────────────────────── */}
      <div className={styles.content}>

        {/* Loading */}
        {isLoadingProjects && (
          <div className={styles.loadingState}>
            <span className={styles.spinner} />
            <span>Loading projects…</span>
          </div>
        )}

        {/* Error */}
        {!isLoadingProjects && error && (
          <div className={styles.errorState}>{error}</div>
        )}

        {/* ── Favorites tab ────────────────────────── */}
        {!isLoadingProjects && !error && activeTab === "favorites" && (
          filteredFavorites.length === 0 ? (
            <div className={styles.emptyState}>
              <div className={styles.emptyIcon}>
                <StarOutlineIcon />
              </div>
              <p>{query ? "No matches found" : "No favorites yet"}</p>
              <span>
                {query
                  ? `No favorite projects match "${searchQuery}".`
                  : "Star a project in All Projects to pin it here."}
              </span>
            </div>
          ) : (
            <ul className={styles.projectList}>
              {filteredFavorites.map((project) => (
                <li key={project.id} className={styles.projectItem}>
                  <ProjectAvatar projectKey={project.key} id={project.id} />
                  <div className={styles.projectInfo}>
                    <span className={styles.projectKey}>{project.key}</span>
                    <span className={styles.projectId}>#{project.id}</span>
                  </div>
                </li>
              ))}
            </ul>
          )
        )}

        {/* ── All Projects tab ─────────────────────── */}
        {!isLoadingProjects && !error && activeTab === "all" && (
          filteredAll.length === 0 ? (
            <div className={styles.emptyState}>
              <div className={styles.emptyIcon}>
                <EmptyFolderIcon />
              </div>
              <p>{query ? "No matches found" : "No projects found"}</p>
              <span>
                {query
                  ? `No projects match "${searchQuery}".`
                  : "Your Jira projects will appear here."}
              </span>
            </div>
          ) : (
            <ul className={styles.projectList}>
              {filteredAll.map((project) => {
                const favorited = isFavorite(project.id);
                const updating = !!isFavoriteUpdating[project.id];

                return (
                  <li key={project.id} className={styles.projectItem}>
                    <ProjectAvatar projectKey={project.key} id={project.id} />
                    <div className={styles.projectInfo}>
                      <span className={styles.projectKey}>{project.key}</span>
                      <span className={styles.projectId}>#{project.id}</span>
                    </div>
                    <button
                      className={`${styles.favoriteBtn} ${favorited ? styles.favorited : ""}`}
                      onClick={() => handleToggleFavorite(project)}
                      disabled={updating}
                      title={favorited ? "Remove from favorites" : "Add to favorites"}
                    >
                      {updating ? (
                        <span className={styles.miniSpinner} />
                      ) : favorited ? (
                        <StarFilledIcon />
                      ) : (
                        <StarOutlineIcon />
                      )}
                    </button>
                  </li>
                );
              })}
            </ul>
          )
        )}

      </div>
    </div>
  );
};

export default JiraTool;














// Jira brand palette
$jira-blue: #2684ff;
$jira-blue-dark: #0052cc;
$jira-blue-light: #deebff;
$star-gold: #f59e0b;
$star-gold-hover: #d97706;
$connected-green: #059669;
$connected-bg: #ecfdf5;
$connected-border: #a7f3d0;
$error-red: #dc2626;
$error-bg: #fef2f2;
$error-border: #fecaca;

// ── Wrapper ───────────────────────────────────────────

.wrapper {
  display: flex;
  flex-direction: column;
  height: 100%;
  overflow: hidden;
  background: var(--bg-main);
  animation: fadeSlideIn 0.2s ease both;
}

@keyframes fadeSlideIn {
  from {
    opacity: 0;
    transform: translateY(6px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

// ── Top nav bar ───────────────────────────────────────

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 14px 10px;
  border-bottom: 1px solid var(--border-subtle);
  background: var(--bg-main);
  flex-shrink: 0;
}

.backBtn {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 5px 10px;
  background: transparent;
  border: 1px solid var(--border-subtle);
  border-radius: 6px;
  color: var(--text-secondary);
  font-size: 0.7875rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.15s ease;

  &:hover {
    background: $jira-blue-light;
    color: $jira-blue;
    border-color: rgba($jira-blue, 0.3);

    .backArrow {
      transform: translateX(-3px);
    }
  }
}

.backArrow {
  font-size: 0.875rem;
  transition: transform 0.18s ease;
  display: inline-block;
  line-height: 1;
}

.logoutBtn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 30px;
  height: 30px;
  border-radius: 6px;
  border: 1px solid var(--border-subtle);
  background: transparent;
  color: var(--text-tertiary);
  cursor: pointer;
  transition: all 0.15s ease;

  &:hover:not(:disabled) {
    background: $error-bg;
    border-color: $error-border;
    color: $error-red;
    transform: scale(1.05);
  }

  &:active:not(:disabled) {
    transform: scale(0.95);
  }

  &:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
}

// ── Tool identity strip ───────────────────────────────

.toolHeader {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 16px 14px;
  background: linear-gradient(
    135deg,
