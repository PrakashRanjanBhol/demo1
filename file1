import { Component, OnInit, OnDestroy } from '@angular/core';
import { CommonModule } from '@angular/common';
import { FormsModule } from '@angular/forms';
import { Subject, takeUntil, finalize } from 'rxjs';
import { DatePickerModule } from 'primeng/datepicker';
import { ButtonModule } from 'primeng/button';
import { ProgressBarModule } from 'primeng/progressbar';

import { StatsService } from '../../services/stats.service';
import {
  QaStatsResult,
  BitbucketResult,
  PrCommentsResult,
  DateRange,
  LoadState,
} from '../../core/models/stats.models';

interface SectionState<T> {
  data: T | null;
  loadState: LoadState;
  dateRange: DateRange;
}

@Component({
  selector: 'app-stats-dashboard',
  standalone: true,
  imports: [
    CommonModule,
    FormsModule,
    DatePickerModule,
    ButtonModule,
    ProgressBarModule,
  ],
  templateUrl: './stats-dashboard.component.html',
  styleUrls: ['./stats-dashboard.component.scss'],
})
export class StatsDashboardComponent implements OnInit, OnDestroy {
  private destroy$ = new Subject<void>();

  private defaultRange(): DateRange {
    const end = new Date();
    const start = new Date();
    start.setFullYear(start.getFullYear() - 1);
    return { start, end };
  }

  qa: SectionState<QaStatsResult> = {
    data: null,
    loadState: 'idle',
    dateRange: this.defaultRange(),
  };

  bitbucket: SectionState<BitbucketResult> = {
    data: null,
    loadState: 'idle',
    dateRange: this.defaultRange(),
  };

  pr: SectionState<PrCommentsResult> = {
    data: null,
    loadState: 'idle',
    dateRange: this.defaultRange(),
  };

  readonly today = new Date();

  constructor(private statsService: StatsService) {}

  ngOnInit(): void {
    this.fetchQa();
    this.fetchBitbucket();
    this.fetchPr();
  }

  ngOnDestroy(): void {
    this.destroy$.next();
    this.destroy$.complete();
  }

  private formatDate(date: Date | null): string {
    if (!date) return '';
    return date.toISOString().slice(0, 10);
  }

  fetchQa(): void {
    const { start, end } = this.qa.dateRange;
    if (!start || !end) return;
    this.qa.loadState = 'loading';
    this.statsService
      .getQaStats(this.formatDate(start), this.formatDate(end))
      .pipe(
        takeUntil(this.destroy$),
        finalize(() => {
          if (this.qa.loadState === 'loading') this.qa.loadState = 'idle';
        })
      )
      .subscribe({
        next: (res) => {
          if (res.status === 'Success') {
            this.qa.data = res.result;
            this.qa.loadState = 'success';
          } else {
            this.qa.loadState = 'error';
          }
        },
        error: () => (this.qa.loadState = 'error'),
      });
  }

  fetchBitbucket(): void {
    const { start, end } = this.bitbucket.dateRange;
    if (!start || !end) return;
    this.bitbucket.loadState = 'loading';
    this.statsService
      .getBitbucketAnalysis(this.formatDate(start), this.formatDate(end))
      .pipe(
        takeUntil(this.destroy$),
        finalize(() => {
          if (this.bitbucket.loadState === 'loading')
            this.bitbucket.loadState = 'idle';
        })
      )
      .subscribe({
        next: (res) => {
          if (res.status === 'Success') {
            this.bitbucket.data = res.result;
            this.bitbucket.loadState = 'success';
          } else {
            this.bitbucket.loadState = 'error';
          }
        },
        error: () => (this.bitbucket.loadState = 'error'),
      });
  }

  fetchPr(): void {
    const { start, end } = this.pr.dateRange;
    if (!start || !end) return;
    this.pr.loadState = 'loading';
    this.statsService
      .getPrCommentsAnalysis(this.formatDate(start), this.formatDate(end))
      .pipe(
        takeUntil(this.destroy$),
        finalize(() => {
          if (this.pr.loadState === 'loading') this.pr.loadState = 'idle';
        })
      )
      .subscribe({
        next: (res) => {
          if (res.status === 'Success') {
            this.pr.data = res.result;
            this.pr.loadState = 'success';
          } else {
            this.pr.loadState = 'error';
          }
        },
        error: () => (this.pr.loadState = 'error'),
      });
  }

  isLoading(state: LoadState): boolean {
    return state === 'loading';
  }

  isError(state: LoadState): boolean {
    return state === 'error';
  }

  formatPct(value: number | undefined): string {
    if (value == null) return '—';
    return `${Math.round(value)}%`;
  }
}
























































<div class="sldc-dashboard">

