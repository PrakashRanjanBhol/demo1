// fix #3 — correct text colors for dark mode
:global(:root) {
  // ... existing vars ...
  --sl-text: #0f0c1d;
  --sl-text2: #3d3656;
  --sl-text3: #7a738f;
  --sl-text4: #b0abc4;
}

:global([data-theme='dark']) {
  // ... existing vars ...
  --sl-text: #f2eeff;
  --sl-text2: #c4bbdd;
  --sl-text3: #7b6f9a;
  --sl-text4: #6b6484; // was #4a4264 — too dark, bumped up
}

// fix #3 — headerTitle, headerSub, sectionLabel use correct var
.headerText {
  display: flex;
  flex-direction: column;
  gap: 2px;

  .headerTitle {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--sl-text);        // was --sl-text, ensure it's this
    letter-spacing: -0.01em;
  }

  .headerSub {
    font-size: 0.6875rem;
    color: var(--sl-text3);       // was --sl-text4, bumped to text3
  }
}

.sectionLabel {
  font-size: 0.5875rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--sl-text3);         // was --sl-text4, bumped to text3
  padding: 8px 13px 4px;
}

// fix #4 — navLink needs horizontal margin so it doesn't touch borders
.navBody {
  flex: 1;
  overflow-y: auto;
  padding: 8px 10px;              // was 8px 8px — add more horizontal padding
  display: flex;
  flex-direction: column;
  gap: 2px;

  &::-webkit-scrollbar { width: 3px; }
  &::-webkit-scrollbar-thumb {
    background: rgba(124, 58, 237, 0.18);
    border-radius: 2px;
  }
}

.navLink {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 12px;
  margin: 0 2px;                  // add small margin so active bg doesn't bleed to border
  border-radius: 10px;
  text-decoration: none;
  font-size: 0.8125rem;
  font-weight: 500;
  color: var(--sl-text3);
  position: relative;
  z-index: 1;
  transition: color 0.2s ease;

  // ... rest stays same
}
