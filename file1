<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NoteMind — AI Research Studio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&family=DM+Mono:wght@400;500&display=swap"
        rel="stylesheet" />
    <style>
        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        /* ── THEME TOKENS ── */
        :root {
            /* Accent: warm violet → indigo → electric blue — rich, not generic */
            --a1: #7c3aed;
            /* violet */
            --a2: #4f46e5;
            /* indigo */
            --a3: #2563eb;
            /* blue */
            --a4: #0ea5e9;
            /* sky */
            --grad: linear-gradient(135deg, #7c3aed 0%, #4f46e5 35%, #2563eb 65%, #0ea5e9 100%);
            --grad-soft: linear-gradient(135deg, rgba(124, 58, 237, 0.12) 0%, rgba(37, 99, 235, 0.08) 100%);
            --grad-btn: linear-gradient(135deg, #7c3aed 0%, #4f46e5 50%, #2563eb 100%);
            --shadow-btn: 0 4px 16px rgba(79, 70, 229, 0.38);
            --shadow-btn-h: 0 6px 22px rgba(79, 70, 229, 0.50);
            --radius: 16px;
            --radius-sm: 10px;
            --pill: 999px;
            --gap: 9px;
        }

        /* LIGHT */
        [data-theme="light"] {
            --bg: #ffffff;
            --bg2: #f5f4ff;
            --surface: #ffffff;
            --s2: #f7f6ff;
            --s3: #eeecff;
            --border: rgba(79, 70, 229, 0.11);
            --border-h: rgba(79, 70, 229, 0.22);
            --text: #0f0c1d;
            --text2: #3d3656;
            --text3: #7a738f;
            --text4: #b0abc4;
            --sp: 0 1px 2px rgba(0, 0, 0, 0.04), 0 4px 20px rgba(79, 70, 229, 0.07);
            --sh: 0 2px 6px rgba(0, 0, 0, 0.06), 0 10px 36px rgba(79, 70, 229, 0.13);
            --ib: #f5f4ff;
            --ib-border: rgba(79, 70, 229, 0.15);
            --orb: linear-gradient(135deg, #ede9fe, #ddd6fe);
            --orb-sh: 0 4px 18px rgba(124, 58, 237, 0.15);
        }

        /* DARK */
        [data-theme="dark"] {
            --bg: #0a0a0b;
            --bg2: #111113;
            --surface: #111113;
            --s2: #18171f;
            --s3: #1f1e28;
            --border: rgba(124, 58, 237, 0.13);
            --border-h: rgba(124, 58, 237, 0.28);
            --text: #f2eeff;
            --text2: #c4bbdd;
            --text3: #7b6f9a;
            --text4: #4a4264;
            --sp: 0 1px 0 rgba(124, 58, 237, 0.07) inset, 0 8px 36px rgba(0, 0, 0, 0.5);
            --sh: 0 1px 0 rgba(124, 58, 237, 0.14) inset, 0 14px 48px rgba(0, 0, 0, 0.65);
            --ib: #18171f;
            --ib-border: rgba(124, 58, 237, 0.18);
            --orb: linear-gradient(135deg, rgba(124, 58, 237, 0.22), rgba(79, 70, 229, 0.14));
            --orb-sh: 0 4px 18px rgba(124, 58, 237, 0.28);
        }

        /* ── BASE ── */
        html,
        body {
            height: 100%;
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            overflow: hidden;
            -webkit-font-smoothing: antialiased;
            transition: background .25s, color .25s
        }

        /* Ambient glow */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 0;
            background:
                radial-gradient(ellipse 55% 35% at 0% 0%, rgba(124, 58, 237, 0.07) 0%, transparent 60%),
                radial-gradient(ellipse 45% 30% at 100% 100%, rgba(14, 165, 233, 0.06) 0%, transparent 55%);
        }

        [data-theme="dark"] body::before {
            background:
                radial-gradient(ellipse 55% 35% at 0% 0%, rgba(124, 58, 237, 0.14) 0%, transparent 58%),
                radial-gradient(ellipse 45% 30% at 100% 100%, rgba(14, 165, 233, 0.10) 0%, transparent 55%);
        }

        /* ── SHELL ── */
        .app {
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
            height: 100vh;
            padding: 10px 12px 7px;
            gap: var(--gap)
        }

        /* ══════════════════════════════════════════
   HEADER  — logo + right actions only
══════════════════════════════════════════ */
        header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 42px;
            flex-shrink: 0;
            padding: 0 3px;
            animation: fadeDown .35s ease both;
        }

        /* Logo */
        .logo {
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none
        }

        .logo-mark {
            width: 30px;
            height: 30px;
            border-radius: 9px;
            background: var(--grad-btn);
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 3px 12px rgba(124, 58, 237, 0.42);
            flex-shrink: 0;
        }

        .logo-mark svg {
            width: 15px;
            height: 15px
        }

        .logo-word {
            font-family: 'Lora', serif;
            font-size: 17px;
            font-weight: 600;
            color: var(--text);
            letter-spacing: -.025em;
            line-height: 1;
        }

        .logo-word span {
            background: var(--grad);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Header right */
        .hdr-r {
            display: flex;
            align-items: center;
            gap: 6px
        }

        .hdr-btn {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 5px 13px;
            border-radius: var(--pill);
            font-family: 'DM Sans', sans-serif;
            font-size: 12px;
            font-weight: 500;
            cursor: pointer;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--text2);
            transition: all .18s;
        }

        .hdr-btn:hover {
            border-color: var(--border-h);
            color: var(--text);
            background: var(--s2)
        }

        .hdr-btn-p {
            background: var(--grad-btn);
            color: #fff;
            border-color: transparent;
            box-shadow: var(--shadow-btn);
        }

        .hdr-btn-p:hover {
            box-shadow: var(--shadow-btn-h);
            transform: translateY(-1px);
            filter: brightness(1.07)
        }

        .icon-btn {
            width: 30px;
            height: 30px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--text3);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all .18s;
            font-size: 14px;
        }

        .icon-btn:hover {
            border-color: var(--border-h);
            color: var(--text);
            background: var(--s2)
        }

        .avatar {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: var(--grad-btn);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 600;
            color: #fff;
            cursor: pointer;
            box-shadow: 0 0 0 2px var(--bg), 0 0 0 3.5px rgba(124, 58, 237, 0.35);
        }

        /* ══════════════════════════════════════════
   BODY ROW — three panels
══════════════════════════════════════════ */
        .row {
            flex: 1;
            display: flex;
            gap: var(--gap);
            min-height: 0
        }

        /* ── PANEL BASE ── */
        .panel {
            border-radius: var(--radius);
            background: var(--surface);
            border: 1px solid var(--border);
            box-shadow: var(--sp);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            position: relative;
            transition: box-shadow .25s, border-color .25s, background .25s;
            animation: slideUp .45s cubic-bezier(.16, 1, .3, 1) both;
        }

        .panel:hover {
            box-shadow: var(--sh);
            border-color: var(--border-h)
        }

        /* Top shimmer */
        .panel::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(124, 58, 237, 0.3), rgba(14, 165, 233, 0.25), transparent);
            pointer-events: none;
        }

        .l-panel {
            width: 252px;
            flex-shrink: 0;
            animation-delay: .04s
        }

        .c-panel {
            flex: 1;
            min-width: 0;
            animation-delay: .08s
        }

        .r-panel {
            width: 288px;
            flex-shrink: 0;
            animation-delay: .12s
        }

        /* ── PANEL HEAD ── */
        .ph {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 13px 16px 12px;
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
        }

        .ph-label {
            font-family: 'DM Sans', sans-serif;
            font-size: 10px;
            font-weight: 600;
            letter-spacing: .09em;
            text-transform: uppercase;
            color: var(--a2);
            display: flex;
            align-items: center;
            gap: 5px;
        }

        [data-theme="dark"] .ph-label {
            color: #a78bfa
        }

        .ph-dot {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: var(--a2);
            box-shadow: 0 0 6px rgba(79, 70, 229, .6);
        }

        [data-theme="dark"] .ph-dot {
            background: #a78bfa;
            box-shadow: 0 0 6px rgba(167, 139, 250, .5)
        }

        .ph-acts {
            display: flex;
            gap: 4px
        }

        .pi {
            width: 25px;
            height: 25px;
            border-radius: 7px;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--text3);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all .18s;
        }

        .pi:hover {
            border-color: var(--border-h);
            color: var(--text);
            background: var(--s2)
        }

        /* ── EMPTY STATE — shared ── */
        .empty {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            flex: 1;
            gap: 11px;
            text-align: center;
            padding: 24px 20px;
            animation: fadeUp .4s ease both .12s;
        }

        .e-orb {
            width: 52px;
            height: 52px;
            border-radius: 15px;
            background: var(--orb);
            border: 1px solid var(--border-h);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 2px;
            position: relative;
            box-shadow: var(--orb-sh);
        }

        .e-orb::before {
            content: '';
            position: absolute;
            inset: -8px;
            border-radius: 21px;
            background: radial-gradient(ellipse, rgba(124, 58, 237, 0.12) 0%, transparent 70%);
            animation: breathe 3.5s ease-in-out infinite;
        }

        .e-orb svg {
            width: 22px;
            height: 22px;
            position: relative;
            z-index: 1
        }

        .e-title {
            font-family: 'Lora', serif;
            font-size: 13.5px;
            font-weight: 600;
            color: var(--text)
        }

        .e-desc {
            font-size: 11.5px;
            color: var(--text4);
            line-height: 1.65;
            max-width: 165px
        }

        .e-btn {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 7px 16px;
            border-radius: var(--pill);
            background: var(--grad-btn);
            color: #fff;
            font-family: 'DM Sans', sans-serif;
            font-size: 11.5px;
            font-weight: 500;
            border: none;
            cursor: pointer;
            box-shadow: var(--shadow-btn);
            transition: all .18s;
            margin-top: 3px;
        }

        .e-btn:hover {
            box-shadow: var(--shadow-btn-h);
            transform: translateY(-1px);
            filter: brightness(1.07)
        }

        /* ── PANEL FOOT ── */
        .pf {
            padding: 10px 14px;
            border-top: 1px solid var(--border);
            flex-shrink: 0
        }

        .dash-btn {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 8px;
            border-radius: var(--radius-sm);
            border: 1.5px dashed var(--border-h);
            background: transparent;
            color: var(--text4);
            font-family: 'DM Sans', sans-serif;
            font-size: 12px;
            cursor: pointer;
            transition: all .18s;
        }

        .dash-btn:hover {
            border-color: var(--a2);
            color: var(--a2);
            background: rgba(79, 70, 229, 0.05)
        }

        [data-theme="dark"] .dash-btn:hover {
            background: rgba(124, 58, 237, 0.08)
        }

        /* ══════════════════════════════════════════
   CENTER — chat shell only
══════════════════════════════════════════ */
        .cb {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 18px 11px;
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
        }

        .cb-title {
            font-family: 'Lora', serif;
            font-size: 15px;
            font-weight: 600;
            color: var(--text);
            letter-spacing: -.015em
        }

        .cb-sub {
            font-size: 11px;
            color: var(--text4);
            margin-top: 1px
        }

        .cb-r {
            display: flex;
            gap: 5px
        }

        .c-pill {
            padding: 4px 11px;
            border-radius: var(--pill);
            border: 1px solid var(--border);
            background: transparent;
            color: var(--text3);
            font-family: 'DM Sans', sans-serif;
            font-size: 11px;
            font-weight: 500;
            cursor: pointer;
            transition: all .18s;
        }

        .c-pill:hover {
            border-color: var(--border-h);
            color: var(--text);
            background: var(--s2)
        }

        /* Messages */
        .msgs {
            flex: 1;
            overflow-y: auto;
            padding: 0 20px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .msgs::-webkit-scrollbar {
            width: 3px
        }

        .msgs::-webkit-scrollbar-thumb {
            background: rgba(124, 58, 237, 0.18);
            border-radius: 2px
        }

        /* Chat welcome */
        .cw {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            gap: 14px;
            padding: 36px 24px;
            animation: fadeUp .5s ease both .1s;
        }

        .cw-orb {
            width: 74px;
            height: 74px;
            border-radius: 22px;
            background: var(--orb);
            border: 1px solid var(--border-h);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            margin-bottom: 4px;
            box-shadow: var(--orb-sh);
        }

        .cw-orb::before {
            content: '';
            position: absolute;
            inset: -10px;
            border-radius: 28px;
            background: radial-gradient(ellipse, rgba(124, 58, 237, 0.15) 0%, transparent 70%);
            animation: breathe 3.5s ease-in-out infinite;
        }

        .cw-orb svg {
            width: 30px;
            height: 30px;
            position: relative;
            z-index: 1
        }

        .cw-h {
            font-family: 'Lora', serif;
            font-size: 22px;
            font-weight: 600;
            color: var(--text);
            letter-spacing: -.02em;
            line-height: 1.25;
        }

        .cw-h em {
            font-style: italic;
            background: var(--grad);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .cw-p {
            font-size: 12.5px;
            color: var(--text3);
            max-width: 290px;
            line-height: 1.7
        }

        /* Suggestion cards */
        .sg {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 7px;
            width: 100%;
            max-width: 370px;
            margin-top: 6px
        }

        .sc {
            padding: 11px 13px;
            border-radius: 11px;
            border: 1px solid var(--border);
            background: var(--s2);
            text-align: left;
            cursor: pointer;
            transition: all .2s;
        }

        [data-theme="light"] .sc:hover {
            background: #ede9fe;
            border-color: rgba(124, 58, 237, 0.22);
            box-shadow: 0 4px 16px rgba(124, 58, 237, 0.10)
        }

        [data-theme="dark"] .sc:hover {
            background: var(--s3);
            border-color: rgba(124, 58, 237, 0.25);
            box-shadow: 0 4px 16px rgba(0, 0, 0, .3)
        }

        .sc:hover {
            transform: translateY(-2px)
        }

        .sc-i {
            font-size: 16px;
            margin-bottom: 5px
        }

        .sc-t {
            font-size: 11.5px;
            color: var(--text2);
            font-weight: 500;
            line-height: 1.4
        }

        /* Input */
        .ciz {
            padding: 10px 16px 12px;
            flex-shrink: 0
        }

        .ib {
            display: flex;
            align-items: flex-end;
            gap: 9px;
            background: var(--ib);
            border: 1.5px solid var(--ib-border);
            border-radius: 13px;
            padding: 10px 10px 10px 15px;
            transition: all .2s;
        }

        .ib:focus-within {
            border-color: rgba(124, 58, 237, 0.40);
            box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.09);
            background: var(--surface);
        }

        textarea.ti {
            flex: 1;
            border: none;
            background: transparent;
            resize: none;
            font-family: 'DM Sans', sans-serif;
            font-size: 13px;
            color: var(--text);
            outline: none;
            line-height: 1.5;
            min-height: 20px;
            max-height: 90px;
        }

        textarea.ti::placeholder {
            color: var(--text4)
        }

        .sb {
            width: 34px;
            height: 34px;
            border-radius: 9px;
            background: var(--grad-btn);
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: all .18s;
            box-shadow: var(--shadow-btn);
        }

        .sb:hover {
            filter: brightness(1.1);
            transform: scale(1.04);
            box-shadow: var(--shadow-btn-h)
        }

        .if {
            display: flex;
            align-items: center;
            gap: 5px;
            margin-top: 7px;
            padding: 0 2px
        }

        .ifb {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 3px 9px;
            border-radius: var(--pill);
            border: 1px solid var(--border);
            background: transparent;
            color: var(--text4);
            font-family: 'DM Sans', sans-serif;
            font-size: 11px;
            cursor: pointer;
            transition: all .18s;
        }

        .ifb:hover {
            border-color: var(--border-h);
            color: var(--text2);
            background: var(--s2)
        }

        .ifh {
            margin-left: auto;
            font-size: 10.5px;
            color: var(--text4);
            font-family: 'DM Mono', monospace
        }

        /* ══════════════════════════════════════════
   RIGHT — tab shell only
══════════════════════════════════════════ */
        .rtabs {
            display: flex;
            gap: 1px;
            padding: 0 7px;
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
        }

        .rt {
            flex: 1;
            padding: 10px 4px 9px;
            font-family: 'DM Sans', sans-serif;
            font-size: 11.5px;
            font-weight: 500;
            color: var(--text3);
            border: none;
            background: transparent;
            cursor: pointer;
            border-bottom: 2px solid transparent;
            margin-bottom: -1px;
            transition: all .18s;
        }

        .rt:hover {
            color: var(--text)
        }

        .rt.on {
            color: var(--a2);
            border-bottom-color: var(--a2)
        }

        [data-theme="dark"] .rt.on {
            color: #a78bfa;
            border-bottom-color: #a78bfa
        }

        .rbody {
            flex: 1;
            overflow-y: auto;
            display: flex;
            flex-direction: column
        }

        .rbody::-webkit-scrollbar {
            width: 3px
        }

        .rbody::-webkit-scrollbar-thumb {
            background: rgba(124, 58, 237, 0.18);
            border-radius: 2px
        }

        /* ══════════════════════════════════════════
   FOOTER  — version + rights only
══════════════════════════════════════════ */
        footer {
            height: 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 4px;
            flex-shrink: 0;
            animation: fadeUp .35s ease .25s both;
        }

        .ft-v {
            font-family: 'DM Mono', monospace;
            font-size: 10.5px;
            color: var(--text4);
            letter-spacing: .02em;
        }

        .ft-r {
            font-size: 10.5px;
            color: var(--text4)
        }

        /* ══════════════════════════════════════════
   ANIMATIONS
══════════════════════════════════════════ */
        @keyframes fadeDown {
            from {
                opacity: 0;
                transform: translateY(-8px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(8px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(14px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        @keyframes breathe {

            0%,
            100% {
                opacity: .5;
                transform: scale(1)
            }

            50% {
                opacity: 1;
                transform: scale(1.06)
            }
        }

        @keyframes blink {

            0%,
            80%,
            100% {
                opacity: .2;
                transform: scale(.85)
            }

            40% {
                opacity: 1;
                transform: scale(1.1)
            }
        }

        ::-webkit-scrollbar {
            width: 4px;
            height: 4px
        }

        ::-webkit-scrollbar-track {
            background: transparent
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(124, 58, 237, 0.18);
            border-radius: 2px
        }

        button:focus-visible {
            outline: 2px solid var(--a2);
            outline-offset: 2px
        }
    </style>
</head>

<body>
    <div class="app">

        <!-- ═══ HEADER ═══ -->
        <header>
            <a class="logo" href="#">
                <div class="logo-mark">
                    <svg viewBox="0 0 18 18" fill="none">
                        <path d="M4 5h10M4 9h7M4 13h9" stroke="#fff" stroke-width="1.8" stroke-linecap="round" />
                        <circle cx="14" cy="13" r="2.1" fill="#fff" opacity=".9" />
                    </svg>
                </div>
                <span class="logo-word">Note<span>Mind</span></span>
            </a>

            <div class="hdr-r">
                <button class="icon-btn" title="Search">
                    <svg width="13" height="13" viewBox="0 0 13 13" fill="none">
                        <circle cx="5.5" cy="5.5" r="4" stroke="currentColor" stroke-width="1.4" />
                        <path d="M9 9l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                </button>
                <button class="hdr-btn hdr-btn-p">
                    <svg width="11" height="11" viewBox="0 0 11 11" fill="none">
                        <path d="M5.5 1v9M1 5.5h9" stroke="#fff" stroke-width="1.7" stroke-linecap="round" />
                    </svg>
                    New Notebook
                </button>
                <button class="icon-btn" id="themeBtn" onclick="toggleTheme()" title="Toggle theme">🌙</button>
                <div class="avatar">AR</div>
            </div>
        </header>

        <!-- ═══ BODY ═══ -->
        <div class="row">

            <!-- LEFT: Sources -->
            <aside class="panel l-panel">
                <div class="ph">
                    <span class="ph-label"><span class="ph-dot"></span>Sources</span>
                    <div class="ph-acts">
                        <button class="pi" title="Add">
                            <svg width="11" height="11" viewBox="0 0 11 11" fill="none">
                                <path d="M5.5 1v9M1 5.5h9" stroke="currentColor" stroke-width="1.6"
                                    stroke-linecap="round" />
                            </svg>
                        </button>
                        <button class="pi" title="Filter">
                            <svg width="11" height="11" viewBox="0 0 11 11" fill="none">
                                <path d="M1 2.5h9M2.5 5.5h6M4 8.5h3" stroke="currentColor" stroke-width="1.4"
                                    stroke-linecap="round" />
                            </svg>
                        </button>
                    </div>
                </div>

                <!-- Empty body -->
                <div class="rbody">
                    <div class="empty">
                        <div class="e-orb">
                            <svg viewBox="0 0 22 22" fill="none">
                                <path d="M5 4h8l4 4v10a1 1 0 01-1 1H5a1 1 0 01-1-1V5a1 1 0 011-1z" stroke="var(--a1)"
                                    stroke-width="1.4" stroke-linejoin="round" />
                                <path d="M13 4v4h4" stroke="var(--a1)" stroke-width="1.4" stroke-linecap="round"
                                    stroke-linejoin="round" />
                                <path d="M8 12h6M8 15h4" stroke="var(--a2)" stroke-width="1.3" stroke-linecap="round" />
                            </svg>
                        </div>
                        <div class="e-title">No sources yet</div>
                        <div class="e-desc">Add PDFs, web pages, or text to start your research</div>
                        <button class="e-btn">
                            <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                                <path d="M5 1v8M1 5h8" stroke="#fff" stroke-width="1.6" stroke-linecap="round" />
                            </svg>
                            Add Source
                        </button>
                    </div>
                </div>

                <div class="pf">
                    <button class="dash-btn">
                        <svg width="11" height="11" viewBox="0 0 11 11" fill="none">
                            <path d="M5.5 1v9M1 5.5h9" stroke="currentColor" stroke-width="1.5"
                                stroke-linecap="round" />
                        </svg>
                        Add source
                    </button>
                </div>
            </aside>

            <!-- CENTER: Chat -->
            <main class="panel c-panel">
                <div class="cb">
                    <div>
                        <div class="cb-title">Untitled Notebook</div>
                        <div class="cb-sub">0 sources · Add documents to begin</div>
                    </div>
                    <div class="cb-r">
                        <button class="c-pill">Export</button>
                        <button class="c-pill">History</button>
                        <button class="c-pill">Share</button>
                    </div>
                </div>

                <!-- Empty / welcome -->
                <div class="msgs" id="msgs">
                    <div class="cw" id="welcome">
                        <div class="cw-orb">
                            <svg viewBox="0 0 30 30" fill="none">
                                <path d="M6 9h18M6 15h12M6 21h14" stroke="var(--a1)" stroke-width="1.8"
                                    stroke-linecap="round" />
                                <circle cx="23" cy="21" r="5.5" fill="url(#wg)" />
                                <path d="M21 21l1.5 1.5L25 19" stroke="#fff" stroke-width="1.4" stroke-linecap="round"
                                    stroke-linejoin="round" />
                                <defs>
                                    <linearGradient id="wg" x1="18" y1="16" x2="29" y2="27"
                                        gradientUnits="userSpaceOnUse">
                                        <stop stop-color="#7c3aed" />
                                        <stop offset="1" stop-color="#4f46e5" />
                                    </linearGradient>
                                </defs>
                            </svg>
                        </div>
                        <h2 class="cw-h">Ask anything about<br /><em>your sources</em></h2>
                        <p class="cw-p">Upload documents, paste URLs, or add text — then ask questions and uncover
                            insights.</p>
                        <div class="sg">
                            <div class="sc" onclick="fill('Summarize the key findings')">
                                <div class="sc-i">📝</div>
                                <div class="sc-t">Summarize key findings</div>
                            </div>
                            <div class="sc" onclick="fill('Compare different perspectives')">
                                <div class="sc-i">🔍</div>
                                <div class="sc-t">Compare perspectives</div>
                            </div>
                            <div class="sc" onclick="fill('Generate a study guide')">
                                <div class="sc-i">💡</div>
                                <div class="sc-t">Generate study guide</div>
                            </div>
                            <div class="sc" onclick="fill('Create a FAQ from my sources')">
                                <div class="sc-i">❓</div>
                                <div class="sc-t">Create FAQ list</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="ciz">
                    <div class="ib">
                        <textarea class="ti" id="ti" placeholder="Ask anything about your sources…" rows="1"
                            oninput="this.style.height='auto';this.style.height=Math.min(this.scrollHeight,90)+'px'"
                            onkeydown="if(e=(event),(e.metaKey||e.ctrlKey)&&e.key==='Enter'){e.preventDefault();send()}"></textarea>
                        <button class="sb" onclick="send()">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                                <path d="M2 7h10M8 3l4 4-4 4" stroke="#fff" stroke-width="1.7" stroke-linecap="round"
                                    stroke-linejoin="round" />
                            </svg>
                        </button>
                    </div>
                    <div class="if">
                        <button class="ifb" onclick="fill('Summarize all sources')">✦ Summarize</button>
                        <button class="ifb" onclick="fill('Generate a study guide')">📋 Study guide</button>
                        <button class="ifb" onclick="fill('Create a timeline')">⏱ Timeline</button>
                        <span class="ifh">⌘↵ send</span>
                    </div>
                </div>
            </main>

            <!-- RIGHT: Notes / Discover / Map -->
            <div class="panel r-panel">
                <div class="rtabs">
                    <button class="rt on" onclick="rtab(this,'rn')">Notes</button>
                    <button class="rt" onclick="rtab(this,'rd')">Discover</button>
                    <button class="rt" onclick="rtab(this,'rm')">Mind Map</button>
                </div>

                <!-- Notes empty -->
                <div class="rbody" id="rn">
                    <div class="empty">
                        <div class="e-orb">
                            <svg viewBox="0 0 22 22" fill="none">
                                <rect x="4" y="3" width="14" height="16" rx="2" stroke="var(--a1)" stroke-width="1.4" />
                                <path d="M7 8h8M7 11h5M7 14h6" stroke="var(--a2)" stroke-width="1.3"
                                    stroke-linecap="round" />
                            </svg>
                        </div>
                        <div class="e-title">No notes yet</div>
                        <div class="e-desc">Save AI responses and highlights to build your notes</div>
                        <button class="e-btn">
                            <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                                <path d="M5 1v8M1 5h8" stroke="#fff" stroke-width="1.6" stroke-linecap="round" />
                            </svg>
                            New Note
                        </button>
                    </div>
                </div>

                <!-- Discover empty -->
                <div class="rbody" id="rd" style="display:none">
                    <div class="empty">
                        <div class="e-orb">
                            <svg viewBox="0 0 22 22" fill="none">
                                <circle cx="11" cy="11" r="6.5" stroke="var(--a1)" stroke-width="1.4" />
                                <path d="M11 7.5v3.5l2.5 1.5" stroke="var(--a2)" stroke-width="1.4"
                                    stroke-linecap="round" />
                                <circle cx="11" cy="11" r="1.3" fill="var(--a1)" />
                            </svg>
                        </div>
                        <div class="e-title">Nothing to discover</div>
                        <div class="e-desc">Add sources to unlock key topics, concepts, and insights</div>
                    </div>
                </div>

                <!-- Mind Map empty -->
                <div class="rbody" id="rm" style="display:none">
                    <div class="empty">
                        <div class="e-orb">
                            <svg viewBox="0 0 22 22" fill="none">
                                <circle cx="11" cy="11" r="2.4" fill="var(--a1)" opacity=".85" />
                                <circle cx="4" cy="6" r="1.8" stroke="var(--a2)" stroke-width="1.2" />
                                <circle cx="18" cy="6" r="1.8" stroke="var(--a2)" stroke-width="1.2" />
                                <circle cx="4" cy="16" r="1.8" stroke="var(--a2)" stroke-width="1.2" />
                                <circle cx="18" cy="16" r="1.8" stroke="var(--a2)" stroke-width="1.2" />
                                <line x1="8.5" y1="8.5" x2="11" y2="11" stroke="var(--a2)" stroke-width="1.1"
                                    opacity=".7" />
                                <line x1="13.5" y1="8.5" x2="11" y2="11" stroke="var(--a2)" stroke-width="1.1"
                                    opacity=".7" />
                                <line x1="8.5" y1="13.5" x2="11" y2="11" stroke="var(--a2)" stroke-width="1.1"
                                    opacity=".7" />
                                <line x1="13.5" y1="13.5" x2="11" y2="11" stroke="var(--a2)" stroke-width="1.1"
                                    opacity=".7" />
                            </svg>
                        </div>
                        <div class="e-title">No concept graph</div>
                        <div class="e-desc">A mind map generates automatically once sources are added</div>
                    </div>
                </div>
            </div>

        </div><!-- /row -->

        <!-- ═══ FOOTER ═══ -->
        <footer>
            <span class="ft-v">v1.0.0</span>
            <span class="ft-r">© 2025 NoteMind. All rights reserved.</span>
        </footer>

    </div><!-- /app -->

    <script>
        /* Theme */
        function toggleTheme() {
            const h = document.documentElement, b = document.getElementById('themeBtn');
            const dark = h.getAttribute('data-theme') === 'dark';
            h.setAttribute('data-theme', dark ? 'light' : 'dark');
            b.textContent = dark ? '🌙' : '☀️';
        }

        /* Right tabs */
        function rtab(btn, id) {
            document.querySelectorAll('.rt').forEach(t => t.classList.remove('on'));
            btn.classList.add('on');
            ['rn', 'rd', 'rm'].forEach(n => {
                const el = document.getElementById(n);
                if (el) el.style.display = n === id ? 'flex' : 'none';
            });
        }
        document.getElementById('rn').style.display = 'flex';

        /* Fill input */
        function fill(t) {
            const ta = document.getElementById('ti');
            ta.value = t; ta.style.height = 'auto';
            ta.style.height = Math.min(ta.scrollHeight, 90) + 'px';
            ta.focus();
        }

        /* Send */
        const replies = [
            "Based on your sources, here's what I found — the documents highlight several key themes worth exploring.",
            "Great question! Your sources collectively suggest a nuanced perspective on this topic.",
            "Across the documents you've uploaded, three main threads stand out consistently.",
            "I've analyzed the relevant sections. The evidence points to a strong correlation here.",
        ];
        let ri = 0;
        function send() {
            const ta = document.getElementById('ti');
            const msgs = document.getElementById('msgs');
            const wl = document.getElementById('welcome');
            const t = ta.value.trim(); if (!t) return;
            if (wl) wl.remove();

            // User bubble
            const u = document.createElement('div');
            u.style.cssText = 'display:flex;justify-content:flex-end;margin:6px 0;animation:fadeUp .25s ease both';
            u.innerHTML = `<div style="max-width:72%;padding:9px 14px;border-radius:14px 14px 4px 14px;background:var(--grad-btn);color:#fff;font-family:'DM Sans',sans-serif;font-size:13px;line-height:1.55;box-shadow:0 3px 14px rgba(124,58,237,0.28)">${esc(t)}</div>`;
            msgs.appendChild(u);
            ta.value = ''; ta.style.height = 'auto';

            // Typing
            const tp = document.createElement('div');
            tp.style.cssText = 'display:flex;gap:10px;align-items:flex-start;margin:6px 0;animation:fadeUp .25s ease both';
            tp.innerHTML = `<div style="width:28px;height:28px;border-radius:50%;background:var(--grad-btn);display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:var(--shadow-btn)"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 9l3-6 2 4 1.5-2.5L11 9H2z" fill="#fff" opacity=".9"/></svg></div><div style="padding:9px 13px;border-radius:4px 13px 13px 13px;background:var(--s2);border:1px solid var(--border);display:flex;gap:4px;align-items:center"><span style="width:5px;height:5px;border-radius:50%;background:var(--a1);animation:blink 1s 0s infinite"></span><span style="width:5px;height:5px;border-radius:50%;background:var(--a2);animation:blink 1s .2s infinite"></span><span style="width:5px;height:5px;border-radius:50%;background:var(--a3);animation:blink 1s .4s infinite"></span></div>`;
            msgs.appendChild(tp); msgs.scrollTop = msgs.scrollHeight;

            setTimeout(() => {
                tp.remove();
                const ai = document.createElement('div');
                ai.style.cssText = 'display:flex;gap:10px;align-items:flex-start;margin:6px 0;animation:fadeUp .25s ease both';
                ai.innerHTML = `<div style="width:28px;height:28px;border-radius:50%;background:var(--grad-btn);display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:var(--shadow-btn)"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 9l3-6 2 4 1.5-2.5L11 9H2z" fill="#fff" opacity=".9"/></svg></div><div style="flex:1;min-width:0"><div style="font-family:'DM Sans',sans-serif;font-size:10.5px;font-weight:600;color:var(--text4);margin-bottom:4px;letter-spacing:.03em;text-transform:uppercase">NoteMind AI</div><div style="padding:10px 13px;border-radius:4px 13px 13px 13px;background:var(--s2);border:1px solid var(--border);font-family:'DM Sans',sans-serif;font-size:13px;line-height:1.6;color:var(--text)">${replies[ri++ % replies.length]}</div></div>`;
                msgs.appendChild(ai); msgs.scrollTop = msgs.scrollHeight;
            }, 1200);
        }
        function esc(s) { return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;') }
    </script>
</body>

</html>
