import { createAsyncThunk, createSlice, PayloadAction } from '@reduxjs/toolkit';
import {
  Department,
  UpdateEmployeeAccessRequest,
  UpdateTeamAccessRequest,
  fetchTeamAccessApi,
  updateEmployeeAccessApi,
  updateTeamAccessApi,
} from '../../api/accessManagementApi';

interface AccessManagementState {
  departments: Department[];
  loading: boolean;
  error: string | null;
  updatingTeams: boolean;
  updatingEmployees: boolean;
}

const initialState: AccessManagementState = {
  departments: [],
  loading: false,
  error: null,
  updatingTeams: false,
  updatingEmployees: false,
};

export const fetchTeamAccess = createAsyncThunk(
  'accessManagement/fetchTeamAccess',
  async (_, { rejectWithValue }) => {
    try {
      return await fetchTeamAccessApi();
    } catch (err: unknown) {
      return rejectWithValue(err instanceof Error ? err.message : 'Failed to fetch');
    }
  }
);

export const updateTeamAccess = createAsyncThunk(
  'accessManagement/updateTeamAccess',
  async (payload: UpdateTeamAccessRequest[], { rejectWithValue, dispatch }) => {
    try {
      await updateTeamAccessApi(payload);
      dispatch(fetchTeamAccess());
      return payload;
    } catch (err: unknown) {
      return rejectWithValue(err instanceof Error ? err.message : 'Failed to update team access');
    }
  }
);

export const updateEmployeeAccess = createAsyncThunk(
  'accessManagement/updateEmployeeAccess',
  async (
    payload: { updates: UpdateEmployeeAccessRequest[]; dept_name: string },
    { rejectWithValue, dispatch }
  ) => {
    try {
      await updateEmployeeAccessApi(payload.updates);
      dispatch(fetchTeamAccess());
      return payload;
    } catch (err: unknown) {
      return rejectWithValue(err instanceof Error ? err.message : 'Failed to update employee access');
    }
  }
);

const accessManagementSlice = createSlice({
  name: 'accessManagement',
  initialState,
  reducers: {},
  extraReducers: (builder) => {
    builder
      .addCase(fetchTeamAccess.pending, (state) => {
        state.loading = true;
        state.error = null;
      })
      .addCase(fetchTeamAccess.fulfilled, (state, action: PayloadAction<Department[]>) => {
        state.loading = false;
        state.departments = action.payload;
      })
      .addCase(fetchTeamAccess.rejected, (state, action) => {
        state.loading = false;
        state.error = action.payload as string;
      })
      .addCase(updateTeamAccess.pending, (state) => {
        state.updatingTeams = true;
      })
      .addCase(updateTeamAccess.fulfilled, (state) => {
        state.updatingTeams = false;
      })
      .addCase(updateTeamAccess.rejected, (state) => {
        state.updatingTeams = false;
      })
      .addCase(updateEmployeeAccess.pending, (state) => {
        state.updatingEmployees = true;
      })
      .addCase(updateEmployeeAccess.fulfilled, (state) => {
        state.updatingEmployees = false;
      })
      .addCase(updateEmployeeAccess.rejected, (state) => {
        state.updatingEmployees = false;
      });
  },
});

export default accessManagementSlice.reducer;













