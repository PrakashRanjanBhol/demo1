<div class="panel">

  <!-- ── Panel Header ── -->
  <div class="panel-header">
    <div class="header-left">
      <h2 class="panel-title">History</h2>
      <div class="date-range" *ngIf="startDate && endDate">
        <svg class="date-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
        </svg>
        <span class="date-text">{{ startDate }}</span>
        <svg class="arrow-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
        <span class="date-text">{{ endDate }}</span>
      </div>
    </div>

    <div class="header-actions">
      <!-- Filter toggle -->
      <button class="icon-btn"
              [class.active]="isFilterVisible"
              [disabled]="isActionsDisabled"
              (click)="toggleFilter()"
              title="Filter">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z" />
        </svg>
      </button>

      <!-- Export mode toggle -->
      <button class="icon-btn icon-btn--export"
              *ngIf="hasAnyFiles"
              [class.active]="isExportMode"
              [disabled]="isActionsDisabled"
              (click)="toggleExportMode()"
              title="Export files">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
        </svg>
      </button>

      <!-- Delete mode toggle -->
      <button class="icon-btn icon-btn--danger"
              *ngIf="hasAnyFiles"
              [class.active]="isDeleteMode"
              [disabled]="isActionsDisabled || isProcessingDelete"
              (click)="toggleDeleteMode()"
              title="Delete files">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
        </svg>
      </button>

      <!-- Inference mode toggle — only shown when no running/queued files -->
      <button class="icon-btn icon-btn--inference"
              *ngIf="canUseInferenceMode"
              [class.active]="isInferenceMode"
              [disabled]="isActionsDisabled"
              (click)="toggleInferenceMode()"
              title="Run batch inference">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z" />
        </svg>
      </button>
    </div>
  </div>

  <!-- ── Filter Section ── -->
  <div class="filter-section" *ngIf="isFilterVisible">
    <div class="filter-group">
      <label class="filter-label">Date Range</label>
      <div class="date-filter">
        <div class="date-input-wrapper">
          <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
          </svg>
          <input type="date" class="date-input" [(ngModel)]="filterFromDate">
        </div>
        <span class="date-separator">to</span>
        <div class="date-input-wrapper">
          <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
          </svg>
          <input type="date" class="date-input" [(ngModel)]="filterToDate">
        </div>
        <button class="refresh-btn" (click)="applyDateFilter()" [disabled]="isRefreshing">
          <svg [class.spinning]="isRefreshing" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
          </svg>
        </button>
      </div>
    </div>

    <div class="filter-group">
      <label class="filter-label">Search</label>
      <div class="search-input-wrapper">
        <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
        </svg>
        <input type="text" class="search-input" [(ngModel)]="searchText" (ngModelChange)="onSearchChange()" placeholder="Search by file name or ID...">
        <button class="clear-search-btn" *ngIf="searchText" (click)="clearSearch()">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- ── Live Poll Bar ── -->
  <div class="poll-bar" *ngIf="isLivePolling">
    <span class="pulse-dot"></span>
    <span class="poll-text">
      Live — refreshing in <strong>{{ pollCountdown }}s</strong>
      <span class="poll-detail" *ngIf="liveFileCount">&nbsp;·&nbsp;{{ liveFileCount }}</span>
    </span>
  </div>

  <!-- ── Delete Action Bar ── -->
  <div class="delete-action-bar" *ngIf="isDeleteMode">
    <span class="delete-action-info">{{ selectedDeleteItems.size }} file(s) selected</span>
    <div class="delete-action-buttons">
      <button class="cancel-btn" (click)="cancelMultipleDelete()">Cancel</button>
      <button class="confirm-delete-btn" [disabled]="selectedDeleteItems.size === 0" (click)="showDeleteConfirmation()">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
        </svg>
        Delete ({{ selectedDeleteItems.size }})
      </button>
    </div>
  </div>

  <!-- ── Inference Action Bar ── -->
  <div class="inference-action-bar" *ngIf="isInferenceMode">
    <div class="inference-action-info">
      <svg class="inference-info-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
      </svg>
      <span>{{ inferenceSelectionCount }} file(s) selected for inference</span>
    </div>
    <div class="inference-action-buttons">
      <button class="cancel-btn" (click)="cancelInference()">Cancel</button>
      <button class="start-inference-btn"
              [disabled]="inferenceSelectionCount === 0 || isSubmittingBatch"
              (click)="startBatchInference()">
        <svg *ngIf="isSubmittingBatch" class="spinning" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
        <svg *ngIf="!isSubmittingBatch" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.348a1.125 1.125 0 010 1.971l-11.54 6.347a1.125 1.125 0 01-1.667-.985V5.653z" />
        </svg>
        {{ isSubmittingBatch ? 'Starting...' : 'Run Inference (' + inferenceSelectionCount + ')' }}
      </button>
    </div>
  </div>

  <!-- ── Export Action Bar ── -->
  <div class="export-action-bar" *ngIf="isExportMode">
    <div class="export-action-info">
      <svg class="export-info-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
      </svg>
      <span>{{ exportSelectionCount }} file(s) selected for export</span>
    </div>
    <div class="export-action-buttons">
      <button class="cancel-btn" (click)="cancelExport()">Cancel</button>
      <button class="start-export-btn"
              [disabled]="exportSelectionCount === 0 || isExporting"
              (click)="startExport()">
        <svg *ngIf="isExporting" class="spinning" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
        <svg *ngIf="!isExporting" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
        </svg>
        {{ isExporting ? 'Exporting...' : 'Export (' + exportSelectionCount + ')' }}
      </button>
    </div>
  </div>

  <!-- ── Panel Content ── -->
  <div class="panel-content">

    <!-- Loading skeletons -->
    <ng-container *ngIf="isLoading">
      <div class="section-block">
        <div class="skeleton-header"></div>
        <div class="skeleton-row" *ngFor="let i of [1,2,3]">
          <div class="skeleton-icon"></div>
          <div class="skeleton-details">
            <div class="skeleton-name"></div>
            <div class="skeleton-date"></div>
          </div>
          <div class="skeleton-badge"></div>
        </div>
      </div>
    </ng-container>

    <!-- Empty state -->
    <div class="empty-state" *ngIf="!isLoading && !hasAnyFiles">
      <div class="empty-icon">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z" />
        </svg>
      </div>
      <h3 class="empty-title">No History Available</h3>
      <p class="empty-desc">Upload your first file to get started</p>

      <div class="guide-steps">
        <div class="guide-step" *ngFor="let step of (showAllSteps ? allSteps : allSteps.slice(0,4))">
          <div class="step-num">{{ step.num }}</div>
          <div>
            <p class="step-title">{{ step.title }}</p>
            <p class="step-desc" [innerHTML]="step.desc"></p>
          </div>
        </div>
        <button class="view-more-btn" (click)="toggleShowAllSteps()">
          {{ showAllSteps ? 'Show less' : 'View +2 more steps' }}
        </button>
      </div>
    </div>

    <!-- ── File Sections ── -->
    <ng-container *ngIf="!isLoading && hasAnyFiles">

      <!-- RUNNING -->
      <div class="section-block section-block--running" *ngIf="runningFiles.length > 0 || isRefreshing">
        <div class="section-header" (click)="toggleSection('running')">
          <span class="status-dot status-dot--running"></span>
          <span class="section-label">Running</span>
          <span class="section-count">{{ isRefreshing ? '…' : runningFiles.length }} files</span>
          <div class="select-all-wrap" *ngIf="isDeleteMode" (click)="$event.stopPropagation(); toggleSelectAll('running')">
            <div class="checkbox" [class.checked]="areAllSelected('running')">
              <svg *ngIf="areAllSelected('running')" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            </div>
          </div>
          <div class="select-all-wrap" *ngIf="isExportMode" (click)="$event.stopPropagation(); toggleSelectAllExport('running')">
            <div class="checkbox checkbox--export" [class.checked]="areAllSelectedForExport('running')">
              <svg *ngIf="areAllSelectedForExport('running')" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            </div>
          </div>
          <button class="chevron-btn" [class.collapsed]="!sectionExpanded['running']">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
          </button>
        </div>

        <div class="section-body" *ngIf="sectionExpanded['running']">
          <div class="file-row running-row"
               *ngFor="let item of runningFiles"
               [attr.data-item-id]="item.id"
               [class.selected]="selectedHistoryItem?.id === item.id"
               [class.delete-selected]="isDeleteMode && isSelectedForDelete(item.id)"
               [class.export-selected]="isExportMode && isSelectedForExport(item.id)"
               (click)="onHistoryItemClick(item.id)">

            <div class="delete-checkbox" *ngIf="isDeleteMode" (click)="$event.stopPropagation(); toggleDeleteSelection(item.id)">
              <div class="checkbox" [class.checked]="isSelectedForDelete(item.id)">
                <svg *ngIf="isSelectedForDelete(item.id)" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              </div>
            </div>

            <div class="delete-checkbox" *ngIf="isExportMode" (click)="$event.stopPropagation(); toggleExportSelection(item.id, $event)">
              <div class="checkbox checkbox--export" [class.checked]="isSelectedForExport(item.id)">
                <svg *ngIf="isSelectedForExport(item.id)" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              </div>
            </div>

            <div class="file-icon file-icon--running">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" />
              </svg>
            </div>

            <div class="file-info">
              <p class="file-name">
                <span class="file-id">#{{ item.id }}</span>
                <span class="file-name-text">{{ item.name }}</span>
              </p>
              <p class="file-date">{{ item.displayDate }}</p>
              <div class="progress-wrap">
                <div class="progress-track">
                  <div class="progress-fill progress-fill--running" [style.width.%]="item.progress"></div>
                </div>
                <span class="progress-pct">{{ item.progress }}%</span>
              </div>
            </div>

            <div class="file-actions">
              <span class="badge badge--running">running</span>
            </div>
          </div>

          <div class="no-results" *ngIf="!isRefreshing && runningFiles.length === 0">
            <p>No running files</p>
          </div>
        </div>
      </div>

      <!-- QUEUED -->
      <div class="section-block section-block--queued" *ngIf="queuedFiles.length > 0">
        <div class="section-header" (click)="toggleSection('queued')">
          <span class="status-dot status-dot--queued"></span>
          <span class="section-label">Queued</span>
          <span class="section-count">{{ queuedFiles.length }} files</span>
          <div class="select-all-wrap" *ngIf="isDeleteMode" (click)="$event.stopPropagation(); toggleSelectAll('queued')">
            <div class="checkbox" [class.checked]="areAllSelected('queued')">
              <svg *ngIf="areAllSelected('queued')" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            </div>
          </div>
          <div class="select-all-wrap" *ngIf="isExportMode" (click)="$event.stopPropagation(); toggleSelectAllExport('queued')">
            <div class="checkbox checkbox--export" [class.checked]="areAllSelectedForExport('queued')">
              <svg *ngIf="areAllSelectedForExport('queued')" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            </div>
          </div>
          <button class="chevron-btn" [class.collapsed]="!sectionExpanded['queued']">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
          </button>
        </div>

        <div class="section-body" *ngIf="sectionExpanded['queued']">
          <div class="file-row"
               *ngFor="let item of queuedFiles; let idx = index"
               [attr.data-item-id]="item.id"
               [class.selected]="selectedHistoryItem?.id === item.id"
               [class.delete-selected]="isDeleteMode && isSelectedForDelete(item.id)"
               [class.export-selected]="isExportMode && isSelectedForExport(item.id)"
