.tableScroll {
  flex: 1;
  overflow-y: auto;

  &::-webkit-scrollbar {
    width: 5px;
  }

  &::-webkit-scrollbar-track {
    background: transparent;
  }

  &::-webkit-scrollbar-thumb {
    background: var(--border-color);
    border-radius: 999px;

    &:hover {
      background: var(--text-secondary);
    }
  }
}

table {
  width: auto;
  min-width: 100%;
  border-collapse: collapse;
}

thead {
  position: sticky;
  top: 0;
  z-index: 2;
  background: var(--table-thead-bg);

  th {
    padding: 11px 20px;
    text-align: left;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-color);
    white-space: nowrap;
    cursor: pointer;
    user-select: none;
    transition: color 0.15s ease;

    &:hover {
      color: var(--text-primary);
    }

    .thInner {
      display: inline-flex;
      align-items: center;
      gap: 5px;
    }

    .sortIcon {
      display: inline-flex;
      flex-direction: column;
      gap: 1.5px;

      span {
        display: block;
        width: 0;
        height: 0;
        border-left: 3.5px solid transparent;
        border-right: 3.5px solid transparent;

        &.up {
          border-bottom: 4px solid var(--text-secondary);

          &.active {
            border-bottom-color: var(--btn-bg);
          }
        }

        &.down {
          border-top: 4px solid var(--text-secondary);

          &.active {
            border-top-color: var(--btn-bg);
          }
        }
      }
    }
  }
}

tbody {
  tr {
    border-bottom: 1px solid var(--border-color);
    transition: background 0.12s ease;

    &:last-child {
      border-bottom: none;
    }

    &:nth-child(odd) {
      background: var(--table-row-odd);
    }

    &:nth-child(even) {
      background: var(--table-row-even);
    }

    &:hover {
      background: var(--hover-bg);
    }
  }

  td {
    padding: 13px 20px;
    font-size: 0.95rem;
    color: var(--text-secondary);
    white-space: nowrap;
  }
}

.emptyState {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 56px 20px;
  gap: 10px;

  svg {
    width: 36px;
    height: 36px;
    color: var(--text-secondary);
    opacity: 0.5;
  }

  p {
    margin: 0;
    font-size: 0.875rem;
    color: var(--text-secondary);
  }
}

.pagination {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 20px;
  border-top: 1px solid var(--border-color);
  background: var(--table-thead-bg);
  flex-shrink: 0;

  .pageInfo {
    font-size: 0.78125rem;
    color: var(--text-secondary);
  }

  .pageControls {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .navBtn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    background: var(--content-bg);
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.15s ease;

    svg {
      width: 16px;
      height: 16px;
      display: block;
    }

    &:hover:not(:disabled) {
      background: var(--hover-bg);
      border-color: var(--btn-bg);
      color: var(--btn-bg);
    }

    &:disabled {
      opacity: 0.35;
      cursor: not-allowed;
    }
  }

  .pageDots {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    padding: 0 2px;
    user-select: none;
  }

  .pageBtn {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 32px;
    height: 32px;
    padding: 0 6px;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    background: var(--content-bg);
    color: var(--text-secondary);
    font-size: 0.8125rem;
    font-family: system-ui, sans-serif;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s ease;

    &:hover:not(.activePage) {
      background: var(--hover-bg);
      border-color: var(--btn-bg);
      color: var(--btn-bg);
    }

    &.activePage {
      background: var(--btn-bg);
      border-color: var(--btn-bg);
      color: var(--btn-text);
      font-weight: 700;
      box-shadow: 0 2px 8px var(--box-shadow);
    }
  }
}






















