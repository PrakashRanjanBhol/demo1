:global(:root) {
  --sl-bg: #f5f4ff;
  --sl-surface: #ffffff;
  --sl-s2: #f7f6ff;
  --sl-s3: #eeecff;
  --sl-border: rgba(79, 70, 229, 0.11);
  --sl-border-h: rgba(79, 70, 229, 0.24);
  --sl-text: #0f0c1d;
  --sl-text2: #3d3656;
  --sl-text3: #7a738f;
  --sl-text4: #b0abc4;
  --sl-sp: 0 1px 2px rgba(0,0,0,0.04), 0 4px 12px rgba(0,0,0,0.05), 0 8px 32px rgba(79,70,229,0.08);
  --sl-sh: 0 2px 6px rgba(0,0,0,0.07), 0 10px 32px rgba(79,70,229,0.13), 0 20px 60px rgba(79,70,229,0.07);
  --sl-grad: linear-gradient(135deg, #7c3aed 0%, #4f46e5 35%, #2563eb 65%, #0ea5e9 100%);
  --sl-grad-btn: linear-gradient(135deg, #7c3aed 0%, #4f46e5 50%, #2563eb 100%);
  --sl-accent: #4f46e5;
  --sl-accent-light: #eef2ff;
  --sl-orb: linear-gradient(135deg, #ede9fe, #ddd6fe);
  --sl-orb-sh: 0 4px 20px rgba(124, 58, 237, 0.18);
  --sl-radius: 16px;
}

:global([data-theme='dark']) {
  --sl-bg: #0a0a0b;
  --sl-surface: #121214;
  --sl-s2: #18171f;
  --sl-s3: #1f1e2a;
  --sl-border: rgba(124, 58, 237, 0.13);
  --sl-border-h: rgba(124, 58, 237, 0.30);
  --sl-text: #f2eeff;
  --sl-text2: #c4bbdd;
  --sl-text3: #7b6f9a;
  --sl-text4: #4a4264;
  --sl-sp: 0 1px 0 rgba(124,58,237,0.09) inset, 0 0 0 1px rgba(124,58,237,0.06) inset, 0 8px 36px rgba(0,0,0,0.55), 0 2px 8px rgba(0,0,0,0.35);
  --sl-sh: 0 1px 0 rgba(124,58,237,0.16) inset, 0 0 0 1px rgba(124,58,237,0.10) inset, 0 16px 52px rgba(0,0,0,0.70), 0 4px 16px rgba(124,58,237,0.08);
  --sl-grad: linear-gradient(135deg, #7c3aed 0%, #4f46e5 35%, #2563eb 65%, #0ea5e9 100%);
  --sl-grad-btn: linear-gradient(135deg, #7c3aed 0%, #4f46e5 50%, #2563eb 100%);
  --sl-accent: #a78bfa;
  --sl-accent-light: rgba(124, 58, 237, 0.14);
  --sl-orb: linear-gradient(135deg, rgba(124,58,237,0.26), rgba(79,70,229,0.16));
  --sl-orb-sh: 0 4px 20px rgba(124, 58, 237, 0.32);
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes breathe {
  0%, 100% { opacity: 0.5; transform: scale(1); }
  50%       { opacity: 1;   transform: scale(1.06); }
}

.layout {
  display: flex;
  flex: 1;
  overflow: hidden;
  gap: 9px;
  padding: 0 9px;
  background: var(--sl-bg);
  min-height: 0;
}

/* ── PANEL BASE ── */
.panel {
  border-radius: var(--sl-radius);
  background: var(--sl-surface);
  border: 1px solid var(--sl-border);
  box-shadow: var(--sl-sp);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  position: relative;
  transition: box-shadow 0.25s, border-color 0.25s, background 0.25s;
  animation: slideUp 0.45s cubic-bezier(0.16, 1, 0.3, 1) both;

  &:hover {
    box-shadow: var(--sl-sh);
    border-color: var(--sl-border-h);
  }

  // top shimmer line
  &::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(124, 58, 237, 0.18) 15%,
      rgba(99,  60, 220, 0.38) 36%,
      rgba(79,  70, 229, 0.42) 50%,
      rgba(37,  99, 235, 0.32) 68%,
      rgba(14, 165, 233, 0.18) 85%,
      transparent 100%
    );
    pointer-events: none;
  }
}

.sidebar {
  composes: panel;
  width: 280px;
  flex-shrink: 0;
  animation-delay: 0.04s;
}

.content {
  composes: panel;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  animation-delay: 0.08s;
}

/* ── PANEL HEAD ── */
.panelHead {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 13px 16px 12px;
  border-bottom: 1px solid var(--sl-border);
  flex-shrink: 0;
}

.panelLabel {
  font-size: 0.625rem;
  font-weight: 600;
  letter-spacing: 0.09em;
  text-transform: uppercase;
  color: var(--sl-accent);
  display: flex;
  align-items: center;
  gap: 5px;
}

.panelDot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--sl-accent);
  box-shadow: 0 0 6px rgba(79, 70, 229, 0.6);
}

/* ── NAV LINKS ── */
.navBody {
  flex: 1;
  overflow-y: auto;
  padding: 8px 8px;
  display: flex;
  flex-direction: column;
  gap: 2px;

  &::-webkit-scrollbar { width: 3px; }
  &::-webkit-scrollbar-thumb {
    background: rgba(124, 58, 237, 0.18);
    border-radius: 2px;
  }
}

.navLink {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 12px;
  border-radius: 10px;
  text-decoration: none;
  font-size: 0.8125rem;
  font-weight: 500;
  color: var(--sl-text3);
  position: relative;
  z-index: 1;
  transition: color 0.2s ease;

  &::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 10px;
    background: transparent;
    z-index: -1;
    transition:
      background 0.22s cubic-bezier(0.4, 0, 0.2, 1),
      transform  0.22s cubic-bezier(0.4, 0, 0.2, 1),
      opacity    0.22s cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 0.22s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    transform: scaleX(0.93) scaleY(0.88);
  }

  &:hover {
    color: var(--sl-text);

    &::before {
      background: var(--sl-s2);
      opacity: 1;
      transform: scaleX(1) scaleY(1);
    }

    .navIcon {
      color: var(--sl-accent);
      border-color: var(--sl-border-h);
      background: var(--sl-s3);
    }
  }

  &.active {
    color: var(--sl-accent);
    font-weight: 600;

    &::before {
      background: var(--sl-accent-light);
      opacity: 1;
      transform: scaleX(1) scaleY(1);
      box-shadow:
        0 2px 8px rgba(79, 70, 229, 0.10),
        inset 0 0 0 1px rgba(79, 70, 229, 0.13);
    }

    .navIcon {
      color: var(--sl-accent);
      border-color: rgba(79, 70, 229, 0.28);
      background: var(--sl-surface);
      box-shadow: 0 1px 4px rgba(79, 70, 229, 0.15);
    }

    .activePill {
      opacity: 1;
      transform: scale(1);
    }
  }
}

.navIcon {
  width: 30px;
  height: 30px;
  border-radius: 8px;
  background: var(--sl-s2);
  border: 1px solid var(--sl-border);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: var(--sl-text3);
  transition: all 0.22s cubic-bezier(0.4, 0, 0.2, 1);

  svg {
    width: 14px;
    height: 14px;
    transition: transform 0.22s cubic-bezier(0.4, 0, 0.2, 1);
  }
}

.navLink:hover .navIcon svg,
.navLink.active .navIcon svg {
  transform: scale(1.1);
}

.navLabel {
  flex: 1;
  transition: transform 0.22s cubic-bezier(0.4, 0, 0.2, 1);
}

.navLink.active .navLabel {
  transform: translateX(2px);
}

.activePill {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--sl-accent);
  box-shadow: 0 0 6px rgba(79, 70, 229, 0.5);
  opacity: 0;
  transform: scale(0.4);
  transition:
    opacity   0.22s cubic-bezier(0.4, 0, 0.2, 1),
    transform 0.22s cubic-bezier(0.4, 0, 0.2, 1);
  flex-shrink: 0;
}

/* ── SIDEBAR HEADER SECTION ── */
.sidebarHeader {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px 16px 14px;
  border-bottom: 1px solid var(--sl-border);
  margin-bottom: 4px;
  flex-shrink: 0;
}

.headerOrb {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: var(--sl-orb);
  border: 1px solid var(--sl-border-h);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: var(--sl-orb-sh);
  position: relative;

  &::before {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 14px;
    background: radial-gradient(ellipse, rgba(124, 58, 237, 0.12) 0%, transparent 70%);
    animation: breathe 3.5s ease-in-out infinite;
  }

  svg {
    width: 16px;
    height: 16px;
    position: relative;
    z-index: 1;
  }
}

.headerText {
  display: flex;
  flex-direction: column;
  gap: 2px;

  .headerTitle {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--sl-text);
    letter-spacing: -0.01em;
  }

  .headerSub {
    font-size: 0.6875rem;
    color: var(--sl-text4);
  }
}

.sectionLabel {
  font-size: 0.5875rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--sl-text4);
  padding: 8px 13px 4px;
}

/* ── CONTENT AREA ── */
.contentInner {
  flex: 1;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  min-height: 0;
  padding: 28px 32px;
}

@media (min-width: 1400px) {
  .sidebar { width: 300px; }
  .contentInner { padding: 36px 44px; }
  .navLink { font-size: 0.875rem; padding: 10px 14px; }
  .navIcon { width: 32px; height: 32px; }
  .headerTitle { font-size: 0.9375rem !important; }
  .headerOrb { width: 40px; height: 40px; }
}














