/* YOUR existing rule — just change the overflow value */
.session-container {
  overflow-x: hidden;
}

/* Add this to keep the glow from bleeding */
.session-card-wrapper {
  position: relative;
  border-radius: 10px 0 10px 0;
  padding: 2px;
  background: transparent;
  margin: 10px;        /* keep spacing */
  width: calc(100% - 20px); /* stay within sidebar */
}

.session-card-wrapper .session-card {
  margin: 0;
  width: 100%;
  box-sizing: border-box;
}
