.toolCard {
  position: relative;
  overflow: hidden;
  z-index: 0;

  /* spinning border arc */
  &::before {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: 13px;
    background: conic-gradient(
      from var(--angle, 0deg),
      transparent   0%,
      transparent  35%,
      currentColor 45%,
      currentColor 55%,
      transparent  65%,
      transparent 100%
    );
    z-index: -1;
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  /* inner mask — fills card body, hides ::before except at border */
  &::after {
    content: '';
    position: absolute;
    inset: 1.5px;
    border-radius: 11px;
    background: var(--app-bg);       /* resting state */
    z-index: -1;
    transition: background 0.15s ease;
  }

  &:hover::before { opacity: 1; animation: borderSpin 2s linear infinite; }
}

/* ── Per-tool: accent color + matching ::after on hover ── */

.toolCard__jira {
  border-left: 3px solid var(--card-jira-accent);

  &:hover {
    color: var(--card-jira-accent);
    background: var(--card-jira-hover-bg);
    border-color: var(--card-jira-hover-border);
    border-left-color: var(--card-jira-accent);
    box-shadow: 0 2px 10px var(--box-shadow);
    transform: translateY(-1px);

    &::after { background: var(--card-jira-hover-bg); }   /* ← sync */

    .cardIconWrap { border-color: var(--card-jira-hover-border); }
    .cardName     { color: var(--card-jira-accent); }
  }
}

