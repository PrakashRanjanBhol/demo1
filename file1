@media (min-width: 1400px) {
  .formCard {
    max-width: 620px;
    padding: 40px;
    gap: 32px;
  }

  .label {
    font-size: 0.9375rem;
  }

  .hint {
    font-size: 0.8125rem;
  }

  .input {
    font-size: 0.9375rem;
    padding: 12px 16px;
  }

  .unit {
    font-size: 0.875rem;
    padding: 12px 16px;
  }

  .saveBtn {
    font-size: 0.9375rem;
    padding: 12px 28px;
  }
}
