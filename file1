import axiosInstance from './axiosInstance';

export interface AdminSettings {
  file_size_limit: number;
  no_of_file_upload: number;
}

export interface AdminSettingsResponse {
  status: 'Success' | 'Error';
  result: AdminSettings;
}

export const fetchAdminSettingsApi = async (): Promise<AdminSettings> => {
  const response = await axiosInstance.get<AdminSettingsResponse>('/auth/get_admin_settings');
  return response.data.result;
};

export const saveAdminSettingsApi = async (payload: AdminSettings): Promise<void> => {
  await axiosInstance.post('/auth/save_admin_settings', payload);
};













