import React, { useEffect, useState } from "react";
import { useDispatch, useSelector } from "react-redux";
import type { AppDispatch, RootState } from "../../store";
import styles from "./PanelTools.module.scss";

import { AtlassianConnect } from "./AtlassianConnect";
import { JiraTool } from "./JiraTool";
import { ConfluenceTool } from "./ConfluenceTool";
import { setActiveTool, clearActiveTool } from "./toolSlice";
import type { ToolId } from "./toolSlice";
import { setupAtlassianInterceptor } from "./atlassianService";

import jiraIcon from "../../assets/icons/jira.png";
import confluenceIcon from "../../assets/icons/confluence.webp";
import summaryIcon from "../../assets/icons/summary.png";

interface Tool {
  id: NonNullable<ToolId> | "summary";
  name: string;
  icon: string;
}

const tools: Tool[] = [
  { id: "jira",       name: "Jira",       icon: jiraIcon },
  { id: "confluence", name: "Confluence", icon: confluenceIcon },
  { id: "summary",    name: "Summary",    icon: summaryIcon },
];

export const PanelTools: React.FC = () => {
  const dispatch = useDispatch<AppDispatch>();
  const [selectedToolId, setSelectedToolId] = useState<ToolId>(null);

  const isExpanded: boolean = useSelector(
    (state: RootState) => state.layout.isRightPanelOpen
  );
  const isConnected: boolean = useSelector(
    (state: RootState) => state.atlassian.isConnected
  );
  const activeTool = useSelector(
    (state: RootState) => state.tool.activeTool
  );

  useEffect(() => {
    setupAtlassianInterceptor(dispatch);
  }, [dispatch]);

  useEffect(() => {
    if (!isConnected && selectedToolId === null && activeTool) {
      setSelectedToolId(activeTool);
    }
  }, [isConnected]);

  const handleSelect = (id: NonNullable<ToolId> | "summary") => {
    if (id === "summary") {
      console.log("Hello");
      return;
    }
    setSelectedToolId(id);
    dispatch(setActiveTool(id));
  };

  const handleBack = () => {
    setSelectedToolId(null);
    dispatch(clearActiveTool());
  };

  const renderToolContent = () => {
    if (selectedToolId) {
      if (!isConnected) return <AtlassianConnect toolId={selectedToolId} onBack={handleBack} />;
      if (selectedToolId === "jira") return <JiraTool onBack={handleBack} />;
      if (selectedToolId === "confluence") return <ConfluenceTool onBack={handleBack} />;
    }

    return (
      <>
        <div className={styles.panelHeader}>
          <span className={styles.panelTitle}>Tools</span>
        </div>
        <div className={styles.toolGrid}>
          {tools.map(({ id, name, icon }) => (
            <button
              key={id}
              className={`${styles.toolCard} ${styles[`toolCard__${id}`]}`}
              onClick={() => handleSelect(id)}
            >
              <span className={styles.cardIconWrap}>
                <img src={icon} alt={name} width={16} height={16} className={styles.cardIcon} />
              </span>
              <span className={styles.cardName}>{name}</span>
            </button>
          ))}
        </div>

        <div className={styles.panelSeparator} />

        <div className={styles.panelHint}>
          <span className={styles.panelHintIcon}>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
              <path d="M15 4V2" /><path d="M15 16v-2" /><path d="M8 9h2" /><path d="M20 9h2" />
              <path d="M17.8 11.8 19 13" /><path d="M15 9h.01" /><path d="M17.8 6.2 19 5" />
              <path d="m3 21 9-9" /><path d="M12.2 6.2 11 5" />
            </svg>
          </span>
          <span className={styles.panelHintTagline}>Tool output will be saved here.</span>
          <span className={styles.panelHintSub}>Select a tool to view results alongside your workspace.</span>
        </div>
      </>
    );
  };

  return (
    <>
      {/* Collapsed icon strip — hidden when expanded */}
      <div className={styles.panelCollapsed} style={{ display: isExpanded ? "none" : undefined }}>
        {tools.map(({ id, name, icon }) => (
          <button
            key={id}
            className={styles.collapsedBtn}
            onClick={() => handleSelect(id)}
            title={name}
          >
            <img src={icon} alt={name} width={18} height={18} className={styles.collapsedIcon} />
          </button>
        ))}
      </div>

      {/* Full panel — hidden when collapsed */}
      <div className={styles.panel} style={{ display: isExpanded ? undefined : "none" }}>
        {renderToolContent()}
      </div>
    </>
  );
};

export default PanelTools;
