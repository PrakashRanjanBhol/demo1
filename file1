/* ── CSS custom property for angle animation ── */
@property --angle {
  syntax: '<angle>';
  initial-value: 0deg;
  inherits: false;
}

/* ── CSS Variables ── */
:root {
  --session-card-bg: #fafafa;
  --playground-item-color: #1a1a1a;
  --playground-item-muted: #888;
  --session-card-border-color: #d4d4d8;
  --accent: #7c3aed;
  --accent-glow: rgba(124, 58, 237, 0.18);
}

.dark-mode {
  --session-card-bg: #1d1d1d;
  --playground-item-color: #f5f5f5;
  --playground-item-muted: #888;
  --session-card-border-color: #27272a;
  --accent-glow: rgba(124, 58, 237, 0.22);
}

/* ── Wrapper (needed for the border animation) ── */
.session-card-wrapper {
  position: relative;
  border-radius: 8px 0 8px 0;
  padding: 2px;
  cursor: pointer;
}

/* Spinning gradient ring */
.session-card-wrapper::before {
  content: '';
  position: absolute;
  inset: -2px;
  border-radius: 10px 0 10px 0;
  background: conic-gradient(
    from var(--angle),
    transparent 0%, transparent 25%,
    #7c3aed 40%, #ec4899 52%,
    #06b6d4 63%, #f59e0b 74%,
    transparent 88%, transparent 100%
  );
  opacity: 0;
  transition: opacity 0.4s ease;
  z-index: 0;
}

/* Soft glow behind */
.session-card-wrapper::after {
  content: '';
  position: absolute;
  inset: -10px;
  border-radius: 14px 0 14px 0;
  background: conic-gradient(
    from var(--angle),
    transparent 0%, transparent 25%,
    #7c3aed 40%, #ec4899 52%,
    #06b6d4 63%, #f59e0b 74%,
    transparent 88%, transparent 100%
  );
  opacity: 0;
  filter: blur(18px);
  z-index: -1;
  transition: opacity 0.4s ease;
}

.session-card-wrapper:hover::before {
  opacity: 1;
  animation: spin-border 2.2s linear infinite;
}

.session-card-wrapper:hover::after {
  opacity: 0.3;
  animation: spin-border 2.2s linear infinite;
}

@keyframes spin-border {
  to { --angle: 360deg; }
}

/* ── The card ── */
.session-card {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.85rem 1rem;
  border-radius: 7px 0 7px 0;
  background-color: var(--session-card-bg);
  color: var(--playground-item-color);
  border: 1.5px solid var(--session-card-border-color);
  transition: border-color 0.35s ease, box-shadow 0.35s ease,
              transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  overflow: hidden;
}

.session-card-wrapper:hover .session-card {
  border-color: transparent;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.10);
  transform: translateY(-2px);
}

/* Inner shimmer */
.session-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(130deg, rgba(124, 58, 237, 0.04) 0%, transparent 55%);
  opacity: 0;
  transition: opacity 0.35s;
  pointer-events: none;
}

.session-card-wrapper:hover .session-card::before { opacity: 1; }

/* ── Session name ── */
.session-name {
  font-size: 14px;
  font-weight: 600;
  color: var(--playground-item-color);
  display: flex;
  align-items: center;
  gap: 6px;
}

/* Coloured pip */
.session-name::before {
  content: '';
  display: inline-block;
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: linear-gradient(135deg, #7c3aed, #ec4899);
  flex-shrink: 0;
  transition: transform 0.3s ease;
}

.session-card-wrapper:hover .session-name::before {
  transform: scale(1.4);
}

/* ── Date ── */
.session-time {
  font-style: normal;
  font-size: 11.5px;
  color: var(--playground-item-muted);
  letter-spacing: 0.03em;
  padding-left: 13px;
}

/* ── Ellipsis button ── */
.session-menu-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 30px;
  height: 30px;
  border-radius: 6px 0 6px 0;
  border: none;
  background: transparent;
  color: var(--playground-item-muted);
  cursor: pointer;
  transition: background 0.2s, color 0.2s, transform 0.2s;
  flex-shrink: 0;
}

.session-menu-btn:hover {
  background: var(--accent-glow);
  color: var(--accent);
  transform: scale(1.1);
}













