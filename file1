[data-theme='light'] {
    // ... all previous variables ...
    --sources-header-bg:                linear-gradient(135deg, #7c3aed 0%, #4f46e5 50%, #2563eb 100%);
    --sources-header-border:            transparent;
    --sources-header-title:             #ffffff;
    --sources-header-line2:             #a5f3fc;
    --sources-close-btn-color:          rgba(255, 255, 255, 0.7);
    --sources-close-btn-bg-hover:       rgba(255, 255, 255, 0.15);
    --sources-close-btn-color-hover:    #ffffff;
}

[data-theme='dark'] {
    // ... all previous variables ...
    --sources-header-bg:                linear-gradient(135deg, #7c3aed 0%, #4f46e5 50%, #2563eb 100%);
    --sources-header-border:            transparent;
    --sources-header-title:             #ffffff;
    --sources-header-line2:             #a5f3fc;
    --sources-close-btn-color:          rgba(255, 255, 255, 0.7);
    --sources-close-btn-bg-hover:       rgba(255, 255, 255, 0.15);
    --sources-close-btn-color-hover:    #ffffff;
}









.uploadModal {
    background-color: var(--sources-modal-bg);
    border: 1px solid var(--sources-modal-border);
    border-radius: 12px;
    box-shadow: 0 8px 32px var(--sources-modal-shadow);
    width: 100%;
    max-width: 480px;
    position: relative;
    overflow: hidden;
}

.modalHeader {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    background: var(--sources-header-bg);
    border-bottom: 1px solid var(--sources-header-border);
    position: relative;
    min-height: 80px;
}

.headerText {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 4px;
    transition: opacity 0.4s ease, transform 0.4s ease;
    opacity: 1;
    transform: translateY(0);
}

.headerFading {
    opacity: 0;
    transform: translateY(-6px);
}

.headerLine1 {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--sources-header-title);
    line-height: 1.4;
}

.headerLine2 {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--sources-header-line2);
    line-height: 1.4;
}

.closeModalBtn {
    position: absolute;
    top: 50%;
    right: 1rem;
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    color: var(--sources-close-btn-color);
    padding: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    transition: all 0.2s ease;
    flex-shrink: 0;

    &:hover {
        background-color: var(--sources-close-btn-bg-hover);
        color: var(--sources-close-btn-color-hover);
    }
}
