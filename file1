  --card-conf-border-hover:    rgba(124,58,237,0.42);
  --card-conf-shadow:          0 1px 3px rgba(79,70,229,0.10), 0 4px 12px rgba(79,70,229,0.08);
  --card-conf-shadow-hover:    0 4px 20px rgba(124,58,237,0.22), 0 1px 4px rgba(79,70,229,0.15);
  --card-conf-accent:          linear-gradient(180deg, #7c3aed, #4f46e5);
  --card-conf-name:            #4f46e5;
  --card-conf-icon-bg:         linear-gradient(135deg, #fff 0%, #ede9fe 100%);

  --card-summ-bg:              linear-gradient(145deg, #fef3c7 0%, #fffbeb 55%, #fef9ee 100%);
  --card-summ-bg-hover:        linear-gradient(145deg, #fde68a 0%, #fef3c7 60%, #fde9a8 100%);
