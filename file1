        <h2 class="sldc-card__title">Questions Overview</h2>
      </div>
      <div class="sldc-date-row">
        <div class="sldc-date-group">
          <label class="sldc-date-label">From</label>
          <p-datepicker
            [(ngModel)]="qa.dateRange.start"
            [maxDate]="qa.dateRange.end ?? today"
            dateFormat="dd-mm-yy"
            [showIcon]="true"
            appendTo="body"
            placeholder="Start date"
            styleClass="sldc-datepicker"
          />
        </div>
        <span class="sldc-date-sep">—</span>
        <div class="sldc-date-group">
          <label class="sldc-date-label">To</label>
          <p-datepicker
            [(ngModel)]="qa.dateRange.end"
            [minDate]="qa.dateRange.start ?? undefined"
            [maxDate]="today"
            dateFormat="dd-mm-yy"
            [showIcon]="true"
            appendTo="body"
            placeholder="End date"
            styleClass="sldc-datepicker"
          />
        </div>
