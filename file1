import React, { useState } from "react";
import { useDispatch } from "react-redux";
import type { AppDispatch } from "../../store";
import { updateLLMRequest } from "./excelSlice";
import styles from "./ExcelAnalysisTool.module.scss";

import excelAnalysisIcon from "../../assets/icons/excel-analysis.png";

interface ExcelAnalysisToolProps {
  onBack: () => void;
}

interface FileItem {
  created_at: string;
  file_job_id: string;
  file_name: string;
  file_size: number;
  file_type: string;
  state_id: string;
  status: string;
}

