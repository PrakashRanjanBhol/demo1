// ─── Keyframes ────────────────────────────────────────────────────────────────

@keyframes cmi-ping {
  0%        { transform: scale(1);   opacity: 0.6; }
  75%, 100% { transform: scale(2.4); opacity: 0;   }
}

@keyframes cmi-scale-in {
  from { opacity: 0; transform: scale(0.82); }
  to   { opacity: 1; transform: scale(1);    }
}

@keyframes cmi-scale-out {
  from { opacity: 1; transform: scale(1);    }
  to   { opacity: 0; transform: scale(0.82); }
}

// ─── Badge ────────────────────────────────────────────────────────────────────

.badge {
  display:        inline-flex;
  align-items:    center;
  gap:            6px;
  height:         28px;
  padding:        0 11px 0 8px;
  border-radius:  100px;
  border:         1px solid var(--cmi-active-border);
  background:     var(--cmi-active-bg);
  color:          var(--cmi-active-accent);
  cursor:         default;
  user-select:    none;
  white-space:    nowrap;

  // smooth color transitions when accent changes
  transition:
    background    0.25s ease,
    border-color  0.25s ease,
    color         0.25s ease;

  // enter/exit animation phases
  &.exit {
    animation: cmi-scale-out 0.18s ease forwards;
  }

  &.enter {
    animation: cmi-scale-in 0.24s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }
}

// ─── Inner elements ───────────────────────────────────────────────────────────

.icon {
  display:     inline-flex;
  align-items: center;
  flex-shrink: 0;
  opacity:     0.85;
}

.label {
  font-size:      12px;
  font-weight:    600;
  letter-spacing: 0.01em;
}

// ─── Pulsing dot ──────────────────────────────────────────────────────────────

.dot {
  position:    relative;
  display:     inline-flex;
  width:       7px;
  height:      7px;
  flex-shrink: 0;
}

.dotRing {
  position:      absolute;
  inset:         0;
  border-radius: 50%;
  background:    var(--cmi-active-accent);
  animation:     cmi-ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;
}

.dotCore {
  position:      relative;
  width:         7px;
  height:        7px;
  border-radius: 50%;
  background:    var(--cmi-active-accent);
}

// ─── Accent modifiers ─────────────────────────────────────────────────────────

.accentGray {
  --cmi-active-accent: var(--cmi-gray-accent);
  --cmi-active-bg:     var(--cmi-gray-bg);
  --cmi-active-border: var(--cmi-gray-border);
}

.accentTeal {
  --cmi-active-accent: var(--cmi-teal-accent);
  --cmi-active-bg:     var(--cmi-teal-bg);
  --cmi-active-border: var(--cmi-teal-border);
}

.accentBlue {
  --cmi-active-accent: var(--cmi-blue-accent);
  --cmi-active-bg:     var(--cmi-blue-bg);
  --cmi-active-border: var(--cmi-blue-border);
}

.accentPurple {
  --cmi-active-accent: var(--cmi-purple-accent);
  --cmi-active-bg:     var(--cmi-purple-bg);
  --cmi-active-border: var(--cmi-purple-border);
}

.accentGreen {
  --cmi-active-accent: var(--cmi-green-accent);
  --cmi-active-bg:     var(--cmi-green-bg);
  --cmi-active-border: var(--cmi-green-border);
}
