// Modify completeMultipleInference method
private completeMultipleInference(): void {
    this.isProcessingInference = false;
    this.currentInferenceItem = null;
    
    // Keep queue for a moment to show results
    setTimeout(() => {
      this.inferenceQueue = [];
      this.failedInferenceItems.clear(); // Clear failure flags after showing queue
    }, 5000);
}

// Add helper method to check if item failed
isInferenceFailed(itemId: string): boolean {
  return this.failedInferenceItems.has(itemId);
}













