/* ═══════════════════════════════════════
   File Icon — Dark Mode Overrides
═══════════════════════════════════════ */
:host-context(.dark),
:host-context([data-theme="dark"]),
:host-context(body.dark-mode) {

  .file-icon--running {
    background: rgba(55, 138, 221, 0.2);
    border-color: rgba(55, 138, 221, 0.4);
  }
  .file-icon--running svg { stroke: #93c5fd; }

  .file-icon--queued {
    background: rgba(239, 159, 39, 0.2);
    border-color: rgba(239, 159, 39, 0.4);
  }
  .file-icon--queued svg { stroke: #fcd34d; }

  .file-icon--pending {
    background: rgba(136, 135, 128, 0.2);
    border-color: rgba(136, 135, 128, 0.4);
  }
  .file-icon--pending svg { stroke: #d1d0cc; }

  .file-icon--completed {
    background: rgba(99, 153, 34, 0.2);
    border-color: rgba(99, 153, 34, 0.4);
  }
  .file-icon--completed svg { stroke: #86efac; }
}
