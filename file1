/* ═══════════════════════════════════════════════════════════════════════════
   Component styles
   ═══════════════════════════════════════════════════════════════════════════ */

.sldc-dashboard {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1.25rem;
  padding: 1.5rem 0;
  font-family: 'DM Sans', system-ui, sans-serif;
  background: var(--sldc-statistics-bg-page);
}

/* ── Card ───────────────────────────────────────────────────────────────────── */
.sldc-card {
  background: var(--sldc-statistics-bg-card);
  border: 1px solid var(--sldc-statistics-border-card);
  border-radius: var(--sldc-statistics-radius-card);
  padding: 1rem 1.25rem;
  min-width: 0;
}

.sldc-card__header {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0.6rem;
  margin-bottom: 1rem;
}

/* ── Title block ────────────────────────────────────────────────────────────── */
.sldc-card__title-block {
  flex-shrink: 0;
}

/* ── Section labels ─────────────────────────────────────────────────────────── */
.sldc-section-label {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--sldc-statistics-text-tertiary);
  margin: 0 0 4px;
}

.sldc-section-title {
  font-size: 16px;
  font-weight: 500;
  color: var(--sldc-statistics-text-primary);
  margin: 0;
  white-space: nowrap;
}

/* ── Divider ────────────────────────────────────────────────────────────────── */
.sldc-divider {
  height: 1px;
  background: var(--sldc-statistics-border-divider);
  margin-bottom: 1.25rem;
}

/* ── Date row ───────────────────────────────────────────────────────────────── */
.sldc-date-row {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: nowrap;
  width: 100%;
}

.sldc-date-group {
  display: flex;
  align-items: center;
  gap: 6px;
}

.sldc-date-label {
  font-size: 12px;
  color: var(--sldc-statistics-text-secondary);
  white-space: nowrap;
}

.sldc-date-sep {
  font-size: 12px;
  color: var(--sldc-statistics-text-tertiary);
}

.sldc-date-input {
  font-family: inherit;
  font-size: 13px;
  padding: 5px 9px;
  border: 1px solid var(--sldc-statistics-border-input);
  border-radius: var(--sldc-statistics-radius-element);
  background: var(--sldc-statistics-bg-input);
  color: var(--sldc-statistics-text-primary);
  outline: none;
  cursor: pointer;
  transition: border-color 0.15s;
  width: 130px;
}

.sldc-date-input:focus {
  border-color: var(--sldc-statistics-accent-bar);
}

/* ── Apply button ───────────────────────────────────────────────────────────── */
.sldc-apply-btn {
  font-family: inherit;
  font-size: 13px;
  font-weight: 500;
  padding: 5px 16px;
  border-radius: var(--sldc-statistics-radius-element);
  border: none;
  background: var(--sldc-statistics-theme-gradient);
  color: var(--sldc-statistics-theme-text);
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  white-space: nowrap;
  transition: opacity 0.15s, transform 0.1s;
  min-width: 68px;
  justify-content: center;
}

.sldc-apply-btn:hover:not(:disabled) {
  opacity: 0.88;
}

.sldc-apply-btn:active:not(:disabled) {
  transform: scale(0.97);
}

.sldc-apply-btn:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

/* ── Spinner ────────────────────────────────────────────────────────────────── */
.sldc-spinner {
  display: inline-block;
  width: 14px;
  height: 14px;
  border: 1.5px solid rgba(255, 255, 255, 0.35);
  border-top-color: #ffffff;
  border-radius: 50%;
  animation: sldc-spin 0.7s linear infinite;
}

@keyframes sldc-spin {
  to { transform: rotate(360deg); }
}

/* ── Error banner ───────────────────────────────────────────────────────────── */
.sldc-error-banner {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: var(--sldc-statistics-error-text);
  background: var(--sldc-statistics-error-bg);
  border: 1px solid var(--sldc-statistics-error-border);
  border-radius: var(--sldc-statistics-radius-element);
  padding: 8px 12px;
  margin-bottom: 1rem;
}

/* ── Metric grid ────────────────────────────────────────────────────────────── */
.sldc-grid {
  display: grid;
  gap: 10px;
}

.sldc-grid--2 {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.sldc-grid--4 {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

/* ── Metric card ────────────────────────────────────────────────────────────── */
.sldc-metric {
  background: var(--sldc-statistics-bg-metric);
  border-radius: var(--sldc-statistics-radius-element);
  padding: 14px 16px;
}

.sldc-metric__label {
  font-size: 12px;
  color: var(--sldc-statistics-text-label);
  margin: 0 0 6px;
  line-height: 1.4;
}

.sldc-metric__value {
  font-size: 26px;
  font-weight: 500;
  color: var(--sldc-statistics-text-primary);
  margin: 0;
  line-height: 1;
}

/* ── Badges ─────────────────────────────────────────────────────────────────── */
.sldc-badge {
  display: inline-block;
  font-size: 11px;
  font-weight: 500;
  padding: 2px 8px;
  border-radius: var(--sldc-statistics-radius-badge);
  margin-top: 8px;
}

.sldc-badge--blue {
  background: var(--sldc-statistics-badge-blue-bg);
  color: var(--sldc-statistics-badge-blue-text);
}

.sldc-badge--green {
  background: var(--sldc-statistics-badge-green-bg);
  color: var(--sldc-statistics-badge-green-text);
}

/* ── Progress bar ───────────────────────────────────────────────────────────── */
.sldc-bar-track {
  height: 5px;
  background: var(--sldc-statistics-border-divider);
  border-radius: 20px;
  overflow: hidden;
  margin-top: 10px;
}

.sldc-bar-fill {
  height: 100%;
  border-radius: 20px;
  background: var(--sldc-statistics-accent-bar);
  transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ── Info note ──────────────────────────────────────────────────────────────── */
.sldc-info-note {
  display: flex;
  flex-direction: column;
  gap: 6px;
  font-size: 12px;
  color: var(--sldc-statistics-info-text);
  margin-top: 1rem;
  padding-top: 0.875rem;
  border-top: 1px solid var(--sldc-statistics-info-border);
  line-height: 1.5;
}

.sldc-info-note__badge {
  display: inline-flex;
  align-self: flex-start;
  align-items: center;
  gap: 4px;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--sldc-statistics-accent-bar);
  background: color-mix(in srgb, var(--sldc-statistics-accent-bar) 10%, transparent);
  border: 1px solid color-mix(in srgb, var(--sldc-statistics-accent-bar) 25%, transparent);
  border-radius: 4px;
  padding: 2px 6px 2px 4px;
  white-space: nowrap;
  line-height: 1.4;
}

/* ── 3-column grid ──────────────────────────────────────────────────────────── */
.sldc-grid--3 {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

/* ── Project badge row ──────────────────────────────────────────────────────── */
.sldc-project-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 14px;
}

/* ── Success / danger metric variants ───────────────────────────────────────── */
.sldc-metric--success {
  background: var(--sldc-statistics-success-bg);
}

.sldc-metric--danger {
  background: var(--sldc-statistics-danger-bg);
}

.sldc-metric__value--success {
  color: var(--sldc-statistics-success-text);
}

.sldc-metric__value--danger {
  color: var(--sldc-statistics-danger-text);
}

/* ── Colored bar fill variants ───────────────────────────────────────────────── */
.sldc-bar-fill--success {
  background: var(--sldc-statistics-success-bar) !important;
}

.sldc-bar-fill--danger {
  background: var(--sldc-statistics-danger-bar) !important;
}



/* ── Q&A Coverage card — coloured values ─────────────────────────────────────── */

/* Total panel: subtle gradient tint to mark it as the headline stat */
.sldc-qa-item--total {
  background: linear-gradient(145deg, #6366f110, #8b5cf615);
}

/* Gradient text on total value */
.sldc-qa-value--total {
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* Jira — blue */
.sldc-qa-value--jira {
  color: #2563eb;
}

/* Confluence — violet */
.sldc-qa-value--confluence {
  color: #7c3aed;
}

[data-theme="dark"] .sldc-qa-value--jira { color: #60a5fa; }
[data-theme="dark"] .sldc-qa-value--confluence { color: #a78bfa; }

@media (prefers-color-scheme: dark) {
  .sldc-qa-value--jira       { color: #60a5fa; }
  .sldc-qa-value--confluence { color: #a78bfa; }
}

/* ═══════════════════════════════════════════════════════════════════════════
   Skeleton loading animation
   ═══════════════════════════════════════════════════════════════════════════ */

@keyframes sldc-shimmer {
  0%   { background-position: -600px 0; }
  100% { background-position:  600px 0; }
}

.sldc-skeleton-wrap {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

/* Base skeleton block — shimmer shared by all variants */
.sldc-skel {
  border-radius: 6px;
  background: linear-gradient(
    90deg,
    var(--sldc-statistics-bg-metric)  25%,
    var(--sldc-statistics-border-divider) 50%,
    var(--sldc-statistics-bg-metric)  75%
  );
  background-size: 600px 100%;
  animation: sldc-shimmer 1.4s ease-in-out infinite;
}

/* ── Skeleton shape variants ───────────────────────────────────────────────── */

/* Large value number inside a banner panel */
.sldc-skel--value {
  width: 44px;
  height: 22px;
  border-radius: 6px;
}

/* Small uppercase label beneath a value */
.sldc-skel--label {
  width: 48px;
  height: 10px;
  border-radius: 4px;
}

/* Medium-length text line (label in rate row) */
.sldc-skel--text-md {
  width: 130px;
  height: 12px;
  border-radius: 4px;
}

/* Progress bar */
.sldc-skel--bar {
  width: 100%;
  height: 6px;
  border-radius: 20px;
}

/* Colour dot in a rate row */
.sldc-skel--dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

/* Project pill */
.sldc-skel--pill {
  width: 110px;
  height: 24px;
  border-radius: 20px;
}

/* Ratio grid cell */
.sldc-skel--ratio-item {
  height: 40px;
  border-radius: 6px;
}

/* ── Skeleton structural containers ─────────────────────────────────────────── */

/* Mirrors sldc-gen-banner layout */
.sldc-skel-banner {
  display: flex;
  align-items: stretch;
  border: 1px solid var(--sldc-statistics-border-card);
  border-radius: var(--sldc-statistics-radius-element);
  overflow: hidden;
}

.sldc-skel-banner__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  padding: 10px 8px;
  background: var(--sldc-statistics-bg-metric);
}

.sldc-skel-banner__divider {
  width: 1px;
  background: var(--sldc-statistics-border-divider);
  flex-shrink: 0;
}

/* Mirrors sldc-rate-row layout */
.sldc-skel-rate-row {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.sldc-skel-rate-row__meta {
  display: flex;
  align-items: center;
  gap: 8px;
}

/* Mirrors sldc-ratio-grid layout */
.sldc-skel-ratio-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
  padding: 12px;
  background: var(--sldc-statistics-bg-metric);
  border-radius: var(--sldc-statistics-radius-element);
  border: 1px solid var(--sldc-statistics-border-divider);
}

.sldc-skel-ratio-grid--3col {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

@media (max-width: 480px) {
  .sldc-skel-banner {
    flex-direction: column;
  }
  .sldc-skel-banner__divider {
    width: auto;
    height: 1px;
  }
  .sldc-skel-ratio-grid,
  .sldc-skel-ratio-grid--3col {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

/* ── SLDC Analysis — redesigned ─────────────────────────────────────────────── */

/* Project pill */
.sldc-project-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  font-weight: 500;
  color: var(--sldc-statistics-badge-blue-text);
  background: var(--sldc-statistics-badge-blue-bg);
  border-radius: 20px;
  padding: 4px 12px 4px 8px;
  margin-bottom: 14px;
}

/* Generation summary banner */
.sldc-gen-banner {
  display: flex;
  align-items: stretch;
  border: 1px solid var(--sldc-statistics-border-card);
  border-radius: var(--sldc-statistics-radius-element);
  overflow: hidden;
  margin-bottom: 14px;
}

.sldc-gen-banner__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  padding: 10px 8px;
  background: var(--sldc-statistics-bg-metric);
}

.sldc-gen-banner__divider {
  width: 1px;
  background: var(--sldc-statistics-border-divider);
  flex-shrink: 0;
}

.sldc-gen-banner__value {
  font-size: 20px;
  font-weight: 500;
  color: var(--sldc-statistics-text-primary);
  line-height: 1;
}

.sldc-gen-banner__value--success {
  color: var(--sldc-statistics-success-text);
}

.sldc-gen-banner__value--danger {
  color: var(--sldc-statistics-danger-text);
}

.sldc-gen-banner__label {
  font-size: 10px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--sldc-statistics-text-tertiary);
}

/* Rate rows */
.sldc-rate-section {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 14px;
}

.sldc-rate-row {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.sldc-rate-row__meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.sldc-rate-row__label {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: var(--sldc-statistics-text-secondary);
}

.sldc-rate-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

.sldc-rate-dot--success { background: var(--sldc-statistics-success-bar); }
.sldc-rate-dot--danger  { background: var(--sldc-statistics-danger-bar); }
.sldc-rate-dot--accent  { background: var(--sldc-statistics-accent-bar); }
.sldc-rate-dot--teal    { background: #0d9488; }

.sldc-rate-row__value {
  font-size: 13px;
  font-weight: 500;
  color: var(--sldc-statistics-text-primary);
}

.sldc-rate-row__value--success { color: var(--sldc-statistics-success-text); }
.sldc-rate-row__value--danger  { color: var(--sldc-statistics-danger-text); }
.sldc-rate-row__value--accent  { color: var(--sldc-statistics-accent-bar); }
.sldc-rate-row__value--teal    { color: #0d9488; }

/* Shared track for rate rows and ratio items */
.sldc-rate-track {
  height: 6px;
  background: var(--sldc-statistics-border-divider);
  border-radius: 20px;
  overflow: hidden;
}

.sldc-rate-fill {
  height: 100%;
  border-radius: 20px;
  transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.sldc-rate-fill--success { background: var(--sldc-statistics-success-bar); }
.sldc-rate-fill--danger  { background: var(--sldc-statistics-danger-bar); }
.sldc-rate-fill--accent  { background: var(--sldc-statistics-accent-bar); }
.sldc-rate-fill--teal    { background: #0d9488; }

/* Ratio grid */
.sldc-ratio-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
  padding: 12px;
  background: var(--sldc-statistics-bg-metric);
  border-radius: var(--sldc-statistics-radius-element);
  border: 1px solid var(--sldc-statistics-border-divider);
}

.sldc-ratio-item {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.sldc-ratio-item__top {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 4px;
}

.sldc-ratio-item__label {
  font-size: 11px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--sldc-statistics-text-tertiary);
}

.sldc-ratio-item__value {
  font-size: 14px;
  font-weight: 500;
  color: var(--sldc-statistics-text-primary);
}

.sldc-ratio-item__value--success {
  color: var(--sldc-statistics-success-text);
}

.sldc-ratio-grid--3col {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

@media (max-width: 480px) {
  .sldc-gen-banner {
    flex-direction: column;
  }
  .sldc-gen-banner__divider {
    width: auto;
    height: 1px;
  }
  .sldc-ratio-grid,
  .sldc-ratio-grid--3col {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}


[data-theme="dark"] .sldc-rate-dot--teal,
[data-theme="dark"] .sldc-rate-fill--teal { background: #2dd4bf; }
[data-theme="dark"] .sldc-rate-row__value--teal { color: #2dd4bf; }

@media (prefers-color-scheme: dark) {
  .sldc-rate-dot--teal,
  .sldc-rate-fill--teal    { background: #2dd4bf; }
  .sldc-rate-row__value--teal { color: #2dd4bf; }
}

/* ── Responsive ─────────────────────────────────────────────────────────────── */

/* > 1600px: 3 cards per row — header stacks vertically (default) */

/* 1100px – 1600px: 2 cards per row — header goes horizontal */
@media (max-width: 1600px) {
  .sldc-dashboard {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .sldc-card__header {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    flex-wrap: nowrap;
  }

  .sldc-date-row {
    width: auto;
    flex-shrink: 0;
  }
}

/* < 1100px: 1 card per row */
@media (max-width: 1100px) {
  .sldc-dashboard {
    grid-template-columns: 1fr;
  }
}

/* < 700px: collapse inner grids, allow header to wrap */
@media (max-width: 700px) {
  .sldc-grid--3,
  .sldc-grid--4 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .sldc-date-row {
    flex-wrap: wrap;
    width: 100%;
  }

  .sldc-date-input {
    width: 100%;
  }

  .sldc-apply-btn {
    width: 100%;
  }
}

@media (max-width: 400px) {
  .sldc-grid--2 {
    grid-template-columns: 1fr;
  }
}
