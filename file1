import axios from "axios";

const LOCAL_STORAGE_KEY = "ATLASIAN_CONNECTION";

// ── Helpers ───────────────────────────────────────────

const getAuthHeader = () => {
  const token = localStorage.getItem(LOCAL_STORAGE_KEY) ?? "";
  return { Authorization: `Bearer ${token}` };
};

// ── Types ─────────────────────────────────────────────

export interface ConnectPayload {
  username: string;
  password: string;
}

export interface ConnectResponse {
  status: string;
  result: string;
}

export interface DisconnectResponse {
  status: string;
  result: string;
}

export interface JiraProject {
  key: string;
  id: string;
  type: "project";
  icon: string;
}

export interface ProjectsResult {
  [id: string]: JiraProject;
}

export interface ProjectsResponse {
  status: string;
  result: ProjectsResult;
}

export interface JiraTicket {
  type: string;
  summary: string;
  key: string;
}

export interface JiraIssueGroup {
  icon: string;
  tickets: JiraTicket[];
}

export interface ProjectDataResult {
  [issueType: string]: JiraIssueGroup;
}

export interface ProjectDataResponse {
  status: string;
  result: ProjectDataResult;
}

export interface FavoritePayload {
  project_key: string;
}

export interface FavoriteResponse {
  status: string;
  result: string;
}

// ── Confluence Types ──────────────────────────────────

export interface ConfluenceSpace {
  key: string;
  id: string;
  type: "space";
  icon: string;
}

export interface SpacesResult {
  [id: string]: ConfluenceSpace;
}

export interface SpacesResponse {
  status: string;
  result: SpacesResult;
}

export interface SpaceFavoritePayload {
  space_key: string;
}

export interface ConfluencePage {
  page_id: string;
  title: string;
  url: string;
  last_modified: string;
  children: ConfluencePage[];
}

export interface SpaceDataResponse {
  status: string;
  result: ConfluencePage[];
}

// ── Service ───────────────────────────────────────────

export const atlassianService = {
  // Auth
  connect: async (payload: ConnectPayload): Promise<ConnectResponse> => {
    const credentials = btoa(`${payload.username}:${payload.password}`);
    const response = await axios.post<ConnectResponse>(
      "/api/atlassian/connect",
      payload,
      {
        headers: {
          Authorization: `Basic ${credentials}`,
        },
      }
    );
    return response.data;
  },

  disconnect: async (): Promise<DisconnectResponse> => {
    const response = await axios.put<DisconnectResponse>(
      "/api/atlassian/disconnect",
      {},
      { headers: getAuthHeader() }
    );
    return response.data;
  },

  // Jira Projects
  fetchAllProjects: async (): Promise<ProjectsResponse> => {
    const response = await axios.get<ProjectsResponse>(
      "/api/jira/projects",
      { headers: getAuthHeader() }
    );
    return response.data;
  },

  fetchFavoriteProjects: async (): Promise<ProjectsResponse> => {
    const response = await axios.get<ProjectsResponse>(
      "/api/jira/projects/favorites",
      { headers: getAuthHeader() }
    );
    return response.data;
  },

  addFavoriteProject: async (
    payload: FavoritePayload
  ): Promise<FavoriteResponse> => {
    const response = await axios.post<FavoriteResponse>(
      "/api/jira/projects/favorites",
      payload,
      { headers: getAuthHeader() }
    );
    return response.data;
  },

  removeFavoriteProject: async (
    payload: FavoritePayload
  ): Promise<FavoriteResponse> => {
    const response = await axios.delete<FavoriteResponse>(
      "/api/jira/projects/favorites",
      {
        headers: getAuthHeader(),
        data: payload,
      }
    );
    return response.data;
  },

  fetchProjectData: async (id: string): Promise<ProjectDataResponse> => {
    const response = await axios.get<ProjectDataResponse>(
      `/api/jira/get_project_data/${id}`,
      { headers: getAuthHeader() }
    );
    return response.data;
  },

  // ── Confluence Spaces ───────────────────────────────

  fetchAllSpaces: async (): Promise<SpacesResponse> => {
    const response = await axios.get<SpacesResponse>(
      "/api/confluence/spaces",
      { headers: getAuthHeader() }
    );
    return response.data;
  },

  fetchFavoriteSpaces: async (): Promise<SpacesResponse> => {
    const response = await axios.get<SpacesResponse>(
      "/api/confluence/spaces/favorites",
      { headers: getAuthHeader() }
    );
    return response.data;
  },

  addFavoriteSpace: async (
    payload: SpaceFavoritePayload
  ): Promise<FavoriteResponse> => {
    const response = await axios.post<FavoriteResponse>(
      "/api/confluence/spaces/favorites",
      payload,
      { headers: getAuthHeader() }
    );
    return response.data;
  },

  removeFavoriteSpace: async (
    payload: SpaceFavoritePayload
  ): Promise<FavoriteResponse> => {
    const response = await axios.delete<FavoriteResponse>(
      "/api/confluence/spaces/favorites",
      {
        headers: getAuthHeader(),
        data: payload,
      }
    );
    return response.data;
  },

  fetchSpaceData: async (id: string): Promise<SpaceDataResponse> => {
    const response = await axios.get<SpaceDataResponse>(
      `/api/confluence/get_space_data/${id}`,
      { headers: getAuthHeader() }
    );
    return response.data;
  },
};







import { createSlice, createAsyncThunk } from "@reduxjs/toolkit";
import {
  atlassianService,
  type ConfluenceSpace,
  type SpacesResult,
  type ConfluencePage,
} from "./atlassianService";

export interface ConfluenceState {
  allSpaces: SpacesResult;
  favoriteSpaces: SpacesResult;
  isLoadingSpaces: boolean;
  isFavoriteUpdating: Record<string, boolean>;
  spaceData: Record<string, ConfluencePage[]>; // keyed by space id
  loadingSpaceId: string | null;
  checkedPages: string[]; // page_ids currently checked
  error: string | null;
}

const initialState: ConfluenceState = {
  allSpaces: {},
  favoriteSpaces: {},
  isLoadingSpaces: false,
  isFavoriteUpdating: {},
  spaceData: {},
  loadingSpaceId: null,
  checkedPages: [],
  error: null,
};

// ── Thunks ────────────────────────────────────────────

export const fetchConfluenceSpaces = createAsyncThunk(
  "confluence/fetchSpaces",
  async (_, { rejectWithValue }) => {
    try {
      const [allRes, favRes] = await Promise.all([
        atlassianService.fetchAllSpaces(),
        atlassianService.fetchFavoriteSpaces(),
      ]);

      if (allRes.status !== "Success") {
        return rejectWithValue("Failed to fetch spaces.");
      }
      if (favRes.status !== "Success") {
        return rejectWithValue("Failed to fetch favorite spaces.");
      }

      return {
        allSpaces: allRes.result,
        favoriteSpaces: favRes.result,
      };
    } catch (error: any) {
      return rejectWithValue(
        error?.response?.data?.message ?? "Failed to load Confluence spaces."
      );
    }
  }
);

export const addFavoriteSpace = createAsyncThunk(
  "confluence/addFavorite",
  async (space: ConfluenceSpace, { rejectWithValue }) => {
    try {
      const res = await atlassianService.addFavoriteSpace({
        space_key: space.id,
      });
      if (res.status !== "Success") return rejectWithValue("Failed to add favorite.");
      return space;
    } catch (error: any) {
      return rejectWithValue(
        error?.response?.data?.message ?? "Failed to add favorite."
      );
    }
  }
);

export const removeFavoriteSpace = createAsyncThunk(
  "confluence/removeFavorite",
  async (space: ConfluenceSpace, { rejectWithValue }) => {
    try {
      const res = await atlassianService.removeFavoriteSpace({
        space_key: space.id,
      });
      if (res.status !== "Success") return rejectWithValue("Failed to remove favorite.");
      return space;
    } catch (error: any) {
      return rejectWithValue(
        error?.response?.data?.message ?? "Failed to remove favorite."
      );
    }
  }
);

export const fetchSpaceData = createAsyncThunk(
  "confluence/fetchSpaceData",
  async (space: ConfluenceSpace, { rejectWithValue }) => {
    try {
      const res = await atlassianService.fetchSpaceData(space.id);
      if (res.status !== "Success") {
        return rejectWithValue("Failed to load space data.");
      }
      return { id: space.id, data: res.result };
    } catch (error: any) {
      return rejectWithValue(
        error?.response?.data?.message ?? "Failed to load space data."
      );
    }
  }
);

// ── Slice ─────────────────────────────────────────────

const confluenceSlice = createSlice({
  name: "confluence",
  initialState,
  reducers: {
    clearConfluenceError(state) {
      state.error = null;
    },
    resetConfluenceState() {
      return initialState;
    },
    togglePage(state, action: { payload: string }) {
      const id = action.payload;
      const idx = state.checkedPages.indexOf(id);
      if (idx === -1) {
        state.checkedPages.push(id);
      } else {
        state.checkedPages.splice(idx, 1);
      }
    },
    clearCheckedPages(state) {
      state.checkedPages = [];
    },
  },
  extraReducers: (builder) => {
    // Fetch spaces
    builder
      .addCase(fetchConfluenceSpaces.pending, (state) => {
        state.isLoadingSpaces = true;
        state.error = null;
      })
      .addCase(fetchConfluenceSpaces.fulfilled, (state, action) => {
        state.isLoadingSpaces = false;
        state.allSpaces = action.payload.allSpaces;
        state.favoriteSpaces = action.payload.favoriteSpaces;
      })
      .addCase(fetchConfluenceSpaces.rejected, (state, action) => {
        state.isLoadingSpaces = false;
        state.error = action.payload as string;
      });

    // Add favorite
    builder
      .addCase(addFavoriteSpace.pending, (state, action) => {
        state.isFavoriteUpdating[action.meta.arg.id] = true;
      })
      .addCase(addFavoriteSpace.fulfilled, (state, action) => {
        const space = action.payload;
        state.isFavoriteUpdating[space.id] = false;
        state.favoriteSpaces[space.id] = space;
      })
      .addCase(addFavoriteSpace.rejected, (state, action) => {
        state.isFavoriteUpdating[action.meta.arg.id] = false;
        state.error = action.payload as string;
      });

    // Remove favorite
    builder
      .addCase(removeFavoriteSpace.pending, (state, action) => {
        state.isFavoriteUpdating[action.meta.arg.id] = true;
      })
      .addCase(removeFavoriteSpace.fulfilled, (state, action) => {
        const space = action.payload;
        state.isFavoriteUpdating[space.id] = false;
        delete state.favoriteSpaces[space.id];
        delete state.spaceData[space.id];
      })
      .addCase(removeFavoriteSpace.rejected, (state, action) => {
        state.isFavoriteUpdating[action.meta.arg.id] = false;
        state.error = action.payload as string;
      });

    // Fetch space data
    builder
      .addCase(fetchSpaceData.pending, (state, action) => {
        state.loadingSpaceId = action.meta.arg.id;
        state.error = null;
      })
      .addCase(fetchSpaceData.fulfilled, (state, action) => {
        state.loadingSpaceId = null;
        state.spaceData[action.payload.id] = action.payload.data;
      })
      .addCase(fetchSpaceData.rejected, (state, action) => {
        state.loadingSpaceId = null;
        state.error = action.payload as string;
      });
  },
});

export const {
  clearConfluenceError,
  resetConfluenceState,
  togglePage,
  clearCheckedPages,
} = confluenceSlice.actions;

export default confluenceSlice.reducer;










