const handleDeptClick = (dept: Department) => {
  if (dept.department_id === selectedDeptId) return;
  if (memberLoading) return;                          // ← block click while loading
  dispatch(setSelectedDeptId(dept.department_id));
  dispatch(fetchUserAccessList(dept.department_id));
  setMemberSearch('');
  setMemberBulkMode(false);
  setSelectedMembers(new Set());
};


.teamRow {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 12px;
  border-radius: 10px;
  cursor: pointer;
  border: 1px solid transparent;
  transition: background 0.15s ease, border-color 0.15s ease, opacity 0.15s ease;
  background: transparent;

  &:hover { background: var(--am-s2); border-color: var(--am-border); }

  &.selected {
    background: var(--am-selected-bg);
    border-color: var(--am-selected-border);
    box-shadow: 0 2px 8px rgba(79, 70, 229, 0.08);
  }

  &.loading {
    opacity: 0.55;
    cursor: not-allowed;
    pointer-events: none;         // ← belt-and-suspenders with the JS guard
  }
}




<div
  key={dept.department_id}
  className={`
    ${styles.teamRow}
    ${selectedDeptId === dept.department_id ? styles.selected : ''}
    ${memberLoading && selectedDeptId !== dept.department_id ? styles.loading : ''}
  `}
  onClick={() => handleDeptClick(dept)}
>
