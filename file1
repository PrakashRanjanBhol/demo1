import {
  Component, EventEmitter, Output, Input,
  OnInit, OnChanges, SimpleChanges, OnDestroy
} from '@angular/core';
import { HistoryService, FileItem } from './history.service';
import { UploadGenerateService } from './upload-generate.service';
import { Subscription, interval, forkJoin, of } from 'rxjs';
import { switchMap, catchError } from 'rxjs/operators';

export type FileStatus = 'running' | 'queued' | 'pending' | 'completed';

export interface HistoryItem {
  id: string;
  name: string;
  displayDate: string;
  date: Date;
  status: FileStatus;
  progress: number;
  summary_prompt: string | null;
  faq_prompt: string | null;
}

export interface HistoryItemSelect {
  id: string;
  name: string;
  displayDate: string;
  date: Date;
  summary_prompt: string | null;
  faq_prompt: string | null;
}

interface RemoveGenerateFile {
  id: number;
  name: string;
}

interface NewUploadFile {
  id: number;
  original_name: string;
  created_at: string;
  summary_prompt: string | null;
  faq_prompt: string | null;
}

interface ProcessStatus {
  id: number | null;
  isProcessing: boolean;
}

interface GenerationStatus {
  id: number;
  status: 'Success' | 'Failure';
  summary_prompt?: string;
  faq_prompt?: string;
}

const POLL_INTERVAL_MS = 10_000;

@Component({
  selector: 'app-history',
  templateUrl: './history.component.html',
  styleUrls: ['./history.component.css']
})
export class HistoryComponent implements OnInit, OnChanges, OnDestroy {

  /* ── Inputs from parent ── */
  @Input() removeGenerateFile: RemoveGenerateFile | null = null;
  @Input() generationStatus: GenerationStatus | null = null;
  @Input() newUploadFile: NewUploadFile | null = null;
  @Input() processStatus: ProcessStatus | null = null;
  @Input() isFileUploading: boolean = false;

  /* ── Outputs ── */
  @Output() onItemSelect = new EventEmitter<HistoryItemSelect>();
  @Output() onAddToContentGeneration = new EventEmitter<HistoryItem>();
  @Output() onRemoveFromContentGeneration = new EventEmitter<string>();

  /* ── Display state ── */
  historyItems: HistoryItem[] = [];
  isLoading = false;
  isRefreshing = false;
  errorMessage = '';

  selectedHistoryItem: HistoryItem | null = null;
  addedToGenerationId: string | null = null;

  /* ── Section collapse state ── */
  sectionExpanded: Record<FileStatus, boolean> = {
    running: true,
    queued: true,
    pending: true,
    completed: true
  };

  /* ── Filter / search ── */
  isFilterVisible = false;
  filterFromDate = '';
  filterToDate = '';
  searchText = '';
  startDate = '';
  endDate = '';

  /* ── Delete mode ── */
  isDeleteMode = false;
  isProcessingDelete = false;
  isDeleteConfirmationVisible = false;
  selectedDeleteItems = new Set<string>();

  /* ── Inference mode (only available when queued=[] and running=[]) ── */
  isInferenceMode = false;
  isSubmittingBatch = false;
  selectedInferenceItems = new Set<string>();
  inferenceModelName = 'ABC';

  /* ── Poll state ── */
  pollCountdown = POLL_INTERVAL_MS / 1000;
  private pollSubscription: Subscription | null = null;
  private countdownSubscription: Subscription | null = null;

  /* ── Empty state guide ── */
  showAllSteps = false;
  allSteps = [
    { num: 1, title: 'Upload file', desc: 'Upload a <strong>.VTT</strong> or <strong>.SRT</strong> file in the Upload & Generate section.' },
    { num: 2, title: 'File appears in history', desc: 'On successful upload the file appears here under <strong>Pending</strong>.' },
    { num: 3, title: 'Start inference', desc: 'Click the <strong>+</strong> icon to add the file to the Generate component, then start inference.' },
    { num: 4, title: 'File moves to Queued', desc: 'Once inference is triggered the file enters the <strong>Queued</strong> section.' },
    { num: 5, title: 'File starts Running', desc: 'When the server picks it up the file moves to <strong>Running</strong> with a live progress bar.' },
    { num: 6, title: 'View results', desc: 'After completion the file moves to <strong>Completed</strong> where you can view and export results.' },
  ];

  constructor(
    private historyService: HistoryService,
    private uploadGenerateService: UploadGenerateService
  ) {}

  /* ═══════════════════════════════════════════
     Lifecycle
  ═══════════════════════════════════════════ */

  ngOnInit(): void {
    this.initializeDateRange();
    this.fetchAll();
  }

  ngOnChanges(changes: SimpleChanges): void {
    if (changes['removeGenerateFile']?.currentValue) {
      this.handleRemoveFromParent(changes['removeGenerateFile'].currentValue);
    }
    if (changes['generationStatus']?.currentValue) {
      this.handleGenerationStatusChange(changes['generationStatus'].currentValue);
    }
    if (changes['newUploadFile']?.currentValue) {
      this.handleNewFileUpload(changes['newUploadFile'].currentValue);
    }
    if (changes['processStatus']?.currentValue) {
      this.handleProcessStatusChange(changes['processStatus'].currentValue);
    }
  }

  ngOnDestroy(): void {
    this.stopPolling();
  }

  /* ═══════════════════════════════════════════
     Computed getters
  ═══════════════════════════════════════════ */

  get runningFiles(): HistoryItem[] {
    return this.applySearch(this.historyItems.filter(i => i.status === 'running'));
  }

  get queuedFiles(): HistoryItem[] {
    return this.applySearch(this.historyItems.filter(i => i.status === 'queued'));
  }

  get pendingFiles(): HistoryItem[] {
    return this.applySearch(this.historyItems.filter(i => i.status === 'pending'));
  }

  get completedFiles(): HistoryItem[] {
    return this.applySearch(this.historyItems.filter(i => i.status === 'completed'));
  }

  get hasAnyFiles(): boolean {
    return this.historyItems.length > 0;
  }

  get isLivePolling(): boolean {
    return this.pollSubscription !== null;
  }

  get liveFileCount(): string {
    const r = this.historyItems.filter(i => i.status === 'running').length;
    const q = this.historyItems.filter(i => i.status === 'queued').length;
    const parts: string[] = [];
    if (r) parts.push(`${r} running`);
    if (q) parts.push(`${q} queued`);
    return parts.join(', ');
  }

  /** Inference mode is only available when server has no active work */
  get canUseInferenceMode(): boolean {
    return (
      this.historyItems.filter(i => i.status === 'running').length === 0 &&
      this.historyItems.filter(i => i.status === 'queued').length === 0 &&
      this.hasAnyFiles
    );
  }

  get inferenceSelectionCount(): number {
    return this.selectedInferenceItems.size;
  }

  /* ═══════════════════════════════════════════
     Data fetching
  ═══════════════════════════════════════════ */

  private fetchAll(isRefresh = false): void {
    if (isRefresh) {
      this.isRefreshing = true;
    } else {
      this.isLoading = true;
    }

    const today = new Date();
    const thirtyDaysAgo = new Date();
    thirtyDaysAgo.setDate(today.getDate() - 30);

    const start = this.filterFromDate || this.formatDateForApi(thirtyDaysAgo);
    const end = this.filterToDate || this.formatDateForApi(today);

    this.historyService.getFilesByDateRange(start, end).subscribe({
      next: (response) => {
        if (response.status === 'success' && response.data) {
          this.mergeResponseIntoItems(response.data);
        }
        this.isLoading = false;
        this.isRefreshing = false;
        this.updatePollingState();
      },
      error: (err) => {
        console.error('Error fetching history:', err);
        this.errorMessage = 'Failed to load history. Please try again.';
        this.isLoading = false;
        this.isRefreshing = false;
      }
    });
  }

  private mergeResponseIntoItems(data: any): void {
    const buildItem = (file: FileItem, status: FileStatus): HistoryItem => ({
      id: file.id.toString(),
      name: file.original_name,
      displayDate: `Created on ${file.inserted_at}`,
      date: new Date(file.inserted_at),
      status,
      progress: 0,
      summary_prompt: file.summary_prompt,
      faq_prompt: file.faq_prompt
    });

    const newItems: HistoryItem[] = [
      ...(data.running  || []).map((f: FileItem) => buildItem(f, 'running')),
      ...(data.queued   || []).map((f: FileItem) => buildItem(f, 'queued')),
      ...(data.pending  || []).map((f: FileItem) => buildItem(f, 'pending')),
      ...(data.completed|| []).map((f: FileItem) => buildItem(f, 'completed')),
    ];

    // Preserve progress values for running items across refreshes
    newItems.forEach(newItem => {
      const existing = this.historyItems.find(i => i.id === newItem.id);
      if (existing && newItem.status === 'running') {
        newItem.progress = existing.progress;
      }
    });

    this.historyItems = newItems;
  }

  /* ═══════════════════════════════════════════
     Polling
  ═══════════════════════════════════════════ */

  private updatePollingState(): void {
    const hasActiveFiles =
      this.historyItems.some(i => i.status === 'running') ||
      this.historyItems.some(i => i.status === 'queued');

    if (hasActiveFiles && !this.pollSubscription) {
      this.startPolling();
    } else if (!hasActiveFiles && this.pollSubscription) {
      this.stopPolling();
    }
  }

  private startPolling(): void {
    this.pollCountdown = POLL_INTERVAL_MS / 1000;
    this.startCountdown();

    this.pollSubscription = interval(POLL_INTERVAL_MS).pipe(
      switchMap(() => {
        const runningIds = this.historyItems
          .filter(i => i.status === 'running')
          .map(i => Number(i.id));

        if (runningIds.length === 0) {
          return of(null);
        }
        return this.historyService.getFilesProgress(runningIds).pipe(
          catchError(err => {
            console.error('Progress poll error:', err);
            return of(null);
          })
        );
      })
    ).subscribe(progressResponse => {
      // Step 1: apply progress updates
      if (progressResponse && progressResponse.status === 'Success') {
        Object.entries(progressResponse.result).forEach(([id, pct]) => {
          const item = this.historyItems.find(i => i.id === id);
          if (item) item.progress = pct as number;
        });
      }

      // Step 2: re-fetch full list to re-bucket files
      this.fetchAll(true);

      // Step 3: reset countdown
      this.pollCountdown = POLL_INTERVAL_MS / 1000;
    });
  }

  private startCountdown(): void {
    this.stopCountdown();
    this.countdownSubscription = interval(1000).subscribe(() => {
      if (this.pollCountdown > 0) {
        this.pollCountdown--;
      }
    });
  }

  private stopCountdown(): void {
    this.countdownSubscription?.unsubscribe();
    this.countdownSubscription = null;
  }

  private stopPolling(): void {
    this.pollSubscription?.unsubscribe();
    this.pollSubscription = null;
    this.stopCountdown();
  }

  /* ═══════════════════════════════════════════
     Date filter
  ═══════════════════════════════════════════ */

  toggleFilter(): void {
    this.isFilterVisible = !this.isFilterVisible;
    if (this.isFilterVisible && !this.filterFromDate && !this.filterToDate) {
      const today = new Date();
      const thirtyDaysAgo = new Date();
      thirtyDaysAgo.setDate(today.getDate() - 30);
      this.filterFromDate = this.formatDateForInput(thirtyDaysAgo);
      this.filterToDate = this.formatDateForInput(today);
    }
  }

  applyDateFilter(): void {
    if (!this.filterFromDate || !this.filterToDate) return;
    const from = new Date(this.filterFromDate);
    const to = new Date(this.filterToDate);
    if (from > to) return;

    this.startDate = this.formatDateForDisplay(from);
    this.endDate = this.formatDateForDisplay(to);
    this.fetchAll(true);
  }

  onSearchChange(): void { /* filtering is reactive via getters */ }
  clearSearch(): void { this.searchText = ''; }

  /* ═══════════════════════════════════════════
     Stop queued files
  ═══════════════════════════════════════════ */

  stopQueuedFile(itemId: string, event: Event): void {
    event.stopPropagation();
    this.historyService.stopFiles([Number(itemId)]).subscribe({
      next: (res) => {
        if (res.status === 'success') {
          // Optimistically remove from queued; next poll will confirm
          const item = this.historyItems.find(i => i.id === itemId);
          if (item) item.status = 'pending';
        }
      },
      error: (err) => console.error('Stop file error:', err)
    });
  }

  /* ═══════════════════════════════════════════
     Section collapse
  ═══════════════════════════════════════════ */

  toggleSection(status: FileStatus): void {
    this.sectionExpanded[status] = !this.sectionExpanded[status];
  }

  /* ═══════════════════════════════════════════
     Item selection & add to generation
  ═══════════════════════════════════════════ */

  onHistoryItemClick(itemId: string): void {
    if (this.isDeleteMode) {
      this.toggleDeleteSelection(itemId);
      return;
    }
    if (this.isInferenceMode) {
      const event = new Event('click');
      this.toggleInferenceSelection(itemId, event);
      return;
    }
    const item = this.historyItems.find(i => i.id === itemId);
    if (item) {
      this.selectedHistoryItem = item;
      this.onItemSelect.emit({
        id: item.id,
        name: item.name,
        displayDate: item.displayDate,
        date: item.date,
        summary_prompt: item.summary_prompt,
        faq_prompt: item.faq_prompt
      });
    }
  }

  onAddToGeneration(event: Event, item: HistoryItem): void {
    event.stopPropagation();
    if (this.isFileUploading) {
      alert('A file is currently uploading. Please wait.');
      return;
    }

    const btn = (event.currentTarget as HTMLElement);
    const row = btn.closest('.file-row') as HTMLElement;

    if (this.addedToGenerationId === item.id) {
      this.animateRow(row, 'removing-animation');
      this.addedToGenerationId = null;
      this.onRemoveFromContentGeneration.emit(item.id);
    } else {
      this.animateRow(row, 'adding-animation');
      this.addedToGenerationId = item.id;
      this.onAddToContentGeneration.emit(item);
    }
  }

  isAddedToGeneration(itemId: string): boolean {
    return this.addedToGenerationId === itemId;
  }

  /* ═══════════════════════════════════════════
     Inference mode
  ═══════════════════════════════════════════ */

  toggleInferenceMode(): void {
    if (!this.canUseInferenceMode) return;
    this.isInferenceMode = !this.isInferenceMode;
    if (!this.isInferenceMode) {
      this.selectedInferenceItems.clear();
    }
    // Exit delete mode if active
    if (this.isInferenceMode && this.isDeleteMode) {
      this.isDeleteMode = false;
      this.selectedDeleteItems.clear();
    }
  }

  toggleInferenceSelection(itemId: string, event: Event): void {
    event.stopPropagation();
    if (this.selectedInferenceItems.has(itemId)) {
      this.selectedInferenceItems.delete(itemId);
    } else {
      this.selectedInferenceItems.add(itemId);
    }
  }

  isSelectedForInference(itemId: string): boolean {
    return this.selectedInferenceItems.has(itemId);
  }

  toggleSelectAllInference(status: FileStatus): void {
    const items = this.getItemsByStatus(status);
    const allSelected = items.every(i => this.selectedInferenceItems.has(i.id));
    if (allSelected) {
      items.forEach(i => this.selectedInferenceItems.delete(i.id));
    } else {
      items.forEach(i => this.selectedInferenceItems.add(i.id));
    }
  }

  areAllSelectedForInference(status: FileStatus): boolean {
    const items = this.getItemsByStatus(status);
    return items.length > 0 && items.every(i => this.selectedInferenceItems.has(i.id));
  }

  cancelInference(): void {
    this.selectedInferenceItems.clear();
    this.isInferenceMode = false;
  }

  startBatchInference(): void {
    if (this.selectedInferenceItems.size === 0) return;
    this.isSubmittingBatch = true;

    const fileIds = Array.from(this.selectedInferenceItems).map(Number);

    this.historyService.batchProcess(fileIds, this.inferenceModelName).subscribe({
      next: (res) => {
        // 200 response means batch started — kick off polling
        this.isSubmittingBatch = false;
        this.isInferenceMode = false;
        this.selectedInferenceItems.clear();
        // Immediately refresh to get updated statuses (files should now appear as queued/running)
        this.fetchAll(true);
      },
      error: (err) => {
        console.error('Batch process error:', err);
        this.isSubmittingBatch = false;
        alert('Failed to start batch inference. Please try again.');
      }
    });
  }

  /* ═══════════════════════════════════════════
     Delete mode
  ═══════════════════════════════════════════ */

  toggleDeleteMode(): void {
    this.isDeleteMode = !this.isDeleteMode;
    if (!this.isDeleteMode) this.selectedDeleteItems.clear();
    // Exit inference mode if active
    if (this.isDeleteMode && this.isInferenceMode) {
      this.isInferenceMode = false;
      this.selectedInferenceItems.clear();
    }
  }

  toggleDeleteSelection(itemId: string): void {
    if (this.selectedDeleteItems.has(itemId)) {
      this.selectedDeleteItems.delete(itemId);
    } else {
      this.selectedDeleteItems.add(itemId);
    }
  }

  isSelectedForDelete(itemId: string): boolean {
    return this.selectedDeleteItems.has(itemId);
  }

  toggleSelectAll(status: FileStatus): void {
    const items = this.getItemsByStatus(status);
    const allSelected = items.every(i => this.selectedDeleteItems.has(i.id));
    if (allSelected) {
      items.forEach(i => this.selectedDeleteItems.delete(i.id));
    } else {
      items.forEach(i => this.selectedDeleteItems.add(i.id));
    }
  }

  areAllSelected(status: FileStatus): boolean {
    const items = this.getItemsByStatus(status);
    return items.length > 0 && items.every(i => this.selectedDeleteItems.has(i.id));
  }

  showDeleteConfirmation(): void {
    if (this.selectedDeleteItems.size === 0) return;
    this.isDeleteConfirmationVisible = true;
  }

  closeDeleteConfirmation(): void {
    if (!this.isProcessingDelete) this.isDeleteConfirmationVisible = false;
  }

  cancelMultipleDelete(): void {
    this.selectedDeleteItems.clear();
    this.isDeleteMode = false;
  }

  confirmMultipleDelete(): void {
    this.isDeleteConfirmationVisible = false;
    this.isProcessingDelete = true;
    const ids = Array.from(this.selectedDeleteItems).map(Number);

    this.historyService.deleteFiles(ids).subscribe({
      next: (res) => {
        if (res.status === 'success') {
          this.historyItems = this.historyItems.filter(i => !ids.includes(Number(i.id)));
          if (this.selectedHistoryItem && ids.includes(Number(this.selectedHistoryItem.id))) {
            this.selectedHistoryItem = null;
          }
          if (this.addedToGenerationId && ids.includes(Number(this.addedToGenerationId))) {
            this.addedToGenerationId = null;
          }
        }
        this.selectedDeleteItems.clear();
        this.isProcessingDelete = false;
        this.isDeleteMode = false;
      },
      error: (err) => {
        console.error('Delete error:', err);
        this.isProcessingDelete = false;
        this.isDeleteConfirmationVisible = false;
      }
    });
  }

  /* ═══════════════════════════════════════════
     Input change handlers
  ═══════════════════════════════════════════ */

  private handleNewFileUpload(newFile: NewUploadFile): void {
    if (this.historyItems.find(i => i.id === newFile.id.toString())) return;

    const newItem: HistoryItem = {
      id: newFile.id.toString(),
      name: newFile.original_name,
      displayDate: `Created on ${newFile.created_at}`,
      date: new Date(newFile.created_at),
      status: 'pending',
      progress: 0,
      summary_prompt: newFile.summary_prompt,
      faq_prompt: newFile.faq_prompt
    };

    this.historyItems.unshift(newItem);
    this.sectionExpanded['pending'] = true;

    setTimeout(() => {
      const el = document.querySelector(`.file-row[data-item-id="${newFile.id}"]`) as HTMLElement;
      el?.classList.add('new-item-animation');
      el?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      setTimeout(() => el?.classList.remove('new-item-animation'), 800);
    }, 100);
  }

  private handleGenerationStatusChange(statusUpdate: GenerationStatus): void {
    const item = this.historyItems.find(i => i.id === statusUpdate.id.toString());
    if (!item) return;

    if (statusUpdate.summary_prompt !== undefined) item.summary_prompt = statusUpdate.summary_prompt;
    if (statusUpdate.faq_prompt !== undefined) item.faq_prompt = statusUpdate.faq_prompt;

    if (statusUpdate.status === 'Success') {
      item.status = 'completed';
      item.progress = 100;
      this.sectionExpanded['completed'] = true;
      if (this.addedToGenerationId === item.id) this.addedToGenerationId = null;
      this.animateItemById(item.id, 'success-animation');
      this.updatePollingState();
    } else if (statusUpdate.status === 'Failure') {
      item.status = 'pending';
      item.progress = 0;
      this.sectionExpanded['pending'] = true;
      if (this.addedToGenerationId === item.id) this.addedToGenerationId = null;
      this.animateItemById(item.id, 'failure-animation');
      this.updatePollingState();
    }
  }

  private handleRemoveFromParent(fileToRemove: RemoveGenerateFile): void {
    const itemId = fileToRemove.id.toString();
    if (this.addedToGenerationId === itemId) {
      this.addedToGenerationId = null;
    }
  }

  private handleProcessStatusChange(status: ProcessStatus): void {
    // Kept for backward compatibility — status is now tracked via polling
  }

  /* ═══════════════════════════════════════════
     Helpers
  ═══════════════════════════════════════════ */

  toggleShowAllSteps(): void {
    this.showAllSteps = !this.showAllSteps;
  }

  clearSelection(): void { this.selectedHistoryItem = null; }
  clearAddedToGeneration(): void { this.addedToGenerationId = null; }

  getItemsByStatus(status: FileStatus): HistoryItem[] {
    switch (status) {
      case 'running':   return this.runningFiles;
      case 'queued':    return this.queuedFiles;
      case 'pending':   return this.pendingFiles;
      case 'completed': return this.completedFiles;
    }
  }

  private applySearch(items: HistoryItem[]): HistoryItem[] {
    if (!this.searchText.trim()) return items;
    const term = this.searchText.toLowerCase().trim();
    return items.filter(i =>
      i.name.toLowerCase().includes(term) || i.id.toLowerCase().includes(term)
    );
  }

  private animateRow(el: HTMLElement | null, cls: string): void {
    if (!el) return;
    el.classList.add(cls);
    setTimeout(() => el.classList.remove(cls), 800);
  }

  private animateItemById(id: string, cls: string): void {
    setTimeout(() => {
      const el = document.querySelector(`.file-row[data-item-id="${id}"]`) as HTMLElement;
      this.animateRow(el, cls);
    }, 100);
  }

  private initializeDateRange(): void {
    const today = new Date();
    const thirtyDaysAgo = new Date();
    thirtyDaysAgo.setDate(today.getDate() - 30);
    this.startDate = this.formatDateForDisplay(thirtyDaysAgo);
    this.endDate = this.formatDateForDisplay(today);
  }

  private formatDateForDisplay(date: Date): string {
    return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  }

  private formatDateForApi(date: Date): string {
    return `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`;
  }

  private formatDateForInput(date: Date): string {
    return this.formatDateForApi(date);
  }
}


















