<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>File Sidebar</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />

  <style>
    /* ── Reset & base ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #F5F4F1;
      font-family: 'DM Sans', sans-serif;
    }

    /* ── Sidebar shell ── */
    .sidebar {
      width: 320px;
      background: #ffffff;
      border: 0.5px solid rgba(0, 0, 0, 0.12);
      border-radius: 14px;
      overflow: hidden;
    }

    /* ── Header ── */
    .sidebar-header {
      padding: 14px 16px;
      border-bottom: 0.5px solid rgba(0, 0, 0, 0.08);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .sidebar-title {
      font-size: 11px;
      font-weight: 600;
      color: #888780;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .selected-count {
      font-size: 12px;
      color: #aaa;
      font-family: 'DM Mono', monospace;
      transition: color 0.2s;
    }

    /* ── File list ── */
    .file-list {
      padding: 6px;
      display: flex;
      flex-direction: column;
      gap: 1px;
    }

    /* ── Divider ── */
    .divider {
      height: 0.5px;
      background: rgba(0, 0, 0, 0.06);
      margin: 3px 10px;
    }

    /* ── Individual row ── */
    .file-row {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 10px;
      border-radius: 8px;
      cursor: pointer;
      position: relative;
      border: 0.5px solid transparent;
      transition:
        background 0.15s ease,
        border-color 0.15s ease;
    }

    .file-row:hover {
      background: #F5F4F1;
      border-color: rgba(0, 0, 0, 0.10);
    }

    .file-row:hover .file-icon-wrap {
      transform: scale(1.08);
    }

    .file-row:hover .file-name {
      color: #111;
    }

    .file-row:hover .file-size {
      opacity: 1;
    }

    .file-row:hover .check-box {
      border-color: rgba(0, 0, 0, 0.3);
    }

    /* checked state */
    .file-row.checked {
      background: #EFF6FF;
      border-color: rgba(23, 143, 244, 0.25);
    }

    .file-row.checked .file-name {
      color: #1D6FB8;
    }

    .file-row.checked .file-size {
      color: #1D6FB8;
      opacity: 0.6;
    }

    /* ── Checkbox ── */
    .check-box {
      width: 16px;
      height: 16px;
      border-radius: 4px;
      border: 0.5px solid rgba(0, 0, 0, 0.18);
      background: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition:
        border-color 0.15s ease,
        background 0.15s ease;
    }

    .file-row.checked .check-box {
      background: #178FF4;
      border-color: #178FF4;
    }

    .check-tick {
      width: 8px;
      height: 6px;
      opacity: 0;
      transform: scale(0.5) rotate(-10deg);
      transition:
        opacity 0.15s ease,
        transform 0.18s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .file-row.checked .check-tick {
      opacity: 1;
      transform: scale(1) rotate(0deg);
    }

    /* ── File icon wrapper ── */
    .file-icon-wrap {
      width: 32px;
      height: 32px;
      border-radius: 7px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .file-icon-wrap svg {
      width: 18px;
      height: 18px;
    }

    /* icon bg colours */
    .icon-pdf  { background: #FEF2F2; }
    .icon-img  { background: #EFF6FF; }
    .icon-doc  { background: #EFF6FF; }
    .icon-zip  { background: #FFF7ED; }
    .icon-csv  { background: #F0FDF4; }
    .icon-mp4  { background: #FAF5FF; }
    .icon-psd  { background: #FFF1F2; }
    .icon-svg  { background: #F0FDF4; }

    /* ── File info ── */
    .file-info {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 1px;
    }

    .file-name {
      font-size: 13px;
      font-weight: 500;
      color: #1a1a1a;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      transition: color 0.15s ease;
      line-height: 1.3;
    }

    .file-size {
      font-size: 11px;
      color: #aaa;
      font-family: 'DM Mono', monospace;
      opacity: 0.7;
      transition:
        opacity 0.15s ease,
        color 0.15s ease;
      line-height: 1.3;
    }

    /* ── Footer ── */
    .sidebar-footer {
      padding: 10px 16px;
      border-top: 0.5px solid rgba(0, 0, 0, 0.08);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .footer-action {
      font-size: 12px;
      font-weight: 500;
      color: #aaa;
      cursor: pointer;
      transition: color 0.12s;
      user-select: none;
      background: none;
      border: none;
      font-family: 'DM Sans', sans-serif;
    }

    .footer-action:hover { color: #333; }

    .footer-action.primary {
      color: #178FF4;
      padding: 5px 12px;
      border-radius: 7px;
      border: 0.5px solid #178FF4;
      transition:
        background 0.15s ease,
        color 0.15s ease;
    }

    .footer-action.primary:hover {
      background: #178FF4;
      color: #fff;
    }
  </style>
</head>
<body>

  <div class="sidebar">
    <div class="sidebar-header">
      <span class="sidebar-title">Files</span>
      <span class="selected-count" id="count-label">0 selected</span>
    </div>

    <div class="file-list" id="file-list">
      <!-- rows injected by JS below -->
    </div>

    <div class="sidebar-footer">
      <button class="footer-action" id="select-all-btn">Select all</button>
      <button class="footer-action primary" id="download-btn">Download</button>
    </div>
  </div>

  <script>
    const files = [
      { name: 'Q4_Report_Final.pdf',   size: '2.4 MB',  type: 'pdf' },
      { name: 'hero_banner.png',        size: '840 KB',  type: 'img' },
      { name: 'Project_Brief.docx',     size: '128 KB',  type: 'doc' },
      { name: 'assets_v2.zip',          size: '18.3 MB', type: 'zip' },
      { name: 'analytics_export.csv',   size: '64 KB',   type: 'csv' },
      { name: 'product_demo.mp4',       size: '54.1 MB', type: 'mp4' },
      { name: 'brand_kit.psd',          size: '11.7 MB', type: 'psd' },
      { name: 'logo_final.svg',         size: '22 KB',   type: 'svg' },
    ];

    /* Inline SVG icons per type */
    const icons = {
      pdf: `<svg viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="2" y="1" width="11" height="14" rx="1.5" fill="#FCA5A5"/>
              <rect x="4" y="1" width="11" height="14" rx="1.5" fill="#EF4444"/>
              <path d="M6 8h6M6 10.5h4" stroke="#fff" stroke-width="1.2" stroke-linecap="round"/>
              <path d="M10 1v4h4" fill="none" stroke="#fff" stroke-width="1"/>
            </svg>`,

      img: `<svg viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="2" y="3" width="14" height="12" rx="2" fill="#93C5FD"/>
              <circle cx="6.5" cy="7.5" r="1.5" fill="#2563EB"/>
              <path d="M2 12l4-3.5 3 3 2-2 5 4.5" stroke="#2563EB" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>`,

      doc: `<svg viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="2" y="1" width="14" height="16" rx="1.5" fill="#DBEAFE"/>
              <path d="M5 6h8M5 9h8M5 12h5" stroke="#2563EB" stroke-width="1.2" stroke-linecap="round"/>
            </svg>`,

      zip: `<svg viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="3" y="1" width="12" height="16" rx="1.5" fill="#FED7AA"/>
              <path d="M8 1v16" stroke="#F97316" stroke-width="1.5" stroke-dasharray="2 2"/>
              <rect x="6.5" y="7" width="5" height="4" rx="1" fill="#F97316" opacity=".5"/>
            </svg>`,

      csv: `<svg viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="2" y="2" width="14" height="14" rx="2" fill="#BBF7D0"/>
              <path d="M2 7h14M2 11h14M7 2v14" stroke="#16A34A" stroke-width="1"/>
            </svg>`,

      mp4: `<svg viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="1" y="3" width="16" height="12" rx="2" fill="#E9D5FF"/>
              <path d="M7 7l5 2.5L7 12V7z" fill="#7C3AED"/>
            </svg>`,

      psd: `<svg viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="2" y="1" width="14" height="16" rx="2" fill="#FFE4E6"/>
              <text x="9" y="12" text-anchor="middle" font-size="6" font-weight="700" fill="#E11D48" font-family="sans-serif">PSD</text>
            </svg>`,

      svg: `<svg viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="2" y="2" width="14" height="14" rx="2" fill="#DCFCE7"/>
              <path d="M5 9c0-2.2 1.8-4 4-4s4 1.8 4 4-1.8 4-4 4" stroke="#16A34A" stroke-width="1.2" stroke-linecap="round"/>
              <circle cx="9" cy="9" r="1.5" fill="#16A34A"/>
            </svg>`,
    };

    const list         = document.getElementById('file-list');
    const countLabel   = document.getElementById('count-label');
    const selectAllBtn = document.getElementById('select-all-btn');
    const checkedSet   = new Set();

    function updateCount() {
      const n = checkedSet.size;
      countLabel.textContent = n === 0 ? '0 selected' : `${n} selected`;
      selectAllBtn.textContent = checkedSet.size === files.length ? 'Deselect all' : 'Select all';
    }

    files.forEach((file, i) => {
      /* divider every 4 rows */
      if (i > 0 && i % 4 === 0) {
        const div = document.createElement('div');
        div.className = 'divider';
        list.appendChild(div);
      }

      const row = document.createElement('div');
      row.className = 'file-row';
      row.innerHTML = `
        <div class="check-box">
          <svg class="check-tick" viewBox="0 0 8 6" fill="none">
            <path d="M1 3l2 2 4-4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="file-icon-wrap icon-${file.type}">${icons[file.type]}</div>
        <div class="file-info">
          <div class="file-name">${file.name}</div>
          <div class="file-size">${file.size}</div>
        </div>
      `;

      row.addEventListener('click', () => {
        if (checkedSet.has(i)) {
          checkedSet.delete(i);
          row.classList.remove('checked');
        } else {
          checkedSet.add(i);
          row.classList.add('checked');
        }
        updateCount();
      });

      list.appendChild(row);
    });

    selectAllBtn.addEventListener('click', () => {
      const rows = list.querySelectorAll('.file-row');
      if (checkedSet.size === files.length) {
        checkedSet.clear();
        rows.forEach(r => r.classList.remove('checked'));
      } else {
        files.forEach((_, i) => checkedSet.add(i));
        rows.forEach(r => r.classList.add('checked'));
      }
      updateCount();
    });
  </script>
</body>
</html>
