/* ── YOUR EXISTING CSS (unchanged) ── */
:root {
  --session-card-bg: #fafafa;
  --playground-item-color: #242424;
  --session-card-border: 1px solid #bfbfbf;
}

.dark-mode {
  --session-card-bg: #1d1d1d;
  --playground-item-color: #FFF;
  --session-card-border: 1px solid #27272a;
}

.session-card {
  margin: 10px;
  padding: 1rem;
  border-radius: 8px 0px 8px 0px;
  background-color: var(--session-card-bg);
  color: var(--playground-item-color);
  border: var(--session-card-border);
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.session-container {
  overflow-x: hidden;
}

/* ── NEW CSS ── */

@property --border-angle {
  syntax: '<angle>';
  initial-value: 0deg;
  inherits: false;
}

@keyframes spin-border {
  to { --border-angle: 360deg; }
}

.session-card-wrapper {
  position: relative;
  border-radius: 10px 0 10px 0;
  padding: 2px;
  background: transparent;
  margin: 10px;
  width: calc(100% - 20px);
}

.session-card-wrapper .session-card {
  margin: 0;
  width: 100%;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

/* Spinning gradient border on hover */
.session-card-wrapper::before {
  content: '';
  position: absolute;
  inset: -2px;
  border-radius: 10px 0 10px 0;
  background: conic-gradient(
    from var(--border-angle),
    transparent 0%, transparent 25%,
    #7c3aed 45%, #ec4899 58%, #06b6d4 70%,
    transparent 85%, transparent 100%
  );
  opacity: 0;
  z-index: 0;
  transition: opacity 0.35s ease;
}

/* Glow on hover */
.session-card-wrapper::after {
  content: '';
  position: absolute;
  inset: -6px;
  border-radius: 14px 0 14px 0;
  background: conic-gradient(
    from var(--border-angle),
    transparent 0%, transparent 25%,
    #7c3aed 45%, #ec4899 58%, #06b6d4 70%,
    transparent 85%, transparent 100%
  );
  opacity: 0;
  filter: blur(14px);
  z-index: -1;
  transition: opacity 0.35s ease;
}

.session-card-wrapper:hover::before {
  opacity: 1;
  animation: spin-border 2.2s linear infinite;
}

.session-card-wrapper:hover::after {
  opacity: 0.3;
  animation: spin-border 2.2s linear infinite;
}

.session-card-wrapper:hover .session-card {
  border-color: transparent;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
  transform: translateY(-2px);
}

/* Menu button */
.session-menu-btn {
  width: 30px;
  height: 30px;
  border-radius: 6px 0 6px 0;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.4;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.session-card:hover .session-menu-btn {
  opacity: 1;
  background: rgba(124, 58, 237, 0.1);
  color: #7c3aed;
}

/* Session time */
.session-time {
  font-size: 11.5px;
  font-style: normal;
  opacity: 0.5;
  letter-spacing: 0.02em;
  display: block;
}

/* ── ACTIVE STATE ── */
.session-card-wrapper:has(.active-session-card) .session-card {
  border: 2px solid transparent !important;
  background-color: unset !important;
  background: linear-gradient(var(--session-card-bg), var(--session-card-bg)) padding-box,
              linear-gradient(135deg, #7c3aed, #ec4899, #06b6d4) border-box !important;
  box-shadow: 0 4px 16px rgba(124, 58, 237, 0.12);
}

/* Hide spinning border when active */
.session-card-wrapper:has(.active-session-card)::before,
.session-card-wrapper:has(.active-session-card)::after {
  display: none;
}

.session-card.active-session-card .session-menu-btn {
  opacity: 1;
  color: #7c3aed;
}

/* Dark mode active */
.dark-mode .session-card-wrapper:has(.active-session-card) .session-card {
  background: linear-gradient(var(--session-card-bg), var(--session-card-bg)) padding-box,
              linear-gradient(135deg, #7c3aed, #ec4899, #06b6d4) border-box !important;
  box-shadow: 0 4px 20px rgba(124, 58, 237, 0.25);
}
