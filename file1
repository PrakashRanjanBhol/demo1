      </div>
      <div class="sldc-metric">
        <p class="sldc-metric__label">Total questions on Confluence</p>
        <p class="sldc-metric__value">{{ qa.data?.confluence_count ?? '—' }}</p>
        <span class="sldc-badge sldc-badge--blue">Confluence</span>
      </div>
    </div>
  </div>

  <!-- ── Bitbucket Analysis ── -->
