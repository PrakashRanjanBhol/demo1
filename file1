    border: none;
    cursor: pointer;
    color: #6b7280;
    padding: 4px;
    display: flex;
    align-items: center;
    border-radius: 4px;

    &:hover {
        background-color: #f3f4f6;
        color: #111827;
    }
}

.urlViewTitle {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    color: #111827;
}

