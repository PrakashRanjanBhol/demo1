// ─── Keyframes ────────────────────────────────────────────────────────────────

@keyframes cmi-ping {
  0%        { transform: scale(1);   opacity: 0.55; }
  75%, 100% { transform: scale(2.4); opacity: 0;    }
}

@keyframes cmi-tooltip-in {
  from { opacity: 0; transform: translateX(-50%) translateY(4px); }
  to   { opacity: 1; transform: translateX(-50%) translateY(0);   }
}

// ─── Wrapper ──────────────────────────────────────────────────────────────────

.wrapper {
  display:         inline-flex;
  align-items:     center;
  justify-content: center;
  height:          44px;          // ← fixed constraint
  user-select:     none;
  transition:      opacity 0.16s ease, transform 0.16s ease;

  &.visible {
    opacity:   1;
    transform: translateY(0);
  }

  &.hidden {
    opacity:   0;
    transform: translateY(-4px);
  }
}

// ─── Pill ─────────────────────────────────────────────────────────────────────

.pill {
  display:       inline-flex;
  align-items:   center;
  gap:           8px;
  height:        32px;
  padding:       0 10px 0 8px;
  border-radius: 100px;
  background:    var(--cmi-bg-surface);
  border:        1px solid transparent;
  transition:    border-color 0.3s ease, background 0.3s ease;
}

// ─── Panel section ────────────────────────────────────────────────────────────

.panelSection {
  display:     flex;
  align-items: center;
  gap:         4px;
}

.arrowIcon {
  flex-shrink: 0;
  color:       var(--cmi-active-accent);
}

.panelLabel {
  font-size:      10px;
  font-weight:    700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color:          var(--cmi-active-accent);
  white-space:    nowrap;
  transition:     color 0.3s ease;
}

// ─── Divider ──────────────────────────────────────────────────────────────────

.divider {
  display:     block;
  width:       1px;
  height:      14px;
  flex-shrink: 0;
  background:  var(--cmi-border-subtle);
}

// ─── Badge ────────────────────────────────────────────────────────────────────

.badge {
  display:       inline-flex;
  align-items:   center;
  gap:           5px;
  height:        22px;
  padding:       0 9px 0 6px;
  border-radius: 100px;
  background:    var(--cmi-active-badge-bg);
  border:        1px solid var(--cmi-active-badge-border);
  color:         var(--cmi-active-accent);
  white-space:   nowrap;
  transition:    background 0.3s ease, border-color 0.3s ease, color 0.3s ease;
}

.badgeLabel {
  font-size:   11px;
  font-weight: 600;
}

// ─── Pulsing dot ──────────────────────────────────────────────────────────────

.dot {
  position:    relative;
  display:     inline-flex;
  width:       7px;
  height:      7px;
  flex-shrink: 0;
}

.dotRing {
  position:      absolute;
  inset:         0;
  border-radius: 50%;
  background:    var(--cmi-active-accent);
  animation:     cmi-ping 1.8s cubic-bezier(0, 0, 0.2, 1) infinite;
}

.dotCore {
  position:      relative;
  width:         7px;
  height:        7px;
  border-radius: 50%;
  background:    var(--cmi-active-accent);
}

// ─── Info icon + tooltip ──────────────────────────────────────────────────────

.infoWrapper {
  position:    relative;
  display:     inline-flex;
  align-items: center;
  cursor:      default;

  // Reveal tooltip on hover / focus-within
  &:hover .tooltip,
  &:focus-within .tooltip {
    opacity:        1;
    pointer-events: auto;
    animation:      cmi-tooltip-in 0.16s ease forwards;
  }
}

.infoIcon {
  display:     block;
  color:       var(--cmi-info-color);
  flex-shrink: 0;
  transition:  color 0.15s ease;

  .infoWrapper:hover & {
    color: var(--cmi-info-hover);
  }
}

.tooltip {
  position:       absolute;
  bottom:         calc(100% + 8px);
  left:           50%;
  transform:      translateX(-50%) translateY(4px);
  white-space:    nowrap;
  padding:        6px 11px;
  border-radius:  7px;
  background:     var(--cmi-tooltip-bg);
  border:         1px solid var(--cmi-tooltip-border);
  color:          var(--cmi-tooltip-text);
  pointer-events: none;
  opacity:        0;
  transition:     opacity 0.15s ease;
  z-index:        200;
}

.tooltipText {
  font-size:      11.5px;
  font-weight:    400;
  letter-spacing: 0.01em;
  line-height:    1;
}

// Downward-pointing caret
.tooltipArrow {
  position:   absolute;
  top:        100%;
  left:       50%;
  transform:  translateX(-50%);
  width:      0;
  height:     0;
  border:     5px solid transparent;
  border-top-color: var(--cmi-tooltip-bg);

  // Slightly larger border-only version for the outline effect
  &::before {
    content:    "";
    position:   absolute;
    top:        -4px;
    left:       -5px;
    width:      0;
    height:     0;
    border:     5px solid transparent;
    border-top-color: var(--cmi-tooltip-border);
    z-index:    -1;
  }
}

// ─── Accent modifiers ────────────────────────────────────────────────────────

.accentTeal {
  --cmi-active-accent:       var(--cmi-teal-accent);
  --cmi-active-badge-bg:     var(--cmi-teal-badge-bg);
  --cmi-active-badge-border: var(--cmi-teal-badge-border);

  .pill { border-color: var(--cmi-teal-pill-border); }
}

.accentBlue {
  --cmi-active-accent:       var(--cmi-blue-accent);
  --cmi-active-badge-bg:     var(--cmi-blue-badge-bg);
  --cmi-active-badge-border: var(--cmi-blue-badge-border);

  .pill { border-color: var(--cmi-blue-pill-border); }
}

.accentPurple {
  --cmi-active-accent:       var(--cmi-purple-accent);
  --cmi-active-badge-bg:     var(--cmi-purple-badge-bg);
  --cmi-active-badge-border: var(--cmi-purple-badge-border);

  .pill { border-color: var(--cmi-purple-pill-border); }
}

.accentGreen {
  --cmi-active-accent:       var(--cmi-green-accent);
  --cmi-active-badge-bg:     var(--cmi-green-badge-bg);
  --cmi-active-badge-border: var(--cmi-green-badge-border);

  .pill { border-color: var(--cmi-green-pill-border); }
}
