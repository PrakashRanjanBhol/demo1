export const ExcelAnalysisTool: React.FC<ExcelAnalysisToolProps> = ({ onBack }) => {
  // Replace MOCK_FILES with your store data when ready
  const files: FileItem[] = MOCK_FILES;

  const excelFiles = files.filter(
    (f) => f.file_type === "xlsx" || f.file_type === "csv"
  );

  const [selectedJobId, setSelectedJobId] = useState<string | null>(null);
  const [isLoading, setIsLoading]         = useState(false);
  const [error, setError]                 = useState<string | null>(null);
  const [warning, setWarning]             = useState<string | null>(null);
  const [success, setSuccess]             = useState(false);

  const handleToggle = (file_job_id: string) => {
    setSelectedJobId((prev) => (prev === file_job_id ? null : file_job_id));
    setError(null);
    setWarning(null);
    setSuccess(false);
  };

  const handleAnalyse = async () => {
    setIsLoading(true);
    setError(null);
    setWarning(null);
    setSuccess(false);

    try {
      const res = await fetch("/api/excel-analysis/generate", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          file_job_id:  selectedJobId,
          tool_type_id: 6,
        }),
      });

      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        throw new Error(data?.message ?? "Failed to analyse file.");
      }

      setSuccess(true);
    } catch (err: any) {
      setError(err?.message ?? "Something went wrong.");
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <div className={styles.wrapper}>

      {/* ── Header ── */}
      <div className={styles.toolHeader}>
        <div className={styles.toolHeaderTop}>
          <div className={styles.breadcrumb}>
            <button className={styles.breadcrumbLink} onClick={onBack}>Tools</button>
            <span className={styles.breadcrumbSep}>›</span>
            <span className={styles.breadcrumbCurrent}>Excel Analysis</span>
          </div>
        </div>
        <div className={styles.toolHeaderBottom}>
          <div className={styles.toolIcon}>
            <img src={excelAnalysisIcon} alt="Excel Analysis" width={22} height={22} className={styles.img} />
          </div>
          <div className={styles.toolMeta}>
            <h2 className={styles.toolName}>Excel Analysis</h2>
          </div>
        </div>
      </div>

      {/* ── Body ── */}
      <div className={styles.body}>

        <p className={styles.description}>
          Select an Excel or CSV file to analyse. Only one file can be selected at a time.
        </p>

        {/* File list */}
        {excelFiles.length === 0 ? (
          <div className={styles.emptyState}>
            <div className={styles.emptyIcon}><EmptyIcon /></div>
            <p>No Excel or CSV files available</p>
            <span>Upload an .xlsx or .csv file to get started.</span>
          </div>
        ) : (
          <ul className={styles.fileList}>
            {excelFiles.map((file) => {
              const isSelected  = selectedJobId === file.file_job_id;
              const isDisabled  = selectedJobId !== null && !isSelected;
              const isXlsx      = file.file_type === "xlsx";

              return (
                <li key={file.file_job_id}>
                  <label
                    className={`${styles.fileItem} ${isSelected ? styles.fileItemSelected : ""} ${isDisabled ? styles.fileItemDisabled : ""}`}
                  >
                    <input
                      type="checkbox"
                      className={styles.fileCheckbox}
                      checked={isSelected}
                      disabled={isDisabled}
                      onChange={() => handleToggle(file.file_job_id)}
                    />
                    <span className={`${styles.fileTypeIcon} ${isXlsx ? styles.fileTypeIconXlsx : styles.fileTypeIconCsv}`}>
                      {isXlsx ? <XlsxIcon /> : <CsvIcon />}
                    </span>
                    <div className={styles.fileInfo}>
                      <span className={styles.fileName}>{file.file_name}</span>
                      <span className={styles.fileMeta}>
                        <span className={`${styles.fileTypeBadge} ${isXlsx ? styles.fileTypeBadgeXlsx : styles.fileTypeBadgeCsv}`}>
                          {file.file_type.toUpperCase()}
                        </span>
                        <span className={styles.fileSize}>{formatFileSize(file.file_size)}</span>
                      </span>
                    </div>
                  </label>
                </li>
              );
            })}
          </ul>
        )}

        {/* Warning */}
        {warning && (
          <div className={styles.warningState}>{warning}</div>
        )}

        {/* Error */}
        {error && (
          <div className={styles.errorState}>{error}</div>
        )}

        {/* Success */}
        {success && !error && (
          <div className={styles.successState}>
            Analysis started successfully!
          </div>
        )}

        {/* Analyse button */}
        {excelFiles.length > 0 && (
          <button
            className={styles.analyseBtn}
            onClick={handleAnalyse}
            disabled={isLoading || !selectedJobId}
          >
            {isLoading ? (
              <>
                <span className={styles.spinner} />
                <span>Analysing…</span>
              </>
            ) : (
              <>
                <SparkleIcon />
                <span>Analyse</span>
              </>
            )}
          </button>
        )}

      </div>
    </div>
  );
};

export default ExcelAnalysisTool;


















