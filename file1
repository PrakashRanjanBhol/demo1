GeneralSettings.module.scss
---------------------------



.formCard {
  background: var(--settings-content-bg);
  border: 1px solid var(--settings-panel-border-color);
  border-radius: 14px;
  padding: 32px;
  box-shadow: var(--settings-panel-box-shadow);
  max-width: 540px;
  display: flex;
  flex-direction: column;
  gap: 28px;
}

.fieldGroup {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.labelRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.label {
  font-size: 0.84375rem;
  font-weight: 600;
  color: var(--settings-text-primary);
}

.hint {
  font-size: 0.75rem;
  color: var(--settings-text-tertiary);
}

.inputWrapper {
  display: flex;
  align-items: center;
  border: 1.5px solid var(--settings-border-color);
  border-radius: 9px;
  background: var(--settings-content-bg);
  overflow: hidden;
  transition: border-color 0.15s ease, box-shadow 0.15s ease;

  &:focus-within {
    border-color: var(--settings-accent-border);
    box-shadow: 0 0 0 3px var(--settings-accent-light);
  }

  &.error {
    border-color: var(--settings-error-color);
    box-shadow: 0 0 0 3px var(--settings-error-bg);
  }
}

.input {
  flex: 1;
  border: none;
  outline: none;
  padding: 10px 14px;
  font-size: 0.875rem;
  font-family: system-ui, sans-serif;
  color: var(--settings-text-primary);
  background: transparent;

  &::placeholder {
    color: var(--settings-text-tertiary);
  }

  &::-webkit-outer-spin-button,
  &::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  &[type='number'] {
    -moz-appearance: textfield;
  }
}

.unit {
  padding: 10px 14px;
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--settings-accent);
  background: var(--settings-accent-light);
  border-left: 1.5px solid var(--settings-border-color);
  user-select: none;
}

.errorText {
  font-size: 0.75rem;
  color: var(--settings-error-color);
  margin-top: 2px;
}

.divider {
  height: 1px;
  background: var(--settings-border-color);
}

.footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.saveBtn {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 24px;
  border-radius: 9px;
  border: none;
  background: var(--settings-gradient);
  color: var(--settings-btn-text);
  font-size: 0.875rem;
  font-weight: 600;
  font-family: system-ui, sans-serif;
  cursor: pointer;
  transition: opacity 0.15s ease, box-shadow 0.15s ease;

  &:hover:not(:disabled) {
    opacity: 0.9;
    box-shadow: 0 4px 12px var(--settings-box-shadow);
  }

  &:disabled {
    opacity: 0.45;
    cursor: not-allowed;
    box-shadow: none;
  }

  svg {
    width: 15px;
    height: 15px;
  }
}

.successMsg {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.8125rem;
  color: var(--settings-success-color);
  font-weight: 500;

  svg {
    width: 15px;
    height: 15px;
  }
}

.saveErrMsg {
  font-size: 0.8125rem;
  color: var(--settings-error-color);
}

.spinner {
  display: inline-block;
  width: 15px;
  height: 15px;
  border: 2px solid rgba(255, 255, 255, 0.4);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.skeletonCard {
  background: var(--settings-content-bg);
  border: 1px solid var(--settings-panel-border-color);
  border-radius: 14px;
  padding: 32px;
  box-shadow: var(--settings-panel-box-shadow);
  max-width: 540px;
  display: flex;
  flex-direction: column;
  gap: 28px;
}

.skeletonField {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.skeletonLabel {
  height: 13px;
  width: 140px;
  border-radius: 4px;
  background: linear-gradient(
    90deg,
    var(--settings-table-row-odd) 25%,
    var(--settings-border-color) 50%,
    var(--settings-table-row-odd) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.4s ease-in-out infinite;
}

.skeletonInput {
  height: 42px;
  border-radius: 9px;
  background: linear-gradient(
    90deg,
    var(--settings-table-row-odd) 25%,
    var(--settings-border-color) 50%,
    var(--settings-table-row-odd) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.4s ease-in-out infinite;
}

.skeletonBtn {
  height: 40px;
  width: 130px;
  border-radius: 9px;
  background: linear-gradient(
    90deg,
    var(--settings-table-row-odd) 25%,
    var(--settings-border-color) 50%,
    var(--settings-table-row-odd) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.4s ease-in-out infinite;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
