// Add this method to handle folder/directory selection
async handleFileOrFolderSelection(items: FileList | DataTransferItemList): Promise<File[]> {
  const files: File[] = [];
  
  if (items instanceof FileList) {
    // Handle file input selection
    for (let i = 0; i < items.length; i++) {
      const file = items[i];
      if (this.isValidFileType(file) && file.size > 0) {
        files.push(file);
      }
    }
  } else {
    // Handle drag and drop with DataTransferItemList
    const entries: FileSystemEntry[] = [];
    
    for (let i = 0; i < items.length; i++) {
      const item = items[i].webkitGetAsEntry();
      if (item) {
        entries.push(item);
      }
    }
    
    // Process all entries (files and directories)
    for (const entry of entries) {
      const extractedFiles = await this.processEntry(entry);
      files.push(...extractedFiles);
    }
  }
  
  return files;
}

// Recursively process file system entries
private async processEntry(entry: FileSystemEntry): Promise<File[]> {
  const files: File[] = [];
  
  if (entry.isFile) {
    const file = await this.getFileFromEntry(entry as FileSystemFileEntry);
    if (file && this.isValidFileType(file) && file.size > 0) {
      files.push(file);
    }
  } else if (entry.isDirectory) {
    const dirFiles = await this.readDirectory(entry as FileSystemDirectoryEntry);
    files.push(...dirFiles);
  }
  
  return files;
}

// Get File object from FileSystemFileEntry
private getFileFromEntry(entry: FileSystemFileEntry): Promise<File> {
  return new Promise((resolve, reject) => {
    entry.file(resolve, reject);
  });
}

// Read directory recursively
private async readDirectory(directory: FileSystemDirectoryEntry): Promise<File[]> {
  const files: File[] = [];
  const entries = await this.readAllDirectoryEntries(directory);
  
  for (const entry of entries) {
    const extractedFiles = await this.processEntry(entry);
    files.push(...extractedFiles);
  }
  
  return files;
}

// Read all entries from a directory
private readAllDirectoryEntries(directory: FileSystemDirectoryEntry): Promise<FileSystemEntry[]> {
  return new Promise((resolve, reject) => {
    const reader = directory.createReader();
    const entries: FileSystemEntry[] = [];
    
    const readEntries = () => {
      reader.readEntries(
        (results) => {
          if (results.length === 0) {
            resolve(entries);
          } else {
            entries.push(...results);
            readEntries(); // Continue reading if there are more entries
          }
        },
        reject
      );
    };
    
    readEntries();
  });
}

// Update the onFileSelected method
async onFileSelected(event: any): Promise<void> {
  if (this.isUploading) return;

  const files = event.target.files;
  if (files && files.length > 0) {
    const validFiles = await this.handleFileOrFolderSelection(files);
    
    for (const file of validFiles) {
      const exists = this.uploadedFilesWithStatus.some(f => f.file.name === file.name);
      if (!exists) {
        this.uploadedFilesWithStatus.push({
          file: file,
          status: 'pending',
          progress: 0
        });
      }
    }
    
    if (validFiles.length === 0) {
      alert('No valid .vtt or .srt files found in the selected folder(s).');
    }
  }
  // Reset input value to allow re-uploading same file
  event.target.value = '';
}

// Update the onFileDrop method
async onFileDrop(event: DragEvent): Promise<void> {
  if (this.isUploading) return;

  event.preventDefault();
  this.isDragging = false;

  const items = event.dataTransfer?.items;
  if (items && items.length > 0) {
    const validFiles = await this.handleFileOrFolderSelection(items);
    
    for (const file of validFiles) {
      const exists = this.uploadedFilesWithStatus.some(f => f.file.name === file.name);
      if (!exists) {
        this.uploadedFilesWithStatus.push({
          file: file,
          status: 'pending',
          progress: 0
        });
      }
    }
    
    if (validFiles.length === 0) {
      alert('No valid .vtt or .srt files found in the dropped folder(s).');
    }
  }
}









