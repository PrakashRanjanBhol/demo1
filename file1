    <img src={summaryIcon} alt="Summary" className={styles.cardIcon} />
  </span>
  <span className={styles.cardNameGroup}>
    <span className={styles.cardName}>Summary</span>
    <span className={styles.cardMeta}>AI-generated digest</span>
  </span>
  <svg className={styles.cardChevron} width="14" height="14" viewBox="0 0 14 14" fill="none">
    <path d="M4 7h6M8 5l2 2-2 2" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"/>
  </svg>
</button>

