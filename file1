.cardIcon {
  object-fit: contain;
  display: block;
}

.cardPlus {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  border: 1.5px solid var(--border-color);
  background: var(--sidebar-bg);
  color: var(--text-secondary);
  flex-shrink: 0;
  transition: all 0.18s ease;
  margin-top: 1px;
}

// ── Card text ─────────────────────────────────────────

.cardName {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.2;
  letter-spacing: -0.01em;
}

.cardDesc {
  font-size: 0.72rem;
  color: var(--text-secondary);
