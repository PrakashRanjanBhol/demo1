getInferenceProgress(itemId: string): number {
  const queueItem = this.inferenceQueue.find(qi => qi.id === itemId);
  return queueItem ? queueItem.progress : 0;
}



<div class="queue-progress-fill" [style.width.%]="inferenceQueue.find(qi => qi.id === item.id)?.progress || 0"></div>

<span class="queue-progress-text">{{ inferenceQueue.find(qi => qi.id === item.id)?.progress || 0 }}%</span>






<div class="queue-progress-fill" [style.width.%]="getInferenceProgress(item.id)"></div>

<span class="queue-progress-text">{{ getInferenceProgress(item.id) }}%</span>







