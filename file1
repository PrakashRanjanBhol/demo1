stopQueuedFile(itemId: string, event: Event): void {
  event.stopPropagation();
  this.historyService.stopFiles([Number(itemId)]).subscribe({
    next: (res) => {
      if (res.status === 'success') {
        const item = this.historyItems.find(i => i.id === itemId);
        if (item) item.status = 'pending';
      }
    },
    error: (err) => {
      console.error('Stop file error:', err);
      if (err.status === 403) {
        const item = this.historyItems.find(i => i.id === itemId);
        if (item) item.status = 'running';
        this.sectionExpanded['running'] = true;
        alert(
          'This file has already started running and can no longer be stopped. ' +
          'It has been moved to the Running section.'
        );
        this.fetchAll(true);
      } else {
        alert('Failed to stop the file. Please try again.');
      }
    }
  });
}
