import { createAsyncThunk, createSlice, PayloadAction } from '@reduxjs/toolkit';
import {
  Department,
  Member,
  UpdateEmployeeAccessRequest,
  UpdateTeamAccessRequest,
  fetchDeptAccessListApi,
  fetchUserAccessListApi,
  updateEmployeeAccessApi,
  updateTeamAccessApi,
} from '../../api/accessManagementApi';

interface AccessManagementState {
  departments: Department[];
  members: Member[];
  selectedDeptId: number | null;
  deptLoading: boolean;
  memberLoading: boolean;
  deptError: string | null;
  memberError: string | null;
  updatingTeams: string[];
  updatingEmployees: string[];
}

const initialState: AccessManagementState = {
  departments: [],
  members: [],
  selectedDeptId: null,
  deptLoading: false,
  memberLoading: false,
  deptError: null,
  memberError: null,
  updatingTeams: [],
  updatingEmployees: [],
};

export const fetchDeptAccessList = createAsyncThunk(
  'accessManagement/fetchDeptAccessList',
  async (_, { rejectWithValue }) => {
    try {
      return await fetchDeptAccessListApi();
    } catch (err: unknown) {
      return rejectWithValue(err instanceof Error ? err.message : 'Failed to fetch departments');
    }
  }
);

export const fetchUserAccessList = createAsyncThunk(
  'accessManagement/fetchUserAccessList',
  async (department_id: number, { rejectWithValue }) => {
    try {
      return await fetchUserAccessListApi(department_id);
    } catch (err: unknown) {
      return rejectWithValue(err instanceof Error ? err.message : 'Failed to fetch members');
    }
  }
);

export const updateTeamAccess = createAsyncThunk(
  'accessManagement/updateTeamAccess',
  async (
    payload: UpdateTeamAccessRequest[],
    { rejectWithValue, dispatch, getState }
  ) => {
    try {
      await updateTeamAccessApi(payload);
      // update dept is_allowed in store directly
      // then re-fetch members for currently selected dept
      const state = (getState() as { accessManagement: AccessManagementState }).accessManagement;
      if (state.selectedDeptId !== null) {
        dispatch(fetchUserAccessList(state.selectedDeptId));
      }
      return payload;
    } catch (err: unknown) {
      return rejectWithValue(err instanceof Error ? err.message : 'Failed to update team access');
    }
  }
);

export const updateEmployeeAccess = createAsyncThunk(
  'accessManagement/updateEmployeeAccess',
  async (
    payload: { updates: UpdateEmployeeAccessRequest[] },
    { rejectWithValue }
  ) => {
    try {
      await updateEmployeeAccessApi(payload.updates);
      return payload.updates;
    } catch (err: unknown) {
      return rejectWithValue(err instanceof Error ? err.message : 'Failed to update employee access');
    }
  }
);

const accessManagementSlice = createSlice({
  name: 'accessManagement',
  initialState,
  reducers: {
    setSelectedDeptId(state, action: PayloadAction<number>) {
      state.selectedDeptId = action.payload;
    },
  },
  extraReducers: (builder) => {
    builder
      // fetch depts
      .addCase(fetchDeptAccessList.pending, (state) => {
        state.deptLoading = true;
        state.deptError = null;
      })
      .addCase(fetchDeptAccessList.fulfilled, (state, action: PayloadAction<Department[]>) => {
        state.deptLoading = false;
        state.departments = action.payload;
      })
      .addCase(fetchDeptAccessList.rejected, (state, action) => {
        state.deptLoading = false;
        state.deptError = action.payload as string;
      })

      // fetch members
      .addCase(fetchUserAccessList.pending, (state) => {
        state.memberLoading = true;
        state.memberError = null;
      })
      .addCase(fetchUserAccessList.fulfilled, (state, action: PayloadAction<Member[]>) => {
        state.memberLoading = false;
        state.members = action.payload;
      })
      .addCase(fetchUserAccessList.rejected, (state, action) => {
        state.memberLoading = false;
        state.memberError = action.payload as string;
      })

      // update team — update store directly + fetch members
      .addCase(updateTeamAccess.pending, (state, action) => {
        state.updatingTeams = action.meta.arg.map((d) => d.department_name);
      })
      .addCase(updateTeamAccess.fulfilled, (state, action) => {
        state.updatingTeams = [];
        action.payload.forEach(({ department_name, is_allowed }) => {
          const dept = state.departments.find((d) => d.department_name === department_name);
          if (dept) dept.is_allowed = is_allowed;
        });
      })
      .addCase(updateTeamAccess.rejected, (state) => {
        state.updatingTeams = [];
      })

      // update employees — update store directly
      .addCase(updateEmployeeAccess.pending, (state, action) => {
        state.updatingEmployees = action.meta.arg.updates.map((u) => u.username);
      })
      .addCase(updateEmployeeAccess.fulfilled, (state, action) => {
        state.updatingEmployees = [];
        action.payload.forEach(({ username, is_allowed }) => {
          const member = state.members.find((m) => m.username === username);
          if (member) member.is_allowed = is_allowed;
        });
      })
      .addCase(updateEmployeeAccess.rejected, (state) => {
        state.updatingEmployees = [];
      });
  },
});

export const { setSelectedDeptId } = accessManagementSlice.actions;
export default accessManagementSlice.reducer;










