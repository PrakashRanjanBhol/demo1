/* Select All Checkbox for Inference */
.select-all-checkbox-inference {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    cursor: pointer;
    margin-right: 8px;
}

.select-all-checkbox-inference .checkbox-inner {
    width: 20px;
    height: 20px;
    border: 2px solid var(--border-color);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    background: var(--bg-color);
}

.select-all-checkbox-inference .checkbox-inner.checked {
    background: linear-gradient(135deg, #f59e0b, #f97316);
    border-color: #f59e0b;
}

.select-all-checkbox-inference .checkbox-inner svg {
    width: 14px;
    height: 14px;
    stroke: white;
}

/* Responsive */
@media screen and (max-width: 1400px) {
    .select-all-checkbox-inference {
        width: 20px;
        height: 20px;
        margin-right: 6px;
    }

    .select-all-checkbox-inference .checkbox-inner {
        width: 18px;
        height: 18px;
    }

    .select-all-checkbox-inference .checkbox-inner svg {
        width: 12px;
        height: 12px;
    }
}


